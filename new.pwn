stock VehicleSpeed(carid)
{
	new Float:X, Float:Y, Float:Z;
	GetVehicleVelocity(carid,X,Y,Z);
	return floatround( floatsqroot( X * X + Y * Y + Z * Z ) * 100.0 );
}
