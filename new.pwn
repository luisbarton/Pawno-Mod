CMD:givedonate(playerid, params[], help)
{
    if(User[playerid][pLogin] == 0) return true;
    if(User[playerid][pAdmin] < 9) return true;
	if(sscanf(params, "ud",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /givedonate [ид] [сумма]");
	if(!IsPlayerConnected(params[0])) return true;
	new string[128];
	f(string, "%d донат рубли переведены игроку", params[1]);
	SendClientMessage(playerid, COLOR_WHITE, string);
	User[params[0]][pDonateAccount] += params[1];
	f(string, "Администратор %s пополнил ваш донат счет.",Name(playerid));
	SendClientMessage(params[0], COLOR_NEWS, string);
	f(string, "Прежний: %d, Сейчас: %d",User[params[0]][pDonateAccount]-params[1],User[params[0]][pDonateAccount]);
	SendClientMessage(params[0], COLOR_WHITE, string);
	
	format(YCMDstr, sizeof(YCMDstr), "Администратор %s дал доната %s [Кол-во: %i]", Name(playerid), Name(params[0]), params[1]);
	WriteLog("GiveDonate.txt", YCMDstr);
	return true;
}
CMD:setcasinoowner(playerid, params[])
{
    if(User[playerid][pAdmin] < 10) return true;
    if(sscanf(params, "dd",params[0], params[1])) return SendClientMessage(playerid, COLOR_WHITE, " Введите: /setcasinoowner [id мафии] (6 - Yakuza | 5 - LCN | 14 - Russian Mafia) [id казино]");
    if(params[0] != 6 && params[0] < 0 && params[0] != 5 && params[0] != 14) return SendClientMessage(playerid,COLOR_GREY,"Неверный ид");
    CasinoInfo[params[1]][caMafia] = params[0];
    return SendClientMessage(playerid,COLOR_WHITE,"Успешно! (/cinfo)");
}
CMD:setmng(playerid, params[])
{
    for(new i = 1; i <= TOTALCASINO; i++)
	{
		if(!PlayerToPoint(200,playerid, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2])) continue;
		if(User[playerid][pMember] != CasinoInfo[i][caMafia] || User[playerid][pRank] < 9) return 1;
		if(sscanf(params, "ud",params[0],params[1]) || (params[0] == playerid && params[0] > -1)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setmng [playerid (-1 для увольнения)] [слот (0 - 2)]");
		new string[156];
		if(params[0] > -1 && User[params[0]][pMember]) return SendClientMessage(playerid,COLOR_GREY,"Этот человек состоит в организации!");
		switch(params[1])
		{
			case 0:
			{
				if(params[0] == -1)
				{
					strmid(CasinoInfo[i][caManager],"-", 0, strlen("-"), 32);
					f(string, "Вы уволили %s с должности Менеджера [%i]",User[params[0]][pName],params[1]);
					return SCM(playerid, COLOR_BLUE, string);
				}
				else strmid(CasinoInfo[i][caManager],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
			}
			case 1:
			{
				if(params[0] == -1)
				{
					strmid(CasinoInfo[i][caManager2],"-", 0, strlen("-"), 32);
					f(string, "Вы уволили %s с должности Менеджера [%i]",User[params[0]][pName],params[1]);
					return SCM(playerid, COLOR_BLUE, string);
				}
				else strmid(CasinoInfo[i][caManager2],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
			}
			case 2:
			{
				if(params[0] == -1)
				{
					strmid(CasinoInfo[i][caManager3],"-", 0, strlen("-"), 32);
					f(string, "Вы уволили %s с должности Менеджера [%i]",User[params[0]][pName],params[1]);
					return SCM(playerid, COLOR_BLUE, string);
				}
				else strmid(CasinoInfo[i][caManager3],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
			}
			default: return SendClientMessage(playerid,COLOR_GREY,"Неверный слот!");
		}
		f(string, "%s назначил вас Менеджером казино [%i]",User[playerid][pName],params[1]);
		SCM(params[0], COLOR_BLUE, string);
		f(string, "Вы назначили %s Менеджером казино [%i]",User[params[0]][pName],params[1]);
		SCM(playerid, COLOR_BLUE, string);
		break;
	}
	return true;
}
