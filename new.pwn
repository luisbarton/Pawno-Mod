CMD:tunload(playerid, params[])
{
	new str[128];
	if(User[playerid][pJob] != 99)return SendClientMessage(playerid,COLOR_GREY, "Вы не Дальнобойщик");
	if(DriverJob[playerid] == false) return SendClientMessage(playerid,COLOR_GREY,"Вы не загружены");
	switch(bGruz[playerid])
	{
	case 1:
		{
			if(IsPlayerInRangeOfPoint(playerid, 10.0, 2601.7222,-2226.5867,13.3732))
			{
                if(GetPVarInt(playerid, "togran") > gettime()+1) return SendClientMessage(playerid,COLOR_GREY,"Извините, мы вас немного задержим, в порту нет места");
				User[playerid][pCash] += User[playerid][pDgruz]*Sellbenz[0];
				//if(booston == false) User[playerid][pDExp] += 400+User[playerid][pDgruz]*200;
				//else if(booston == true) User[playerid][pDExp] += 400+User[playerid][pDgruz]*600;
				if(User[playerid][pDonateRank]) User[playerid][pDExp] += 400+User[playerid][pDgruz]*600;
				else User[playerid][pDExp] += 400+User[playerid][pDgruz]*200;
				format(str, sizeof(str), "{00D26D}Вы доставили %d т.груза на сумму %i вирт",User[playerid][pDgruz],Sellbenz[0]*User[playerid][pDgruz]);
				SendClientMessage(playerid, 0x66FBA6FF, str);
				if(Sellbenz[0] != 200) Sellbenz[0] -= 100;
				if(Sellbenz[1] != 900) Sellbenz[1] += 100;
				format(str, sizeof(str), "Порт ЛС\nНефть: %d\nУголь: %d\nДерево: %d",Sellbenz[0],Sellugol[0],Sellderevo[0]);
				UpdateDynamic3DTextLabelText(Doki[0], 0xFFFF00FF, str);
				format(str, sizeof(str), "Порт СФ\nНефть: %d\nУголь: %d\nДерево: %d",Sellbenz[1],Sellugol[1],Sellderevo[1]);
