CMD:buyhouse(playerid, params[])
{
	if(!IsPlayerConnected(playerid)) return true;
	for(new h = 1; h <= TotalHouse; h++)
	{
		if((PlayerToPoint(2.0, playerid, HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez]) || (PlayerToPoint(2.0, playerid, HouseInfo[h][hExitx], HouseInfo[h][hExity], HouseInfo[h][hExitz]) && GetPlayerVirtualWorld(playerid) == h+50))
		&& strcmp(HouseInfo[h][hOwner],"None",true) == 0)
		{
			if(HGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "У вас уже есть дом!");
			if(KGet(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Для начала продайте квартиру!");
			if(User[playerid][pCash] < HouseInfo[h][hValue]) return SendClientMessage(playerid,COLOR_GREY, "Недостаточно денег на руках!");
			HouseInfo[h][hHel] = 0;
			HouseInfo[h][hLock] = 1;
			strmid(HouseInfo[h][hOwner],User[playerid][pName], 0, strlen(User[playerid][pName]), 32);
			HGet(playerid);
			User[playerid][pCash] -= HouseInfo[h][hValue];
			SetPlayerInterior(playerid,HouseInfo[h][hInt]);
			t_SetPlayerPos(playerid,HouseInfo[h][hExitx],HouseInfo[h][hExity],HouseInfo[h][hExitz]);
			SetPlayerVirtualWorld(playerid, h+50);
			HouseInfo[h][hTakings] = GetHouseOplata(h);
			SendClientMessage(playerid, 0x3AA94CFF, "Поздравляем с покупкой!");
			format(YCMDstr, sizeof(YCMDstr), "Внимание! Теперь с Вашего домашнего счёта будут снимать квартплату в размере {FF6347}%i$/час",GetHouseOplata(h));
			SendClientMessage(playerid, 0xF0E79CFF,YCMDstr);
			SendClientMessage(playerid, 0xF0E79CFF, "Если на счету будет недостаточно денег, Вас выселят.");
			SendClientMessage(playerid, 0xF0E79CFF, "Пополнить домашний счёт или узнать баланс можно через банк или банкомат.");
			GameTextForPlayer(playerid,"~w~welcome home~n~print:~g~/exit", 5000, 3);
			new house = GetPVarInt(playerid,"House");
			if(house_car[playerid] != -1)
			{
				DestroyVehicle(house_car[playerid]);
				house_car[playerid] = -1;
			}
			house_car[playerid] = CreateVehicleAC(CarInfo[playerid][carModel][0], HouseInfo[house][hCarx], HouseInfo[house][hCary], HouseInfo[house][hCarz], HouseInfo[house][hCarc] , CarInfo[playerid][carColor_one][0] ,CarInfo[playerid][carColor_two][0], 86400);
			SetVehicleParamsEx(house_car[playerid],false,false,false,true,false,false,false);
            CarHealth[house_car[playerid]] = float(1000);
			LoadTuning(playerid,house_car[playerid]);
			User[playerid][pSpawnChange] = 1;
			//createdcar = house_car[playerid];
			//createdcar ++;
			BuyHouse(house);
			SaveServerHouses(house);
			Fuell[house_car[playerid]] = 100;
			if(User[playerid][quest_store][1] == 60)
			{
				SendClientMessage(playerid, COLOR_YELLOW,"[Подсказка] Вы купили дом, квест пройден!");
				UpdateQuestInfo(playerid, 0, 100);
				QuestNagrada(playerid);
			}
			return true;
		}
	}
	return true;
}



CMD:sellprodsone(playerid, params[])
{
	for(new bizz = 1; bizz <= TotalBizz; bizz++)
	{
		if(PlayerToPoint(5.0, playerid, BizzInfo[bizz][bEntranceX], BizzInfo[bizz][bEntranceY], BizzInfo[bizz][bEntranceZ]) && BizzInfo[bizz][bType] == 1)
		{
			new newcar = GetPlayerVehicleID(playerid);
			if(newcar >= comptruck[4] && newcar <= comptruck[9])
			{
			    new string[256];
				if(strcmp(BizzInfo[bizz][bOwner],"None",true) == 0) return SCM(playerid,COLOR_GREY,"У бизнеса нет владельца");
				SetPVarInt(playerid, "bizz", bizz);
				f(string,"Вы собираетесь продать продукты\n\n{15B5B8}Бизнес: %s\n{FFD500}Количество: %d\n{E51212}Стоимость: %d вирт",BizzInfo[bizz][bMessage],car_prods[GetPlayerVehicleID(playerid)][3],car_prods[GetPlayerVehicleID(playerid)][3]*16);
				return ShowPlayerDialogEx(playerid,1387,DIALOG_STYLE_MSGBOX,"Продажа продуктов",string,"Продать","Отмена");
			}
			else return SCM(playerid,COLOR_GREY,"Нужно быть в транспортном средстве, которое может перевозить данный тип груза");
		}
	}
	return true;
}
