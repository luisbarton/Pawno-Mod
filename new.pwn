stock GetGangColor(fractionid)
	return
	    (fractionid == 34) ? (0xF45000AA) :
		(fractionid == 35) ? (0xB30000AA) :
		(fractionid == 36) ? (0xFFEE8AAA) :
		(fractionid == 12) ? (0xCC00FFAA) :
		(fractionid == 18) ? (0x6666FFAA) :
		(fractionid == 17) ? (TEAM_AZTECAS_COLOR) :
		(fractionid == 13) ? (0xF1C33AAA) :
		(fractionid == 15) ? (0x009900AA) : (0x00CCFFAA);
stock GetGangName(fnumbwer)
{
	new str[30];
	switch(fnumbwer)
	{
	case 12: format(str,sizeof(str), "BALLAS");
	case 13: format(str,sizeof(str), "VAGOS");
	case 15: format(str,sizeof(str), "GROVE");
	case 17: format(str,sizeof(str), "AZTECAS");
	case 18: format(str,sizeof(str), "RIFA");
	case 34: format(str,sizeof(str), "CRIPS");
	case 35: format(str,sizeof(str), "TRIADS");
	case 36: format(str,sizeof(str), "BLOODS");
	}
	return str;
}
stock GetMafiaName(fnumbwer)
{
	new str[25];
	switch(fnumbwer)
	{
	case 5: format(str,sizeof(str), "LCN");
	case 6: format(str,sizeof(str), "Yakuza");
	case 14: format(str,sizeof(str), "Russian Mafia");
	}
	return str;
}
public OnVehicleDeath(vehicleid, killerid)
{
	SetVehicleParamsEx(vehicleid,false,false,false,false,false,false,false);
	car_ex[vehicleid] = true;
	if(killerid != INVALID_PLAYER_ID)
	{
    	if(ac_player_vehicle_old[killerid] != vehicleid)
    	{
        	if(++ac_player_warning_vehicle_death[killerid] > 2)
        	{
            	SendWarningCheatMessageToAdmin(killerid, "Spawn Car");
        	}
    	}
    	else
    	{
        	ac_player_warning_vehicle_death[killerid] = 0;
    	}
	}
	// --------------- [ Очистка матов в фурах ] -----------------
	if(vehicleid >= matsfura[0] && vehicleid <= matsfura[0])
	{
        Furi[vehicleid-matsfura[0]][gBallas] = 0;
	}
	else if(vehicleid >= matsfuragrove[0] && vehicleid <= matsfuragrove[0])
	{
        Furi[vehicleid-matsfuragrove[0]][gGrove] = 0;
	}
	else if(vehicleid >= matsfuraactek[0] && vehicleid <= matsfuraactek[0])
	{
        Furi[vehicleid-matsfuraactek[0]][gAztek] = 0;
	}
	else if(vehicleid >= matsfuravagos[0] && vehicleid <= matsfuravagos[0])
	{
        Furi[vehicleid-matsfuravagos[0]][gVagos] = 0;
	}
	else if(vehicleid >= matsfurarifa[0] && vehicleid <= matsfurarifa[0])
	{
	    Furi[vehicleid-matsfurarifa[0]][gRifa] = 0;
	}
	// -----------------------------------------------------------
	
	return true;
}
public OnVehicleSpawn(vehicleid)
{
    jobcar[vehicleid] = false;
    car_ex[vehicleid] = true;
    GetVehiclePos(vehicleid,car_coord[vehicleid][0],car_coord[vehicleid][1],car_coord[vehicleid][2]);
    GetVehicleZAngle(vehicleid,car_coord[vehicleid][3]);
	SetVehicleParamsEx(vehicleid,false,false,false,false,false,false,false);
	CarHealth[vehicleid] = float(1000);
	enginebrokened[vehicleid] = 0;
	if(car_pickup[vehicleid] > 0) DestroyDynamic3DTextLabel(car_text[vehicleid]), DestroyDynamicPickup(car_pickup[vehicleid]), car_pickup[vehicleid] = 0;
	if(Farmcar_pickup[vehicleid] > 0) DestroyDynamic3DTextLabel(Farmcar_text[vehicleid]), DestroyDynamicPickup(Farmcar_pickup[vehicleid]), Farmcar_pickup[vehicleid] = 0;
	if(Farmcar_pickup[vehicleid] > 0) DestroyDynamic3DTextLabel(Farmcar_text[vehicleid]), DestroyDynamicPickup(Farmcar_pickup[vehicleid]), Farmcar_pickup[vehicleid] = 0;
	if(GetVehicleModel(vehicleid) == 462)
	{
		foreach(new i : Player)
		{
			if(GetPVarInt(i,"FaggioRent") == vehicleid)
			{
	 			DestroyVehicle(vehicleid);
	 			DeletePVar(i,"FaggioRent");
	 			User[i][pAreaskut] = 0;
	 			SCM(i,COLOR_GREY, "[RENT]: Ваш арендованный мопед долго простоял и был изъят!");
			}
		}
	}
//	UnLockCar(-1,vehicleid);
	foreach(new i : Player)
	{
	 	if(vehicleid == house_car[i]) Fuell[house_car[i]] = CarInfo[i][carFuel][GetPVarInt(i,"SelectCar")],SetVehicleParamsEx(vehicleid,false,false,false,true,false,false,false), LoadTuning(i,house_car[i]);
	}
	//for(new i = 0; i < 5; i++) if(vehicleid == taxi5lvlcar[i]) DestroyObject(police[taxi5lvlcar[i]]), police[taxi5lvlcar[i]] = CreateObject(19308,0,0,0,0,0,0,100.0), AttachObjectToVehicle(police[taxi5lvlcar[i]], taxi5lvlcar[i], 0.000000, -0.400000, 0.854999, 0.000000, 0.000000, 0.0);
	//for(new i = 0; i < 8; i++) if(vehicleid == taxi10lvlcar[i]) DestroyObject(police[taxi10lvlcar[i]]), police[taxi10lvlcar[i]] = CreateObject(19308,0,0,0,0,0,0,100.0), AttachObjectToVehicle(police[taxi10lvlcar[i]], taxi10lvlcar[i], -0.014999, -0.140000, 0.919999, -1.005000, 0.000000, 0.0);
	return true;
}
publics: Random(min, max)
{
	new a = random(max - min) + min;
	return a;
}
publics: PlayerToPoint(Float:radi, playerid, Float:x, Float:y, Float:z)
{
	new Float:oldposx, Float:oldposy, Float:oldposz;
	new Float:tempposx, Float:tempposy, Float:tempposz;
	GetPlayerPos(playerid, oldposx, oldposy, oldposz);
	tempposx = (oldposx -x);
	tempposy = (oldposy -y);
	tempposz = (oldposz -z);
	if (((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) return true;
	return false;
}
