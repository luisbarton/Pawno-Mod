                f(str, "Вы авторизовались как администратор %i уровня", GetPVarInt(playerid,"level"));
				SCM(playerid, 0xAFAFAFFF, str);
				User[playerid][pAdmin] = GetPVarInt(playerid,"level");
        		SetPVarInt(playerid, "Dostup", 1);
        		format(str, sizeof(str), "<ALogin> вошел %s[%i]", User[playerid][pName], playerid);
        		SendAdminMessage(0xAFAFAFFF, str);
        		return 1;
    		}
    		else if(GetPVarInt(playerid, "Alogin") == 2)
    		{
			    if(!strlen(inputtext)) return ShowPlayerDialogEx(playerid, 1227, DIALOG_STYLE_PASSWORD, "{F1C33A}Доступ администратора", "{FFFFFF}Введите Ваш пароль от панели администратора", "Принять", "Отмена");
				mysql_format(dbHandle, YCMDstr, sizeof(YCMDstr), "SELECT * FROM admin WHERE name = '%s' AND password = md5(md5('%e'))", Name(playerid), inputtext);
				mysql_tquery(dbHandle, YCMDstr, "@AloginAuth", "i", playerid);
			}
