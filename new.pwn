		if(IsAArm(i) && GetPVarInt(i,"Fraction_Duty") || IsAMedic(i) && GetPVarInt(i,"Fraction_Duty") || IsAMayor(i) && GetPVarInt(i,"Fraction_Duty") || IsACop(i) && GetPVarInt(i,"Fraction_Duty") || User[i][pMember] == 11 && GetPVarInt(i,"Fraction_Duty")) SendClientMessage(i, color, str);
	}
}

