stock HealthDamage(playerid,attackerid,weaponid,Float:ammount)
{
	if(User[playerid][pHP] <= 0) return false;
	if(User[playerid][pHP] - ammount <= 0)
	{
		Killed[playerid] = true;
		SetPlayerHealthAC(playerid,0.0);
		OnPlayerBulletDeath(playerid,attackerid,weaponid);
	}
	else SetPlayerHealthAC(playerid,User[playerid][pHP] - ammount);
	return true;
}
stock GiveDamageForPlayer(playerid,attackerid,weaponid,Float:ammount)
{
	if(Armour[playerid] >= 1)
 	{
 		if(Armour[playerid] - ammount <= 0)
		{
 			SetPlayerArmourAC(playerid,0.0);
			HealthDamage(playerid,attackerid,weaponid,ammount - Armour[playerid]);
		}
		else ArmorDamage(playerid,ammount);
  	}
	else HealthDamage(playerid,attackerid,weaponid,ammount);
	return true;
}
ShowDamage(playerid, hitplayerid, idweapon, Float: amouth)
{
	if(GetPVarInt(playerid, "Hide_Damage") != 0)
	{
	    KillTimer(HideDamage[playerid]);
     	Hide_Damage_Text_Draw_3000ms_p(playerid);
	}
	if(GetPVarInt(hitplayerid, "Hide_Damage") != 0)
	{
	    KillTimer(HideDamage[hitplayerid]);
     	Hide_Damage_Text_Draw_3000ms_h(hitplayerid);
	}

	SetPVarInt(playerid, "Hide_Damage", 1);
	SetPVarInt(hitplayerid, "Hide_Damage", 1);

    new Weapon_Name[32],
		show_damage_string[MAX_PLAYER_NAME + 32 + 12];

    GetWeaponName(idweapon,Weapon_Name,sizeof(Weapon_Name));

	foreach(Player, i)
	{
		if (s_Spectating[i] == playerid && i != playerid || s_Spectating[i] == hitplayerid && i != hitplayerid)
		{
 			if(GetPVarInt(i, "Hide_Damage") != 0)
			{
			    KillTimer(HideDamage[playerid]);
		     	if(s_Spectating[i] == playerid)
		 		{
			 		Hide_Damage_Text_Draw_3000ms_p(i);
			 	}
		     	else if(s_Spectating[i] == hitplayerid)
	 			{
		 			Hide_Damage_Text_Draw_3000ms_h(i);
		 		}
			}

			SetPVarInt(i, "Hide_Damage", 1);

	        if(s_Spectating[i] == playerid)
	        {
	  			format(show_damage_string,sizeof(show_damage_string),"%s - %s +%.0f", User[hitplayerid][pName], Weapon_Name, amouth);
	    		PlayerTextDrawSetString(i,Damage_Text_Draw[i][0],show_damage_string);
	    		PlayerTextDrawShow(i, Damage_Text_Draw[i][0]);
	    		PlayerPlaySound(i, 17802, 0.0, 0.0, 0.0);
	    	}
			else if(s_Spectating[i] == hitplayerid)
			{
			    format(show_damage_string,sizeof(show_damage_string),"%s - %s -%.0f", User[playerid][pName], Weapon_Name, amouth);
			    PlayerTextDrawSetString(i,Damage_Text_Draw[i][1],show_damage_string);
			    PlayerTextDrawShow(i, Damage_Text_Draw[i][1]);
			    PlayerPlaySound(i, 17802, 0.0, 0.0, 0.0);
			}

     		if(s_Spectating[i] == hitplayerid)
 			{
      			HideDamage[i] = SetTimerEx("Hide_Damage_Text_Draw_3000ms_h", 3000, 0, "i", i);
      		}
      		else if(s_Spectating[i] == playerid)
      		{
    			HideDamage[i] = SetTimerEx("Hide_Damage_Text_Draw_3000ms_p", 3000, 0, "i", i);
    		}
    	}
    }

    format(show_damage_string,sizeof(show_damage_string),"%s - %s +%.0f", User[hitplayerid][pName], Weapon_Name, amouth);
    PlayerTextDrawSetString(playerid,Damage_Text_Draw[playerid][0],show_damage_string);
    PlayerTextDrawShow(playerid, Damage_Text_Draw[playerid][0]);
    PlayerPlaySound(playerid, 17802, 0.0, 0.0, 0.0);

    format(show_damage_string,sizeof(show_damage_string),"%s - %s -%.0f", User[playerid][pName], Weapon_Name, amouth);
    PlayerTextDrawSetString(hitplayerid,Damage_Text_Draw[hitplayerid][1],show_damage_string);
    PlayerTextDrawShow(hitplayerid, Damage_Text_Draw[hitplayerid][1]);
    PlayerPlaySound(hitplayerid, 17802, 0.0, 0.0, 0.0);

    HideDamage[hitplayerid] = SetTimerEx("Hide_Damage_Text_Draw_3000ms_h", 3000, 0, "i", hitplayerid);
    HideDamage[playerid] = SetTimerEx("Hide_Damage_Text_Draw_3000ms_p", 3000, 0, "i", playerid);
    return 1;
}

