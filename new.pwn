CMD:selldrugs(playerid, params[])
{
    if(!IsAGang(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Вы не бандит!");
	if(sscanf(params, "udd", params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_GRAD2, "Введите: /selldrugs [id] [кол-во] [Цена]");
	if(params[1] < 1 || params[1] > 150) { SendClientMessage(playerid, COLOR_GREY, "Вес не может быть меньше 1 и больше 150!"); return true; }
	if(params[2] < 1 || params[2] > 5000) { SendClientMessage(playerid, COLOR_GREY, "Цена не может быть меньше 1 и больше 5000 вирт!"); return true; }
	if(params[1] > User[playerid][pDrugs]) { SendClientMessage(playerid, COLOR_GREY, "У вас нет столько наркотиков!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid,COLOR_GREY,"Вы должны находиться рядом друг с другом");
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете продать себе наркотики!");
	format(YCMDstr, sizeof(YCMDstr), "Вы предложили %s купить %i грамм наркоты за %i вирт",User[params[0]][pName],params[1],params[2]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "%s предлагает вам купить %i грам наркоты за %i вирт. (( Введите /accept drugs для покупки ))",User[playerid][pName],params[1],params[2]);
	SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
	DrugOffer[params[0]] = playerid;
	DrugPrice[params[0]] = params[2];
	DrugGram[params[0]] = params[1];
	return true;
}
CMD:quitjob(playerid, params[])
{
    if(User[playerid][pJob] == 65 && avtocar[playerid] > 0) User[playerid][pSkilla]--;
    new carid = GetPlayerVehicleID(playerid);
    if(User[playerid][pJob] == 1 && (carid >= buscar[0] && carid <= buscar[1]) || (carid >= buscar[2] && carid <= buscar[3]) || (carid >= buscar[4] && carid <= buscar[5]) || (carid >= buscar[6] && carid <= buscar[7]))
	{
		format(YCMDstr, sizeof(YCMDstr), "Рабочий день завершен. Вами заработано: %i вирт. За ремонт: -%i вирт", GetPVarInt(playerid, "BusMoney"), GetPVarInt(playerid,"BusRepairMoney"));
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		SendClientMessage(playerid, COLOR_WHITE, "Деньги будут перечислены на счет во время зарплаты");
		User[playerid][pPayCheck] -= GetPVarInt(playerid,"BusRepairMoney");
		DeletePVar(playerid, "BusTime");
		DeletePVar(playerid, "TypeBus");
		DeletePVar(playerid, "BusStop");
		DeletePVar(playerid, "BusMoney");
		DeletePVar(playerid, "BusRepairMoney");
		DeletePVar(playerid, "rentcar_job");
		pPressed[playerid] = 0;
		//Delete3DTextLabel(JobText3D[GetPlayerVehicleID(playerid)]);
		if(IsValidDynamic3DTextLabel(BusText3D[playerid])) DestroyDynamic3DTextLabel(BusText3D[playerid]);
		SetVehicleToRespawn(GetPlayerVehicleID(playerid));
		DisablePlayerRaceCheckpoint(playerid);
	}
    User[playerid][pJob] = 0;
	SendClientMessage(playerid, COLOR_GREY, "Вы уволились с работы");
	return true;
}
CMD:sellbiz(playerid)
{
    if(!IsPlayerConnected(playerid)) return true;
	if(!BGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	if(strcmp(User[playerid][pName], BizzInfo[GetPVarInt(playerid,"Bizz")][bOwner], true) == 0)
	{
	    new str[40];
		new bouse = GetPVarInt(playerid,"Bizz");
		if (!PlayerToPoint(3, playerid,BizzInfo[bouse][bEntranceX], BizzInfo[bouse][bEntranceY], BizzInfo[bouse][bEntranceZ])) return SendClientMessage(playerid, COLOR_GREY, "Вы не у своего бизнеса!");
		BizzInfo[bouse][bLocked] = 1;
		BizzInfo[bouse][bProducts] = 0;
		strmid(BizzInfo[bouse][bOwner], "None", 0, strlen("None"), 32);
		//User[playerid][pBank] +=BizzInfo[bouse][bTill]+BizzInfo[bouse][bLandTax];
		User[playerid][pBank] +=BizzInfo[bouse][bBuyPrice]/2;
		PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
		format(str,sizeof(str),"~w~business in sold~n~~g~$%i",BizzInfo[bouse][bBuyPrice]/2);
		GameTextForPlayer(playerid,str, 5000, 3);
		SCM(playerid, -1, "{F0E79C}Вы получили {FF6347}50%{F0E79C} средств от стоимости бизнеса");
		BizzInfo[bouse][bTill] = 0;
		BizzInfo[bouse][bPrice] = 0;
		BizzInfo[bouse][bMafia] = 0;
		BizzInfo[bouse][bLandTax] = 0;
		BizzPay[bouse] = 0;
		BizzInfo[bouse][bLicense] = 0;
		BGet(playerid);
		format(YCMDstr, sizeof(YCMDstr), "{FF9900}%s{F0E79C}\nПродаётся \n\n /buybiz для покупки\nЦена: {3AA94C}%d$", BizzInfo[bouse][bMessage],BizzInfo[bouse][bBuyPrice]);
		UpdateDynamic3DTextLabelText(BizzInfo[bouse][bLabel], COLOR_GREEN, YCMDstr);
		return true;
	}
	return true;
}
CMD:gangfreeze(playerid,params[])
{
	if(User[playerid][pAdmin] < 5) return true;//SendErr(playerid,"Вы не уполномочены использовать эту команду!");

	if(sscanf(params,"d",params[0]))
	{
		SendClientMessage(playerid,COLOR_GREY,"/gangfreeze [id банды]");
		SendClientMessage(playerid,COLOR_GREY,"1 - Ballas | 2 - Vagos | 3 - Grove");
		SendClientMessage(playerid,COLOR_GREY,"4 - Rifa | 5 - Aztecas");
		return 1;
	}
	if(params[0] < 1 || params[0] > 5)
	{
		SendClientMessage(playerid,COLOR_GREY,"/gangfreeze [id банды]");
		SendClientMessage(playerid,COLOR_GREY,"1 - The Ballas | 2 - The Vagos | 3 - The Grove");
		SendClientMessage(playerid,COLOR_GREY,"4 - The Rifa | 5 - The Aztecas");
		return 1;
	}
	if(fracmoroz[params[0]-1] == 0)
	{
		fracmoroz[params[0]-1] = 1;
		//UpdateMorozed();
		format(YCMDstr,128,"Администратор %s заморозил банду %s",Name(playerid),fracmorozName[params[0]-1]);
		SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
		return 1;
	}
	format(YCMDstr,128,"Администратор %s разморозил банду %s.",Name(playerid),fracmorozName[params[0]-1]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	fracmoroz[params[0]-1] = 0;
	//UpdateMorozed();
	return 1;
}
CMD:capture(playerid, params[])
{
	new str[128];
    if(Flood[playerid] > 0) return SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
	Flood[playerid] = 1;
	new gang1 = -1;

	switch(User[playerid][pMember])
	{
		case 12: gang1 = MOROZ_BALLAS;
		case 13: gang1 = MOROZ_VAGOS;
		case 15: gang1 = MOROZ_GROVE;
		case 17: gang1 = MOROZ_AZTECAS;
		case 18: gang1 = MOROZ_RIFA;
	}
	if(gang1 != -1)
	{
		if(fracmoroz[gang1] > 0)
		{
			SCM(playerid,COLOR_RED,"Ваша банда заморожена");
			return 1;
		}
	}
	if(FrakCD[User[playerid][pMember]] != 0) return SendClientMessage(playerid,COLOR_GREY,"Ваша банда уже воевала за территорию.");
	if(!IsInAllowed(playerid)) return SendClientMessage(playerid,COLOR_GRAD1, "Вы не можете захватить территорию");
	if(GetSVarInt("capture") > gettime()) return SendClientMessage(playerid,COLOR_GREY,"В данное время захват не возможен");
	new tmphour, tmpminute, tmpsecond;
	gettime(tmphour, tmpminute, tmpsecond);
	tmphour = shifthour;
	for(new i = 1; i <= TOTALGZ; i++)
	{
		if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]) && GZInfo[i][gFrakVlad] != User[playerid][pMember] && ZoneOnBattle[i]==0)
		{
		    new gang = -1;

			switch(GZInfo[i][gFrakVlad])
			{
				case 12: gang = MOROZ_BALLAS;
				case 13: gang = MOROZ_VAGOS;
				case 15: gang = MOROZ_GROVE;
				case 17: gang = MOROZ_AZTECAS;
				case 18: gang = MOROZ_RIFA;
			}

			if(gang != -1)
			{
				if(fracmoroz[gang] > 0)
				{
					SCM(playerid,COLOR_RED,"Банду которую вы хотите захватить невозможно");
					SCM(playerid,COLOR_RED,"Она заморожена администратором, ожидайте сообщения в чате когда заморозка будет снята");
					return 1;
				}
			}
			new playerss = 0;
			foreach(new m : Player)
			{
				if(User[m][pMember] == GZInfo[i][gFrakVlad]) playerss++;
			}
			if(FrakCD[GZInfo[i][gFrakVlad]] != 0) return SendClientMessage(playerid,COLOR_GRAD1,"Банда на которую вы хотите напасать уже воевала в этом часу");
			if(IsARespawn(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Нельзя захватить эту территорию");
            if(playerss == 0)
			{
                GZSafeTime[i] = 1;
			}
			else
			{
                GZSafeTime[i] = 900;
			}
			FrakCD[GZInfo[i][gFrakVlad]] = 1;
			FrakCD[User[playerid][pMember]] = 1;
			format(str, sizeof(str),"[Внимание]: Ваша банда напала на территорию %s",GetGangName(GZInfo[i][gFrakVlad]));
			SendFamilyMessage(User[playerid][pMember],0x00B953AA,str);
			format(str, sizeof(str), "[Внимание]: На вашу территорию напала банда %s",GetGangName(User[playerid][pMember]));
			SendFamilyMessage(GZInfo[i][gFrakVlad],0xFF8CEFAA,str);
			GangZoneFlashForAll(GZInfo[i][gZone],GetGZColorF(User[playerid][pMember]));
			SendClientMessage(playerid,COLOR_WHITE,"Территория будет мигать 15 минут. Победит банда, которая останется последней");
			SendClientMessage(playerid,COLOR_WHITE,"Территория будет мигать до тех пор, пока на ней не останется 1 банда");
			f(str, "%s развязал войну за территорию", User[playerid][pName]);
			SendFamilyMessage(User[playerid][pMember], COLOR_YELLOW, str);
			SendFamilyMessage(GZInfo[i][gFrakVlad], COLOR_YELLOW, str);
			switch(GZInfo[i][gFrakVlad])
			{
			    case 12: str="Ballas";
			    case 13: str="Vagos";
			    case 15: str="Grove";
			    case 17: str="Aztecas";
			    case 18: str="Rifa";
			}
			new str2[10];
			switch(User[playerid][pMember])
			{
			    case 12: str2="Ballas";
			    case 13: str2="Vagos";
			    case 15: str2="Grove";
			    case 17: str2="Aztecas";
			    case 18: str2="Rifa";
			}
			format(str, sizeof(str),"{BEBEBE}Банда %s напала на банду %s.",str2,str);
			SendAdminMessage(0x00a86bAA,str);
			GZInfo[i][gNapad] = User[playerid][pMember];
			ZoneOnBattle[i] = 1;
			captures++;
			if(GzCheckOn == 0)
			{
				GzCheckTimer = SetTimer("GzCheck", 1000,1);
				GzCheckOn = 1;
			}
			break;
		}
	}
	return true;
}
ALTX:bizwar("/mafiawar");
CMD:bizwar(playerid, params[])
{
    if(!User[playerid][pLogin] || !IsAMafia(playerid) || User[playerid][pRank] < 6) return 1;
    new hour; gettime(hour);
	if(hour >= 1 && hour < 7)
	    return err(!"Ошибка: {ffffff}Стрелы отключены с 01:00 до 07:00 утра!");
    if(WarStart > gettime())
		return SCMF(playerid, COLOR_GREY, "Следующий захват можно начать через %s",Convert(WarStart - gettime()));
	if(sscanf(params, "d",params[0]) || params[0] < 1 || params[0] > 3) return SCM(playerid, COLOR_WHITE, !"Введите: /bizwar [id стрелы (1 - Аэропорт | 2 - Карьер | 3 - Дамба)]");
	for(new b = 1; b <= TotalBizz; b++)
	{
		if(PlayerToPoint(3, playerid,BizzInfo[b][bEntranceX], BizzInfo[b][bEntranceY], BizzInfo[b][bEntranceZ]))
		{
		    if(BizzInfo[b][bMafia] == User[playerid][pMember]) return SCM(playerid, COLOR_WHITE, !" Этот бизнес под Вашим контролем");
		    if(BizzInfo[b][bMafia] == 0)
			{
			    if(strcmp(BizzInfo[b][bOwner],"The State",true) == 0)
			        return err(!"Ошибка: {ffffff}Бизнес на данный момент принадлежит государству - Вы не можете взять его под свой контроль!");
				BizzInfo[b][bMafia] = User[playerid][pMember];
				UpdateBizz(b);
				return SCM(playerid, COLOR_WHITE, !"Бизнес взят под контроль");

			}
			if(mafia_frac_id[0] != 0) return err(!"Ошибка: {ffffff}В данное время уже идет война!");
		  	new string_[128];
			format(string_, sizeof string_, "Вы забили стрелку %s. Бизнес: %s. Место встречи: Территория [ID %d]",GetMafiaName(BizzInfo[b][bMafia]), BizzInfo[b][bMessage],params[0]);
			SendFamilyMessage(User[playerid][pMember],0x114D71AA, string_);
			SendFamilyMessage(User[playerid][pMember],0x114D71AA, "Встреча через 20 минут!");
            format(string_, sizeof string_, "%s забила вам стрелку. Бизнес: %s. Место встречи: Территория [ID %d]",GetMafiaName(User[playerid][pMember]),BizzInfo[b][bMessage],params[0]);
			SendFamilyMessage(BizzInfo[b][bMafia],COLOR_RED, string_);
			SendFamilyMessage(BizzInfo[b][bMafia],COLOR_RED, "Встреча через 20 минут!");
			format(string_, sizeof string_,"%s %s инициировал(а) захват бизнеса", GetRank(playerid), User[playerid][pName]);
			SendFamilyMessage(User[playerid][pMember], TEAM_AZTECAS_COLOR, string_);
			SendFamilyMessage(BizzInfo[b][bMafia], TEAM_AZTECAS_COLOR, string_);

			format(string_, sizeof(string_), "[A] Начался захват между мафии %s и %s | Бизнес: %s [ID: %d]", GetMafiaName(User[playerid][pMember]), GetMafiaName(BizzInfo[b][bMafia]), BizzInfo[b][bMessage], params[0]);
			ABroadCast(0xFFC100FF, string_, 1);

			BizzInfo[b][bCapture] = User[playerid][pMember];
			ZoneID = params[0];
			mafia_frac_id[0] = User[playerid][pMember];
			mafia_frac_id[1] = BizzInfo[b][bMafia];
			kills_mafia[0] = 0;
			kills_mafia[1] = 0;
			ZoneTimer = 1200;//1200;
            if(ZoneID == 1) ZoneWar = GangZoneCreate(228.0, 2464.0, 370.0, 2539.0);
			else if(ZoneID == 2) ZoneWar = GangZoneCreate(324.6, 833.3, 393.8, 983.9);
			else ZoneWar = GangZoneCreate(-789.8281,2015.9144, -662.7654,2083.9297);
			GangZoneShowForAll(ZoneWar, 0xB2B2B2AA);
			GangZoneFlashForAll(ZoneWar,COLOR_RED);

			MzCheckTimer = SetTimerEx("MzCheck",1000, true, "iii",b,User[playerid][pMember],BizzInfo[b][bMafia]);

			
			foreach(new idx: Player)
	 		{
	 		    if(User[idx][pMember] == mafia_frac_id[0])
	 		    {
	 		        

					for(new i_ = 0; i_ < 5; i_++)
					{
						SendDeathMessageToPlayer(idx,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0);
					}
					SetPlayerToTeamColor(idx);
				}
				else if(User[idx][pMember] == mafia_frac_id[1])
				{
				    

				    for(new i_ = 0; i_ < 5; i_++)
					{
						SendDeathMessageToPlayer(idx,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0);
					}
					SetPlayerToTeamColor(idx);
				}
	 		}
	 		break;
		}
	}
	return 1;
}
publics: MzCheck(i,napad,vlad)
{
	if(ZoneID < 1 || ZoneID > 3)
	{
		KillTimer(MzCheckTimer);
		print("Error MzCheck <> ZoneID");
		return 1;
	}
	static const Float: coor_zone[3][4] = {
		{228.0, 2464.0, 370.0, 2539.0},
		{324.6, 833.3, 393.8, 983.9},
		{-789.8281,2015.9144, -662.7654,2083.9297}
	};
	ZoneTimer--;

    foreach(new x: Player)
	{
		new y = User[x][pMember];
		if(y == napad || y == vlad)
		{
  			if(!GetPVarInt(x,"mafiawar"))
			{
				PlayerTextDrawShow(x, Capture[x]);
				SetPVarInt(x,"mafiawar",1);
				SetPlayerToTeamColor(x);
			}
			format(YCMDstr,120,"~y~kills~n~~n~~g~%s:~w~ %i~n~~r~%s:~w~ %i", GetMafiaName2(mafia_frac_id[0]), kills_mafia[0], GetMafiaName2(mafia_frac_id[1]), kills_mafia[1]);
			PlayerTextDrawSetString(x,Capture[x],YCMDstr);
		}
	}

	if(ZoneTimer == 900)
	{
	    SendFamilyMessage(napad,0x114D71AA, !"У вас осталось 15 минут на подготовку!");
	    SendFamilyMessage(vlad,0x114D71AA, !"У вас осталось 15 минут на подготовку!");
	}
	if(ZoneTimer == 600)
	{
	    SendFamilyMessage(napad,0x114D71AA, !"У вас осталось 10 минут на подготовку!");
	    SendFamilyMessage(vlad,0x114D71AA, !"У вас осталось 10 минут на подготовку!");
	}
	if(ZoneTimer == 180)
	{
	    SendFamilyMessage(napad,COLOR_RED, !"Пора решать кому будет принадлежать бизнес. Осталось 3 минуты");
	    SendFamilyMessage(vlad,COLOR_RED, !"Пора решать кому будет принадлежать бизнес. Осталось 3 минуты");
	}

	if(ZoneTimer < 1)

	{

		new count_on_zone[2],z = ZoneID-1;

        foreach(new x: Player)
        {
            if(User[x][pMember] == vlad)
            {
                if(IsPlayerToSquare(x,coor_zone[z][0], coor_zone[z][1],coor_zone[z][2],coor_zone[z][3]) && GetPVarInt(x,"AFK_Time") < 2)
            	{
                	count_on_zone[0] = 1;
                	break;
            	}
            }

        }

        foreach(new x: Player)
        {
            if(User[x][pMember] == napad)
            {
                if(IsPlayerToSquare(x,coor_zone[z][0], coor_zone[z][1],coor_zone[z][2],coor_zone[z][3]) && GetPVarInt(x,"AFK_Time") < 2)
	            {
	                count_on_zone[1] = 1;
	                break;
	            }
	        }
        }

		new str_biz_name[64],str_control[68+sizeof(str_biz_name)];
		format(str_biz_name,sizeof(str_biz_name),"%s",BizzInfo[i][bMessage]);

        if(count_on_zone[0] == 1 && count_on_zone[1] == 1)
        {
            ZoneTimer = 180;
			format( str_control,sizeof(str_control),"Вам добавлено 3 минуты для решения: кто будет контролировать бизнес %s.",str_biz_name);
			SendFamilyMessage(napad, 0x00cc44FF,str_control);
			SendFamilyMessage(vlad, 0x00cc44FF,str_control);
            return 1;
        }
        if(count_on_zone[0] == 0)
        {
			format(str_control,sizeof(str_control),"Вы взяли под контроль бизнес %s",str_biz_name);
			SendFamilyMessage(napad, 0x114D71AA,str_control);
			format(str_control,sizeof(str_control),"Вы потеряли контроль над бизнесом %s",str_biz_name);
			SendFamilyMessage(vlad, 0xC56565AA,str_control);
			BizzInfo[i][bMafia] = napad;
			UpdateBizz(i);
			StopWar();
        }
        else
        {
			format(str_control,sizeof(str_control),"Вы отстояли бизнес %s",str_biz_name);
           	SendFamilyMessage(vlad,0x114D71AA,str_control);
			format(str_control,sizeof(str_control),"Вам не удалось захватить  бизнес %s",str_biz_name);
			SendFamilyMessage(napad,0xC56565AA,str_control);
			StopWar();
        }

	}
	return 1;
}

stock StopWar()
{

    foreach(new idx: Player)
	{
	    if(User[idx][pMember] == mafia_frac_id[0])
	    {
			for(new i_ = 0; i_ < 5; i_++)
			{
				SendDeathMessageToPlayer(idx,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0);
			}
			DeletePVar(idx,"mafiawar");
			PlayerTextDrawHide(idx, Capture[idx]);
		}
		if(User[idx][pMember] == mafia_frac_id[1])
		{
		    for(new i_ = 0; i_ < 5; i_++)
			{
				SendDeathMessageToPlayer(idx,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0);
			}
			DeletePVar(idx,"mafiawar");
			PlayerTextDrawHide(idx, Capture[idx]);
		}
	}

    WarStart = gettime() + 5000;
	ZoneID = 0;
	ZoneTimer = 0;
	mafia_frac_id[0] = 0;
	mafia_frac_id[1] = 0;
	kills_mafia[0] = 0;
	kills_mafia[1] = 0;
	GangZoneStopFlashForAll(ZoneWar);
	GangZoneHideForAll(ZoneWar);
	KillTimer(MzCheckTimer);
}
CMD:bizlist(playerid, params[])
{
	if(!IsAMafia(playerid)) return err(!"Ошибка: {ffffff}Вам недоступна данная команда");
    new strrr[1000], count_ = 0;
	for(new h = 1; h <= TotalBizz; h++)
	{
		if(BizzInfo[h][bMafia] == User[playerid][pMember])
		{
		    count_ ++;
			format(YCMDstr, sizeof(YCMDstr), " [%d] %s\n",count_, BizzInfo[h][bMessage]);
			strcat(strrr, YCMDstr);
		}
	}
	if (strlen(strrr) > 1) ShowPlayerDialogEx(playerid, 0, 2, "Завоёванные бизнесы", strrr, "$", "$");
	else SendClientMessage(playerid,-1, !"Нет бизнесов");
	return 1;
}
CMD:bizmafia(playerid, params[])
{
	if(!BGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	new bouse = GetPVarInt(playerid,"Bizz");
	if(BizzInfo[bouse][bMafia]) return SendClientMessage(playerid,COLOR_GREY,"Бизнес уже крышуют!");
	if(sscanf(params, "d", params[0]))
	{
		SendClientMessage(playerid, COLOR_GREY, "Используйте: /bizmafia [мафия]");
		return SendClientMessage(playerid, COLOR_WHITE,"0 - Yakuza | 1 - RM | 2 - LCN");
	}
	switch (params[0])
	{
		case 0: BizzInfo[bouse][bMafia] = 6, SendClientMessage(playerid,  COLOR_WHITE, "Крыша бизнеса - Yakuza");
		case 1: BizzInfo[bouse][bMafia] = 14, SendClientMessage(playerid,  COLOR_WHITE, "Крыша бизнеса - RM");
		case 2: BizzInfo[bouse][bMafia] = 5, SendClientMessage(playerid,  COLOR_WHITE, "Крыша бизнеса - LCN");
		default: SendClientMessage(playerid, COLOR_GREY,"Неверное значение");
	}
	return true;
}
