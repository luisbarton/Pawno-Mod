CMD:fcar(playerid, params[])
{
    if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
    if(FamilyInfo[User[playerid][pFamilyMember]][famSpawn] == 0) return SendClientMessage(playerid, COLOR_GREY, "В Вашей семье не установлен дом для парковки!");
	format(QUERY, sizeof(QUERY), "Слот\tНазвание\n\
	#1\t%s\n\
	#2\t%s\n\
	#3\t%s\n\
	#4\t%s\n\
	#5\t%s", VehicleNames[FamilyInfo[User[playerid][pFamilyMember]][famCar][0]-400],
	VehicleNames[FamilyInfo[User[playerid][pFamilyMember]][famCar][1]-400],
	VehicleNames[FamilyInfo[User[playerid][pFamilyMember]][famCar][2]-400],
	VehicleNames[FamilyInfo[User[playerid][pFamilyMember]][famCar][3]-400],
	VehicleNames[FamilyInfo[User[playerid][pFamilyMember]][famCar][4]-400]);
	ShowPlayerDialogEx(playerid, 2202, DIALOG_STYLE_TABLIST_HEADERS, "{F1C33A}Выбор транспорта семьи", QUERY, // и т.д.
	"Выбрать", "Отмена");
	return 1;
}
