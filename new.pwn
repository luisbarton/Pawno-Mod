CMD:transfer(playerid, params[])
{
    if(User[playerid][pLevel] < 7) return SendClientMessage(playerid, COLOR_GREY, "У Вас должен быть 7 уровень");
	if(!IsABank(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в банке!");
	if(User[playerid][pPayDayHad] < 5) return SendClientMessage(playerid, COLOR_GREY, "Вы должны отыграть 5 часов!");
	new year1, month1, day1, hour1, minute1, second1;
    getdate(year1, month1, day1);
    gettime(hour1, minute1, second1);
	if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /transfer [id] [Сумма]");
	if (!IsPlayerConnected(params[0])) return true;
	if(params[1] > 0 && User[playerid][pBank] >= params[1])
	{
		User[playerid][pBank] -= params[1];
		User[params[0]][pBank] += params[1];
		LogingTargetMoney(playerid, params[0], params[1], "Перевел деньги в банке(/transfer)");
		format(YCMDstr, sizeof(YCMDstr), "Вы передали %i вирт, на счет %s [%i/%i/%i  %i:%i]", params[1], User[params[0]][pName], day1,month1,year1,hour1, minute1);
		SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Вы получили %i вирт, на свой счет от %s [%i/%i/%i  %i:%i]",params[1],User[playerid][pName], day1,month1,year1,hour1, minute1);
		SendClientMessage(params[0], COLOR_WHITE, YCMDstr);
		PlayerPlaySound(params[0], 1052, 0.0, 0.0, 0.0);
	}
	format(YCMDstr, sizeof(YCMDstr), "[TRANSFER] %s перевёл %s %i вирт", User[playerid][pName], User[params[0]][pName], params[1]);
	WriteLog("Transfer.txt", YCMDstr);
	return true;
}
CMD:withdraw(playerid, params[])
{
    if(!IsABank(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в банке!");
	if(sscanf(params, "d", params[0]))
	{
	    SendClientMessage(playerid, COLOR_GREY, "Используйте: /withdraw [Сумма]");
	    new string[80];
	    f(string, "На вашем счету: %i вирт",User[playerid][pBank]);
		return SCM(playerid, COLOR_WHITE, string);
	}
	if(params[0] < 1 || params[0] > 100000000) { SendClientMessage(playerid, COLOR_GREY, "Нельзя снять 1$ и более 100000000$!"); return true; }
	if(User[playerid][pBank] < params[0]) return SendClientMessage(playerid, COLOR_GREY, "У Вас нет столько денег!");
	User[playerid][pCash] += params[0];
	User[playerid][pBank] -= params[0];
	format(YCMDstr, sizeof(YCMDstr), "Вы сняли %i вирт. Остаток: %i вирт",params[0], User[playerid][pBank]);
	SendClientMessage(playerid, COLOR_YELLOW, YCMDstr);
	return true;
}
CMD:gethousemoney(playerid, params[])
{
    if(!IsABank(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в банке!");
	if(User[playerid][pHousecash] <=0) return	SendClientMessage(playerid, COLOR_GREY, "Нет денег за Ваш дом"), User[playerid][pText] = 0;
	User[playerid][pCash] += User[playerid][pHousecash];
	format(YCMDstr, sizeof(YCMDstr), "Вам возвращены %i вирт за ваш дом", User[playerid][pHousecash]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	User[playerid][pHousecash] = 0;
	User[playerid][pText] = 0;
	return true;
}
CMD:en(playerid, params[])
{

	new newcar = GetPlayerVehicleID(playerid);
	if((newcar >= rentcarsf[0] && newcar <= rentcarsf[6] || newcar >= rentcarls[0] && newcar <= rentcarls[8] || newcar >= rentcarlv[0] && newcar <= rentcarlv[17]) && GetPVarInt(playerid, "Arenda") != newcar) return true;
    if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 481 || GetVehicleModel(GetPlayerVehicleID(playerid)) == 509 || GetVehicleModel(GetPlayerVehicleID(playerid)) == 510) return true;
    if(GetPlayerVehicleID(playerid) == INVALID_VEHICLE_ID) return true;
    if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
    GetVehicleParamsEx(GetPlayerVehicleID(playerid),engine,lights,alarm,doors,bonnet,boot,objective);
    if(!engine)
    {
        if(Fuell[newcar] <= 0 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 462)
		{
			Fuell[newcar] = 0;
			GameTextForPlayer(playerid,"~r~FUEL HAS ENDED", 5000, 3);
			SCM(playerid, COLOR_RED, " Двигатель не заводится");
			SCM(playerid, COLOR_GREEN, " {00A86B}Используйте телефон {FFFFFF}(( /call )) {00A86B}чтобы вызвать механика / таксиста");
			SCM(playerid, COLOR_GREEN, " {00A86B}Если у вас есть канистра с бензином, введите {FFFFFF}(( /fillcar ))");
			return true;
		}
        if(CarHealth[GetPlayerVehicleID(playerid)] < 300) return GameTextForPlayer(playerid,"~r~ENGINE HAS BROKENED", 5000, 3);
        if(!IsAPlane(newcar) && !IsABoat(newcar) && !IsABike(newcar))
		{
        	PlayerTextDrawBoxColor(playerid, SpeedPlayer[playerid][0], 8388863);
        	PlayerTextDrawShow(playerid, SpeedPlayer[playerid][0]);
        	PlayerTextDrawBoxColor(playerid, SpeedPlayer[playerid][1], 8388863);
        	PlayerTextDrawShow(playerid, SpeedPlayer[playerid][1]);
        }
        GetVehicleParamsEx(GetPlayerVehicleID(playerid),engine,lights,alarm,doors,bonnet,boot,objective);
        SetVehicleParamsEx(GetPlayerVehicleID(playerid),true,true,alarm,doors,bonnet,boot,objective);
  	}
    else
    {
        SetPVarInt(playerid,"not_engine",0);
 		SetPVarInt(playerid,"not_engine_",0);
        GetVehicleParamsEx(GetPlayerVehicleID(playerid),engine,lights,alarm,doors,bonnet,boot,objective);
        SetVehicleParamsEx(GetPlayerVehicleID(playerid),false,false,alarm,doors,bonnet,boot,objective);
        if(!IsAPlane(newcar) && !IsABoat(newcar) && !IsABike(newcar))
		{
        	PlayerTextDrawBoxColor(playerid, SpeedPlayer[playerid][0], -1523963137);
        	PlayerTextDrawShow(playerid, SpeedPlayer[playerid][0]);
        	PlayerTextDrawBoxColor(playerid, SpeedPlayer[playerid][1], -1523963137);
        	PlayerTextDrawShow(playerid, SpeedPlayer[playerid][1]);
        }
   	}
    return true;
}
CMD:hi(playerid, params[])
{
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(!IsPlayerConnected(playerid)) return true;
	if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Нельзя использовать в машине");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /hi [ид]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(2.0, playerid, params[0]) || IsPlayerInAnyVehicle(params[0])) return true;
	if(params[0] == playerid)  return  SendClientMessage(playerid,COLOR_GREY, "Вы указали свой ID");
	new Float:angle;
	GetPlayerFacingAngle(playerid, angle);
	SetPlayerFacingAngle(params[0], angle + 180);
	format(YCMDstr, sizeof(YCMDstr), "%s пожал руку %s'у",User[playerid][pName],User[params[0]][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,10.0);
	ApplyAnimation(playerid, "GANGS", "hndshkfa",4.0,0,0,0,0,0,1);
	ApplyAnimation(params[0], "GANGS", "hndshkfa",4.0,0,0,0,0,0,1);
	return true;
}
