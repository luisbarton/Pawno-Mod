CMD:getgun(playerid, params[])
{
	if(!User[playerid][pLogin]) return SCM(playerid,COLOR_WHITE,"Вы не авторизованы!");
	switch(User[playerid][pMember])
	{
	case 5,6,14:
		{
			if(PlayerToPoint(5.0,playerid,1258.4004,-791.0316,1084.0078))
			{
			    if(sscanf(params, "u",params[0]))
				{
				    if(User[playerid][pMember] == 5) if(FracStore[LCNStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
				    if(User[playerid][pMember] == 6) if(FracStore[YakuzaStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
				    if(User[playerid][pMember] == 14) if(FracStore[RMStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
					if(User[playerid][pRank] < 3)return SCM(playerid,COLOR_GRAD1, "Оружие можно взять с 3 ранга!");
					new listitems[] = " Deagle\t[14п. 42м.]\n Shotgun\t[10п. 30м.]\n SMG\t[60п. 120м.]\n AK47\t[60п. 180м.]\n M4A1\t[100п. 300м.]\n Rifle\t[10п. 50м.]";
					ShowPlayerDialogEx(playerid, 2016, DIALOG_STYLE_TABLIST, "Склад оружия", listitems, "Взять", "Выйти");
					getgunsid[playerid] = playerid;
					SendClientMessage(playerid,COLOR_WHITE,"Вы можете использовать {00BF00} /getgun [ид игрока]{ffffff}, чтобы выдать оружие другим членам организации");
				}
				else
				{
				    if(User[playerid][pMember] == 5) if(FracStore[LCNStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
				    if(User[playerid][pMember] == 6) if(FracStore[YakuzaStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
				    if(User[playerid][pMember] == 14) if(FracStore[RMStatus] == 1) return SendClientMessage(playerid, COLOR_GREY, "Склад закрыт!");
				    if(User[params[0]][pMember] != User[playerid][pMember]) return SendClientMessage(playerid,COLOR_GREY,"Игрок не состоит в вашей организации");
				    if(User[playerid][pRank] < 3)return SCM(playerid,COLOR_GRAD1, "Оружие можно взять с 3 ранга!");
					new listitems[] = " Deagle\t[14п. 42м.]\n Shotgun\t[10п. 30м.]\n SMG\t[60п. 120м.]\n AK47\t[60п. 180м.]\n M4A1\t[100п. 300м.]\n Rifle\t[10п. 50м.]";
					ShowPlayerDialogEx(playerid, 2016, DIALOG_STYLE_TABLIST, "Склад оружия", listitems, "Взять", "Выйти");
					getgunsid[playerid] = params[0];
				}
			}
		}
	}
	return true;
}
CMD:bbank(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pMember] == 24 || User[playerid][pMember] == 26 || User[playerid][pMember] == 29)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /bbank [количество]");
	if(User[playerid][pCash] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!"); return true; }
	if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
	switch(User[playerid][pMember])
	{
	    case 24:
	    {
		    FracBank[0][fHamc] += params[0];
		    User[playerid][pCash] -= params[0];
		    format(YCMDstr, sizeof(YCMDstr), "Вы положили в банк Hell's Angels MC: %i вирт", params[0]);
		    SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	    }
	    case 26:
	    {
		    FracBank[0][fWmc] += params[0];
		    User[playerid][pCash] -= params[0];
		    format(YCMDstr, sizeof(YCMDstr), "Вы положили в банк Warlocks MC: %i вирт",params[0]);
		    SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	    }
	    case 29:
	    {
		    FracBank[0][fPmc] += params[0];
		    User[playerid][pCash] -= params[0];
		    format(YCMDstr, sizeof(YCMDstr), "Вы положили в банк Pagans MC: %i вирт", params[0]);
		    SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	    }
	}
	return true;
}
CMD:bwithdraw(playerid, params[])
{
	if(User[playerid][pLeader] == 23 || User[playerid][pLeader] == 24 || User[playerid][pLeader] == 25 || User[playerid][pLeader] == 26 || User[playerid][pLeader] == 27 || User[playerid][pLeader] == 28 || User[playerid][pLeader] == 29 || User[playerid][pLeader] == 30 || User[playerid][pLeader] == 31 || User[playerid][pLeader] == 32 )
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /bwithdraw [количество]");
	if(User[playerid][pMember] == 24 && User[playerid][pRank] == 9)
	{
		if(FracBank[0][fHamc] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке Hell's Angels MC нет денег"); return true; }
		if(FracBank[0][fHamc] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке Hell's Angels MC нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
		FracBank[0][fHamc] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка Hell's Angels MC: %i вирт",params[0]);
		SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	}
	else if(User[playerid][pMember] == 26 && User[playerid][pRank] == 9)
	{
		if(FracBank[0][fWmc] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке Highwayman MC нет денег"); return true; }
		if(FracBank[0][fWmc] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке Highwayman MC нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
		FracBank[0][fWmc] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка Highwayman MC: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	}
	else if(User[playerid][pMember] == 29 && User[playerid][pRank] == 9)
	{
		if(FracBank[0][fPmc] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке Pagans MC нет денег"); return true; }
		if(FracBank[0][fPmc] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке Pagans MC нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
		FracBank[0][fPmc] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка Pagans MC: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
	}
	return true;
}
CMD:bbalance(playerid, params[])
{
    switch(User[playerid][pMember])
	{
		case 24:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Hell's Angels MC: %i вирт", FracBank[0][fHamc]);
			SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
		}
		case 26:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Warlocks MC: %i вирт", FracBank[0][fWmc]);
			SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
		}
		case 29:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Pagans MC: %i вирт", FracBank[0][fPmc]);
			SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
		}
		default: SendClientMessage(playerid,COLOR_GREY,"Вам недоступна данная команда");
	}
	return true;
}
