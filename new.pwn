						t_SetPlayerPos(playerid, 2197.4595,-2252.8787,13.5469);
						User[ playerid ][ pPos_x ] = 265.0579;
    					User[ playerid ][ pPos_y ] = 78.0565;
			    		User[ playerid ][ pPos_z ] = 1004.6830;
			    		SetPVarInt(playerid, "AntiBreik", 2);
						SetPlayerInterior(playerid,0);
						return true;
					}
				case 24:
