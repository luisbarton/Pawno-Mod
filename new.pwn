CMD:alogin(playerid, params[])
{
    if(GetPVarInt(playerid, "Dostup")) return true;
	static const fmt_query[] = "SELECT * FROM `admin` WHERE `name` = '%e' LIMIT 1";
    new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
    mysql_format(dbHandle,query,sizeof(query), fmt_query,User[playerid][pName]);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",14,playerid,"");
    return true;
}
CMD:biz(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GRAD2, "Введите: /biz [biznumber]");
	if(BizzInfo[params[0]][bType] != 4)
	{
	    PickupX[playerid] = BizzInfo[params[0]][bExitX], PickupY[playerid] = BizzInfo[params[0]][bExitY];
		oldpickup[playerid] = BizzInfo[params[0]][bExitPic];
		timepickup[playerid] = 3;
		SetPlayerInterior(playerid,BizzInfo[params[0]][bInterior]);
		t_SetPlayerPos(playerid,BizzInfo[params[0]][bExitX],BizzInfo[params[0]][bExitY],BizzInfo[params[0]][bExitZ]);
        SetPlayerVirtualWorld(playerid,BizzInfo[params[0]][bVirtualWorld]);
	}
	else
	{
	    SetPlayerInterior(playerid,0);
		t_SetPlayerPos(playerid,BizzInfo[params[0]][bEntranceX],BizzInfo[params[0]][bEntranceY],BizzInfo[params[0]][bEntranceZ]);
		SetPlayerVirtualWorld(playerid,0);
	}
	return true;
}
CMD:asellbiz(playerid, params[])
{
    if (User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return	SendClientMessage(playerid, COLOR_GRAD1, "Введите: /asellbiz [bizid]");
	if(strcmp(BizzInfo[params[0]][bOwner],"None",true) == 0) return SendClientMessage(playerid,COLOR_GREY,"У бизнеса нет владельца");
	if(IsPlayerConnected(GetPlayerID(HouseInfo[params[0]][hOwner]))) DeletePVar(GetPlayerID(HouseInfo[params[0]][hOwner]),"Bizz"), SendClientMessage(GetPlayerID(HouseInfo[params[0]][hOwner]),COLOR_RED,"Ваш бизнес был продан администратором");
	BizzInfo[params[0]][bLocked] = 1;
	strmid(BizzInfo[params[0]][bOwner], "None", 0, strlen("None"), 32);
	PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
	SendClientMessage(playerid, COLOR_GRAD1,"Бизнес продан");
	format(YCMDstr, sizeof(YCMDstr), "{FF9900}%s{F0E79C}\nПродаётся \n\n /buybiz для покупки\nЦена: {3AA94C}%d$", BizzInfo[params[0]][bMessage],BizzInfo[params[0]][bBuyPrice]);
	UpdateDynamic3DTextLabelText(BizzInfo[params[0]][bLabel], COLOR_GREEN, YCMDstr);
	GameTextForPlayer(playerid, YCMDstr, 10000, 3);
	return true;
}
CMD:asellhouse(playerid, params[])
{
    if (User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return	SendClientMessage(playerid, COLOR_GRAD1, "Введите: /asellhouse [houseid]");
	if(strcmp(HouseInfo[params[0]][hOwner],"None",true) == 0) return SendClientMessage(playerid,COLOR_GREY,"У дома нет владельца");
	if(IsPlayerConnected(GetPlayerID(HouseInfo[params[0]][hOwner]))) DeletePVar(GetPlayerID(HouseInfo[params[0]][hOwner]),"House"), SendClientMessage(GetPlayerID(HouseInfo[params[0]][hOwner]),COLOR_RED,"Ваш дом был продан администратором");

	HouseInfo[params[0]][hHel] = 0;
	HouseInfo[params[0]][hLock] = 1;
	for(new h = 0; h < 10; h++) HouseInfo[params[0]][hSafe][h] = 0;
	strmid(HouseInfo[params[0]][hOwner], "None", 0, strlen("None"), 32);
	GameTextForPlayer(playerid, YCMDstr, 10000, 3);
	BuyHouse(params[0]);

	SendClientMessage(playerid, COLOR_GREY, "Дом продан");
	return true;
}
CMD:allsellhouse(playerid, params[])
{
    if(User[playerid][pLogin] == 0 || User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return 1;

	for(new i = 0; i<990; i++)
	{
		if(strcmp(HouseInfo[i][hOwner],"None",true) == 0) continue;

		HouseInfo[i][hHel] = 0;
		HouseInfo[i][hLock] = 1;
		for(new h = 0; h < 10; h++) HouseInfo[i][hSafe][h] = 0;
		strmid(HouseInfo[i][hOwner], "None", 0, strlen("None"), 32);
		BuyHouse(i);
	}
	SendClientMessage(playerid, COLOR_GREY, "Дома проданы");
	return 1;
}
CMD:safe(playerid, params[])
{
    if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизрваны!");
    if(!HGet(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"У вас нет дома");
    new bouse = GetPVarInt(playerid,"House");
    if(!PlayerToPoint(50, playerid,HouseInfo[bouse][hExitx], HouseInfo[bouse][hExity], HouseInfo[bouse][hExitz]) || GetPlayerVirtualWorld(playerid) != bouse+50) return true;
    if(!IsASafe(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Вы далеко от сейфа!");
    if(GetPlayerVirtualWorld(playerid) != bouse+50) return true;
    ShowPlayerDialogEx(playerid,1054,DIALOG_STYLE_LIST, "Сейф","Взять\nПоложить", "Выбор", "Отмена");
    return 1;
}
CMD:open(playerid, params[])
{
	if(!HGet(playerid)) return true;
	new bouse = GetPVarInt(playerid,"House");
	if((!PlayerToPoint(10, playerid,HouseInfo[bouse][hExitx], HouseInfo[bouse][hExity], HouseInfo[bouse][hExitz]) || GetPlayerVirtualWorld(playerid) != bouse+50) && !PlayerToPoint(2.0, playerid, HouseInfo[bouse][hEntrancex], HouseInfo[bouse][hEntrancey], HouseInfo[bouse][hEntrancez])) return true;
	if(HouseInfo[bouse][hLock] == 1)
	{
		HouseInfo[bouse][hLock] = 0;
		GameTextForPlayer(playerid,"~w~House ~g~UNLOCK", 5000, 3);
		PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
		return true;
	}
	if(HouseInfo[bouse][hLock] == 0)
	{
		HouseInfo[bouse][hLock] = 1;
		GameTextForPlayer(playerid, "~w~House ~r~LOCK", 5000, 3);
		PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
		return true;
	}
	return true;
}
CMD:sellhouse(playerid, params[])
{
	if(!HGet(playerid)) return true;
	new bouse = GetPVarInt(playerid,"House");
	if(!PlayerToPoint(10, playerid,HouseInfo[bouse][hExitx], HouseInfo[bouse][hExity], HouseInfo[bouse][hExitz])) return true;
	if(GetPlayerVirtualWorld(playerid) != bouse+50) return true;
	ShowPlayerDialogEx(playerid,5032,DIALOG_STYLE_MSGBOX, "{F1C33A}Продажа имущества", "{FFFFFF}Вы действительно хотите продать дом?", "Да", "Нет");
	return true;
}
CMD:healme(playerid, params[])
{
    for(new i = 1; i <= TotalHouse; i++)
	{
	    if(HealmeObject[playerid]>0) return 0;
		if(!PlayerToPoint(5, playerid,HouseInfo[i][hExitx], HouseInfo[i][hExity], HouseInfo[i][hExitz])) continue;
		if(GetPlayerVirtualWorld(playerid) != i+50) continue;
		if(HouseInfo[i][hHel] == 0)return SendClientMessage(playerid, COLOR_GREY, "В этом месте нет аптечек");
		if(GetPVarInt(playerid,"_Hel") >= 10) return SendClientMessage(playerid,COLOR_GREY, "Использовать можно только 10 шт. в час");
		new Float:health;
		GetPlayerHealth(playerid,health);
		if(health == 100) return SendClientMessage(playerid, COLOR_GREY, "Вы здоровы");
		SendClientMessage(playerid, COLOR_WHITE, "Вы были вылечены на 25 процентов");
		format(YCMDstr, sizeof(YCMDstr), "Осталось %i аптечек", HouseInfo[i][hHel]-1);
		SendClientMessage(playerid, COLOR_BLUE, YCMDstr);
		HouseInfo[i][hHel] -= 1;
		SetPlayerHealthAC(playerid, User[playerid][pHP] + 25.0);
		if(health > 100) SetPlayerHealthAC(playerid, 100.0);
		SetPlayerChatBubble(playerid, "использовал(а) аптечку", COLOR_PURPLE, 30.0, 10000);
		SetPVarInt(playerid,"_Hel",GetPVarInt(playerid,"_Hel")+1);
		if(!IsPlayerInAnyVehicle(playerid))
		{
			ApplyAnimation(playerid,"PED","gum_eat",4.0,0,0,0,0,0,1);
			SetPlayerAttachedObject(playerid, 7, 11736, 5,  0.186999, 0.037000, 0.022999,  -102.499969, -179.900024, -91.400024,  1.000000, 1.000000, 1.000000);
			HealmeObject[playerid] = 5;
		}
		return true;
	}
	if(IsAMedKit(playerid))
	{
	    if(HealmeObject[playerid]>0) return 0;
	    new _null;
	    switch(User[playerid][pMember])
	    {
	        case 12: _null = ballashel; case 13: _null = vagoshel; case 15: _null = groovhel;
			case 17: _null = aztekhel; case 18: _null = rifahel; case 6: _null = yakuzahel;
			case 5: _null = lcnhel; case 14: _null = rmhel;
		}
		if(_null <= 0) return SendClientMessage(playerid, COLOR_GREY, "На базе нет аптечек");
		if(User[playerid][pHP] >= 100) return SendClientMessage(playerid, COLOR_GREY, "Вы здоровы");
		SendClientMessage(playerid, COLOR_WHITE, "Вы были вылечены на 25%");
		format(YCMDstr, 64, "Осталось %i аптечек", _null-1);
		SendClientMessage(playerid, COLOR_BLUE, YCMDstr);
		switch(User[playerid][pMember])
	    {
	        case 12: ballashel--; case 13: vagoshel--; case 15: groovhel--;
			case 17: aztekhel--; case 18: rifahel--; case 6: yakuzahel--;
			case 5: lcnhel--; case 14: rmhel--;
		}
		SetPlayerHealthAC(playerid, User[playerid][pHP] + 25.0);
		if(User[playerid][pHP] > 100) SetPlayerHealthAC(playerid, 100.0);
		if(!IsPlayerInAnyVehicle(playerid))
		{
			ApplyAnimation(playerid,"PED","gum_eat",4.0,0,0,0,0,0,1);
			SetPlayerAttachedObject(playerid, 7, 11736, 5,  0.186999, 0.037000, 0.022999,  -102.499969, -179.900024, -91.400024,  1.000000, 1.000000, 1.000000);
			HealmeObject[playerid] = 5;
		}
		SetPlayerChatBubble(playerid, "использовал(а) аптечку", COLOR_PURPLE, 30.0, 10000);
		return 1;
	}
	
	if(HealmeObject[playerid]>0) return SendClientMessage(playerid, COLOR_GREY, "Не флудите!");
	if(IsAAntidm(playerid)) return SendClientMessage(playerid, COLOR_GREY, "В данном месте вы не можете использовать аптечку!");
	else if(User[playerid][pAptechka] == 0) return SendClientMessage(playerid, COLOR_GREY, "У вас нет аптечек, купить их можно в магазине 24/7");
	new Float:shealth = User[playerid][pHP];
	GetPlayerHealth(playerid, shealth);
	if(shealth >= 100) return SendClientMessage(playerid, COLOR_GREY, "Вы не нуждаетесь в лечении!");
	if(shealth <= 50) SetPlayerHealthAC(playerid, shealth+50);
	else SetPlayerHealthAC(playerid, 100);
	if(!IsPlayerInAnyVehicle(playerid))
	{
		ApplyAnimation(playerid,"PED","gum_eat",4.0,0,0,0,0,0,1);
		SetPlayerAttachedObject(playerid, 7, 11736, 5,  0.186999, 0.037000, 0.022999,  -102.499969, -179.900024, -91.400024,  1.000000, 1.000000, 1.000000);
		HealmeObject[playerid] = 5;
	}
	User[playerid][pAptechka]--;
	SetPlayerChatBubble(playerid,"использует аптечку",COLOR_PURPLE,30.0,1000);
    GameTextForPlayer(playerid, "~b~+50 HP", 100, 1);
	return true;
}
CMD:robhouse(playerid, params[])
{
    if(!IsAGang(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Вы не бандит!");
    for(new h = 1; h <= TotalHouse; h++)
	{
		for(new i =1; i <= TOTALGZ; i++)
		{
			if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]) && User[playerid][pMember] == GZInfo[i][gFrakVlad])
			{
				if(!PlayerToPoint(2.0, playerid, HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez])) continue;
				if(robhouse[h] != false) return SendClientMessage(playerid, COLOR_GREY, "Этот дом уже был ограблен в этом часу");
				if(strcmp(HouseInfo[h][hOwner],"None",true) == 0) return SendClientMessage(playerid, COLOR_GREY, "У дома нет владельца");
				if(!IsPlayerConnected(GetPlayerID(HouseInfo[h][hOwner]))) return SendClientMessage(playerid, COLOR_GREY, "Владелец дома оффлайн");
				SendClientMessage(playerid, COLOR_GREEN, "Вы ограбили дом, везите материалы в доки (( /gps - [1] - [11] сдача металла ))");
				SendClientMessage(GetPlayerID(HouseInfo[h][hOwner]),COLOR_REDD,"Вам дом ограбили! С вашего счета было списано 500 вирт на востановление труб и оплату энергии");
				User[playerid][pZakonp] -= 1;
				robh[playerid] = true;
				robhouse[h] = true;
				HouseInfo[h][hTakings] -= 500;
			}
		}
	}
	return true;
}
CMD:getskill(playerid, params[])
{
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /getskill [id]");
    show_skill(playerid, params[0]);
	return true;
}
