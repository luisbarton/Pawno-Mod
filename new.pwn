CMD:hbjectid(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /hbjecdit [object slot]");
	if(IsPlayerAttachedObjectSlotUsed(playerid, params[0])) EditAttachedObject(playerid, params[0]);
	return true;
}
CMD:hbject(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    new giveplayerids = -1, slot = -1, objectid = -1, bone = -1, Float:oX, Float:oY, Float:oZ, Float:rX, Float:rY, Float:rZ, Float:sX, Float:sY, Float:sZ;
	if(sscanf(params, "udddfffffffff", giveplayerids, slot, objectid, bone, oX, oY, oZ, rX, rY, rZ, sX, sY, sZ)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /hbject [playerid] [слот 0-9] [id объект] [1-18]  [x][y][z]  [rx][ry][rz] [sx][sy][sz]");
	if(IsPlayerAttachedObjectSlotUsed(giveplayerids, slot)) return RemovePlayerAttachedObject(giveplayerids, slot), SendClientMessage(playerid, COLOR_WHITE, "Объект удален");
	SetPlayerAttachedObject(giveplayerids, slot, objectid, bone, oX, oY, oZ, rX, rY, rZ, sX, sY, sZ);
	return true;
}
CMD:getobjectpos(playerid, params[])
{
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	new str[128];
	new Float:x1,Float:y1,Float:z1;
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /getobjectpos [Слот]");
	GetObjectPos(SlotObject[params[0]],x1,y1,z1);
	format(str, sizeof(str), "GetDynamicObjectPos %f,%f,%f",x1,y1,z1);
	SendClientMessage(playerid,COLOR_GREY,str);
	return true;
}
CMD:obj(playerid, params[])
{
	if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return 1;
	if(sscanf(params, "dd", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /obj [слот] [id объекта]");
	if(SlotObject[params[0]] != 0) return 1;
	new Float:x1,Float:y1,Float:z1;
	GetPlayerPos(playerid,x1,y1,z1);
	SlotObject[params[0]] = CreateObject(params[1],x1,y1,z1,0.00,0.00,0.00);
	return 1;
}
CMD:dobject(playerid, params[])
{
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return 1;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /dobject [слот]");
	if(SlotObject[params[0]] != 0)
	{
		DestroyObject(SlotObject[params[0]]);
		SlotObject[params[0]] = 0;
	}
	return 1;
}
CMD:eobject(playerid, params[])
{
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return 1;
	if(sscanf(params, "d", params[0])) { SelectObject(playerid); } else
	{
		if(SlotObject[params[0]] != 0)
		{
			EditObject(playerid,SlotObject[params[0]]);
		}
	}
	return 1;
}
CMD:podeezd(playerid, params[])
{
    if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d", params[0]))return SendClientMessage(playerid, -1, "Введите: /podeezd [1-9]");
    new Float:X,Float:Y,Float:Z;
    if(global[playerid] == 0)
    {
    	if(params[0] > 9 || params[0] < 1) return SendClientMessage(playerid, -1, "Неверное кол-во подъездов");
    	static const fmt_query[] = "INSERT INTO `podezd` (`podEtazi`) VALUES ('%d')";
    	new query[sizeof(fmt_query)+(-2+15)];
    	mysql_format(dbHandle, query, sizeof(query), fmt_query, params[0]);
		mysql_tquery(dbHandle, query, "", "");
     	AllPODEZD ++;
      	GetPlayerPos(playerid, X,Y,Z);
       	new carid = CreateVehicleAC(560, X,Y,Z, 0.0, 230, 230, 60000);
        PutPlayerInVehicleEx(playerid, carid, 0), Fuell[carid] = 200;
        SetPlayerArmedWeapon(playerid,0);
        PodeezdInfo[AllPODEZD][podEtazi] = params[0];
        PodeezdInfo[AllPODEZD][pid] = AllPODEZD;
        global[playerid] = 1;
        SendClientMessage(playerid, COLOR_WHITE, "Поставьте автомобиль туда, где будет находиться парковочное место и введите /podcrt");
        return true;
    }
    return true;
}
