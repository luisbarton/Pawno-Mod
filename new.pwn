stock QuestLines(playerid)
{
	if(User[playerid][pQuestFirst] == 0 && User[playerid][pQuestTwo] == 0 && User[playerid][pQuestThree] == 0)
	{
		ShowPlayerDialog(playerid, 954, DIALOG_STYLE_LIST, "{FFFFFF}Квестовая линия", "{FFFFFF}1. Первые шаги\n2. Теперь водитель", "Далее", "Отмена");
	}
	else if(User[playerid][pQuestFirst] == 1 && User[playerid][pQuestTwo] == 0 && User[playerid][pQuestThree] == 0)
	{
	    ShowPlayerDialog(playerid, 954, DIALOG_STYLE_LIST, "{FFFFFF}Квестовая линия", "1. Первые шаги\n{FFFFFF}2. Теперь водитель", "Далее", "Отмена");
	}
	return 1;
}

