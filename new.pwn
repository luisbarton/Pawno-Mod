CMD:paintlist(playerid,params[])
{
	new string_[512], str_[128];
	format(string_, sizeof string_,"\tИмя\t\t\tУбийств\t\t\tСмертей\n___________________________________________________________________\n");
	for(new i = 0; i < Painlist; i++)
	{
		format(str_, sizeof(str_), "\t%s\t\t\t%d\t\t\t%d\n",PaintStats[i][paName],PaintStats[i][paKills],PaintStats[i][paDeaths]);
		strcat(string_, str_);
	}
	if(Painlist > 0) return ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX, "Список игроков", string_, "Отмена", "");
	err(!"Ошибка: {ffffff}Список игроков пуст");
	return 1;
}
CMD:racelist(playerid,params[])
{
	new string_[512];
	if(RaceList == 0) return err(!"Ошибка: {ffffff}Список пуст!");
 	new null, str[100];
  	for(new i = 0; i < RaceList; i++)
   	{
    	null++;
		format(str, sizeof str,"%d. %s\n",null,RaceInfo[i][rName]);
		strcat(string_,str);
	}
	return ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX, "Список игроков", string_, "Отмена", "");
}
CMD:gmx(playerid, params[])
{
    if (User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
	foreach(new i : Player)
	{
		GameTextForPlayer(i,"~r~RESTART", 1000, 0);
		SavePlayer(i);
		SaveCar(i);
	}
	SaveOtherServer();
	//SaveGZ();
	for(new i = 1; i <= TOTALCASINO; i++) SaveCasinoServer(i);
	for(new i = 1; i <= TOTALSHOPS; i++) SaveServerShops(i);
	for(new i = 1; i <= TotalBizz; i++) SaveServerBizz(i);
	for(new i = 1; i <= TotalHouse; i++) SaveServerHouses(i);
	for(new i = 1; i <= ALLKVARTIRI; i++) SaveServerKvartirs(i);
	for(new i = 1; i <= AllPODEZD; i++) SaveServerPodezds(i);
	for(new i = 1; i <= TOTALATM; i++) SaveServerATM(i);
	for(new i = 1; i <= TOTALFARM; i++) SaveServerFarms(i);
	mysql_query(dbHandle, "UPDATE `accounts` SET `pLogin` = '0'");
	SendRconCommand("gmx");
	return true;
}
CMD:clearreconnect(playerid,params[])
{
    if(User[playerid][pAdmin] < 8 || !GetPVarInt(playerid, "Dostup")) return true;
    ClearReconnect();
    SendClientMessage(playerid,COLOR_WHITE,"Reconnect лист очищен");
    return true;
}
CMD:setallbizint(playerid,params[])
{
    if(User[playerid][pAdmin] < 8 || !GetPVarInt(playerid, "Dostup")) return true;
    for(new i = 1; i <= TotalBizz; i++)
    {
        if(BizzInfo[i][bType] == 3)
        {
			BizzInfo[i][bInterior] = 6;
			BizzInfo[i][bExitX] = -2240.4685;
			BizzInfo[i][bExitY] = 137.0604;
			BizzInfo[i][bExitZ] = 1035.4140;
			BizzInfo[i][bBarX] = -2236.1130;
            BizzInfo[i][bBarY] = 130.1580;
            BizzInfo[i][bBarZ] = 1035.4141;
            DestroyDynamicPickup(BizzInfo[i][bExitPic]);
			BizzInfo[i][bExitPic] = CreateDynamicPickup(19132, 23, BizzInfo[i][bExitX], BizzInfo[i][bExitY], BizzInfo[i][bExitZ],BizzInfo[i][bVirtualWorld]);
		}
	}
	SendClientMessage(playerid,-1,"Бизнесы по интерьерам распределены");
	return true;
}
CMD:buycar(playerid, params[])
{
    if(User[playerid][pCarLic] != 1) return SendClientMessage(playerid,COLOR_WHITE, "У вас нет Лицензии на управление авто");
	if(!HGet(playerid) && !KGet(playerid)) return SendClientMessage(playerid,COLOR_GREY, "У вас нет дома/квартиры");
	if(IsPlayerInRangeOfPoint(playerid,5.0, 562.2836,-1291.9972,17.2482))
	{
		SetPVarInt(playerid,"AutoShop",1);
		return ShowBuyCar(playerid);
	}
	else if(IsPlayerInRangeOfPoint(playerid,5.0, -1951.2544,293.6375,35.4688))
	{
		SetPVarInt(playerid,"AutoShop",2);
		return ShowPlayerDialogEx(playerid,14009,0," ","Выберите класс машин","C","D");
	}
	else if(IsPlayerInRangeOfPoint(playerid,5.0, -1657.7015,1210.2267,7.2500))
	{
		SetPVarInt(playerid,"AutoShop",3);
		return ShowPlayerDialogEx(playerid,14009,0," ","Выберите класс машин","A","B");
	}
	else if(IsPlayerInRangeOfPoint(playerid,5.0, 2200.8857,1394.2892,11.0625))
	{
		SetPVarInt(playerid,"AutoShop",4);
		return ShowPlayerDialogEx(playerid,14009,0," ","Выберите класс машин","A","B");
	}
	else SendClientMessage(playerid,COLOR_WHITE,"Вы не в месте продажи автомобилей!");
	return 1;
}
CMD:setspa(playerid, params[])
{
    if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setspa [playerid] [значение]");
    SetPlayerSpecialAction (params[0],params[1]);
    return true;
}
CMD:thefskill(playerid)
{
	new string[35];
	format(string,sizeof(string), "Ваш опыт автоугонщика: %i / 1000.", User[playerid][pSkilla]);
	return SendClientMessage(playerid,COLOR_BLUE,string);
}
CMD:route(playerid, params[])
{
    if(User[playerid][pJob] != 1) return SendClientMessage(playerid, COLOR_GREY, "Вы не работаете водителем автобуса");
	if(GetPlayerState(playerid) != 2) return SendClientMessage(playerid, COLOR_GREY, "Вы должны находиться за рулем автобуса!");
	new carid = GetPlayerVehicleID(playerid);
    if((carid >= buscar[0] && carid <= buscar[1]) || (carid >= buscar[2] && carid <= buscar[3]) || (carid >= buscar[4] && carid <= buscar[5]) || (carid >= buscar[6] && carid <= buscar[7]))
	{
		if(GetPVarInt(playerid, "TypeBus") > 0)
		{
			new string[80];
			format(string, sizeof(string), "Рабочий день завершен. Вами заработано: %i вирт. За ремонт: -%i вирт", GetPVarInt(playerid, "BusMoney"), GetPVarInt(playerid,"BusRepairMoney"));
			SendClientMessage(playerid, 0x6495EDFF, string);
			SendClientMessage(playerid, COLOR_WHITE, "Деньги будут перечислены на счет во время зарплаты");
			User[playerid][pPayCheck] -= GetPVarInt(playerid,"BusRepairMoney");
			DeletePVar(playerid, "BusTime");
			DeletePVar(playerid, "TypeBus");
			DeletePVar(playerid, "BusStop");
			DeletePVar(playerid, "BusMoney");
			DeletePVar(playerid, "BusRepairMoney");
			DeletePVar(playerid, "rentcar_job");
			pPressed[playerid] = 0;
			//Delete3DTextLabel(JobText3D[GetPlayerVehicleID(playerid)]);
			if(IsValidDynamic3DTextLabel(BusText3D[playerid])) DestroyDynamic3DTextLabel(BusText3D[playerid]);
			SetVehicleToRespawn(GetPlayerVehicleID(playerid));
			DisablePlayerRaceCheckpoint(playerid);
			return true;
		}
		if(GetPlayerVehicleID(playerid) >= buscar[0] && GetPlayerVehicleID(playerid) <= buscar[1]) ShowPlayerDialogEx(playerid,1745,DIALOG_STYLE_MSGBOX," ","{FFFFFF}Начать работу водителя автобуса?", "Да", "Нет");
  		else if(GetPlayerVehicleID(playerid) >= buscar[2] && GetPlayerVehicleID(playerid) <= buscar[3]) ShowPlayerDialogEx(playerid,1745,DIALOG_STYLE_MSGBOX," ","{FFFFFF}Начать работу водителя автобуса?", "Да", "Нет");
    	else if(GetPlayerVehicleID(playerid) >= buscar[4] && GetPlayerVehicleID(playerid) <= buscar[5]) ShowPlayerDialogEx(playerid,1745,DIALOG_STYLE_MSGBOX," ","{FFFFFF}Начать работу водителя автобуса?", "Да", "Нет");
     	else ShowPlayerDialogEx(playerid, 163, 2, "Маршрут", "АвтоВокзал LS << >> Автошкола SF\nАвтоВокзал LS << >> АвтоВокзал LV\nАвтоВокзал LS << >> Заводы", "Принять", "Отмена");
	}
	else SendClientMessage(playerid, COLOR_GREY, "Вы должны находиться в автобусе!");
	return true;
}
CMD:play(playerid, params[])
{
	if(GetPVarInt(playerid, "Radio") > 0) StopAudioStreamForPlayer(playerid);
	ShowPlayerDialogEx(playerid, 1905, DIALOG_STYLE_LIST, "Выбор радиостанции", "1. Test FM\n2. Power FM\n3. European Hit Radio", "Выбрать", "Отмена");
	return true;
}
