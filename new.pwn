CMD:unlockallkvart(playerid,params[])
{
	if(User[playerid][pAdmin] < 8 || !GetPVarInt(playerid, "Dostup")) return true;
	for(new i = 1; i <= ALLKVARTIRI; i++) if(kvartinfo[i][lock] == 1) kvartinfo[i][lock] = 0;
	return true;
}
CMD:bpanel(playerid,params[])
{
	if(!BGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	return ShowPlayerDialogEx(playerid, 1746, 2, "{F1C33A}Панель управления бизнесом", "1. Информация о бизнесе\n2. Открыть бизнес\n3. Установить цену за товар\n4. Установить цену за вход (Только для клубов и баров)\n{FF6347}5. Продать бизнес\n{9ACD32}6. Заказать продукты\n{9ACD32}7. Финансовая статистика", "Выбрать", "Закрыть");
}
CMD:smoke(playerid,params[])
{
	if(GetPVarInt(playerid, "IsSmoking")) return SendClientMessage(playerid,COLOR_GREY, "Вы уже курите");
 	if(User[playerid][pLighter] == 0) return SendClientMessage(playerid,COLOR_GREY, "У Вас нет зажигалки");
  	if(User[playerid][pCigarettes] == 0) return SendClientMessage(playerid,COLOR_GREY, "У Вас нет сигарет");
  	new randlighter = Random(0,10);
  	if(randlighter == 3) return User[playerid][pLighter] = 0,SendClientMessage(playerid,COLOR_WHITE,"Вы сломали зажигалку");
   	new randsmoke = random(2)+1;
	new string[52];
	if(randsmoke == 1)
	{
 		User[playerid][pCigarettes] -= 1;
   		f(string, "%s прикурил(а) сигарету.",User[playerid][pName]);
   		SendBeside(playerid,COLOR_PURPLE,string,30.0);
   		SetPVarInt(playerid, "IsSmoking", 60);
   		SendClientMessage(playerid, COLOR_WHITE, "Используйте /dropcigarette чтобы выбросить сигарету.");
   		SetPlayerSpecialAction(playerid,SPECIAL_ACTION_SMOKE_CIGGY);
   		return 1;
	}
	else f(string, "%s пытается прикурить сигарету.",User[playerid][pName]);
	//ProxDetector(30.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
	SendBeside(playerid,COLOR_PURPLE,string,30.0);
	return true;
}
CMD:dropcigarette(playerid,params[])
{
    if(!GetPVarInt(playerid, "IsSmoking")) return SendClientMessage(playerid,COLOR_GREY,"Вы не курите");
    DeletePVar(playerid, "IsSmoking");
	new string[54];
    format(string, sizeof(string), "%s выбросил(а) сигарету на землю.", User[playerid][pName]);
    SendBeside(playerid,COLOR_PURPLE,string,30.0);
	SetPlayerSpecialAction(playerid,SPECIAL_ACTION_NONE);
    return true;
}
CMD:ciga(playerid,params[])
{
	new string[52];
    format(string, sizeof(string), "%s открыл(а) пачку сигарет.", User[playerid][pName]);
    SendBeside(playerid,COLOR_PURPLE,string,30.0);
	format(string, sizeof(string), "У вас в пачке %i сигарет.", User[playerid][pCigarettes]);
    SendClientMessage(playerid,-1,string);
    return true;
}
