				}
				case 1:
				{
					ShowPlayerDialogEx(playerid, 1507, DIALOG_STYLE_INPUT, "Жучок", "\n{FFFFFF}Для того, чтобы установить жучок, введите ID игрока в поле ниже:\n", "Установить", "Назад");
