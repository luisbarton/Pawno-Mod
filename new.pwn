	format(YCMDstr, 144, "(( %s ))", params[0]);
    SetPlayerChatBubble(playerid,params[0],0xFF9900AA,30.0,10000);
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:try(playerid, params[])
{
    if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
		return true;
	}
	AntiReklama(playerid,params[1],"TRY");
	if(GetPVarInt(playerid, "antireklamka") == 1)
	{
	    SetPVarInt(playerid, "antireklamka", 0);
	    return true;
	}
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата");
	if(sscanf(params, "s[64]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /try [действие]");
	new randomchik = Random(0,2);
	format(YCMDstr, sizeof(YCMDstr), "%s %s %s",User[playerid][pName],params[0],(!randomchik)?("{63C600} [Удачно]") : ("{BF0000} [Неудачно]"));
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	SetPlayerChatBubble(playerid,params[0],COLOR_PURPLE,30.0,10000);
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:seetry(playerid, params[])
{
    if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
		return true;
	}
	AntiReklama(playerid,params[1],"TRY");
	if(GetPVarInt(playerid, "antireklamka") == 1)
	{
	    SetPVarInt(playerid, "antireklamka", 0);
	    return true;
	}
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата");
	if(sscanf(params, "s[64]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /seetry [действие]");
	new randomchik = Random(0,2);
	format(YCMDstr, sizeof(YCMDstr), "%s %s",params[0],(!randomchik)?("{63C600} [Удачно]") : ("{BF0000} [Неудачно]"));
	SetPlayerChatBubble(playerid,params[0],COLOR_PURPLE,30.0,10000);
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:shout(playerid, params[])
{
    if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	AntiReklama(playerid,params[1],"Крикнул");
	if(GetPVarInt(playerid, "antireklamka") == 1)
	{
	    SetPVarInt(playerid, "antireklamka", 0);
	    return true;
	}
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата");
	if(sscanf(params, "s[64]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/s)hout [текст]");
	format(YCMDstr, sizeof(YCMDstr), "%s кричит: %s!!",User[playerid][pName],params[0]);
	SendBeside(playerid,COLOR_WHITE,YCMDstr,50.0);
	Flood[playerid] = 2;
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) ApplyAnimation(playerid, "RIOT", "RIOT_shout", 2000.0, 0, 1, 1, 1, 1, 1), SetTimerEx("ClearAnim", 800, false, "d", playerid);
	SetPlayerChatBubble(playerid,params[0],COLOR_YELLOW,60.0,10000);
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:fish(playerid, params[])
{
    ShowPlayerDialogEx(playerid,1342,DIALOG_STYLE_LIST, "Рыбалка","Начать / Закончить рыбалку\nНакопать червей\nПриготовить рыбу\nСъесть рыбу\nПродать рыбу\nИнформация\nПомощь", "Выбор", "Выход");
	return true;
}
