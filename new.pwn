public OnRconLoginAttempt(ip[], password[], success)
{
    if(!success) // if they supplied a bad password
    {
        BlockIpAddress(ip, 60 * 1000); // block the connections from this ip for one minute
    }
    return 1;
}
public OnPlayerPickUpDynamicPickup(playerid, pickupid)
{
	if(pickupid == oldpickup[playerid]) return true;
	oldpickup[playerid] = pickupid;
	timepickup[playerid] = 3;
	printf("%d, %s, %d",pickupid,Name(playerid),User[playerid][pMember]);
	new Float:zx;
	GetPlayerPos(playerid, PickupX[playerid], PickupY[playerid], zx);
	for(new i = GetVehiclePoolSize(); i >= 0; i--)
	{
	    new null;
	    for(new idx = 1; idx <= TOTALFARM; idx++) if(i >= FarmInfo[idx][fSeed_Car][0] && i <= FarmInfo[idx][fSeed_Car][1]) null = idx;
	    if(pickupid == Farmcar_pickup[i] && null)
	    {
	        new Float:x, Float:y, Float:z;
	        if(GetPVarInt(playerid,"farm_id") != null) return 1;
			if(GetPVarInt(playerid,"farm_status") == 0)
			{
   				DisablePlayerCheckpoint(playerid);
				RemovePlayerAttachedObject(playerid,3);
				GetVehiclePos(i, x, y, z);
				GetXYInBackOfPlayer(i,x,y,3.0);
				if(random(2) == 0) Farm_coord[playerid][0] = x+random(3)+2, Farm_coord[playerid][1] = y+random(3)+2, Farm_coord[playerid][2] = z;
				else Farm_coord[playerid][0] = x-random(3)-2, Farm_coord[playerid][1] = y-random(3)-2, Farm_coord[playerid][2] = z;
				SetPlayerCheckpoint(playerid,Farm_coord[playerid][0],Farm_coord[playerid][1],Farm_coord[playerid][2], 1.0);
				SetPVarInt(playerid,"farm_status", 1);
    			SendClientMessage(playerid,COLOR_GREEN,"Для начала соберите урожай{ffffff} (( Встаньте на красный чекпоинт, и ждите 15 секунд ))");
       			SendClientMessage(playerid,COLOR_GREEN,"Когда соберете положите в кузов автомобиля{ffffff} (( Встаньте на желтую стрелку ))");
          		SendClientMessage(playerid,COLOR_GREEN,"Если захотите завершить работу, пройдите к раздевалке{ffffff} (( Встаньте на синий пикап у фермы ))");
            	SendClientMessage(playerid,COLOR_GREEN,"Если вы фермер, то просто сядьте в машину для завершения сбора урожая");
			}
			else if(GetPVarInt(playerid,"farm_status") == 1) return err(!"Ошибка: {ffffff}Вы ещё не собрали урожай");
			else if(GetPVarInt(playerid,"farm_status") == 2)
			{
			    if(Farmcar_prods[i] >= 1000)
				{
					err(!"Ошибка: {ffffff}Машина заполнена!");
					Farmcar_prods[i] = 1000;
					if(IsValidDynamic3DTextLabel(Farmcar_text[i])) UpdateDynamic3DTextLabelText(Farmcar_text[i], 0x5CABBDFF, "Загружено\n{ffffff}1000 / 1000");
					return 1;
				}
				Farmcar_prods[i] += 5;

    		//	FarmStatHour[null][2] += 5;
				/*if(pInfo[playerid][QuestSelect] == 0 && pInfo[playerid][NumberQuest] == 3)
				{
				    pInfo[playerid][QuestProgress] ++;
				    if(pInfo[playerid][QuestProgress] >= 50)
				    {
				        pInfo[playerid][NumberQuest] ++;
				        pInfo[playerid][QuestProgress] = 0;
				        NameQuestLine(playerid);
				    }
				}*/
				SetPVarInt(playerid,"farm_zp", GetPVarInt(playerid,"farm_zp") + FarmInfo[GetPVarInt(playerid,"farm_id")][fZp]);
				new string_[64];
				format(string_, sizeof string_, "~b~count:~w~%d$",GetPVarInt(playerid,"farm_zp"));
				GameTextForPlayer(playerid, string_, 3000, 1);
				DisablePlayerCheckpoint(playerid);
				SetPVarInt(playerid,"farm_status",1);
				RemovePlayerAttachedObject(playerid,3);
                GetVehiclePos(i, x, y, z);
                GetXYInBackOfPlayer(i,x,y,3.0);
			    if(random(2) == 0) Farm_coord[playerid][0] = x+random(3)+2, Farm_coord[playerid][1] = y+random(3)+2, Farm_coord[playerid][2] = z;
				else Farm_coord[playerid][0] = x-random(3)-2, Farm_coord[playerid][1] = y-random(3)-2, Farm_coord[playerid][2] = z;
				SetPlayerCheckpoint(playerid,Farm_coord[playerid][0],Farm_coord[playerid][1],Farm_coord[playerid][2], 1.0);
				format(string_, sizeof string_, "Загружено\n{ffffff}%d / 1000",Farmcar_prods[i]);
				if(IsValidDynamic3DTextLabel(Farmcar_text[i])) UpdateDynamic3DTextLabelText(Farmcar_text[i], 0x5CABBDFF, string_);
			}
		}
		if((i >= comptruck[0] && i <= comptruck[1]) && car_pickup[i] == pickupid)
		{
			if(!IsPlayerInAnyVehicle(playerid) && User[playerid][PlayerWorks] == true && User[playerid][PlayerUseMesh] == true)
			{
				if(car_grain[i][0] >= car_grain[i][1]) return SCM(playerid,COLOR_GREY," В машине нет места"), car_grain[i][0] = car_grain[i][1];
				car_grain[i][0] += 100;
				if(car_grain[i][0] > car_grain[i][1]) car_grain[i][0] = car_grain[i][1];
				JobAmmount[playerid] ++;
				format(YCMDstr,100, "Товаров перенесено: {DCD45C}%i",JobAmmount[playerid]);
				ClearAnimations(playerid);
				ApplyAnimation(playerid, "CARRY", "crry_prtial",4.0,0,0,0,0,1,0);
				SCM(playerid,COLOR_WHITE,YCMDstr);
				DisablePlayerCheckpoint(playerid);
				SetPlayerSpecialAction (playerid, SPECIAL_ACTION_NONE);
				User[playerid][PlayerUseMesh] = false;
//				mesh[playerid] = 0;
