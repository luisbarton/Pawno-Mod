				SCM(playerid, COLOR_WHITE, string);
				break;
			}
			else if(VibrosInfo[i][vModel] == 3)
            {
                /*if(User[playerid][pMats]+VibrosInfo[i][vKol] > 500)
                {
                    SendClientMessage(playerid,COLOR_GREY,"У вас не может быть больше 500 материалов");
