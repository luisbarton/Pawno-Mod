CMD:mafiawithdraw(playerid, params[])
{
	if(User[playerid][pLeader] == 6 || User[playerid][pLeader] == 14 || User[playerid][pLeader] == 5)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /mafiawithdraw [количество]");
	if(kaznawithdrawed > 399999) return SendClientMessage(playerid,COLOR_GREY," Вы исчерпали дневной лимит в 400.000 вирт!");
	if(params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
	if(params[0] > 100000) return SCM(playerid, COLOR_GREY, "Вы не можете снять более 100000 за раз!");
	if(User[playerid][pMember] == 6 && User[playerid][pRank] == 10)
	{
		if(MafiaBank[0][nYakuza] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии Yakuza нет денег"); return true; }
		if(MafiaBank[0][nYakuza] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии Yakuza нет столько денег"); return true; }
		MafiaBank[0][nYakuza] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка мафии Yakuza: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 14 && User[playerid][pRank] == 10)
	{
		if(MafiaBank[0][nRm] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке Русской мафии нет денег"); return true; }
		if(MafiaBank[0][nRm] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке Русской мафии нет столько денег"); return true; }
		MafiaBank[0][nRm] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка Русской мафии: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 5 && User[playerid][pRank] == 10)
	{
		if(MafiaBank[0][nLcn] <= 0) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии LCN нет денег"); return true; }
		if(MafiaBank[0][nLcn] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке мафии LCN нет столько денег"); return true; }
		MafiaBank[0][nLcn] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка мафии LCN: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	kaznawithdrawed += params[0];
	return true;
}
CMD:mafiabank(playerid, params[])
