CMD:cinfo(playerid, params[])
{
	new str[1000];
    for(new i = 1; i <= TOTALCASINO; i++)
	{
		if(!PlayerToPoint(200,playerid, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2])) continue;
		format(str,sizeof(str), "Казино: %s\n\nРаботники казино:",CasinoInfo[i][caName]);
		format(str,sizeof(str), "%s\n\n[0] Менеджер: %s\n[1] Менеджер: %s\n[2] Менеджер: %s\n\n[0] Крупье: %s\n[1] Крупье: %s\n[2] Крупье: %s\n[3] Крупье: %s\n[4] Крупье: %s\n[5] Крупье: %s\n[6] Крупье: %s\n[7] Крупье: %s\n[8] Крупье: %s\n[9] Крупье: %s",str,CasinoInfo[i][caManager],CasinoInfo[i][caManager2],CasinoInfo[i][caManager3],CasinoInfo[i][caKrupie],CasinoInfo[i][caKrupie2],CasinoInfo[i][caKrupie3],CasinoInfo[i][caKrupie4],CasinoInfo[i][caKrupie5],
		CasinoInfo[i][caKrupie6],CasinoInfo[i][caKrupie7],CasinoInfo[i][caKrupie8],CasinoInfo[i][caKrupie9],CasinoInfo[i][caKrupie10]);
		ShowPlayerDialogEx(playerid,2145,DIALOG_STYLE_MSGBOX,"Информация о Казино",str,"Скрыть","");
		break;
	}
	return true;
}
CMD:casino(playerid, params[])
{
    if(User[playerid][pMember] != 0) return SCM(playerid, COLOR_GREY, "Вы состоите в организации");
    if(User[playerid][pLevel] < 2) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас должен быть 2 уровень");
    if(!PlayerToPoint(10, playerid,1961.9512,1062.5677,994.4688)) return SCM(playerid, COLOR_GREY, "Вы должны находиться в казино");
    if(GetPVarInt(playerid,"CasinoStol") == 1) return SCM(playerid, COLOR_GREY, "Чтобы устроиться работником, завершите игру");
    switch(GetPVarInt(playerid,"CasinoRank"))
    {
    	case 0:
     	{
      		//if(!GetCasino(playerid,1)) return true;
        	switch(User[playerid][pSex])
         	{
          		case 1:
				{
		 			SetPlayerSkin(playerid,171);
				 	SendClientMessage(playerid,COLOR_GREY,"Вы были приняты на работу крупье!");
				}
    			case 2:
				{
					SetPlayerSkin(playerid,172);
			 		SendClientMessage(playerid,COLOR_GREY,"Вы были приняты на работу крупье!");
				}
			}
			SetPVarInt(playerid,"CasinoRank",1);
		}
		default:
		{
		    SendClientMessage(playerid,COLOR_GREY,"Вы были уволены с работы крупье!");
  			DeletePVar(playerid,"CasinoRank");
	    	SetPlayerSkin(playerid,User[playerid][pChar][0]);
		}
	}
	return 1;
}
CMD:deal(playerid, params[])
{
	if(!GetPVarInt(playerid,"CasinoRank")) return true;
	if(GetPVarInt(playerid,"Roulet")) return SendClientMessage(playerid,COLOR_GREY,"Вы уже запустили рулетку!");
	if(!GetRoulet(playerid)) return SendClientMessage(playerid,COLOR_GREY,"В данном месте нет рулетки!");
	if(RouletPlay[GetRoulet(playerid)]) return SendClientMessage(playerid,COLOR_GREY,"Рулетка уже запущена!");
	SetPVarInt(playerid,"Roulet",GetRoulet(playerid));
	RouletTimer[GetRoulet(playerid)][2] = random(80) + 70;
	RouletPlay[GetRoulet(playerid)] = true;
    RouletTimer[GetRoulet(playerid)][0] = SetTimerEx("RouletCheck",100,1,"d",GetRoulet(playerid));
    RouletKrupie[GetRoulet(playerid)] = playerid;
    return true;
}
CMD:pick(playerid, params[])
{
	new test = 0;
	for(new i = 0; i < SLOTVIBROS; i++)
	{
        if(PlayerToPoint(1.0,playerid,VibrosInfo[i][vX],VibrosInfo[i][vY],VibrosInfo[i][vZ]))
        {
            if(VibrosInfo[i][vModel] == 1)
            {
                if(User[playerid][pDrugs]+VibrosInfo[i][vKol] > 150)
                {
                    SendClientMessage(playerid,COLOR_GREY,"У вас не может быть больше 150 гр. наркотиков");
                    break;
				}
				User[playerid][pDrugs]+=VibrosInfo[i][vKol];
				VibrosInfo[i][vModel] = 0;
				VibrosInfo[i][vTime] = -1;
				VibrosInfo[i][vX] = 0.0;
				VibrosInfo[i][vY] = 0.0;
				VibrosInfo[i][vZ] = 0.0;
				DestroyDynamic3DTextLabel(VibrosInfo[i][vPodnyat]);
				DestroyObject(VibrosInfo[i][vObject]);
				for(new ix = i; ix < SLOTVIBROS-1; ix++)
				{
				    VibrosInfo[ix][vModel] = VibrosInfo[ix+1][vModel];
				    VibrosInfo[ix][vTime] = VibrosInfo[ix+1][vTime];
				    VibrosInfo[ix][vX] = VibrosInfo[ix+1][vX];
				    VibrosInfo[ix][vY] = VibrosInfo[ix+1][vY];
				    VibrosInfo[ix][vZ] = VibrosInfo[ix+1][vZ];
				    DestroyDynamic3DTextLabel(VibrosInfo[ix+1][vPodnyat]);
					DestroyObject(VibrosInfo[ix+1][vObject]);
					if(VibrosInfo[ix][vModel] == 1)
					{
						VibrosInfo[ix][vPodnyat] = CreateDynamic3DTextLabel("Наркотики\nПоднять: {DCD45C}/pick", COLOR_GREEN, VibrosInfo[ix][vX], VibrosInfo[ix][vY], VibrosInfo[ix][vZ], 10.0);
	    				VibrosInfo[ix][vObject] = CreateObject(1485,VibrosInfo[ix][vX],VibrosInfo[ix][vY],VibrosInfo[ix][vZ],0.00,0.00,0.00);
					}
					else
					{
					    VibrosInfo[ix][vPodnyat] = CreateDynamic3DTextLabel("Материалы\nПоднять: {DCD45C}/pick", COLOR_GREEN, VibrosInfo[ix][vX], VibrosInfo[ix][vY], VibrosInfo[ix][vZ], 10.0);
	    				VibrosInfo[ix][vObject] = CreateObject(1210,VibrosInfo[ix][vX],VibrosInfo[ix][vY],VibrosInfo[ix][vZ],0.00,0.00,0.00);
	    			}
				}
				SLOTVIBROS--;
				test++;
				new string[120];
				f(string, "Вы подняли {DCD45C}%i гр.{FFFFFF} наркотиков",VibrosInfo[i][vKol]);
				SCM(playerid, COLOR_WHITE, string);
				break;
			}
			else if(VibrosInfo[i][vModel] == 2)
            {
                if(User[playerid][pMats]+VibrosInfo[i][vKol] > 500)
                {
                    SendClientMessage(playerid,COLOR_GREY,"У вас не может быть больше 500 материалов");
                    break;
				}
				User[playerid][pMats]+=VibrosInfo[i][vKol];
				VibrosInfo[i][vModel] = 0;
				VibrosInfo[i][vTime] = -1;
				VibrosInfo[i][vX] = 0.0;
				VibrosInfo[i][vY] = 0.0;
				VibrosInfo[i][vZ] = 0.0;
				DestroyDynamic3DTextLabel(VibrosInfo[i][vPodnyat]);
				DestroyObject(VibrosInfo[i][vObject]);
				for(new ix = i; ix < SLOTVIBROS-1; ix++)
				{
				    VibrosInfo[ix][vModel] = VibrosInfo[ix+1][vModel];
				    VibrosInfo[ix][vTime] = VibrosInfo[ix+1][vTime];
				    VibrosInfo[ix][vX] = VibrosInfo[ix+1][vX];
				    VibrosInfo[ix][vY] = VibrosInfo[ix+1][vY];
				    VibrosInfo[ix][vZ] = VibrosInfo[ix+1][vZ];
				    DestroyDynamic3DTextLabel(VibrosInfo[ix+1][vPodnyat]);
					DestroyObject(VibrosInfo[ix+1][vObject]);
					if(VibrosInfo[ix][vModel] == 1)
					{
						VibrosInfo[ix][vPodnyat] = CreateDynamic3DTextLabel("Наркотики\nПоднять: {DCD45C}/pick", COLOR_GREEN, VibrosInfo[ix][vX], VibrosInfo[ix][vY], VibrosInfo[ix][vZ], 10.0);
	    				VibrosInfo[ix][vObject] = CreateObject(1485,VibrosInfo[ix][vX],VibrosInfo[ix][vY],VibrosInfo[ix][vZ],0.00,0.00,0.00);
					}
					else
					{
					    VibrosInfo[ix][vPodnyat] = CreateDynamic3DTextLabel("Материалы\nПоднять: {DCD45C}/pick", COLOR_GREEN, VibrosInfo[ix][vX], VibrosInfo[ix][vY], VibrosInfo[ix][vZ], 10.0);
	    				VibrosInfo[ix][vObject] = CreateObject(1210,VibrosInfo[ix][vX],VibrosInfo[ix][vY],VibrosInfo[ix][vZ],0.00,0.00,0.00);
	    			}
				}
