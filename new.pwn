        	strcat(str,"{DCD45C}<< Первые шаги (Первые деньги) >>{FFFFFF}\n\n");
         	strcat(str,"Вам потребуются деньги, заработать немного денег вы можете на заводе, работая грузчиком.\n");
          	strcat(str,"Добраться на завод вы можете на автобусе \'Внутригородской LS\' или на такси,\n");
           	strcat(str,"таксист отвезет вас бесплатно, просто сядьте в свободное такси.\n");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Первые шаги",str,"Далее","Меню");
        }
        case 9:
        {
        	strcat(str,"{DCD45C}<< Первые шаги (Водительские права) >>\n\n");
         	strcat(str,"Как только вы заработаете немного денег, отправляйтесь в автошколу.\n");
          	strcat(str,"Автошкола находиться в Сан Фиерро (2ой город).\n");
           	strcat(str,"Стоимость сдачи экзамена состовляет 500 вирт.\n");
           	strcat(str,"Добраться вы можете на автобусе \'Лос Сантос - Сан Фиерро\'.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Первые шаги часть 2",str,"Далее","Меню");
        }
        case 10:
        {
        	strcat(str,"{DCD45C}<< Первые шаги (Постоянная работа) >>{FFFFFF}\n\n");
         	strcat(str,"После того как вы заработаете денег и получите права,\n");
          	strcat(str,"вы сможете устроиться на официальную работу.\n");
           	strcat(str,"Устроиться на работу, и ознакомиться со списком профессий, вы можете в мэрии.\n");
            strcat(str,"Добирайтесь на \'Внутригородском LS\'");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Первые шаги часть 3",str,"Далее","Меню");
        }
        case 11:
        {
        	strcat(str,"{DCD45C}<< Часовая зарплата >>{FFFFFF}\n\n");
         	strcat(str,"Каждый час в 00 игроки получают банковский чек, в котором указаны все доходы и\n");
          	strcat(str,"расходы.\n");
           	strcat(str,"Доходы: Зарплата с работы.\n");
           	strcat(str,"Расходы: Налог государству (после 5 лвл), Счет за телефон (если вы звонили),\n");
            strcat(str,"Кварплата (если вы владелец дома).");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Часовая зарплата",str,"Далее","Меню");
        }
        case 12:
        {
        	strcat(str,"{DCD45C}<< Зарплата фракции >>{FFFFFF}\n\n");
         	strcat(str,"В некоторых фракциях вы получаете Зарплату каждый час от государства.\n");
          	strcat(str,"В других эта зарплата выдается лидером. Все организации на сервере имеют\n");
           	strcat(str,"свой заработок. Где то нелегальный бизнес, где то постоянная зарплата.\n\n");
            strcat(str,"Банды: Бизнес(Нелегальный), Оружие и Наркотики, Ограбление.\n");
            strcat(str,"Репортеры: Бизнес(Легальный), Реклама.\n");
            strcat(str,"Мэрия: От адвоката до Управления казной.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Зарплата фракции",str,"Далее","Меню");
        }
        case 13:
        {
        	strcat(str,"{DCD45C}<< Бизнес >>{FFFFFF}\n\n");
         	strcat(str,"Все клубы, бары, забегаловки являются бизнесами, которые можно арендовать.\n");
          	strcat(str,"По мимо этого еще есть Бензоправки и Магазины.\n");
           	strcat(str,"Чтобы заработать на бизнесе нужен начальный капитал. Для лицензии,\n");
            strcat(str,"Аренды помещения, Продуктов.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Бизнес",str,"Далее","Меню");
        }
        case 14:
        {
        	strcat(str,"{DCD45C}<< Местность >>{FFFFFF}\n\n");
         	strcat(str,"Лос Сантос(1 город) самый опасный город, так как здесь большое количество\n");
          	strcat(str,"бандитов. Районы банд выделены на карте особыми цветами, но только там\n");
           	strcat(str,"можно купить оружие по дешевле и ни кто не спросит у вас лицензии\n\n");
            strcat(str,"Сан Фиерро(2 город). Если не хотите каждый день сталкиваться с беззаконием,\n");
            strcat(str,"то поселитесь в этом городе.\n\n");
            strcat(str,"Лас Вентурас(3 город). Город азарта, город богачей. Конечно здесь не такие раскошные\n");
            strcat(str,"особняки как на VINEWOOD, но улицы самые красивые.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Местность",str,"Далее","Меню");
        }
        case 15:
        {
        	strcat(str,"{DCD45C}<< Законопослушность >>{FFFFFF}\n\n");
         	strcat(str,"У каждого игрока есть индикатор, который показывает как вы относитесь к закону.\n");
          	strcat(str,"-100 и +100 Минимум и максимум. Узнать можно заглянув в ваш пасспорт \"/showpass [ид]\"\n");
           	strcat(str,"С плохим отношением к закону вас могут не принять во многии Фракции, но в банду\n");
           	strcat(str,"попасть легче.\n\n");
            strcat(str,"Законопослушность повышается каждый час на 1, однако может резко упасть если\n");
            strcat(str,"совершите преступление");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Законопослушность",str,"Далее","Меню");
        }
        case 16:
        {
        	strcat(str,"{DCD45C}<< Дома >>{FFFFFF}\n\n");
         	strcat(str,"Вы можете в любой момент купить себе дом, тогда при смерти или входе в игру\n");
            strcat(str,"вы будете появляться там. По мимо этого у вас появиться место для парковки машины,\n");
            strcat(str,"а значит вы можете купить себе красивое авто.\n");
            strcat(str,"Дома поделенны по классам - [Nope] [D] [C] [B] [A] [S]. Класс говорит о цене и красоте\n");
            strcat(str,"дома как внутри, так и снаружи.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Дома - часть 1",str,"Далее","Меню");
        }
        case 17:
        {
            strcat(str,"{FFFFFF}После покупки дома с вашего банковского счета будут сниматься Кварплата, она зависит от класса дома.\n");
            strcat(str,"Важное примечание! Деньги снимаются каждый час даже когда вы оффлайн.\n\n");
            strcat(str,"{DCD45C}<< Личный транспорт >>{FFFFFF}\n\n");
            strcat(str,"У нас есть несколько Автосалонов, где вы можете приобрести себе машину. Все они\n");
            strcat(str,"указаны в \"/GPS\". Транспорт как и дома разделены по классам.\n");
        	strcat(str,"Чтобы выбрать себе машину, воспользуйтесь командой \"/Buycar\". Далее вы\n");
        	strcat(str,"увидете подсказку по клавишам с правой стороны, а снизу цену и цвет.");
            return ShowPlayerDialogEx(playerid, 1467, 0,"{F1C33A}Дома - часть 2",str,"Далее","Меню");
		}
	}
	return true;
}
publics: Farmduty(playerid)
{
	new str[32];
    DisablePlayerRaceCheckpoint(playerid);
    SetVehicleParamsEx(GetPlayerVehicleID(playerid),false,false,false,false,false,false,false);
	SetVehicleVelocity(GetPlayerVehicleID(playerid), 0.0, 0.0, 0.0);
	GetVehiclePos(GetPlayerVehicleID(playerid), car_coord[GetPlayerVehicleID(playerid)][0], car_coord[GetPlayerVehicleID(playerid)][1], car_coord[GetPlayerVehicleID(playerid)][2]);
	GetVehicleZAngle(GetPlayerVehicleID(playerid),car_coord[GetPlayerVehicleID(playerid)][3]);
	GetXYInBackOfPlayer(playerid, car_coord[GetPlayerVehicleID(playerid)][0], car_coord[GetPlayerVehicleID(playerid)][1],3.0);
	Farmcar_pickup[GetPlayerVehicleID(playerid)] = CreateDynamicPickup(19197,23,car_coord[GetPlayerVehicleID(playerid)][0], car_coord[GetPlayerVehicleID(playerid)][1],car_coord[GetPlayerVehicleID(playerid)][2]+0.3);
	DeletePVar(playerid,"farm_status");

	format(str, sizeof(str), "Загружено\n{ffffff}%d / 1000",Farmcar_prods[GetPlayerVehicleID(playerid)]);
	if(!IsValidDynamic3DTextLabel(Farmcar_text[GetPlayerVehicleID(playerid)]))  Farmcar_text[GetPlayerVehicleID(playerid)] = CreateDynamic3DTextLabel(str,0x5CABBDFF,car_coord[GetPlayerVehicleID(playerid)][0], car_coord[GetPlayerVehicleID(playerid)][1],car_coord[GetPlayerVehicleID(playerid)][2]+0.6,15.0);

	Farmcar_works[GetPlayerVehicleID(playerid)] = true;
	RemovePlayerFromVehicleAC(playerid);
	TogglePlayerControllable(playerid, 1);
	return true;
}
publics: FarmDuty(playerid)
{
	TogglePlayerControllable(playerid, 1);
	ClearAnim(playerid);
	oldpickup[playerid] = -1;
	KillTimer(Farmtimer[playerid]);
	DisablePlayerCheckpoint(playerid);
	DeletePVar(playerid,"farm_status");
	if(!PlayerToPoint(2.0,playerid,Farm_coord[playerid][0], Farm_coord[playerid][1], Farm_coord[playerid][2])) return SendClientMessage(playerid,COLOR_RED,"Вы должны находиться на красной метке");
	if(!FarmInfo[GetPVarInt(playerid,"farm_id")][fGrain_Sown]) return SendClientMessage(playerid,COLOR_RED,"На поле недостаточно урожая");
	if(FarmInfo[GetPVarInt(playerid,"farm_id")][fBank] < FarmInfo[GetPVarInt(playerid,"farm_id")][fZp]) return SendClientMessage(playerid,COLOR_RED,"На балансе фермы недостаточно средств");
	SetPVarInt(playerid,"farm_status",2);
	SetPlayerAttachedObject(playerid, 3, 856, 6, 0.086999, 0.036999, 0.000000, 0.000000, 0.000000, 0.000000, 0.010999, 0.009000, 0.085999);
	FarmInfo[GetPVarInt(playerid,"farm_id")][fGrain_Sown]--;
	if(User[playerid][quest_store][0] < 40) User[playerid][quest_store][0] ++;
	if(User[playerid][quest_store][0] == 40)
	{
		SendClientMessage(playerid, COLOR_YELLOW,"[Подсказка] Вы собрали 20 кустов, теперь вам нужно купить вод. права");
		//SetPVarInt(playerid, "Quest", 1);
		UpdateQuestInfo(playerid, 0, 40);
		//SetPlayerRaceCheckpoint(playerid, 2, -2026.1276,-98.4965,35.1641, 0.0, 0.0, 0.0, 6.0);
	}
	return true;
}
stock CheatKick(playerid,number)
{
	if(User[playerid][pAdmin] && User[playerid][pLogin]) return true;
	if(GetPVarInt(playerid,"CheatKick") > 0) return true;
	SetPVarInt(playerid,"CheatKick",1);
	new temp[144],str[128];
	format(str,sizeof(str),"Вы были кикнуты по подозрению в читерстве (#%d)",number);
	SendClientMessage(playerid,COLOR_LIGHTRED,str);
	format(temp, sizeof(temp), "<ERROR #%i> %s(%i): Был отсоединен от сервера за читерство!",number,User[playerid][pName], playerid);
	SendAdminMessage(COLOR_RED,temp);
	new strkick[128];
	format(strkick, sizeof(strkick), "AC Kick #%d", number);
	return KickEx(playerid, strkick);
}
//GetFloatDifference(Float: Number1, Float: Number2) return floatround(Number1 > Number2 ? Number1 - Number2 : Number2 - Number1);
public OnUnoccupiedVehicleUpdate(vehicleid, playerid, passenger_seat, Float:new_x, Float:new_y, Float:new_z, Float:vel_x, Float:vel_y, Float:vel_z)
{
    GetVehiclePos(vehicleid, new_x, new_y, new_z);
	new Float:distance = GetPlayerDistanceFromPoint(playerid, new_x, new_y, new_z);
	if(passenger_seat)
	{
		/*new Float:x, Float:y, Float:z;
		GetVehiclePos(vehicleid,x,y,z);
		if(GetFloatDifference(x,gVehicles[vehicleid][carshotX]) > 50.0 || GetFloatDifference(y,gVehicles[vehicleid][carshotY]) > 50.0)
		{
			gVehicles[vehicleid][carshotX] = x;
			gVehicles[vehicleid][carshotY] = y;
			gVehicles[vehicleid][carshotZ] = z;
			SetPVarInt(playerid,"pKick4",GetPVarInt(playerid,"pKick4") + 1);
			if(GetPVarInt(playerid,"pKick4") == 4)
			{
				SendClientMessage(playerid, -1, "{FF0000}Вы были отключены за использование постороннего ПО {FFFFFF}( Vehicle Cheat  #11)"),KickEx(playerid, "Vehicle Cheat  #11");
			}
		}*/
	}
	if(distance > 100.0) return SendWarningCheatMessageToAdmin(playerid,"Раскидывает тачки");
	if(GetVehicleModel(vehicleid) != 570 && GetVehicleModel(vehicleid) != 449)
	{
		if(vel_x > 100 || vel_y > 100 || vel_z > 100) CheatKick(playerid, 1113);
	}
	return true;
}
public OnPlayerSelectObject(playerid, type, objectid, modelid, Float:fX, Float:fY, Float:fZ) return EditObject(playerid,objectid);
public OnPlayerEditDynamicObject( playerid, objectid, response, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz )
{
	if(response) SetDynamicObjectPos(objectid,x, y, z), SetDynamicObjectRot(objectid,rx,ry,rz);
	if(response == 1)
	{
		new str[144];
	    format(str,sizeof(str),"Позиция объекта изменена. [X: %.2f] [Y: %.2f] [Z: %.2f] [RX: %.2f] [RY: %.2f] [RZ: %.2f]",x,y,z,rx,ry,rz);
		SendClientMessage(playerid,COLOR_GREEN,str);
	}
	return true;
}
public OnPlayerSelectDynamicObject(playerid, objectid, modelid, Float:x, Float:y, Float:z) return EditDynamicObject(playerid,objectid);
public OnPlayerEditObject( playerid, playerobject, objectid, response, Float:fX, Float:fY, Float:fZ, Float:fRotX, Float:fRotY, Float:fRotZ )
{
	if(response) SetObjectPos(objectid,fX,fY,fZ), SetObjectRot(objectid,fRotX,fRotY,fRotZ);
	if(response == 1)
	{
		new str[144];
	    format(str,sizeof(str),"Позиция объекта изменена. [X: %.2f] [Y: %.2f] [Z: %.2f] [RX: %.2f] [RY: %.2f] [RZ: %.2f]",fX,fY,fZ,fRotX,fRotY,fRotZ);
		SendClientMessage(playerid,COLOR_GREEN,str);
	}
	return true;
}
