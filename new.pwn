CMD:fillcar(playerid, params[])
{
    if(!User[playerid][pLogin]) return true;
    if(!IsPlayerConnected(playerid)) return true;
    if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid,COLOR_WHITE,"Вы не в авто");
 	new car = GetPlayerVehicleID(playerid);
 	if(User[playerid][pFuel] != 1) return SendClientMessage(playerid, COLOR_GREY, "У вас нет канистры");
 	if(!IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER || GetVehicleModel(car) == 481 || GetVehicleModel(car) == 509 || GetVehicleModel(car) == 510) return SendClientMessage(playerid,COLOR_YELLOW, "Вы не в автомобиле/Этот транспорт нельзя заправить");
 	SendClientMessage(playerid, 0xF0E79CFF, "Вы дозаправили свой автомобиль 20 л. бензина");
	if(Fuell[car] > 180) Fuell[car] = 200;
 	else Fuell[car] += 20;
 	User[playerid][pFuel] = 0;
 	return true;
}
CMD:gethere(playerid, params[])
{
	if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	new plo;
	if(sscanf(params, "u",plo)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /gethere [playerid]");
	new Float:plocx,Float:plocy,Float:plocz;
	new inter = GetPlayerInterior(playerid);
	new worldd = GetPlayerVirtualWorld(playerid);
	if(IsPlayerConnected(plo))
	{
		if(plo != INVALID_PLAYER_ID)
		{
			if(User[playerid][pAdmin] >= 3)
			{
				if(GetPlayerState(plo) != 1 && GetPlayerState(plo) != 2 && GetPlayerState(plo) != 3) return	SendClientMessage(playerid, COLOR_GRAD1, "Игрок оффлайн / не залогинен");
				if(GetPVarInt(plo, "AFK_Time") > 2) return SendClientMessage(playerid, COLOR_GREY, "Данный игрок AFK");
				GetPlayerPos(playerid, plocx, plocy, plocz);
				SetPlayerInterior(plo,inter);
				SetPlayerVirtualWorld(plo,worldd);
				if (GetPlayerState(plo) == 2)
				{
					TelePos[plo][0] = 0.0;
					TelePos[plo][1] = 0.0;
					SetPlayerInterior(plo,inter);
					new tmpcar = GetPlayerVehicleID(plo);
					SetPlayerVirtualWorld(plo,worldd);
					t_SetVehiclePos(tmpcar, plocx, plocy+4, plocz);
					SetPVarInt(plo, "AntiBreik", 2);
					User[ plo ][ pPos_x ] = plocx;
					User[ plo ][ pPos_y ] = plocy+4;
					User[ plo ][ pPos_z ] = plocz;
					SetPVarInt(plo, "AntiBreik", 2);
				}
				else
				{
					t_SetPlayerPos(plo,plocx,plocy+2, plocz);
					SetPlayerInterior(plo,inter);
					SetPlayerVirtualWorld(plo,worldd);
				}
				SendClientMessage(plo, COLOR_WHITE, "Вас телепортировал к себе администратор "NameServer"");
			}
		}
	}
	return true;
}
CMD:givegun(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "udd",params[0],params[1],params[2])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /givegun [id] [id оружия] [патроны]");
	if(params[2] < 1 || params[2] > 9999) return SendClientMessage(playerid, COLOR_GRAD1, "Нельзя меньше 1 или больше 9999 патронов!");
	GiveWeapon(params[0],params[1],params[2]);
	SendClientMessage(playerid, COLOR_GRAD1, "Оружие Выдано");
	return true;
}
CMD:hp(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	if(IsPlayerInAnyVehicle(playerid))
	{
		AnRepairVehicle(GetPlayerVehicleID(playerid));
		Fuell[GetPlayerVehicleID(playerid)] = 200;
		SendClientMessage(playerid, COLOR_WHITE, "Машина отремонтирована!");
		PlayerPlaySound(playerid, 32000, 0.0, 0.0, 0.0);
	}
	SetPlayerHealthAC(playerid, 100.0);
	return true;
}
CMD:satiety(playerid)
{
	new Stats_Level[40];
	new satiety_chislo = floatround(User[playerid][Satiety], floatround_round);
	switch(satiety_chislo)
	{
	    case 810..1000: Stats_Level = "{63BD4E}[Вы сыты]";
	    case 510..800: Stats_Level = "{CCFF00}[Вы сыты]";
	    case 310..500: Stats_Level = "{FDE910}[Вы немного проголодались]";
	    case 160..300: Stats_Level = "{FF8800}[Вы голодны]";
	    case 0..150: Stats_Level = "{FF0600}[Вы очень голодны]";
	}
	return SCMF(playerid,0x6495EDFF, "Ваша «Сытость»: %d / 100 %s", (satiety_chislo/100)*10, Stats_Level);
}
CMD:sethealcost(playerid, params[])
{
    if(User[playerid][pLeader] == 4 || User[playerid][pLeader] == 22 || User[playerid][pLeader] == 33)
	{
		if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /sethealcost [сумма]");
		if(params[0] < 1 || params[0] > 30) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете поставить меньше 0 и больше 30"); return true; }
		healpric = params[0];
		SendClientMessageToAll(COLOR_WHITE, "---========== Государственные Новости==========---");
		format(YCMDstr, sizeof(YCMDstr), "Цена лечения, в размере %i вирт. установлена Глав. Врачом: %s.", healpric,User[playerid][pName]);
		SendClientMessageToAll(0xA52A2AFF, YCMDstr);
		return true;
	}
	return true;
}
CMD:escape(playerid, params[])
{
    if(User[playerid][pLogin] == 0 || User[playerid][pMestoJail] == 4) return true;
	if(User[playerid][pJailTime] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в тюрьме!");
	if(User[playerid][pKeys] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "У Вас нет ключа от тюрьмы!");
	User[playerid][pKeys] --;
	if(User[playerid][pMestoJail] == 1) SetPlayerInterior(playerid, 0), t_SetPlayerPos(playerid,1553.4962,-1675.2714,16.1953), SetPlayerFacingAngle(playerid, 95.0636);
	if(User[playerid][pMestoJail] == 2) SetPlayerInterior(playerid, 0), t_SetPlayerPos(playerid,-1607.1873,721.3649,12.2721), SetPlayerFacingAngle(playerid, 2.3026);
	if(User[playerid][pMestoJail] == 3) SetPlayerInterior(playerid, 0), t_SetPlayerPos(playerid,2334.8467,2454.9456,14.9688), SetPlayerFacingAngle(playerid, 115.7874);
	User[playerid][pJailTime] = 0;
	User[playerid][pMestoJail] = 0;
	SetPlayerVirtualWorld(playerid, 0);
	DeletePVar(playerid, "PlayerCuffed");
	SendClientMessage(playerid, COLOR_YELLOW, "Вы совершили побег из тюрьмы");
	return true;
}
CMD:getekey(playerid, params[])
{
    if(!IsAGang(playerid) && !IsACop(playerid)) return true;
	if(User[playerid][pKeys] <= 0) return SendClientMessage(playerid, COLOR_GRAD1, "У Вас нет ключей от тюрьмы!");
	format(YCMDstr, sizeof(YCMDstr), "У Вас %d ключей", User[playerid][pKeys]);
	SendClientMessage(playerid, COLOR_YELLOW, YCMDstr);
	//format(YCMDstr, sizeof(YCMDstr), "%s достает ключи",User[playerid][pName]);
	//ProxDetector(30.0, playerid, YCMDstr, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
	return true;
}
CMD:takekeys(playerid, params[])
{
	if(!IsACop(playerid)) return true;
	if(sscanf(params, "s[50]", params[0])) return SCM(playerid, -1, "Введите: /takekeys [причина]");
	if(!IsPlayerInRangeOfPoint(playerid, 6.0, 246.2752,76.2415,1003.6406) && !IsPlayerInRangeOfPoint(playerid, 10.0, 229.2628,119.2880,1003.2188) && !IsPlayerInRangeOfPoint(playerid, 15.0, 226.5690,171.7811,1003.0378) && !IsPlayerInRangeOfPoint(playerid, 10.0, 1380.9489, 30.3601, 1009.2057)) return SCM(playerid, -1, "Вы не в участке");
	if(User[playerid][pKeys] >= 1) return SCM(playerid, COLOR_GREY, "У вас уже есть ключ");
	SCM(playerid, -1, "Вы взяли ключ от камеры!");
	User[playerid][pKeys] = 1;
	format(YCMDstr, sizeof(YCMDstr), "%s взял(а) ключи от камеры",User[playerid][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	SendFamilyMessage(User[playerid][pMember], COLOR_LIGHTRED, YCMDstr);
	return true;
}
CMD:sellekey(playerid, params[])
{

	//if(!IsAGang(playerid)) return SCM(playerid,COLOR_GREY,"Вы не бандит!");
	if(sscanf(params, "udd", params[0],params[1],params[2])) return SCM(playerid, COLOR_GRAD2, "Введите: /sellekey [id] [кол-во] [Цена]");
	if(params[1] < 1 || params[1] > 5) { SCM(playerid, COLOR_GREY, "Ключей не может быть меньше 1 и больше 5!"); return true; }
	if(params[2] < 1 || params[2] > 50000) { SCM(playerid, COLOR_GREY, "Цена не может быть меньше 1 и больше 50000 вирт!"); return true; }
	if(params[1] > User[playerid][pKeys]) { SCM(playerid, COLOR_GREY, "У вас нет столько ключей!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return SCM(playerid,COLOR_GREY,"Вы должны находиться рядом друг с другом");
	if(User[params[0]][pKeys] >= 5)return SCM(playerid,COLOR_GREEN, "У игрока уже имеется 5 ключей!");
	if(params[0] == playerid) return SCM(playerid, COLOR_GREY, "Вы не можете продать себе ключи!");
	new string[256];
	SetPVarInt(params[0], "BuyKeys", playerid);
	f(string, "Вы предложили %s купить %d ключ(а/ей) за %d вирт",User[params[0]][pName],params[1],params[2]);
	SCM(playerid, 0x6495EDFF, string);
	f(string, "%s предлагает вам купить %d ключ(а/ей) за %d вирт.",User[playerid][pName],params[1],params[2]);
	ShowPlayerDialogEx(params[0], 1906, DIALOG_STYLE_MSGBOX, "Покупка ключей", string, "Купить", "Отмена");
	return true;
}
CMD:givecopkeys(playerid, params[])
{
	if(!IsACop(playerid)) return true;
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /givecopkeys [id]");
	if(User[playerid][pMember] == 1 || User[playerid][pMember] == 2 || User[playerid][pMember] == 10 || User[playerid][pMember] == 21)
	{
		if(IsPlayerConnected(params[0]))
		{
            if(GetDistanceBetweenPlayers(playerid, params[0]) > 5.0) return SCM(playerid, COLOR_GREY, "Вы слишком далеко");
			User[params[0]][pKeys] ++;
			format(YCMDstr, sizeof(YCMDstr), "Офицер %s выдал ключи от полицейского участка %s",User[playerid][pName],User[params[0]][pName]);
			SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
			SendClientMessage(playerid, -1, "Вы выдали ключи от полицейского участка!");
		}
	}
	return true;
}
CMD:agivecopkeys(playerid, params[])
{
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /agivecopkeys [id]");
	if(User[playerid][pAdmin] >= 1)
	{
		if(!IsPlayerConnected(params[0])) return true;
		User[params[0]][pKeys] ++;
		format(YCMDstr, sizeof(YCMDstr), "%s выдал ключи от полицейского участка %s",User[playerid][pName],User[params[0]][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	}
	return true;
}
CMD:takecopkeys(playerid, params[])
{
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /takecopkeys [id]");
	if(User[playerid][pMember] == 1 || User[playerid][pMember] == 2 || User[playerid][pMember] == 10 || User[playerid][pMember] == 21 || User[playerid][pAdmin] >= 1)
	{
		if(!IsPlayerConnected(params[0]) || !User[params[0]][pKeys]) return true;
		SCM(playerid, -1, "Вы забрали ключи от полицейского участка!");
		User[params[0]][pKeys] = 0;
		format(YCMDstr, sizeof(YCMDstr), "Офицер %s забрал ключи от полицейского участка %s",User[playerid][pName],User[params[0]][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	}
	return true;
}
CMD:heal(playerid, params[])
{
    if(User[playerid][pMember] != 4) return SCM(playerid, COLOR_GREY, "Вам недоступна данная функция!");
	if(!GetPVarInt(playerid, "Fraction_Duty")) return SCM(playerid, COLOR_GREY, "Вы не в рабочей форме!");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /heal [id]");
	if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "Вы слишком далеко.");
	new Float:HP;
	GetPlayerHealth(params[0], HP);
	if(HP >= 100) return SCM(playerid, -1, "Данный игрок здоров!");
	new giveambu = GetPlayerVehicleID(params[0]);
	new playambu = GetPlayerVehicleID(playerid);
	if(User[playerid][pMember] == 4)
	{
		if(IsAnAmbulance(playambu) && playambu == giveambu || PlayerToPoint(40.0,playerid,366.9755,-60.1330,1076.4773) && ProxDetectorS(8.0, playerid, params[0]))
		{
		    if(User[params[0]][pNarcoLomka])
			{
				User[params[0]][pNarcoLomka] = 0;
				SetPlayerWeather(params[0],10);
				format(YCMDstr,sizeof(YCMDstr),"Вы спасли %s от ломки",User[params[0]][pName]);
				SendClientMessage(playerid,COLOR_GREEN,YCMDstr);
				format(YCMDstr,sizeof(YCMDstr),"Медик %s спас вас от ломки",User[playerid][pName]);
				SendClientMessage(params[0],COLOR_GREEN,YCMDstr);
				startaddiction[params[0]] = 0;
				ApplyAnimation(params[0],"CARRY","crry_prtial",4.0,0,0,0,0,0,1);
				return true;
			}
			new healdialog[90];
			new Float:hp;
			GetPlayerHealth(params[0],hp);
			new ttt = 100 - floatround(hp, floatround_round);
			format(healdialog,sizeof(healdialog), "Медик хочет вылечить вас за %i вирт\nВы согласны?",healpric*ttt);
			ShowPlayerDialogEx(params[0],5522,DIALOG_STYLE_MSGBOX, "Лечение", healdialog, "Да", "Нет");
			HealOffer[params[0]] = playerid;
			HealPrice[params[0]] = healpric*ttt;
		}
	}
	return true;
}
CMD:sethp(playerid, params[])
{
    if (User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /sethp [id] [уровень hp]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[1] > 201) return SendClientMessage(playerid, COLOR_GREY,"Нельзя давать больше 200 хп!");
	SetPlayerHealthAC(params[0], params[1]);
	SendClientMessage(playerid, COLOR_WHITE, "Уровень hp игроку установлен");
	return true;
}
CMD:veh(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "ddd",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /veh [id авто] [Цвет №1] [Цвет №2]");
	new intt = GetPlayerInterior(playerid);
	new vehicleid = GetPlayerVehicleID(playerid);
	if(params[0] < 400 || params[0] > 611) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /veh [id авто] [Цвет №1] [Цвет №2]");
	if(params[1] < 0 || params[1] > 126) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /veh [id авто] [Цвет №1] [Цвет №2]");
	if(params[2] < 0 || params[2] > 126) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /veh [id авто] [Цвет №1] [Цвет №2]");
	new Float:X,Float:Y,Float:Z;
	GetPlayerPos(playerid, X,Y,Z);
	Fuell[vehicleid] = 200;
	creatcar[playerid] = CreateVehicleAC(params[0], X,Y,Z, 0.0, params[1], params[2], 60000);
	PutPlayerInVehicleEx(playerid, creatcar[playerid], 0);
	SetPlayerArmedWeapon(playerid,0);
	vehcreat[creatcar[playerid]] = 1;
	CreatedCar ++;
	CreatedCars[CreatedCar] = creatcar[playerid];
	SetVehicleParamsEx(GetPlayerVehicleID(playerid) ,true,true,false,false,false,false,false);
	CarHealth[creatcar[playerid]] = float(1000);
	UnLockCar(playerid,creatcar[playerid]);
	LinkVehicleToInterior(creatcar[playerid], intt);
	format(YCMDstr, sizeof(YCMDstr), "Машина установлена. ID: %i", params[0]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	return true;
}
CMD:delcar(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(creatcar[playerid] != -1) return DestroyVehicle(creatcar[playerid]),SendClientMessage(playerid,-1,"Автомобиль успешно удален"),creatcar[playerid] = -1;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
	if ( vehcreat[ GetPlayerVehicleID( playerid ) ] != 1 ) return  SendClientMessage(playerid, COLOR_GRAD1, "Эту машину удалять нельзя");
	DestroyVehicle(GetPlayerVehicleID(playerid));
	SendClientMessage(playerid, COLOR_GREEN, "Автомобиль успешно удален!");
	vehcreat[GetPlayerVehicleID(playerid)] = 0;
	CreatedCar --;
	return true;
}
CMD:alldelveh(playerid, params[])
{
    if(User[playerid][pLogin] == 0) return true;
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(!IsPlayerConnected(playerid)) return true;
	for(new i = 0; i < CreatedCar; i++) { DestroyVehicle(CreatedCars[i]); }
 	CreatedCar = 0;
 	SCM(playerid, COLOR_GREEN, "Удалены все транспорты");
 	format(YCMDstr,144,"[A] %s удалил весь созданный транспорт",User[playerid][pName]);
	ABroadCast(COLOR_RED,YCMDstr,1);
	return 1;
}
CMD:weather(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /weather [id погоды]");
	if(params[0] < 0||params[0] > 45) { SendClientMessage(playerid, COLOR_GREY, "ID Погоды не может быть меньше 0 и больше 45!"); return true; }
	SetWeather(params[0]);
	SendClientMessage(playerid, COLOR_WHITE, "Погода изменена!");
	return true;
}
CMD:givemoney(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "ud",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /givemoney [ид] [сумма]");
	if(!IsPlayerConnected(params[0])) return true;
	format(YCMDstr, sizeof(YCMDstr), "%i вирт переведены на счёт игроку", params[1]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	User[params[0]][pCash] += params[1];
	return true;
}
CMD:money(playerid, params[])
{
    if (User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /money [ид] [сумма]");
	if(!IsPlayerConnected(params[0])) return true;
	format(YCMDstr, sizeof(YCMDstr), "%i вирт переведены на счёт игроку %s",params[1],User[params[0]][pName]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	User[params[0]][pBank] += params[1];
	format(YCMDstr, sizeof(YCMDstr), "Пополнение счёта на сумму: %i вирт", params[1]);
	SendClientMessage(params[0], COLOR_WHITE, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Новый баланс в банке: %i вирт", User[params[0]][pBank]);
	SendClientMessage(params[0], COLOR_WHITE, YCMDstr);
	return true;
}
CMD:gm(playerid, params[])
{
    if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
	if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /gm [id]");
    if(!IsPlayerConnected(params[0])) return true;
    GetPlayerHealth(params[0],GMHP[params[0]][0]);
    GetVehicleHealth(GetPlayerVehicleID(params[0]),VEHHP[params[0]][0]);
    GetPlayerArmour(params[0], GMARMOUR[params[0]][0]);
    SetPlayerArmour(params[0], 0);
    SetPlayerHealthAC(params[0], 100.0);
    SetVehHealth(GetPlayerVehicleID(params[0]),10000.0);
    SetTimerEx("GETHP",1000,false,"i",params[0]);
    new Float:boomx, Float:boomy, Float:boomz;
    GetPlayerPos(params[0],boomx, boomy, boomz);
    CreateExplosion(boomx, boomy , boomz+8, 5, 2);
	return true;
}
CMD:agm(playerid, params[])
{
	if(!User[playerid][pLogin]) return true;
	if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u", params[0])) {
		if(AGM[playerid]) {
			AGM[playerid] = false;
			return SCM(playerid, -1, " GM отключен");
		} else {
			AGM[playerid] = true;
			return SCM(playerid, -1, " GM включен");
		}
	} else {
	    if(User[playerid][pAdmin] < 7) return true;
	    if(!IsPlayerConnected(params[0])) return SCM(playerid, COLOR_GREY, " Игрок оффлайн!");
		if(AGM[params[0]]) {
		    AGM[params[0]] = false;
		    new strs[72];
		    format(strs, sizeof(strs), " GM для %s отключен", Name(params[0]));
		    SCM(playerid, -1, strs);
		} else {
			AGM[params[0]] = true;
		    new strs[72];
		    format(strs, sizeof(strs), " GM для %s включен", Name(params[0]));
		    SCM(playerid, -1, strs);
		}
	}
	return true;
}
CMD:slap(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /slap [id]");
	new Float:shealth;
	new Float:slx, Float:sly, Float:slz;
	if(!IsPlayerConnected(params[0])) return true;
	GetPlayerHealth(params[0], shealth);
	SetPlayerHealthAC(params[0], shealth-5);
	GetPlayerPos(params[0], slx, sly, slz);
	t_SetPlayerPos(params[0], slx, sly, slz+5);
	PlayerPlaySound(params[0], 1130, slx, sly, slz+5);
	format(YCMDstr, sizeof(YCMDstr), "Админ: %s дал поджопник %s",User[playerid][pName],User[params[0]][pName]);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	SendClientMessage(params[0],COLOR_LIGHTRED,YCMDstr);
	return true;
}
CMD:agivelicense(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	ShowPlayerDialogEx(playerid,555,DIALOG_STYLE_LIST, "Выдача лицензий:", "Лицензия на вождение\nЛицензия на полёты\nЛицензия на рыболовлю\nЛицензия на вождение водного транспорта\nЛицензия на оружие\nКомплект лицензий\nЛицензия на бизнес", "Продолжить", "Отмена");
	return true;
}
CMD:mute(playerid, params[])
{
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "uds[32]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /mute [playerid] [минуты] [причина]");
	//if(User[params[0]][pMuted] > 0)
	if(params[1] == 0)
	{
		User[params[0]][pMuted] = 0;
		format(YCMDstr, sizeof(YCMDstr), "Администратор %s снял бан чата у %s",User[playerid][pName],User[params[0]][pName]);
		SendClientMessageToAll(COLOR_LIGHTRED, YCMDstr);
		return true;
	}
	User[params[0]][pMuted] = params[1]*60;
	format(YCMDstr, sizeof(YCMDstr), "%s получил бан чата от администратора %s. Причина: %s",User[params[0]][pName],User[playerid][pName],params[2]);
	SendClientMessageToAll(COLOR_LIGHTRED, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Вам дали бан чата!");
	SendClientMessage(params[0], COLOR_WHITE, YCMDstr);
	AdminInfo[playerid][admMuted]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET muted = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admMuted], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:rmute(playerid, params[])
{
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "uds[32]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /rmute [playerid] [минуты] [причина]");
	if(params[1] == 0)
	{
		User[params[0]][pMutedr] = 0;
		format(YCMDstr, sizeof(YCMDstr), "Администратор %s снял бан репорта у %s",User[playerid][pName],User[params[0]][pName]);
		SendClientMessageToAll(COLOR_LIGHTRED, YCMDstr);
		return true;
	}
	User[params[0]][pMutedr] = params[1]*60;
	format(YCMDstr, sizeof(YCMDstr), "%s получил бан репорта от администратора %s. Причина: %s",User[params[0]][pName],User[playerid][pName],params[2]);
	SendClientMessageToAll(COLOR_LIGHTRED, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Вам дали бан репорта!");
	SendClientMessage(params[0], COLOR_WHITE, YCMDstr);
	return true;
}
CMD:id(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
    new id;
    if(sscanf(params,"u",id)) return SendClientMessage(playerid, COLOR_RED, "Используй: /id [id/name]");
    if(!IsPlayerConnected(id)) return SendClientMessage(playerid, COLOR_GREY,"Неверный id");
    format(YCMDstr,sizeof(YCMDstr),"{FFFFFF}ID: {33CCFF}%d{FFFFFF} | Имя: {33CCFF}%s",id,Name(id));
    if(!ShowPlayerDialogEx(playerid,0,0,Name(id),YCMDstr, "Ок", ""))SendClientMessage(playerid, COLOR_GREY, "Недоступно в данный момент.");
    return true;
}
CMD:aad(playerid, params[])
{
	if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
	if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /aad [сообщение]");
	format(YCMDstr, sizeof(YCMDstr), "Администратор %s: %s",User[playerid][pName],params[0]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	return true;
}
CMD:b(playerid, params[])
{
    if(User[playerid][pMuted] > 0) return	SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
		return true;
	}
	AntiReklama(playerid,params[1],"B");
	if(GetPVarInt(playerid, "antireklamka") == 1)
	{
	    SetPVarInt(playerid, "antireklamka", 0);
	    return true;
	}
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /b [сообщение]");
	new succ;
	for(new i; i<strlen(params[0]); i++)
	{
		if(PText[playerid][i] == params[0]) succ++;
	}
	format(YCMDstr, sizeof(YCMDstr), "%s: (( %s ))",User[playerid][pName],params[0]);
	SendBeside(playerid,COLOR_WHITE,YCMDstr,20.0);
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:whisper(playerid, params[])
{
    if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	if(sscanf(params, "s[128]",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /w [сообщение]");
	new succ;
	for(new i; i<strlen(params[0]); i++)
	{
		if(PText[playerid][i] == params[0]) succ++;
	}
	format(YCMDstr, sizeof(YCMDstr), "{6E6E6E}%s шепнул(а): %s", User[playerid][pName],params[0]);
	SendBeside(playerid,0x6E6E6EAA,YCMDstr,1.0);
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	return true;
}
CMD:kick(playerid, params[])
{
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "us[64]",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /kick [playerid] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pAdmin] >= 7 && User[playerid][pAdmin] < User[params[0]][pAdmin])
	{
	 	return SCM(playerid, COLOR_GREY, " Его нельзя!");
	}
	if(User[params[0]][pAdmin] > 0 && User[params[0]][pAdmin] <= 6)
	{
		SCM(playerid, COLOR_LIGHTRED, "Вы были кикнуты за кик администратора.");
		KickEx(playerid, "Admin > 0");
	}
	new string[156];
	format(string, sizeof(string), "Администратор: %s кикнул %s. Причина: %s",User[playerid][pName],User[params[0]][pName],params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED, string);
	KickEx(params[0], "Kick admin");
	AdminInfo[playerid][admKicked]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET kicked = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admKicked], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:skick(playerid, params[])
{
    if(Spectate[playerid]) StopSpectate(playerid);
	if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /skick [playerid]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pAdmin] >= 7 && User[playerid][pAdmin] < User[params[0]][pAdmin])
	{
	 	return SCM(playerid, COLOR_GREY, " Его нельзя!");
	}
	KickEx(params[0], "Skick admin");
	SendClientMessage(playerid, COLOR_LIGHTRED, "Игрок кикнут");
	format(YCMDstr, sizeof(YCMDstr), "[A] Администратор %s[%d] тихо кикнул игрока %s[%d]", User[playerid][pName], playerid, User[params[0]][pName], params[0]);
	SendAdminMessage(COLOR_LIGHTRED,YCMDstr);
	AdminInfo[playerid][admSKicked]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET skicked = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admSKicked], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:delaccount(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid,COLOR_GREY, "Используйте: /delaccount [name]");
	static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%e' LIMIT 1";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle, query, sizeof(query), fmt_query,params[0]);
 	mysql_tquery(dbHandle, query, "DellAccount", "ds",playerid, params[0]);
	return true;
}
