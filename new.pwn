ALTX:setgz("/gzcolor");
CMD:setgz(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d",params[0])) return SendClientMessage(playerid,-1, "Введите: /setgz [банда]");
	for(new i = 1; i <= TOTALGZ; i++)
	{
		if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
		{
			GZInfo[i][gFrakVlad] = params[0];
			GangZoneStopFlashForAll(GZInfo[i][gZone]);
			GangZoneHideForAll(GZInfo[i][gZone]);
			GangZoneShowForAll(GZInfo[i][gZone],GetGangZoneColor(i));
			UpdateTable("gangzone","gang_owner",GZInfo[i][gFrakVlad],"id",GZInfo[i][gID]);
			return true;
		}
	}
	return true;
}
CMD:sellkeys(playerid, params[])
{
	if(!IsAGang(playerid)) return SCM(playerid, COLOR_GREY, "Вы не состоите в банде!");
	if(sscanf(params, "udd", params[0], params[1], params[2])) return SCM(playerid, COLOR_GREY, "Используйте: /sellkeys [id игрока] [кол-во ключей] [сумма]");
	if(params[1] < 1 || params[1] > 5) return SCM(playerid, COLOR_GREY, "Количество ключей не должно быть меньше 1 и больше 5");
	if(params[2] < 1 || params[2] > 50000) return SCM(playerid, COLOR_GREY, "Цена не должна быть меньше 1 или больше 50000");
	if(params[1] > User[playerid][pKeys]) return SCM(playerid, COLOR_GREY, "У Вас недостаточно ключей!");
	if(!IsPlayerConnected(params[0])) return SCM(playerid, COLOR_GREY, "Игрок не в игре!");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SCM(playerid, COLOR_GREY, "Вы находитесь слишком далеко!");
	if(params[0] == playerid) return SCM(playerid, COLOR_GREY, "Вы не можете продать ключи сами себе!");
	new string[156];
	f(string, "Вы предложили %s купить %d ключ(а/ей) за %d вирт", User[params[0]][pName], params[1], params[2]);
	SCM(playerid, 0x6495EDFF, string);
	f(string, "%s предлагает вам купить %d ключ(а/ей) за %d вирт", User[playerid][pName], params[1], params[2]);
	ShowPlayerDialogEx(params[0], 1505, DIALOG_STYLE_MSGBOX, "Покупка ключей", string, "Согласен", "Отказ");
	SetPVarInt(params[0], "KeyOfferID", playerid);
	SetPVarInt(params[0], "KeysOfferNumber", params[1]);
	SetPVarInt(params[0], "KeysPrice", params[2]);
	return true;
}
CMD:tazerall(playerid, params[])
{
    if(User[playerid][pMember] != 2 || User[playerid][pMember] == 2 && User[playerid][pRank] < 3) return true;
	params[0] = GetClosestforeach(playerid);
	if(!ProxDetectorS(6.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Нет никого рядом");
	if(IsPlayerInAnyVehicle(playerid)) return  SendClientMessage(playerid, COLOR_GREY, "Невозможно использовать в машине");
	format(YCMDstr, sizeof(YCMDstr), "Агент FBI %s оглушил всех на 15 секунд",User[playerid][pName]);
	SendBeside(playerid, COLOR_PURPLE,YCMDstr,30.0);
	TogglePlayerControllable(params[0], 0);
	SetPlayerSpecialAction(params[0],SPECIAL_ACTION_HANDSUP);
	SetPVarInt(params[1], "PlayerCuffed", 1);
	SetPVarInt(params[0], "PlayerCuffedTime", 15);
	return true;
}
