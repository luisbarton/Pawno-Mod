stock SetPlayerCheckpointEx(playerid,Float:x,Float:y,Float:z,Float:r)
{
	SetPVarInt(playerid,"checkpoint",1);
	return SetPlayerCheckpoint(playerid,x,y,z,r);
}
stock DisablePlayerCheckpointEx(playerid)
{
    DeletePVar(playerid,"checkpoint");
    return DisablePlayerCheckpoint(playerid);
}
#define SetPlayerCheckpoint SetPlayerCheckpointEx
#define DisablePlayerCheckpoint DisablePlayerCheckpointEx

stock PutPlayerInVehicleEx(playerid,vehicleid,seatid)
{
	VehicleEnters[playerid] = vehicleid;
	VehicleID[playerid] = vehicleid;
	//SetPVarInt(playerid, "MassCarSpawn", GetTickCount());
	PutPlayerInVehicle(playerid,vehicleid,seatid);
}
stock t_SetPlayerPos( playerid, Float:x, Float:y, Float:z )
{
    SetPVarInt(playerid, "AntiBreik", 2);
    TeleportTime[playerid] = 5;
    User[ playerid ][ pPos_x ] = x;
    User[ playerid ][ pPos_y ] = y;
    User[ playerid ][ pPos_z ] = z;
    return SetPlayerPos(playerid,x,y,z);
}
stock SetPlayerPos_S( playerid, Float:x, Float:y, Float:z )
{
    SetPVarInt(playerid, "AntiBreik", 2);
    TeleportTime[playerid] = 5;
	if(User[playerid][pMember] >= 1 && GetPVarInt(playerid,"Fraction_Duty"))
    {
        SetSpawnInfo ( playerid, 0, User[playerid][pModel], x, y, z, 0, 0, 0, 0, 0, 0, 0 ) ;
    }
    else SetSpawnInfo ( playerid, 0, User[playerid][pChar][0], x, y, z, 0, 0, 0, 0, 0, 0, 0 ) ;
    return SetPlayerPos( playerid, x, y, z );
}
new Float:car_coord[MAX_VEHICLES][4], bool:car_ex[MAX_VEHICLES];
stock t_SetVehiclePos(vehicleid, Float:x, Float:y, Float:z)
{
    foreach(new i: Player)
    {
        if(IsPlayerInVehicle(i, vehicleid))
        {
            SetPVarInt(i, "AntiBreik", 2);
    		User[ i ][ pPos_x ] = x;
   			User[ i ][ pPos_y ] = y;
    		User[ i ][ pPos_z ] = z;
        }
    }
    car_coord[vehicleid][0] = x;
	car_coord[vehicleid][1] = y;
	car_coord[vehicleid][2] = z;
	car_ex[vehicleid] = true;
    return SetVehiclePos(vehicleid, x, y, z);
}
//#define SetPlayerPos t_SetPlayerPos
//#define SetVehiclePos t_SetVehiclePos
enum PickInfo
{
    Float: PickX,
    Float: PickY,
    Float: PickZ
}

new PickupInfo[MAX_PICKUPS][PickInfo];
CreatePickupAC(model, type, Float:X, Float:Y, Float:Z, virtualworld = 0)
{
    new TempID = CreateDynamicPickup(model, type, X, Y, Z, virtualworld);
    PickupInfo[TempID][PickX] = X;
    PickupInfo[TempID][PickY] = Y;
    PickupInfo[TempID][PickZ] = Z;
    return TempID;
}
#define CreateDynamicPickup CreatePickupAC
/***************************** АНТИЧИТ НА СПАВН КАРОВ ***********************/
CreateVehicleAC(model, Float:x,Float:y,Float:z,Float:r, c, c_, spawn, siren = 0)
{
	new TempID = CreateVehicle(model,x,y,z,r,c,c_,spawn, siren);
	car_ex[TempID] = true;
	car_coord[TempID][0] = x;
	car_coord[TempID][1] = y;
	car_coord[TempID][2] = z;
	car_coord[TempID][3] = r;
	return TempID;
}
//#define CreateVehicle CreateVehicleAC
SetVehicleZAngleEx(vehicleid,Float:z)
{
	SetVehicleZAngle(vehicleid,z);
	car_ex[vehicleid] = true;
	car_coord[vehicleid][3] = z;
	return true;
}
#define SetVehicleZAngle SetVehicleZAngleEx

#include "other/stock.pwn"
stock SetPlayerSkinEx ( playerid, skinid )
{
	for ( new j = 0 ; j < 8 ; j ++ )
	{
		if ( User [ playerid ] [ accessories_used ] [ j ] == 0 ) continue ;
		GiveItem ( playerid, User [ playerid ] [ accessories ] [ j ] ) ;
	}
	SetPlayerSkin ( playerid, skinid ) ;
	return 1 ;
}

#define SetPlayerSkin SetPlayerSkinEx
/******************************************************************************/
stock GetWeaponSlot(weaponid)
{
	new slot = -1;
	switch(weaponid)
	{
		case 0,1: slot = 0;
		case 2 .. 9: slot = 1;
		case 10 .. 15: slot = 10;
		case 16 .. 18, 39: slot = 8;
		case 22 .. 24: slot =2;
		case 25 .. 27: slot = 3;
		case 28, 29, 32: slot = 4;
		case 30, 31: slot = 5;
		case 33, 34: slot = 6;
		case 35 .. 38: slot = 7;
		case 40: slot = 12;
		case 41 .. 43: slot = 9;
		case 44 .. 46: slot = 11;
	}
	return slot;
}
stock GiveWeapon(playerid, weaponid, ammo)
{
	User[playerid][acWeaponTick] = 3;
	new slot = GetWeaponSlot(weaponid);
	if (slot != -1)
	{
	    if(User[playerid][ac_Weapon][slot] != weaponid || User[playerid][ac_Ammo][slot] >= 1)
		{
			User[playerid][ac_Weapon][slot] = weaponid;
			User[playerid][ac_Ammo][slot] += ammo;
			if (User[playerid][ac_Ammo][slot] < 0) User[playerid][ac_Ammo][slot] = 0;
			return GivePlayerWeapon(playerid, weaponid, ammo), 1;
		}
		else
		{
		    User[playerid][ac_Ammo][slot] += ammo;
		    return SetPlayerAmmo(playerid,weaponid, User[playerid][ac_Ammo][slot]);
		}
	}
	return 1;
}
ResetPlayerWeaponsEx(playerid)
{
	User[playerid][acWeaponTick] = 3;
	for (new i = 0; i < 13; i++)
	{
		User[playerid][ac_Weapon][i] = 0;
		User[playerid][ac_Ammo][i] = 0;
	}
	return ResetPlayerWeapons(playerid);
}

