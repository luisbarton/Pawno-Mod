	if(IsPlayerInAnyVehicle(playerid)){}
	else
	{
		if(areaid >= gAreas[arQuestHelp][0] && areaid <= gAreas[arQuestHelp][2])
		{
		    if(!GetPVarInt(playerid, "QuestHelp"))
		    {
		    	SetPVarInt(playerid, "QuestHelp", 1);
		    	SCMF(playerid, -1, "- Sebastian Mitchell: Эй... %s. Есть дело подстать тебе. Подойди. {DCD45C}[ Клавиша: ALT ]", Name(playerid));
		    	if(areaid == gAreas[arQuestHelp][0]) ApplyActorAnimation(qactors[0], "GANGS", "prtial_gngtlkB", 4.1, 1, 0, 0, 0, 4000);
		    	if(areaid == gAreas[arQuestHelp][1]) ApplyActorAnimation(qactors[1], "GANGS", "prtial_gngtlkB", 4.1, 1, 0, 0, 0, 4000);
		    	if(areaid == gAreas[arQuestHelp][2]) ApplyActorAnimation(qactors[2], "GANGS", "prtial_gngtlkB", 4.1, 1, 0, 0, 0, 4000);
		    }
			return 1;
		}
		if(areaid == gAreas[arGruzJob][0])
		{
			new string_[540], stro_[128];
			format(stro_, sizeof(stro_), "{FFFFFF}Здесь вы можете подработать грузчиком\n\n"),strcat(string_,stro_);
			format(stro_, sizeof(stro_), "В здании на против, вы найдете раздевалку,\n"),strcat(string_,stro_);
			format(stro_, sizeof(stro_), "А так же кассу, где Вы будете получать деньги за работу.\n\n\n"),strcat(string_,stro_);
			format(stro_, sizeof(stro_), "Чтобы начать работу, необходимо переодеться в рабочую форму.\n"),strcat(string_,stro_);
			format(stro_, sizeof(stro_), "За один мешок, Вам будут платить {3AA94C}%d$.{FFFFFF}\n\n", SALARY_GRUZ_JOB);
			strcat(string_, stro_);
			format(stro_, sizeof(stro_), "Как только вы захотите завершить рабочий день,\nПройдите к кассе.\n\n"),strcat(string_,stro_);
			ShowPlayerDialog(playerid, DIALOG_STYLE_MSGBOX, 0,"{F1C33A}Информация о работе",string_,"Готово","");
		    return 1;
		}
		if(areaid == gAreas[arGruzJob][1] || areaid == gAreas[arGruzJob][6])
		{
		    if(User[playerid][PlayerWorks] == false && User[playerid][PlayerUseMesh] == false) return 0;
			DisablePlayerCheckpoint(playerid);
			if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER) return err(!"Ошибка: {ffffff}Выйдите из т.с!");
			
			SetPlayerCheckpoint(playerid,2794.7400,-2429.8586,13.6320,1.5);
			ApplyAnimation(playerid,"CARRY","liftup",1.0,0,1,1,0,0,1);
			SetTimerEx("CarryDelay",1000,false,"d",playerid);
			//SetPlayerAttachedObject(playerid, 7 , 2060, 1,0.11,0.36,0.0,0.0,90.0);
		    SetTimerEx("animeat", 1000, 0, "i", playerid);
			User[playerid][PlayerUseMesh] = true;
			//SetPVarInt(playerid, "MeshokUpTick", GetTickCount());
			return 1;
	 	}
		if(areaid == gAreas[arGruzJob][2]) return ShowPlayerDialogEx(playerid, D_JOB_FUNC, DIALOG_STYLE_MSGBOX, "Раздевалка", "Вы хотите начать рабочий день , или закончить?", "Начать", "Закончить");
		if(areaid == gAreas[arGruzJob][3]) return ShowPlayerDialogEx(playerid, D_JOB_FUNC + 1, DIALOG_STYLE_MSGBOX, "Раздевалка", "Вы хотите начать рабочий день , или закончить?", "Начать", "Закончить");
		if(areaid == gAreas[arGruzJob][4])
		{
			if(!User[playerid][PlayerWorks]) return SendClientMessage(playerid, COLOR_WHITE, "Вы еще не устроились!");
			if(JobAmmount[playerid] == 0) return SendClientMessage(playerid, COLOR_WHITE, "Вы еще ничего не заработали!");
			if(IsPlayerAttachedObjectSlotUsed(playerid, ATTACHED_SLOT_JOB_OBJ)) RemovePlayerAttachedObject(playerid, ATTACHED_SLOT_JOB_OBJ);
			new string_[128];
			format(string_, sizeof string_, "Вы заработали: {FFFFFF}%d$", JobAmmount[playerid] * SALARY_GRUZ_JOB);
			SendClientMessage(playerid, COLOR_GREEN, string_);
			GiveMoney(playerid, JobAmmount[playerid] * SALARY_GRUZ_JOB);
			User[playerid][PlayerWorks] = false;
			User[playerid][PlayerUseMesh] = false;
			JobAmmount[playerid] = 0;
			//DeletePVar(playerid, "DownTickMeshki");

			Employer[playerid] = 999;
			SetPlayerSkin(playerid,User[playerid][pChar][0]);
			DisablePlayerCheckpoint(playerid);
			SendClientMessage(playerid,COLOR_GREEN, "Рабочий день завершён!");
		}
		//Gruz//
	 	if(areaid == gAreas[arGruzJob][5] && User[playerid][PlayerWorks] == true && User[playerid][PlayerUseMesh] == true)
		{
			
			if(IsPlayerAttachedObjectSlotUsed(playerid, ATTACHED_SLOT_JOB_OBJ)) RemovePlayerAttachedObject(playerid, ATTACHED_SLOT_JOB_OBJ);
			JobAmmount[playerid] ++;
			DisablePlayerCheckpoint(playerid);
			ApplyAnimation(playerid,"CARRY","liftup",1.0,0,1,1,0,0,1);
			new string_[128];
			format(string_, sizeof string_, "Товаров перетащено: %d", JobAmmount[playerid]);
			SendClientMessage(playerid, COLOR_GREEN, string_);
			User[playerid][PlayerUseMesh] = false;
			ClearAnimations(playerid);
			ApplyAnimation(playerid, "CARRY", "crry_prtial",4.0,0,0,0,0,1,0);
			SetPlayerSpecialAction (playerid, SPECIAL_ACTION_NONE);
			//SetPVarInt(playerid, "DownTickMeshki", GetTickCount());
			{
				SetPlayerCheckpoint(playerid,2824.0313,-2429.5076,12.1610,2.0); //
			}
			if(User[playerid][pQuestFirst] == 0)
			{
			    if(JobAmmount[playerid] == 15)
			    {
           			new query[72];
                    SendClientMessage(playerid, COLOR_GREEN, "Задание выполнено. Награда: 500 вирт и 1 EXP.");
                    User[playerid][pQuestFirst] = 1;
                    User[playerid][pCash] += 500;
                    User[playerid][pExp] += 1;
                    format(query, sizeof(query), "UPDATE `accounts` SET `pQuestFirst` = '%d', `pCash` = '%d', `pExp` = '%d' WHERE `name` = '%s'", User[playerid][pQuestFirst], User[playerid][pCash], User[playerid][pExp], User[playerid][pName]);
                    mysql_tquery(dbHandle, query);
                    ShowPlayerDialog(playerid, 9965, DIALOG_STYLE_MSGBOX, "{FFFFFF}2. Теперь водитель", "", "Продолжить", "");
			    }
			}
		}
		if(areaid == gAreas[arTrigger][0])
		{
 			if(User[playerid][pCarLic] == 1) return SendClientMessage(playerid, COLOR_GRAD1, "Вы уже имеете водительские права");
    		if(GetPVarInt(playerid,"givecarlic") == 2)
		    {
				SendClientMessage(playerid, COLOR_WHITE, "Извините! Вы недостаточно хорошо ездиете, чтобы получить водительские права!");
				SendClientMessage(playerid, COLOR_WHITE, "Пересдать экзамен можно в любое время.");
				SendClientMessage(playerid, COLOR_WHITE, "Мы настоятельно рекомендуем вам прочесть ПДД");
				LessonCar[playerid] = 0;
				LessonStat[playerid] = 0;
				TakingLesson[playerid] = 0;
				DeletePVar(playerid,"givecarlic");
			}
			else if(GetPVarInt(playerid,"givecarlic") == 1)
			{
				LessonCar[playerid] = 0;
				LessonStat[playerid] = 0;
				TakingLesson[playerid] = 0;
				User[playerid][pCarLic] = 1;
				SendClientMessage(playerid, COLOR_WHITE, "Поздравляем вас! Вы здали экзамен по вождению");
				SendClientMessage(playerid, COLOR_GREEN, "Подсказка: Теперь вы можете устроить на работу в Мэрии << Испльзуйте /GPS >>");
				SendClientMessage(playerid, COLOR_GREEN, "Подсказка: Работа водителя автобуса очень интересная и прибыльная (зарплата государства + деньги за билеты)");
				SendClientMessage(playerid, COLOR_WHITE, "Мы рекомендуем вам поработать пару лет (( 2 левла )), а после вступить в организацию");
				DeletePVar(playerid,"givecarlic");
			}
			else {
			ShowPlayerDialogEx(playerid,10022,DIALOG_STYLE_MSGBOX, "Экзамен по вождению","Приветствуем вас в Автошколе.\nЕсли вы хотите сдать на права, нажмите Далее", "Далее", "Отмена"); }
			return true;
		}
		if(areaid == gAreas[arTrigger][1])
		{
		    ShowPlayerDialogEx(playerid, 10092, DIALOG_STYLE_MSGBOX, "{F1C33A}Устройство на работу", "{FFFFFF}Вы желаете посмотреть список доступных работ?", "Да", "Нет");
			return true;
		}
		if(areaid == gAreas[arTrigger][2])
		{
		    ShowPlayerDialogEx(playerid, 1467, 0, "{F1C33A}[ Помощь ]","{FFFFFF}Добро пожаловать на проект Rise Role Play. Мы рады, что Вы посетили наш сервер!\n\nВ данном разделе помощи Вы узнаете что к чему, просто нажмите 'Далее' и выберите интересующий Вас раздел.", "Далее", "Отмена");
			return true;
		}
	}
	return 1;
}
publics: CarryDelay(playerid) ApplyAnimation(playerid,"CARRY","crry_prtial",4.0,1,1,1,1,1,1);
stock ConvertsCmdTime(number)
{
	new hours = 0, mins = 0, string[30];
	hours = number / 3600;
	mins = (number - hours * 3600) / 60;
	format(string, 30, "%d ч %d мин", hours, mins);
	return string;
}
@OnCheckStatsAdmin(playerid, name[]);
@OnCheckStatsAdmin(playerid, name[])
{
	new rows;
	cache_get_row_count(rows);
	if(!rows) return SendClientMessage(playerid, COLOR_GREY, "Администратор не найден!");

    new string[150], string2[32];
    QUERY[0] = EOS;

    new check_online_monday, check_online_tuesday, check_online_wednesday,
		check_online_thursday, check_online_friday, check_online_saturday,
		check_online_sunday, check_online_allday,
		check_kicked, check_skicked,
		check_warned,
		check_baned, check_offbaned,
		check_muted,
		check_ansed;

	cache_get_value_name_int(0, "online_monday", check_online_monday);
	cache_get_value_name_int(0, "online_tuesday", check_online_tuesday);
	cache_get_value_name_int(0, "online_wednesday", check_online_wednesday);
	cache_get_value_name_int(0, "online_thursday", check_online_thursday);
	cache_get_value_name_int(0, "online_friday", check_online_friday);
	cache_get_value_name_int(0, "online_saturday", check_online_saturday);
	cache_get_value_name_int(0, "online_sunday", check_online_sunday);
	cache_get_value_name_int(0, "kicked", check_kicked);
	cache_get_value_name_int(0, "skicked", check_skicked);
	cache_get_value_name_int(0, "warned", check_warned);
	cache_get_value_name_int(0, "baned", check_baned);
	cache_get_value_name_int(0, "offbaned", check_offbaned);
	cache_get_value_name_int(0, "muted", check_muted);
	cache_get_value_name_int(0, "ansed", check_ansed);

    strcat(QUERY, "{FF9900}Недельный онлайн\n\n");
    format(string, sizeof(string), "{FFFFFF}Понедельник:\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_monday), (check_online_monday/3600>=4)?("{63BD4E}Выполнена"):(check_online_monday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Вторник\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_tuesday),  (check_online_tuesday/3600>=4)?("{63BD4E}Выполнена"):(check_online_tuesday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Среда\t\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_wednesday),  (check_online_wednesday/3600>=4)?("{63BD4E}Выполнена"):(check_online_wednesday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Четверг\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_thursday),  (check_online_thursday/3600>=4)?("{63BD4E}Выполнена"):(check_online_thursday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Пятница\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_friday),  (check_online_friday/3600>=4)?("{63BD4E}Выполнена"):(check_online_friday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Суббота\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_saturday),  (check_online_saturday/3600>=4)?("{63BD4E}Выполнена"):(check_online_saturday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);
    format(string, sizeof(string), "{FFFFFF}Воскресенье\t\t{3399FF}%s {FFFFFF}| Норма онлайна - %s\n", ConvertsCmdTime(check_online_sunday),  (check_online_sunday/3600>=4)?("{63BD4E}Выполнена"):(check_online_sunday/3600>=3)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);

    check_online_allday = check_online_monday + check_online_tuesday + check_online_wednesday + check_online_thursday + check_online_friday + check_online_saturday + check_online_sunday;

    format(string, sizeof(string), "\n{AFAFAF}Общий онлайн:\t{DD90FF}%s {FFFFFF}| Норма онлайна - %s\n\n", ConvertsCmdTime(check_online_allday), (check_online_sunday/3600>=28)?("{63BD4E}Выполнена"):(check_online_sunday/3600>=21)?("{F1C33A}Не выполнена"):("{F04245}Не выполнена"));
    strcat(QUERY, string);

    strcat(QUERY, "{FF9900}Выдача наказаний\n\n");
    format(string2, sizeof(string2), "{FFFFFF}/kick\t\t\t{6666FF}%i\n", check_kicked);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/skick\t\t\t{6666FF}%i\n", check_skicked);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/warn\t\t\t{6666FF}%i\n", check_warned);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/ban\t\t\t{6666FF}%i\n", check_baned);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/offban\t\t\t{6666FF}%i\n", check_offbaned);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/mute\t\t\t{6666FF}%i\n", check_muted);
    strcat(QUERY, string2);
    format(string2, sizeof(string2), "{FFFFFF}/pm\t\t\t{6666FF}%i", check_ansed);
    strcat(QUERY, string2);

    ShowPlayerDialogEx(playerid, dAdminPanel+5, DIALOG_STYLE_MSGBOX, name, QUERY, "Назад", "Закрыть");
	return 1;
}
@ListAllAdmins(playerid);
@ListAllAdmins(playerid)
{
   	new rows;
   	cache_get_row_count(rows);
   	if(!rows) return ShowPlayerDialogEx(playerid, dAdminPanel+1, DIALOG_STYLE_MSGBOX, "{F1C33A}Список всех администраторов", "{FFFFFF}Ничего не найдено", "Назад", "Закрыть");
	new aname[MAX_PLAYER_NAME], alevel, alastcon[20], adata[20];
	QUERY[0] = EOS;
	strcat(QUERY, "{FFFF00}Ник\t{FFFF00}Уровень админа\t{FFFF00}Последний вход\t{FFFF00}Поставлен\n");
    for(new i; i < rows; i++)
    {
        cache_get_value_name(i, "name", aname, MAX_PLAYER_NAME);
		cache_get_value_name_int(i, "level", alevel);
		cache_get_value_name(i, "last_connect", alastcon, 20);
		cache_get_value_name(i, "data", adata, 20);
    	format(QUERY, sizeof(QUERY), "%s{FFFFFF}%s\t%d\t%s\t%s\n", QUERY, aname, alevel, alastcon, adata);
	}
	ShowPlayerDialogEx(playerid, dAdminPanel+1, DIALOG_STYLE_TABLIST_HEADERS, "{F1C33A}Список всех администраторов", QUERY, "Назад", "Закрыть");
	return 1;
}
stock GetWeekName(name[], const size = sizeof(name))
{
    new hour, minuite, second, year, month, day, w = gettime(), saturday = 1310155200, day_week;
    gettime(hour, minuite, second);
	getdate(year, month, day);
	while(w - saturday > 60 * 60 * 24)
    {
        w -= 60 * 60 * 24;
        day_week ++;
    }
    while(day_week >= 7) day_week -= 7;
	return strunpack(name, gDaysOfWeek[day_week], size);
}
stock getDay()
{
	new week_name[10];
	GetWeekName(week_name);
	return week_name;
}

stock getDayEx()
{
    new hour, minuite, second, year, month, day, w = gettime(), saturday = 1310155200, day_week;
    gettime(hour, minuite, second);
	getdate(year, month, day);
	while(w - saturday > 60 * 60 * 24)
    {
        w -= 60 * 60 * 24;
        day_week ++;
    }
    while(day_week >= 7) day_week -= 7;
	return day_week;
}
stock GetString(param1[], param2[])
{
	return !strcmp(param1, param2, false);
}
@AloginAuth(playerid);
@AloginAuth(playerid)
{
	new rows;
	cache_get_row_count(rows);
	if(!rows)
	{
  		format(YCMDstr, sizeof(YCMDstr), "<ALogin> %s[%i]: ввел неверный пароль",User[playerid][pName],playerid);
		SendAdminMessage(0xF4B800AA, YCMDstr);
		return SendClientMessage(playerid, COLOR_GREY, "Неверный пароль!");
	}
	else
	{
		cache_get_value_name_int(0, "admid", AdminInfo[playerid][admID]);
		if(AdminInfo[playerid][admPlayTime] == 0)
		{
			new who_load[32];
			format(who_load, 32, "online_%s", getDay());
			if(GetString(who_load,"online_monday")) cache_get_value_index_int(0,6,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_tuesday")) cache_get_value_index_int(0,7,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_wednesday")) cache_get_value_index_int(0,8,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_thursday")) cache_get_value_index_int(0,9,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_friday")) cache_get_value_index_int(0,10,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_saturday")) cache_get_value_index_int(0,11,AdminInfo[playerid][admPlayTime]);
			else if(GetString(who_load,"online_sunday")) cache_get_value_index_int(0,12,AdminInfo[playerid][admPlayTime]);
		}
		cache_get_value_index_int(0, 13, AdminInfo[playerid][admKicked]); // kicked
		cache_get_value_index_int(0, 14, AdminInfo[playerid][admSKicked]); // skicked
		cache_get_value_index_int(0, 15, AdminInfo[playerid][admWarned]); // warned
		cache_get_value_index_int(0, 16, AdminInfo[playerid][admBaned]); // baned
		cache_get_value_index_int(0, 17, AdminInfo[playerid][admOffBaned]); // offbaned
		cache_get_value_index_int(0, 18, AdminInfo[playerid][admMuted]); // muted
		cache_get_value_index_int(0, 19, AdminInfo[playerid][admAnsed]); // ansed
		YCMDstr[0] = EOS;
		format(YCMDstr, 128, "UPDATE admin SET last_connect = CURDATE() WHERE name = '%s' LIMIT 1", Name(playerid));
		mysql_tquery(dbHandle, YCMDstr, "", "");
		SCMF(playerid, 0xAFAFAFFF,"Вы авторизовались как администратор %i уровня", GetPVarInt(playerid,"level"));
		User[playerid][pAdmin] = GetPVarInt(playerid,"level");
		SetPVarInt(playerid, "Dostup", 1);
		format(YCMDstr, sizeof(YCMDstr), "<ALogin> вошел %s[%i]", User[playerid][pName], playerid);
		if(User[playerid][pAdmin] < 6) SendAdminMessage(0xF5B900AA, YCMDstr);
		else ABroadCast(0xAFAFAFFF,YCMDstr,7);
	}
	return 1;
}
publics: OffWarn(playerid,tmp[])
{
	new rows,warn;//,check;
	new year, month,day;
 	getdate(year, month, day);
 	cache_get_row_count(rows);
	if(!rows)
	{
		return SCMF(playerid, COLOR_GREY, "Аккаунт %s не найден в базе данных.",tmp);
	}
	cache_get_value_name_int(0, "pWarns",warn);
	//cache_get_value_name_int(0, "Unban",check);
	warn++;
	//if(check > 0) return SCM(playerid, COLOR_GREY, "Данный аккаунт заблокирован");
	if(warn < 3)
	{
		format(YCMDstr, sizeof(YCMDstr), "UPDATE `accounts` SET `pWarns` = '%d', `punWarns` = '%d', `pLeader` = '0', `pMember` = '0', `pRank` = '0' WHERE `Name` = '%s'",warn, mktime(0,0,0,day+7,month,year), tmp);
		mysql_tquery(dbHandle, YCMDstr, "", "");
		format(QUERY, sizeof(QUERY), "OffWarn [заварнил: %s] [заварнен: %s] [%i|3]",User[playerid][pName],tmp,warn);
		SendAdminMessage(COLOR_LIGHTRED,QUERY);
	}
	if(warn >= 3)
	{
	    format(YCMDstr,sizeof(YCMDstr),"UPDATE `accounts` SET `pWarns` = '0', `punWarns` = '0' WHERE `Name` = '%s'",tmp);
    	mysql_tquery(dbHandle, YCMDstr, "", "");
    	
    	format(QUERY, sizeof(QUERY), "OffWarn [заварнил: %s] [заварнен: %s] [3|3]",User[playerid][pName],tmp);
		SendAdminMessage(COLOR_LIGHTRED,QUERY);
		mysql_format(dbHandle,QUERY, 256, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('3 WARNS OFF', '%s', '%s', '%i/%i/%i', '%i')",tmp,User[playerid][pName],day,month,year,mktime(5,0,0,day+7,month,year));
		mysql_tquery(dbHandle,QUERY,"","");
	}
	return true;
}
publics: GrandChangeName(playerid)
{
	new rows;
	cache_get_row_count(rows);
	if(!rows) SavePlayer(playerid), ChangeName(playerid);
	else SCM(playerid, COLOR_WHITE, "Данный никнейм занят");
	return true;
}
stock ChangeName(playerid)
{
    User[playerid][pDonateAccount] -= 10;
	mysql_format(dbHandle, QUERY, 256, "UPDATE `accounts` SET `pCash` = '%d',`pBank` = '%d',`pDonateAccount` = '%d',`pGifts` = '%d' WHERE `Name` = '%s'",User[playerid][pCash],User[playerid][pBank],User[playerid][pDonateAccount],User[playerid][pGifts], Name(playerid));
	mysql_query(dbHandle, QUERY);
	DonateLog(playerid, 10, "смена ника");

    mysql_format(dbHandle, QUERY, 256, "UPDATE `accounts` SET `Name`='%s' WHERE `Name` = '%s'",WantNickChange[playerid],Name(playerid));
	mysql_query(dbHandle, QUERY);
	mysql_format(dbHandle, QUERY, 256, "UPDATE `admin` SET `Name`='%s' WHERE `Name` = '%s'",WantNickChange[playerid],Name(playerid));
	mysql_query(dbHandle, QUERY);
	mysql_format(dbHandle, QUERY, 256, "UPDATE `cars` SET `owner`='%s' WHERE `owner` = '%s'",WantNickChange[playerid],Name(playerid));
	mysql_query(dbHandle, QUERY);
	for(new i = 1; i <= TOTALCASINO; i++)
	{
		if(strcmp(User[playerid][pName],CasinoInfo[i][caManager],true) == 0) strmid(CasinoInfo[i][caManager], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caManager2],true) == 0) strmid(CasinoInfo[i][caManager2], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caManager3],true) == 0) strmid(CasinoInfo[i][caManager3], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie],true) == 0) strmid(CasinoInfo[i][caKrupie], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie2],true) == 0) strmid(CasinoInfo[i][caKrupie2], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie3],true) == 0) strmid(CasinoInfo[i][caKrupie3], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie4],true) == 0) strmid(CasinoInfo[i][caKrupie4], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie5],true) == 0) strmid(CasinoInfo[i][caKrupie5], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie6],true) == 0) strmid(CasinoInfo[i][caKrupie6], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie7],true) == 0) strmid(CasinoInfo[i][caKrupie7], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie8],true) == 0) strmid(CasinoInfo[i][caKrupie8], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie9],true) == 0) strmid(CasinoInfo[i][caKrupie9], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],CasinoInfo[i][caKrupie10],true) == 0) strmid(CasinoInfo[i][caKrupie10], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
    }
    for(new i = 1; i <= TOTALSHOPS; i++)
    {
        if(strcmp(User[playerid][pName],WorkshopInfo[i][wDeputy1],true) == 0) strmid(WorkshopInfo[i][wDeputy1], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wDeputy2],true) == 0) strmid(WorkshopInfo[i][wDeputy2], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wDeputy3],true) == 0) strmid(WorkshopInfo[i][wDeputy3], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wMechanic1],true) == 0) strmid(WorkshopInfo[i][wMechanic1], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wMechanic2],true) == 0) strmid(WorkshopInfo[i][wMechanic2], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wMechanic3],true) == 0) strmid(WorkshopInfo[i][wMechanic3], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wMechanic4],true) == 0) strmid(WorkshopInfo[i][wMechanic4], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
		if(strcmp(User[playerid][pName],WorkshopInfo[i][wMechanic5],true) == 0) strmid(WorkshopInfo[i][wMechanic5], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50);
	}
	if(HGet(playerid)) strmid(HouseInfo[GetPVarInt(playerid,"House")][hOwner], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), MAX_PLAYER_NAME);
	if(BGet(playerid)) strmid(BizzInfo[GetPVarInt(playerid,"Bizz")][bOwner], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), MAX_PLAYER_NAME);
	if(WGet(playerid)) strmid(WorkshopInfo[GetPVarInt(playerid,"wShop")][wOwner], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), MAX_PLAYER_NAME);
	//if(KGet(playerid)) strmid(kvartinfo[GetPVarInt(playerid,"Kvart")][vladelec], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), MAX_PLAYER_NAME);
	for(new i = 1; i <= TotalBizz; i++) if(!strcmp(Name(playerid), BizzInfo[i][bNameStavka], true)) { strmid(BizzInfo[i][bNameStavka], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50); }
	for(new i = 1; i <= TOTALSHOPS; i++) if(!strcmp(Name(playerid), WorkshopInfo[i][wAuctionName], true)) { strmid(WorkshopInfo[i][wAuctionName], WantNickChange[playerid], 0, strlen(WantNickChange[playerid]), 50); }
	format(YCMDstr,sizeof(YCMDstr), "[Donate]: %s сменил имя на %s",Name(playerid),WantNickChange[playerid]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	WriteLog("ChangeName.txt", YCMDstr);
	SendClientMessage(playerid, COLOR_WHITE, "Вам необходимо указать новое имя в {3399FF}окне клиента SAMP");
	SendClientMessage(playerid, COLOR_WHITE, "Рекомендуем прямо сейчас свернуть игру {63BD4E}(Alt+Tab) {FFFFFF}и сделать это");
	SetPlayerName(playerid, WantNickChange[playerid]);
	User[playerid][pCheckip] = 0;
	KickEx(playerid, "ChangeName");
	return true;
}
publics: DuelFunk(playerid,target)
{
	new timestring[32];
	if(DuelTime[playerid] > 0)
	{
	    DuelTime[playerid] --;
	    if(DuelTime[playerid] != 0)
	    {
	        format(timestring,sizeof(timestring),"~r~%i",DuelTime[playerid]);
			GameTextForPlayer(playerid,timestring,2000,6);
			GameTextForPlayer(target,timestring,2000,6);
			PlayerPlaySound(playerid,1056,0.0,0.0,0.0);
			PlayerPlaySound(target,1056,0.0,0.0,0.0);
		}
		else
		{
			GameTextForPlayer(playerid,"~g~GO",2000,6);
			GameTextForPlayer(target,"~g~GO",2000,6);
			PlayerPlaySound(playerid,1057,0.0,0.0,0.0);
			PlayerPlaySound(target,1057,0.0,0.0,0.0);
			TogglePlayerControllable(playerid,1);
			TogglePlayerControllable(target,1);
		}
	}
	else
	{
		if(GetPlayerVirtualWorld(target) != playerid+100)
		{
		    KillTimer(DuelTimer[playerid]);
		    ResetPlayerWeaponsEx(playerid);
			SendClientMessage(target,COLOR_RED,"Вы проиграли!");
			SCMF(playerid,COLOR_GREEN,"Вы победили! Выигрыш %d $", GetPVarInt(playerid,"DuelPrice")*2);
			User[playerid][pCash] += GetPVarInt(playerid,"DuelPrice")*2;
			SetPVarInt(target, "DuelSpawn", 1), SetPVarInt(playerid, "DuelSpawn", 1);
			SpawnPlayer(target);//,SetTimerEx("SpawnDuel",3500,false, "i", target);
			SpawnPlayer(playerid);//,SetTimerEx("SpawnDuel",3500,false, "i", playerid);
		}
		else if(GetPlayerVirtualWorld(playerid) != playerid+100)
		{
		    KillTimer(DuelTimer[playerid]);
		    ResetPlayerWeaponsEx(playerid);
			SendClientMessage(playerid,COLOR_RED,"Вы проиграли!");
			SCMF(target,COLOR_GREEN,"Вы победили! Выигрыш %d $", GetPVarInt(playerid,"DuelPrice")*2);
			User[target][pCash] += GetPVarInt(playerid,"DuelPrice")*2;
			SetPVarInt(playerid, "DuelSpawn", 1), SetPVarInt(target, "DuelSpawn", 1);
			SpawnPlayer(playerid);//,SetTimerEx("SpawnDuel",3500,false, "i", playerid);
			SpawnPlayer(target);//,SetTimerEx("SpawnDuel",3500,false, "i", target);
		}
	}
	return 1;
}
