CMD:carpass(playerid, params[])
{
    new string[156];
	if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в машине!");
	if(Vehicleforeach(GetPlayerVehicleID(playerid)) == -1 && caroff[GetPlayerVehicleID(playerid)] == 0) return SendClientMessage(playerid,COLOR_GREY,"В бардачке этого транспортного средства нет документов");
	if(sscanf(params, "u",params[0]))
	{
	    if(IsPlayerConnected(Vehicleforeach(GetPlayerVehicleID(playerid))) && caroff[GetPlayerVehicleID(playerid)] == 0)
		{
			SendClientMessage(playerid,0x589A76FF, "-------========[ VEHICLE PASSPORT ]========-------");
			format(string,sizeof(string), " Модель: %s",VehicleNames[GetVehicleModel(GetPlayerVehicleID(playerid))-400]);
			SendClientMessage(playerid,0xFFFFFFFF, string);
			format(string,sizeof(string), " Владелец: %s",Name(Vehicleforeach(GetPlayerVehicleID(playerid))));
			SendClientMessage(playerid,0xFFFFFFFF, string);
			format(string,sizeof(string), " Состояние: %i процентов",CarInfo[Vehicleforeach(GetPlayerVehicleID(playerid))][carPercent][GetPVarInt(Vehicleforeach(GetPlayerVehicleID(playerid)),"SelectCar")]);
			SendClientMessage(playerid,0xFFFFFFFF, string);
			SendClientMessage(playerid,0x589A76FF, "-------====================================-------");
			SetPlayerChatBubble(playerid,"достал(а) документы из бардачка",COLOR_PURPLE,30.0,10000);
			format(string, sizeof(string), "%s достал(а) документы из бардачка",User[playerid][pName]);
			SendBeside(playerid, COLOR_PURPLE,string,10.0);
			return true;
		}
		else return SendClientMessage(playerid,COLOR_REDD,"Владельца машины нет в сети.");
	}
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,-1,"Игрок не в сети");
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	SendClientMessage(params[0],0x589A76FF, "-------========[ VEHICLE PASSPORT ]========-------");
	format(string,sizeof(string), " Модель: %s",VehicleNames[GetVehicleModel(GetPlayerVehicleID(playerid))-400]);
	SendClientMessage(params[0],0xFFFFFFFF, string);
	format(string,sizeof(string), " Владелец: %s",Name(Vehicleforeach(GetPlayerVehicleID(playerid))));
	SendClientMessage(params[0],0xFFFFFFFF, string);
	format(string,sizeof(string), " Состояние: %i процентов",CarInfo[Vehicleforeach(GetPlayerVehicleID(playerid))][carPercent][GetPVarInt(Vehicleforeach(GetPlayerVehicleID(playerid)),"SelectCar")]);
	SendClientMessage(params[0],0xFFFFFFFF, string);
	SendClientMessage(params[0],0x589A76FF, "-------====================================-------");
	format(string,sizeof(string), "достал(а) документы из бардачка и показал их %s",User[params[0]][pName]);
	SetPlayerChatBubble(playerid,string,COLOR_PURPLE,30.0,10000);
	format(string, sizeof(string), "%s достал(а) документы из бардачка и показал их %s",User[playerid][pName],User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE,string,10.0);
	return true;
}
CMD:sellcar(playerid, params[])
{
	new str[40];
	new null = -1;
	if(house_car[playerid] == -1) return SendClientMessage(playerid,COLOR_GREY, "У вас нет автомобиля");
	if(CarInfo[playerid][carModel][GetPVarInt(playerid,"SelectCar")] == 462) return SendClientMessage(playerid,COLOR_GREY, "Вы не можете продать мопед");
	if(GetPVarInt(playerid,"_changecar") || GetPVarInt(playerid,"changecar")) return SendClientMessage(playerid,COLOR_GREY, "В данный момент вы не можете продать свой автомобиль!");
	for(new i = 0; i < sizeof(ShopCar); i++) if(CarInfo[playerid][carModel][GetPVarInt(playerid,"SelectCar")] == ShopCar[i][0]) null = i;
	if(null == -1) return SendClientMessage(playerid,COLOR_GREY, "Вы не можете продать данный автомобиль!");
	User[playerid][pBank]+=ShopCar[null][1]/2;
	format(str,sizeof(str),"~w~car in sold~n~~g~$%i",ShopCar[null][1]/2);
	GameTextForPlayer(playerid,str, 5000, 3);
	RemoveTuning(playerid,house_car[playerid]);
	CarInfo[playerid][carPercent][GetPVarInt(playerid,"SelectCar")] = 0;
	SendClientMessage(playerid,COLOR_WHITE, "Вы продали свой автомобиль");
	CarInfo[playerid][carModel][GetPVarInt(playerid,"SelectCar")] = 462;
	CarInfo[playerid][carColor_one][GetPVarInt(playerid,"SelectCar")] = 203;
	CarInfo[playerid][carColor_two][GetPVarInt(playerid,"SelectCar")] = 203;
	if(house_car[playerid] != -1)
	{
		DestroyVehicle(house_car[playerid]);
		house_car[playerid] = -1;
	}
	if(HGet(playerid))
	{
	    new house = GetPVarInt(playerid,"House");
		house_car[playerid] = CreateVehicleAC(CarInfo[playerid][carModel][GetPVarInt(playerid,"SelectCar")], HouseInfo[house][hCarx], HouseInfo[house][hCary], HouseInfo[house][hCarz], HouseInfo[house][hCarc] , CarInfo[playerid][carColor_one][GetPVarInt(playerid,"SelectCar")] ,CarInfo[playerid][carColor_two][GetPVarInt(playerid,"SelectCar")], 86400);
		SetVehicleParamsEx(house_car[playerid],false,false,false,true,false,false,false);
		CarHealth[house_car[playerid]] = float(1000);
	}
	SaveCar(playerid);
	return true;
}
CMD:pgetip(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /pgetip [ip]");
	SendClientMessage(playerid, 0xC21D00AA, "Список IP:");
	new playersip[32];
	foreach(new i : Player)
	{
		GetPlayerIp(i,playersip,sizeof(playersip));
		if(!strcmp(playersip, params[0]))
		{
			format(YCMDstr, 256, "Nik [%s] IP [%s]", User[i][pName],playersip);
			SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
		}
	}
	return true;
}
CMD:sellzone(playerid, params[])
{

    for(new i = 1; i <= TOTALGZ; i++)
	{
		if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
		{
			if(ZoneOnBattle[i] == 1) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете продать зону за которую идёт война!");
			if(IsARespawn(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Нельзя продать эту территорию");
			if(User[playerid][pLeader] != GZInfo[i][gFrakVlad]) return SendClientMessage(playerid, COLOR_GREY, "Вы не на своей зоне!");
			if(sscanf(params, "ud",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /sellzone [id] [цена]");
			if(params[1] < 100000 || params[1] > 500000) { SendClientMessage(playerid, COLOR_GREY, "Цена должна быть: от 100000 до 500000!"); return true; }
			if(!IsPlayerConnected(params[0])) return true;
			if(!ProxDetectorS(8.0, playerid, params[0])) return true;
			if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Нельзя продать самому себе!"); return true; }
			format(YCMDstr, sizeof(YCMDstr), "Вы предложили %s купить территорию за %i вирт",User[params[0]][pName],params[1]);
			SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
			format(YCMDstr, sizeof(YCMDstr), "%s предлагает Вам купить территорию за %i вирт. (( Введите: /accept zone для покупки))",User[playerid][pName],params[1]);
			ShowPlayerDialogEx(params[0], 1508, DIALOG_STYLE_MSGBOX, "Покупка территории", YCMDstr, "Купить", "Отмена");
			SetPVarInt(params[0], "ZoneOffer", playerid);
			SetPVarInt(params[0], "sellzone", User[playerid][pMember]);
			SetPVarInt(params[0], "ZonePrice", params[1]);
		}
		//else SendClientMessage(playerid, COLOR_GREY, "Нужно находиться в гетто!");
	}
	return true;
}
CMD:agetip(playerid, params[])
{

    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[42]",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /agetip [Ник]");
	static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle,query, sizeof(query), fmt_query,params[0]);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",20,playerid,params[0]);
	return true;
}
CMD:agetipreg(playerid, params[])
{

    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[42]",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /agetip [Ник]");
	static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle,query, sizeof(query), fmt_query,params[0]);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",21,playerid,params[0]);
	return true;
}
CMD:atm(playerid)
{

	for(new i = 1; i <= TOTALATM; i++)
	{
	    if(!IsPlayerInRangeOfPoint(playerid, 2.0,ATMInfo[i][aX],ATMInfo[i][aY],ATMInfo[i][aZ])) continue;
	    //ClearAnimations(playerid);
	    ShowPlayerDialogEx(playerid, 8900, DIALOG_STYLE_LIST, "{F1C33A}ATM","1. Пополнить счет\n2. Снять со счета\n3. Баланс\n4. Оплатить квартплату", "Выбрать", "Назад");
	    break;
	}
	return 1;
}
CMD:admins(playerid)
{
	if(User[playerid][pLogin] == 0) return true;
	if(User[playerid][pAdmin] < 1 && User[playerid][pDonateRank] < 1 && User[playerid][pLeader] == 0 && !GetPVarInt(playerid, "SDuty")) return SCM(playerid, COLOR_GREY, " Доступно администрации / VIP 2 уровня / саппортам / лидерам");
	SCM(playerid, COLOR_YELLOW, " Админы Online:");
	foreach(new i : Player)
	{
		if(!IsPlayerConnected(i) || (!User[i][pLogin])) continue;
		if(User[i][pAdmin] < 1 || User[i][pAdmin] > 6 && User[playerid][pAdmin] < 7) continue;
		if(GetPVarInt(i,"AFK_Time") > 2) format(YCMDstr, 256, " %s[ID: %i] [level: %i] [AFK: %s]",Name(i),i,User[i][pAdmin], Convert(GetPVarInt(i, "AFK_Time")-2));
		else format(YCMDstr, 256, " %s[ID: %i] [level: %i]",Name(i),i,User[i][pAdmin]);
		SCM(playerid, COLOR_YELLOW2, YCMDstr);
	}
	if(User[playerid][pAdmin] > 0)
	{
		format(YCMDstr, sizeof(YCMDstr), "Время администратирования за сегодня: %s", ConvertsCmdTime(AdminInfo[playerid][admPlayTime]));
		SendClientMessage(playerid, COLOR_YELLOW, YCMDstr);//
	}
	return true;
}
CMD:instructors(playerid, params[])
{
	SendClientMessage(playerid, 0x6495EDFF, "Инструкторы Online:");
	foreach(new i : Player)
	{
		if(!IsPlayerConnected(i)) continue;
		if(User[i][pMember] != 11) continue;
		format(YCMDstr, 256, "Инструктор: %s тел: %i", User[i][pName], User[i][pPnumber]);
		SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	}
	return true;
}
CMD:supports(playerid)
{
	SendClientMessage(playerid, COLOR_YELLOW, "Саппорты Online:");
	foreach(new i : Player)
	{
		if(!IsPlayerConnected(i)) continue;
		if(!User[i][pHelper] || !GetPVarInt(i, "SDuty")) continue;
		if(GetPVarInt(i,"AFK_Time") > 2) format(YCMDstr, 256, "%s[ID: %i] [AFK: %s]",User[i][pName],i, Convert(GetPVarInt(i, "AFK_Time")-2));
		else format(YCMDstr, 256, "%s[ID: %i]",User[i][pName],i);
		SendClientMessage(playerid, COLOR_YELLOW2, YCMDstr);
	}
	return true;
}
CMD:members(playerid, params[])
{
	new str[128];
    new chislo = 0, teamnumber;
    if(User[playerid][pMember] == 0) return SendClientMessage(playerid, COLOR_GREY, "Вам недоступна эта функция");
    if(User[playerid][pLeader] != 0) teamnumber = User[playerid][pLeader];
    else if(User[playerid][pMember] != 0) teamnumber = User[playerid][pMember];
    else
    {
        SendClientMessage(playerid, COLOR_GRAD1, "Вам недоступна эта функция");
        return true;
    }
    SendClientMessage(playerid, 0x059BD3FF, "Члены организации Online:");
    if(!IsAMafia(playerid) && !IsAGang(playerid) && !IsABiker(playerid))
    SendClientMessage(playerid, TEAM_GROVE_COLOR, "На работе:");
    foreach(new i : Player)
	{
        if(IsPlayerConnected(i))
        {
            format(str, sizeof(str), "");
            if(User[i][pLeader] == teamnumber && GetPVarInt(i,"Fraction_Duty")) format(str, sizeof(str), " [%i] %s  ранг: %i [%s]",i,User[i][pName], User[i][pRank], GetRank(i), chislo++);
            else if(User[i][pMember] == User[playerid][pMember] && User[i][pJobHeal] == User[playerid][pJobHeal] && GetPVarInt(i,"Fraction_Duty")) format(str, sizeof(str), " [%i] %s  ранг: %i [%s]",i,User[i][pName], User[i][pRank], GetRank(i)), chislo++;
            if(strlen(str) > 1) SendClientMessage(playerid, 0x059BD3FF, str);
        }
    }
    if(!IsAMafia(playerid) && !IsAGang(playerid) && !IsABiker(playerid))
    SendClientMessage(playerid, COLOR_LIGHTRED, "Выходные:");
    foreach(new i : Player)
	{
        if (IsPlayerConnected(i))
        {
            format(str, sizeof(str), "");
            if(User[i][pLeader] == teamnumber && !GetPVarInt(i,"Fraction_Duty")) format(str, sizeof(str), " [%i] %s  ранг: %i [%s]",i,User[i][pName], User[i][pRank], GetRank(i), chislo++);
            else if(User[i][pMember] == User[playerid][pMember] && !GetPVarInt(i,"Fraction_Duty")) format(str, sizeof(str), " [%i] %s ранг: %i [%s]",i,User[i][pName], User[i][pRank], GetRank(i)), chislo++;
            if(strlen(str) > 1) SendClientMessage(playerid, 0x059BD3FF, str);
        }
    }
    format(str,sizeof(str),"Всего: %i человек",chislo);
	SendClientMessage(playerid,COLOR_YELLOW,str);
    return true;
}
CMD:amembers(playerid, params[])
{
	  new str[128];

      if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
      if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /amembers [1-23]");
      if(params[0] > 36 || params[0] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 36");
      SendClientMessage(playerid, 0x059BD3FF, "Члены организации Online:");
      foreach(new i : Player)
	  {
          format(str, sizeof(str), "");
          if(User[i][pLeader] == params[0]) format(str, sizeof(str), " [%i] %s  ранг: %i [Лидер]",i,User[i][pName], User[i][pRank]);
          else if(User[i][pMember] == params[0]) format(str, sizeof(str), " [%i] %s  ранг: %i [%s]",i,User[i][pName], User[i][pRank], GetRank(i));
          if(strlen(str) > 1) SendClientMessage(playerid, 0x059BD3FF, str);
      }
      return true;
}
CMD:offmembers(playerid, params[])
{
    if(User[playerid][pLogin] == 0) return true;
    if(User[playerid][pLeader] == 0) return SendClientMessage(playerid, COLOR_GREY, "Вам недоступна эта функция! (Доступно только лидерам)");
	SendClientMessage(playerid, 0x059BD3FF, "Список игроков: [Ник] [Ранг] [Последний вход] [Время игры]");
	format(QUERY, sizeof(QUERY), "SELECT * FROM `accounts` WHERE pMember = '%d'",User[playerid][pMember]);
	mysql_tquery(dbHandle,QUERY,"OnMySQL_QUERY","iis",37,playerid,"");
	return true;
}
