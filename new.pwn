stock KickEx(playerid, logtext[])
{
    new plrIP[16];
    GetPlayerIp(playerid, plrIP, sizeof(plrIP));
    if(!strcmp(plrIP, "176.32.39.128")) return true;
    format(YCMDstr, sizeof(YCMDstr), "%s [%s] has kicked: %s", Name(playerid), plrIP, logtext);
    WriteLog("KickLog.txt", YCMDstr);
    SetTimerEx("PlayerKick",500,0,"i", playerid);
    return 1;
}

forward PlayerKick(playerid);
public PlayerKick(playerid)
{
	if(User[playerid][pLogin] == 1) SavePlayer(playerid);
	Kick(playerid);
	return 1;
}

