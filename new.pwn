		default: return true;
	}
	bGruz[playerid] = 0;
	DestroyVehicle(GetVehicleTrailer(GetPlayerVehicleID(playerid)));
	Expirence(playerid);
	DriverJob[playerid] = false;
	User[playerid][pDgruz] = 0;
