stock LockCar(playerid,carid)
{
	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
	    if(!IsAPlane(carid) && !IsABoat(carid) && !IsABike(carid))
		{
	    	PlayerTextDrawBoxColor(playerid,SpeedPlayer[playerid][2], 8388863);
	    	PlayerTextDrawShow(playerid, SpeedPlayer[playerid][2]);
	    }
	}
	GetVehicleParamsEx(carid,engine,lights,alarm,doors,bonnet,boot,objective);
	return SetVehicleParamsEx(carid,engine,lights,alarm,true,bonnet,boot,objective);
}
public OnPlayerExitVehicle(playerid, vehicleid)
{
    SetPVarInt(playerid,"AFK_Time",0);
    SetPVarInt(playerid, "GunCheckTime", 2);
    CheckVehicle[playerid] = gettime() + 2;
    VehicleID[playerid] = INVALID_VEHICLE_ID;
    ac_player_vehicle_old[playerid] = vehicleid;
    car_ex[vehicleid] = true;
   	GetVehiclePos(vehicleid,car_coord[vehicleid][0],car_coord[vehicleid][1],car_coord[vehicleid][2]);
   	GetVehicleZAngle(vehicleid,car_coord[vehicleid][3]);
    if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER && GetPVarInt(playerid,"TaxiDuty"))
    {
        for ( new i = 0; i < 6 ; i ++ )
		{
			TextDrawHideForPlayer ( playerid, TaxiTD [ i ] ) ;
		}
		if(IsValidDynamic3DTextLabel(TaxiText3D[playerid])) DestroyDynamic3DTextLabel(TaxiText3D[playerid]);
		PlayerTextDrawHide(playerid, TaxiZP[playerid][0]);
		PlayerTextDrawHide(playerid, TaxiZP[playerid][1]);
        //Delete3DTextLabel(JobText3D[GetPVarInt(playerid,"rentcar_job")]);
		DeletePVar(playerid,"TaxiDuty");
	}

	if(vehicleid >= armycarsf[17] && vehicleid <= armycarsf[18] || vehicleid >= armycarsf[23] && vehicleid <= armycarsf[24])
	{
	    //DisablePlayerCheckpoint(playerid);
	    ShowPlayerDialogEx(playerid, 1947, DIALOG_STYLE_MSGBOX, "Доставка", "Вы действительно хотите закончить доставку материалов?", "Да", "Нет");
	    //VertMats[playerid] = 0;
	}

	if(race_info[1] > 1 && GetPVarInt(playerid,"gonka") != 0)
	{
	    SetPlayerInterior(playerid,3);
		t_SetPlayerPos(playerid,831.7769,6.8750,1004.1797);
		SetPlayerFacingAngle(playerid,108.1610);
	    DestroyVehicle(RaceInfo[GetPVarInt(playerid,"gonka")-1][rCar]);
	    DeletePVar(playerid,"gonka");
	    SendClientMessage(playerid,COLOR_LIGHTRED,"Вы были дисквалифицированы!");
	}
	if(GetPlayerState(playerid) == PLAYER_STATE_PASSENGER)
	{
	    new str[128];
	    foreach(new i : Player)
		{
			if(IsPlayerInVehicle(i, GetPlayerVehicleID(playerid)) && GetPlayerState(i) == 2 && GetPVarInt(i,"TaxiDuty") > 0)
			{
				if(GetPVarInt(i,"Taxi_")-1 == playerid)
				{
					SendClientMessage(i, COLOR_BLUE, "Пассажир вышел из вашего Такси. Деньги будут зачислены во время зарплаты");
					if(GetPVarInt(i,"PayDayCashJob") > gettime()) {}
					else
					{
						new taxizp = 200+random(200);
						User[i][pPayCheck] += taxizp*User[i][ptaxilvl];
						if(User[i][pPayCheck] > 4000+(User[i][ptaxilvl]*1000)) User[i][pPayCheck] = 4000+(User[i][ptaxilvl]*1000);
					}
					SetPVarInt(playerid, "TaxiPlayer", i);
					ShowPlayerDialogEx(GetPVarInt(i,"Taxi_")-1, 1203, DIALOG_STYLE_MSGBOX, "Такси", "Как вас обслужили?", "Хорошо", "Плохо");
					DeletePVar(i,"Taxi_");
					for(new id; id < GetMaxPlayers(); id++)
					{
						if(IsPlayerInVehicle(id, GetPlayerVehicleID(playerid)) && id != i && id != playerid)
						{
							format(str, sizeof(str), "Довезите пассажира %s и государство заплатит вам",User[id][pName]);
							SendClientMessage(i, COLOR_BLUE, str);
							SetPVarInt(i,"Taxi_",id+1);
							break;
						}
					}
				}
			}
		}
	}
	if(GetPVarInt(playerid, "RabotaOn") == 1) DisablePlayerCheckpoint(playerid);
	if(PEfir[playerid] != 255)
	{
		SendClientMessage(playerid, COLOR_WHITE, "Вы вышли из прямого эфира");
		PEfir[playerid] = 255;
	}
	if(Pefir[playerid] == 1 || Pefir[playerid] == 2)
	{
		PEfir[playerid] = 255;
		SendClientMessage(playerid, COLOR_WHITE, "Вы вышли из прямого эфира");
	}
	return true;
}
