CMD:gettax(playerid, params[])
{
    if(User[playerid][pMember] == 7)
	{
		format(YCMDstr, sizeof(YCMDstr), "В казне: %i вирт", FracBank[0][fKazna]);
		SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	}
	return true;
}
CMD:settax(playerid, params[])
{
	if(!IsAMayor(playerid)) return true;
	if(User[playerid][pRank] < 5) return SCM(playerid, COLOR_GREY, "Вам недоступна данная функция!");
	if(sscanf(params, "d", params[0])) return SCM(playerid, -1, "Введите: /settax [налог]");
	if(params[0] < 1 || params[0] > 1000) return SCM(playerid, COLOR_GREY, "Сумма должна быть от 1 до 1000 вирт");
	nalog = params[0];
	SCM(playerid, COLOR_GRAD2, "Вы установили налог!");
	return true;
}
CMD:setpromo(playerid, params[])
{
    if(!GetPVarInt(playerid, "Dostup")) return true;
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    ShowPlayerDialogEx(playerid, dAdminPanel+9, DIALOG_STYLE_LIST, "{F1C33A}Промокоды", "1. Список промокодов\n2. Создать промокод\n3. Удалить промокод", "Выбрать", "Назад");
    return true;
}
