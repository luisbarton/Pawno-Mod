				SendClientMessage(killerid,0x6495EDFF, "Вы посадили преступника на 1800 секунд!");
			}
			else if(User[playerid][pWantedLevel] == 4)
			{
				//ResetPlayerWeaponsEx(playerid);
				User[playerid][pJailTime] = 2400;
				User[playerid][pWantedLevel] = 0;
				SetPlayerWantedLevel(playerid,User[playerid][pWantedLevel] );
				SetPlayerInterior(playerid, 6);
				t_SetPlayerPos(playerid, 264.6288,77.5742,1001.0391);
