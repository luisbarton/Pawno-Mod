            new str[8], varv[100];
            strcat(varv,"Парковка\n");
            for(new f = 1; f <= PodeezdInfo[g][podEtazi]; f++)
            {
                format(str, 10, "%i этаж\n", f);
                strcat(varv,str);
            }
            return ShowPlayerDialogEx(playerid, 8999, 2, "Лифт", varv, "Перейти", "Закрыть");
        }
    }
	return true;
}
