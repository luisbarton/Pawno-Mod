	return 1;
}*/
CMD:testc(playerid, params[])
{
	return SCMF(playerid, -1, "%d",GetPVarInt(playerid,"SelectCar"));
}
CMD:tpcor(playerid, params[])
{
	if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return true;
	new Float:fx, Float:fy, Float:fz;
	if(sscanf(params, "fff",fx, fy, fz)) return SCM(playerid, -1, " Введите: /tpcor [x] [y] [z]");
	t_SetPlayerPos(playerid, fx, fy, fz);
	SCM(playerid, -1, " Вы были телепортированы");
	printf("Администратор %s телепортировался по координатам %f,%f,%f",Name(playerid), fx, fy, fz);
	return true;
}
CMD:teleport(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	new listitems[] = "LSPD\nLSPD-Тюрьма\nМэрия\nАвтовокзал ЛС\nЛС-СФ Шоссе\nАвтошкола\nФБР\nАэропорт СФ\nАэропорт ЛС\nВоенная база\nЦентр Лас Вентурас\nКлуб Джизи\nАдмин казино\nВокзал ЛВ\nАэро ЛС Въезд\nВокзал СФ\nАвианосец стоянка\nАвианосец\nЗона 51 склад\nФорт карсон\nГетто\nТюрьма ЛВ\nТюрьма СФ\nРабота прораба\nЗа Рестораном (АДМИН ЗОНА)\nДраконы\nКалигула\nЖД-ЛС";
	ShowPlayerDialogEx(playerid, 9000, DIALOG_STYLE_LIST, "TP-List", listitems, "Выбрать", "Отмена");
	return true;
}
CMD:ajob(playerid, params[])
{

	if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	ShowPlayerDialogEx(playerid, 10098, DIALOG_STYLE_TABLIST, "{F1C33A}Список работ", "Водитель автобуса \t2 уровень\nТаксист \t2 уровень\nПродавец хот-догов \t2 уровень\nРазвозчик продуктов \t3 уровень\nМеханик \t3 уровень\nПрораб \t5 уровень\nДальнобойщик \t6 уровень", "Выбрать", "Отмена");
	return true;
}
CMD:mark(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	GetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
	SendClientMessage(playerid, COLOR_WHITE, "Точка телепортирования установлена");
	return true;
}
CMD:gotomark(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(GetPlayerState(playerid) == 2)
	{
		new tmpcar = GetPlayerVehicleID(playerid);
		t_SetVehiclePos(tmpcar, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
		SetPVarInt(playerid, "AntiBreik", 2);
		User[ playerid ][ pPos_x ] = TeleportDest[playerid][0];
		User[ playerid ][ pPos_y ] = TeleportDest[playerid][1];
		User[ playerid ][ pPos_z ] = TeleportDest[playerid][2];
		SetPVarInt(playerid, "AntiBreik", 2);
		TelePos[playerid][0] = 0.0;TelePos[playerid][1] = 0.0;
	}
	else t_SetPlayerPos(playerid, TeleportDest[playerid][0],TeleportDest[playerid][1],TeleportDest[playerid][2]);
	SendClientMessage(playerid, COLOR_WHITE, "Вы были телепортированы");
	SetPlayerInterior(playerid,0);
	return true;
}
CMD:goto(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /g(oto) [playerid]");
	new Float:plocx,Float:plocy,Float:plocz;
	if(!IsPlayerConnected(params[0])) return true;
	if(GetPlayerState(params[0]) != 1 && GetPlayerState(params[0]) != 2 && GetPlayerState(params[0]) != 3) return SendClientMessage(playerid, COLOR_GRAD1, "Игрок оффлайн / не залогинен");
	if(GetPlayerState(params[0]) == PLAYER_STATE_SPECTATING && gSpectateID[params[0]] != INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GRAD1, "Администратор в режиме наблюдения");
	GetPlayerPos(params[0], plocx, plocy, plocz);
	if (GetPlayerState(playerid) == 2)
	{
		new tmpcar = GetPlayerVehicleID(playerid);
		t_SetVehiclePos(tmpcar, plocx, plocy+4, plocz);
		SetPVarInt(playerid, "AntiBreik", 2);
		User[ playerid ][ pPos_x ] = plocx;
		User[ playerid ][ pPos_y ] = plocy+4;
		User[ playerid ][ pPos_z ] = plocz;
		SetPVarInt(playerid, "AntiBreik", 2);
		TelePos[playerid][0] = 0.0;TelePos[playerid][1] = 0.0;
	}
	else
	{
		t_SetPlayerPos(playerid,plocx,plocy+2, plocz);
		SetPlayerVirtualWorld(playerid, GetPlayerVirtualWorld(params[0]));
		SetPlayerInterior(playerid, GetPlayerInterior(params[0]));
	}
	SendClientMessage(playerid, COLOR_WHITE, "Вы были телепортированы");
	return true;
}
CMD:gethome(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup") || User[playerid][pMember] == 2 && User[playerid][pRank] > 3) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /gethome [id]");
	foreach(new i : Player)
	{
		if(HGet(i) && GetPVarInt(i,"House") == i)
		{
			format(YCMDstr,sizeof(YCMDstr),"Home: [%i], Player: [%i]",params[0],i);
			SendClientMessage(playerid,COLOR_GREY,YCMDstr);
		}
	}
	return true;
}
CMD:get(playerid, params[])
{
	new str[128];
	if(!IsPlayerConnected(playerid)) return true;
	new param[40];
	if( sscanf( params, "s[32]S()[64]", param, params ) ) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /get [значение] Доступные значения: guns, drugs, fuel, medkit");
	if(strcmp(param, "fuel",true) == 0)
	{
		for(new b = 1; b <= TotalBizz; b++)
		{
			if(PlayerToPoint(10.0, playerid, BizzInfo[b][bEntranceX], BizzInfo[b][bEntranceY], BizzInfo[b][bEntranceZ]) && BizzInfo[b][bType] == 4)
			{
			    if(BizzInfo[b][bProducts] <= 0 && strcmp(BizzInfo[b][bOwner],"None",true) != 0) return SendClientMessage(playerid,COLOR_GRAD1,"Заправка не работает");
				if(BizzInfo[b][bLocked] == 1) return SendClientMessage(playerid,COLOR_GRAD1, "Заправка закрыта!");
				if(User[playerid][pFuel] != 0) return SendClientMessage(playerid, COLOR_GRAD1, "У вас уже есть канистра");
				if(User[playerid][pCash] < BizzInfo[b][bPrice]/4) return SendClientMessage(playerid,COLOR_GRAD1, "Не достаточно денег!");
				BizzInfo[b][bTill] += BizzInfo[b][bPrice]/4;
				BizzPay[b] += BizzInfo[b][bPrice]/4;
				if(strcmp(BizzInfo[b][bOwner],"None",true) != 0) BizzInfo[b][bProducts] -= 20;
				format(str, sizeof(str), "Вы купили 20 литров бензина за %i вирт",BizzInfo[b][bPrice]/4);
				SendClientMessage(playerid, 0x6495EDFF, str);
				User[playerid][pFuel] = 1;
				User[playerid][pCash] -= BizzInfo[b][bPrice]/4;
				return true;
			}
		}
	}
