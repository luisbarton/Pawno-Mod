CMD:iwep(playerid, params[])
{
	if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	else if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /iwep [id игрока]");
	else if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок не в игре!");
	else if(!User[params[0]][pLogin]) return SendClientMessage(playerid, COLOR_GREY, "Игрок не авторизован!");
	new weapons[13][2], strs[46], gunname[32];
	QUERY[0] = EOS;
	format(strs, sizeof(strs), "Игрок:\t\t\t%s{FFFFFF}", Name(params[0]));
	strcat(QUERY, strs);
	for(new i = 0; i < 13; i++)
	{
		GetPlayerWeaponData(params[0], i, weapons[i][0], weapons[i][1]);
		GetWeaponName(weapons[i][0], gunname, sizeof(gunname));
		if(weapons[i][0] != 0)
		{
			format(QUERY, sizeof(QUERY), "%s\n\nОружие:\t\t%s (%d)\nПатроны:\t\t%d", QUERY, gunname, weapons[i][0], weapons[i][1]);
		}
	}
	ShowPlayerDialogEx(playerid, 0, DIALOG_STYLE_MSGBOX, "{F1C33A}Оружие игрока", QUERY, "Закрыть", "");
	return 1;
}
CMD:agetstats(playerid, params[])
{
	if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	new name[64];
	if(sscanf(params, "s[64]", name)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /agetstats [Nick_Name]");
	static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle,query, sizeof(query), fmt_query,name);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",16,playerid,name);
	return true;
}
CMD:alms(playerid)
{
    if(User[playerid][pLevel] > 6) return SendClientMessage(playerid, COLOR_GREY, "Доступно новичкам до 6 уровня");
    if(GetPlayerInterior(playerid) != 0 || GetPlayerVirtualWorld(playerid) != 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя просить милостыню в интерьере.");
    if(!GetPVarInt(playerid, "Milosti"))
    {
        if(IsPlayerInRangeOfPoint(playerid, 50.0, 1755.4108,-1893.7559,13.5567))
        {
            SendClientMessage(playerid, 0xDC4747FF, !"[Ошибка] {FFFFFF}На территории спавна, нельзя просить деньги!");
            return 1;
        }
        if(IsPlayerInAnyVehicle(playerid))
        {
            SendClientMessage(playerid, -1, !"Покиньте транспорт!");
            return 1;
        }
        if(User[playerid][pBeg][0] > gettime())
        {
            SendClientMessage(playerid, 0xAA3333FF, !"[Ошибка] {FFFFFF}Попрошайничать можно раз в 10 секунд!");
            return 1;
        }
    
    	SendClientMessage(playerid, COLOR_RED, "Вы начали просить милостыню");
    	SendClientMessage(playerid, -1, "Введите еще раз /alms чтобы закончить просить мылостыню");
    	SetPlayerChatBubble(playerid,"Просит милости",COLOR_GREEN,50.0,2000);
		//ApplyAnimation(playerid, "BEACH", "Parksit_M_loop", 4.1, 0, 0, 0, 1, 1, 1);
		//TogglePlayerControllable(playerid, 0);
		SetPVarInt(playerid, "Milosti", 1);
		
		new
		    tmpobjid,
            Float:pos_x,
            Float:pos_y,
            Float:pos_z,
            Float:angle;

        GetPlayerPos(playerid, pos_x, pos_y, pos_z);
        GetXYInFrontOfPlayer(playerid, pos_x, pos_y, 1.0);
        GetPlayerFacingAngle(playerid, angle);
        
        tmpobjid = CreateDynamicObject(2599, pos_x, pos_y, pos_z-0.6, 0.0, 0.0, angle, -1, -1, -1, 300.0, 300.0);
        SetDynamicObjectMaterial(tmpobjid, 0, 14603, !"bikeskool", !"motel_wall3", 0x00000000);//пока не придумал способ "борьбы" с background color in SetDynamicObjectMaterialText
        SetDynamicObjectMaterialText(tmpobjid, 0, !"Подайте\nбомжу на\nеду", 60, !"Calibri", 20, 0, -1, 0x00087978, 1);

        GetXYInFrontOfPlayer(playerid, pos_x, pos_y, 2.0);
        CreateDynamicObject(11744, pos_x, pos_y, pos_z-0.9, 0.0, 0.0, angle, -1, -1, -1, 300.0, 300.0);
        Streamer_Update(playerid);
        User[playerid][pBeg][0] = 10 + gettime();
        User[playerid][pBeg][1] = 1;
        User[playerid][pBeg][2] = tmpobjid;
        User[playerid][pBeg][4] = 0;

        TogglePlayerControllable(playerid, 0);
        ApplyAnimation(playerid, !"BEACH", !"ParkSit_W_loop", 4.1, 0, 1, 1, 1, 1);
  		/*almsobjid[0] = CreateDynamicObject(2599,Xw,Yw+0.9,Zw-0.5,0.000,0.000,0.000,-1,-1,-1,300.000,300.000);
		SetDynamicObjectMaterial(almsobjid[0], 0, 16322, "a51_stores", "des_ghotwood1", 0xFFFFFFFF);
		SetDynamicObjectMaterial(almsobjid[0], 1, 16322, "a51_stores", "des_ghotwood1", 0x00000000);
		almsobjid[1] = CreateDynamicObject(19477,Xw,Yw+0.9,Zw-1.0,0.000,15.000,270.000,-1,-1,-1,300.000,300.000);
		SetDynamicObjectMaterialText(almsobjid[1], 0, "ПОДАЙТЕ", 120, "Ariel", 25, 1, 0xFFFFFFFF, 0x00000000, 0);
		almsobjid[2] = CreateDynamicObject(19477,Xw,Yw+0.9,Zw-1.0,0.000,-15.000,270.000,-1,-1,-1,300.000,300.000);
		SetDynamicObjectMaterialText(almsobjid[2], 0, "НА ЕДУ", 120, "Ariel", 25, 1, 0xFFFFFFFF, 0x00000000, 0);*/
	}
	else
	{
	    TogglePlayerControllable(playerid, 1);

    	DestroyDynamicObject(User[playerid][pBeg][2]);
    	DestroyDynamicObject(User[playerid][pBeg][2]+1);

    	User[playerid][pBeg][1] = 0;
    	ApplyAnimation(playerid, !"CARRY", !"crry_prtial", 4.0, 0, 0, 0, 0, 0);
	    DeletePVar(playerid, "Milosti"), SCM(playerid, COLOR_RED, "Вы закончили просить милостыню");
		//TogglePlayerControllable(playerid, 1);
	}
	return 1;
}
CMD:wbook(playerid, params[])
{
    extract params -> new id_player; else
    return SendClientMessage(playerid, 0xccccccAA, "Используйте /wbook [id игрока]");
    if(!IsPlayerConnected(id_player)) return SendClientMessage(playerid, 0x999999AA, "Такого игрока нет");
    if(GetDistanceBetweenPlayers(playerid, id_player) > 3.0) return SCM(playerid, COLOR_GREY, "Игрок слишком далеко");
    //if(GetPlayerDistanceToPlayer(playerid, id_player) > 3.0 || GetPlayerVirtualWorld(playerid) != GetPlayerVirtualWorld(id_player)) return SendClientMessage(playerid, 0x999999AA, "Игрок слишком далеко");
    if(wbook_proposal[playerid] == true) return SendClientMessage(playerid, 0xffffffAA, "Используйте {ff9900}/cancel{ffffff} чтобы отозвать предыдущее предложение");
    new string_show_employment_history[(134) + (MAX_PLAYER_NAME * 4)],
        name_id_player[MAX_PLAYER_NAME],
        name_playerid[MAX_PLAYER_NAME];

    GetPlayerName(playerid, name_playerid, MAX_PLAYER_NAME);
    GetPlayerName(id_player, name_id_player, MAX_PLAYER_NAME);
    if(playerid == id_player)
    {
        new string_query_employment_history[265 + MAX_PLAYER_NAME];
        //format(string_show_employment_history, sizeof(string_show_employment_history), "%s просматривает свою трудовую книгу", name_playerid);
        //send_client_message_from_radius(playerid, string_show_employment_history);
        SetPlayerChatBubble(playerid,"просматривает свою трудовую книгу",COLOR_PURPLE,30.0,10000);
        mysql_format(dbHandle, string_query_employment_history, sizeof(string_query_employment_history), "SELECT * FROM `employment_history` WHERE `data_invite` < (NOW() - interval 15 day) AND `name_player` = '%e' AND `data_un_invite` IS NOT NULL AND `rang` IS NOT NULL AND `organization` <> 'no_organization' AND `organization_position` <> 'no_organization_position'", name_playerid);
        mysql_tquery(dbHandle, string_query_employment_history, "callback_employment_history", "ds", playerid, name_playerid);
        string_query_employment_history[0] = EOS;
        string_show_employment_history[0] = EOS;
        name_id_player[0] = EOS;
        name_playerid[0] = EOS;
        return 0;
    }
    format(string_show_employment_history, sizeof(string_show_employment_history), "Вы предложили %s посмотреть Вашу трудовую книгу", name_id_player);
    SendClientMessage(playerid, 0x3399ffAA, string_show_employment_history);
    string_show_employment_history[0] = EOS;
    format(string_show_employment_history, sizeof(string_show_employment_history), "%s хочет показать Вам свою трудовую книгу", name_playerid);
    SendClientMessage(id_player, 0x3399ffAA, string_show_employment_history);
    SendClientMessage(id_player, 0xffffffAA, "Нажмите {00cc00}Y{ffffff} для просмотра или {ff6600}N{ffffff} для отказа");
    playerid_wbook = playerid;
    id_player_wbook = id_player;
    wbook_proposal[playerid] = true;
    wbook_proposal[id_player] = true;
    string_show_employment_history[0] = EOS;
    name_id_player[0] = EOS;
    name_playerid[0] = EOS;
    return 1;
}
CMD:number(playerid, params[])
{
    if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /number [id]");
    else if(!IsPlayerConnected(params[0]) || User[params[0]][pLogin] == 0) return 1; //SendClientMessage(playerid, COLOR_GREY, "Игрок не найден");
	//if(!IsPlayerConnected(params[0])) return true;
	format(YCMDstr, 256, "Владелец: %s. Телефон: %i",User[params[0]][pName],User[params[0]][pPnumber]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	return true;
}
