		}
	}
	return true;
}
CMD:call(playerid, params[])
{
    if(sscanf(params, "d",params[0]))
	{
		format(YCMDstr, sizeof(YCMDstr), "%s достает телефон",User[playerid][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
		SetPlayerSpecialAction(playerid,SPECIAL_ACTION_USECELLPHONE);
		ShowPlayerDialogEx(playerid, 9956, DIALOG_STYLE_LIST, "Выберите сервис", "[1] Полиция \n[2] Скорая помощь \n[3] Таксопарк\n[4] Автомастерская", "Выбор", "Отмена");
		return true;
	}
	if(Mobile[playerid] != 999) return SendClientMessage(playerid, COLOR_GREY, "Вы уже разговариваете по телефону ");
	format(YCMDstr, sizeof(YCMDstr), "%s достает телефон",User[playerid][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	GetPlayerPos(playerid,CallInfo[playerid][callx],CallInfo[playerid][cally],CallInfo[playerid][callz]);
	CallInfo[playerid][callused] = 1;
	if(params[0] == User[playerid][pPnumber])
	{
		SendClientMessage(playerid, COLOR_GRAD2, "Линия занята");
		SetPlayerSpecialAction(playerid,13);
		return true;
	}
	if(params[0] == 11888)
	{
		if(smsls == 0) return SendClientMessage(playerid, COLOR_GREY, "Прямой эфир отключен.");
		if(User[playerid][pBank] < smspricels) return SendClientMessage(playerid, COLOR_GREY, "На Вашем банковском счету недостаточно денег!");
		format(YCMDstr, sizeof(YCMDstr), "В студию звонит: %s. Введите /yes [%i], чтобы ответить",User[playerid][pName], playerid);
		SendFamilyMessage(16, COLOR_YELLOW, YCMDstr);
		SetPlayerSpecialAction(playerid,11);
		zvonok[playerid] = 1;
		User[playerid][pMobile] += smspricels;
		FracBank[0][fLsnews] += smspricels;
		return true;
	}
	if(params[0] == 11555)
	{
		if(smssf == 0) return SendClientMessage(playerid, COLOR_GREY, "Прямой эфир отключен.");
		if(User[playerid][pBank] < smspricels) return SendClientMessage(playerid, COLOR_GREY, "На Вашем банковском счету недостаточно денег!");
		format(YCMDstr, sizeof(YCMDstr), "В студию звонит: %s. Введите /yes [%i], чтобы ответить",User[playerid][pName], playerid);
		SendFamilyMessage(9, COLOR_YELLOW, YCMDstr);
		SetPlayerSpecialAction(playerid,11);
		User[playerid][pMobile] += smspricels;
		FracBank[0][fSfnews] += smspricels;
		zvonok[playerid] = 1;
		return true;
	}
	if(params[0] == 11333)
	{
		if(smslv == 0) return SendClientMessage(playerid, COLOR_GREY, "Прямой эфир отключен.");
		if(User[playerid][pBank] < smspricels) return SendClientMessage(playerid, COLOR_GREY, "На Вашем банковском счету недостаточно денег!");
		format(YCMDstr, sizeof(YCMDstr), "В студию звонит: %s. Введите /yes [%i], чтобы ответить",User[playerid][pName], playerid);
		SendFamilyMessage(20, COLOR_YELLOW, YCMDstr);
		SetPlayerSpecialAction(playerid,11);
		User[playerid][pMobile] += smspricels;
		FracBank[0][fLvnews] += smspricels;
		zvonok[playerid] = 1;
		return true;
	}
	foreach(new i : Player)
	{
		if(User[i][pPnumber] == params[0] && params[0] != 0)
		{
			Mobile[playerid] = i;
			if(!IsPlayerConnected(i)) return true;
			if(PhoneOnline[Mobile[playerid]] > 0) return SendClientMessage(playerid, COLOR_GREY, "Телефон абонента выключен.");
			if(Mobile[Mobile[playerid]] == 999)
			{
				format(YCMDstr, sizeof(YCMDstr), "Ваш мобильник звонит. Введите (/P)ickup. Звонит: %s",User[playerid][pName]);
				SendClientMessage(Mobile[playerid], COLOR_WHITE, YCMDstr);
				PlayerPlaySound(Mobile[playerid], 20600, 0.0, 0.0, 0.0);
				format(YCMDstr, sizeof(YCMDstr), "У %s звонит мобильник",User[i][pName]);
				SendBeside(i,COLOR_PURPLE,YCMDstr,30.0);
				SetPlayerSpecialAction(playerid,11);
				CellTime[playerid] = 1;
				return true;
			}
		}
		//else return SendClientMessage(playerid, COLOR_GREY, "Номер не найден. Звонок не удался");
	}
	if(Mobile[playerid] == -1)
	{
		SendClientMessage(playerid, COLOR_GREY, "Телефон вне зоны доступа сети");
		SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
		return true;
	}
	return true;
}
CMD:pickup(playerid, params[])
{
    if(Mobile[playerid] != 999) return SendClientMessage(playerid, COLOR_GREY, "Вы уже разговариваете");
	foreach(new i : Player)
	{
		if(IsPlayerConnected(i))
		{
			if(Mobile[i] == playerid)
			{
				Mobile[playerid] = i;
				SendClientMessage(i, COLOR_GRAD2, "Поднял(а) трубку телефона.");
				SetPlayerSpecialAction(playerid,SPECIAL_ACTION_USECELLPHONE);
				format(YCMDstr, sizeof(YCMDstr), "%s ответил на звонок", User[playerid][pName]);
				SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
				PlayerPlaySound(playerid, 1069, 0.0, 0.0, 0.0);
				GetPlayerPos(playerid,CallInfo[playerid][callx],CallInfo[playerid][cally],CallInfo[playerid][callz]);
				CallInfo[playerid][callused] = 1;
			}
		}
	}
	return true;
}
CMD:hangup(playerid, params[])
{
	if(IsPlayerConnected(Mobile[playerid]))
	{
		if(Mobile[playerid] != 999)
		{
			SendClientMessage(Mobile[playerid], COLOR_GRAD2, "Абонент положил(a) трубку");
			SetPlayerSpecialAction(Mobile[playerid],SPECIAL_ACTION_STOPUSECELLPHONE);
			CellTime[Mobile[playerid]] = 0;
			CellTime[playerid] = 0;
			Mobile[Mobile[playerid]] = 999;
			SendClientMessage(playerid, COLOR_GRAD2, "Вы повесили трубку");
			SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
		}
		Mobile[playerid] = 999;
		//Mobile[Mobile[playerid]] = 999;
		CellTime[playerid] = 0;
		return true;
	}
	SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
	TalkingLive[playerid] = 255;
	TalkingLivels[playerid] = 255;
	TalkingLivelv[playerid] = 255;
	zvonok[playerid] = 0;
	Tel[playerid] = 255;
	return true;
}
CMD:advertise(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/ad)vertise [текст]");
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	//if(User[playerid][pLevel] < 3) return SendClientMessage(playerid, COLOR_GREY, "Подать обьявление можно с 3 левела");
	if(AdvertTime > gettime()) return SendClientMessage(playerid, COLOR_GREY, "Посылать объявление можно раз в 30 секунд!");
	if(gNews[playerid] == true && lNews[playerid] == true && LvNews[playerid] == true) return SendClientMessage(playerid, COLOR_GREY, "Сначало включите радио");
	strmid (ReportQ[playerid],params[0], 0, strlen(params[0]), 128);
	if(lNews[playerid] == false)
	{
		format(YCMDstr,sizeof(YCMDstr),"{B8B8B8}Вы собираетесь отправить объявление:\n               {00FF5E}%s\n\n{B8B8B8}Стоимость:{00FF5E} %i вирт\n\n\n{56839C}Объявление будет подано после проверки!\nСпасибо что воспользовались услугами "NameServer"",params[0],strlen(params[0])*addd[0]);
		ShowPlayerDialogEx(playerid,8454,DIALOG_STYLE_MSGBOX,"{FFFFFF}Проверка",YCMDstr,"Отправить","Отмена");
	}
	else if(gNews[playerid] == false)
	{
		format(YCMDstr,sizeof(YCMDstr),"{B8B8B8}Вы собираетесь отправить объявление:\n               {00FF5E}%s\n\n{B8B8B8}Стоимость:{00FF5E} %i вирт\n\n\n{56839C}Объявление будет подано после проверки!\nСпасибо что воспользовались услугами "NameServer"",params[0],strlen(params[0])*addd[1]);
		ShowPlayerDialogEx(playerid,8455,DIALOG_STYLE_MSGBOX,"{FFFFFF}Проверка",YCMDstr,"Отправить","Отмена");
	}
	else if(LvNews[playerid] == false)
	{
		format(YCMDstr,sizeof(YCMDstr),"{B8B8B8}Вы собираетесь отправить объявление:\n               {00FF5E}%s\n\n{B8B8B8}Стоимость:{00FF5E} %i вирт\n\n\n{56839C}Объявление будет подано после проверки!\nСпасибо что воспользовались услугами "NameServer"",params[0],strlen(params[0])*addd[2]);
		ShowPlayerDialogEx(playerid,8456,DIALOG_STYLE_MSGBOX,"{FFFFFF}Проверка",YCMDstr,"Отправить","Отмена");
	}
	return true;
}
CMD:time(playerid)
{
    if(!IsPlayerConnected(playerid)) return true;
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) ApplyAnimation(playerid, "COP_AMBIENT", "Coplook_watch",4.1,0,0,0,0,0);
	SetPlayerChatBubble (playerid, "взглянул на часы", COLOR_PURPLE, 30.0, 10000);
	new mtext[20];
	new year, month,day;
	getdate(year, month, day);
	if(month == 1) { mtext = "January"; }
	else if(month == 2) { mtext = "February"; }
	else if(month == 3) { mtext = "March"; }
	else if(month == 4) { mtext = "April"; }
	else if(month == 5) { mtext = "May"; }
	else if(month == 6) { mtext = "June"; }
	else if(month == 7) { mtext = "July"; }
	else if(month == 8) { mtext = "August"; }
	else if(month == 9) { mtext = "September"; }
	else if(month == 10) { mtext = "October"; }
	else if(month == 11) { mtext = "November"; }
	else if(month == 12) { mtext = "December"; }
	new hour,minuite,second;
	gettime(hour,minuite,second);
	FixHour(hour);
	hour = shifthour;
	if(User[playerid][pJailTime] > 0) format(YCMDstr, sizeof(YCMDstr), "~y~%02i %s~n~~g~~w~%02i:%02i~n~~w~Jail Time Left: %i sec~n~~g~Server "NumberServer"", day, mtext, hour, minuite, User[playerid][pJailTime]);
	else format(YCMDstr, sizeof(YCMDstr), "~y~%02i %s~n~~g~~w~%02i:%02i~n~~g~Server "NumberServer"", day, mtext, hour, minuite);
	GameTextForPlayer(playerid, YCMDstr, 5000, 1);
	return true;
}
CMD:house(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /house [housenumber]");
	t_SetPlayerPos(playerid,HouseInfo[params[0]][hEntrancex],HouseInfo[params[0]][hEntrancey],HouseInfo[params[0]][hEntrancez]);
	GameTextForPlayer(playerid, "~w~HOUSE", 5000, 1);
	return true;
}
CMD:chat(playerid, params[])
{
	if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(!BigEar[playerid]) BigEar[playerid] = 1, SendClientMessage(playerid, COLOR_GRAD2, "Слушать чат ON");
	else if(BigEar[playerid]) BigEar[playerid] = 0, SendClientMessage(playerid, COLOR_GRAD2, "Слушать чат OFF");
	return true;
}
CMD:recon(playerid, params[])
{
	if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return 1;
	if(!strcmp(params,"OFF",true) && Spectate[playerid]) return StopSpectate(playerid);
	if(!Spectate[playerid] && !strcmp(params,"OFF",true)) return SendClientMessage(playerid, COLOR_GREY, "Вы не в режиме наблюдения!");
	if(sscanf(params, "u",params[0]))
	{
	    if(SpecAd[playerid] != INVALID_PLAYER_ID) SpecID[SpecAd[playerid]] = 65535;
    	SpecAd[playerid] = 65535;
		if(!Spectate[playerid])
		{
			GetPlayerPos(playerid,SpecPlayer[playerid][0],SpecPlayer[playerid][1],SpecPlayer[playerid][2]);
			SpecPlayerInt[playerid] = GetPlayerInterior(playerid);
			SpecPlayerWorld[playerid] = GetPlayerVirtualWorld(playerid);
			GetPlayerFacingAngle(playerid, SpecPlayerAngle[playerid]);
		}
		ReconSelect[playerid] = 7;
		ReconSelectSub[playerid] = INVALID_TEXT_DRAW;

		for(new i = 7; i < 35; i++)
		DisableEnableReconButton(playerid, i, 0, 0);

		for(new i = 0; i < 16; i++)
		PlayerTextDrawShow(playerid, ReconPlayer[i]);

		DisableEnableReconButton(playerid, ReconSelect[playerid], 1);

		Spectate[playerid] = 1;
		TogglePlayerSpectating(playerid, 1);
		return 1;
	}
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок оффлайн / не авторизован");
	if(User[params[0]][pAdmin] != 0 && User[playerid][pAdmin] < 8) return SendClientMessage(playerid, COLOR_GREY, "Наблюдение за администрацией запрещено!");
	//if(Spectate[playerid]) return SendClientMessage(playerid, COLOR_GREY, "Вы уже наблюдете!");
	if(SpecID[params[0]] != 65535) return SendClientMessage(playerid, COLOR_GREY, "Этот игрок уже под наблюдением");
	if(!Spectate[playerid])
	{
		GetPlayerPos(playerid,SpecPlayer[playerid][0],SpecPlayer[playerid][1],SpecPlayer[playerid][2]);
		SpecPlayerInt[playerid] = GetPlayerInterior(playerid);
		SpecPlayerWorld[playerid] = GetPlayerVirtualWorld(playerid);
		GetPlayerFacingAngle(playerid, SpecPlayerAngle[playerid]);
	}
	if(SpecAd[playerid] != INVALID_PLAYER_ID) SpecID[SpecAd[playerid]] = 65535;
	SpecAd[playerid] = 65535;
	SpecAd[playerid] = params[0];
	SpecID[params[0]] = playerid;
	//ShowMenuForPlayer(Admin,playerid);
	//PlayerTextDrawShow(playerid, NikPlayer);
	ReconSelect[playerid] = 7;
	ReconSelectSub[playerid] = INVALID_TEXT_DRAW;

	for(new i = 7; i < 35; i++)
		DisableEnableReconButton(playerid, i, 0, 0);

	for(new i = 0; i < 16; i++)
		PlayerTextDrawShow(playerid, ReconPlayer[i]);

	DisableEnableReconButton(playerid, ReconSelect[playerid], 1);
	Spectate[playerid] = 1;
	SetTimerEx("SpecPlayers", 100, false, "i", playerid);
	return 1;
}

CMD:sc(playerid, params[])
{
	if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_GREY, "Вы не авторизованы!");
    if((User[playerid][pHelper] == 0 || !GetPVarInt(playerid, "SDuty") || User[playerid][pHelper] == 2) && (User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup"))) return SendClientMessage(playerid, COLOR_GREY, "Вам недоступна эта команда");
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /sc [текст]");
	format(YCMDstr, sizeof(YCMDstr), "<SUPPORTS-CHAT> %s[%i]: %s",User[playerid][pName],playerid,params[0]);
	HelperMessage(0xF4B800AA,YCMDstr);
	return true;
}
CMD:admin(playerid, params[])
{
	if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_GREY, "Вы не авторизированы");
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/a)dmin [текст]");
	new string[156];
	f(string, "<ADM-CHAT> %s[%d]: %s", User[playerid][pName], playerid, params[0]);
	ABroadCast(COLOR_YELLOW,string,1);
	return true;
}
CMD:jail(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /jail [id] [минуты], /jail [id] 0 - вытащить из тюрьмы");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[1] == 0)
	{
		SCM(playerid, -1, "Вы выпустили игрока из тюрьмы!");
	    SetPlayerInterior(params[0], 0);
		t_SetPlayerPos(params[0],1553.4962,-1675.2714,16.1953);
		SetPlayerFacingAngle(params[0], 95.0636);
		User[params[0]][pJailTime] = 0;
		User[params[0]][pMestoJail] = 0;
		User[params[0]][pWantedLevel] = 0;
		SetPlayerWantedLevel(params[0], 0);
		SetPlayerVirtualWorld(params[0], 0);
	 	GameTextForPlayer(params[0], "~g~Freedom", 5000, 1);
	 	return true;
	}
	ResetPlayerWeaponsEx(params[0]);
	t_SetPlayerPos(params[0],2416.1682,2488.2820,1563.6757);
	SetPlayerFacingAngle(params[0], 89.8888);
	User[params[0]][pMestoJail] = 1;
	User[params[0]][pJailTime] = params[1]*60;
	format(YCMDstr, sizeof(YCMDstr), "[A] %s посадил в тюрьму %s на %d минут",User[playerid][pName],Name(params[0]),params[1]);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	format(YCMDstr, sizeof(YCMDstr), "Вы были посажены в тюрьму администратором "NameServer" на %i минут(ы)",params[1]);
	SendClientMessage(params[0], COLOR_LIGHTRED, YCMDstr);
	return true;
}
CMD:prison(playerid, params[])
{
	if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "dds[100]",params[0],params[1],params[2])) return SCM(playerid, COLOR_GREY, "Используйте: /prison [id] [минуты] [причина], /unjail [id] - вытащить из тюрьмы");
    if(!IsPlayerConnected(params[0])) return true;
	ResetPlayerWeaponsEx(params[0]);
	SetPlayerVirtualWorld(params[0],1);
	SetPlayerInterior(params[0], 0);
	t_SetPlayerPos(params[0],5512.2275,1248.5988,8.8505);
	SetPlayerFacingAngle(params[0], 179.7971);
	User[params[0]][pMestoJail] = 4;
	User[params[0]][pJailTime] = params[1]*60;
	GameTextForPlayer(params[0], "~w~YOU IN ~R~PRISON", 5000, 4);
	QUERY="";
	format(QUERY, 144, "[A] %s[%d] посадил в ДеМорган игрока %s[%d] на %d минут. Причина: %s",User[playerid][pName],playerid, User[params[0]][pName],params[0],params[1],params[2]);
	ABroadCast(COLOR_LIGHTRED, QUERY,1);
	format(QUERY, 144, "Вы помещены в форт ДеМорган администратором %s на %d минут. Причина: %s.",User[playerid][pName], params[1],params[2]);
	SendClientMessage(params[0], COLOR_LIGHTRED, QUERY);
	format(QUERY,sizeof(QUERY), "{"#cGREEN"}\tВы посажены в форт ДеМорган!\nПосадил: "WHITE"%s\n{"#cGREEN"}Посажен:"WHITE" %s\n{"#cGREEN"}На "WHITE"%d{"#cGREEN"} минут(-ы).\nПричина:"WHITE" %s",User[playerid][pName],User[params[0]][pName],params[1],params[2]);
	ShowPlayerDialogEx(params[0], 0, DIALOG_STYLE_MSGBOX, "{FFFFFF}Информационное окно", QUERY, "Закрыть","");
	return 1;
}
CMD:settime(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /settime [час] (0-23)");
	SetWorldTime(params[0]);
	format(YCMDstr, sizeof(YCMDstr), "Время установлено на %i часов.",params[0]);
	SendClientMessageToAll(COLOR_WHITE, YCMDstr);
	return true;
}
CMD:family(playerid, params[])
{
    if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
    ShowPlayerDialogEx(playerid,dFamily,DIALOG_STYLE_LIST,"{F1C33A}Меню семьи","{FFFFFF}1. Информация о семье\n2. Меню общака\n3. Члены семьи онлайн\n4. Общий список членов семьи\n5. Управление семьёй\n{FF0000}Покинуть семью","Выбрать","Закрыть");
    return true;
}
ALTX:fam("/fc", "/fchat");
CMD:fam(playerid, params[])
{
    if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
	else if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	else if(isnull(params)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /fam [текст]");
	new mesid[128];
	format(mesid, sizeof(mesid), "{%s}%s %s: %s", family_chat_color[FamilyInfo[User[playerid][pFamilyMember]][famChatColor]], family_rank [ User[playerid][pFamilyMember] ] [ User[playerid][pFamilyRank] - 1 ], Name(playerid), params[0]);
	SendFAMMes(User[playerid][pFamilyMember], -1, mesid);
    return true;
}
CMD:frank ( playerid, params [] )
{
	if ( User[playerid][pFamilyRank] <  5 )return 1 ;
	if ( sscanf ( params, "u", params [ 0 ] ) )return SendClientMessage ( playerid, COLOR_GREY,"Используйте: /frank [ид/имя]" ) ;
	if ( ! IsPlayerConnected ( params [ 0 ] )  || params [ 0 ] == playerid ) return SendClientMessage ( playerid, COLOR_GREY, "Игрок не найден." ) ;
	if ( User [ params [ 0 ] ] [ pFamilyMember ] != User [ playerid ] [ pFamilyMember ] ) return SendClientMessage ( playerid, COLOR_GREY, "Игрок не состоит в Вашей семье." ) ;
    //if(!istext(User[ params [ 0 ]][pName], FamilyInfo[User[params [ 0 ]][pFamilyMember]][famLeader])) return SendClientMessage(playerid,COLOR_GREY,"Это владелец семьи!");
    //if(params[1] >= User[playerid][pRank]) return SCM(playerid, COLOR_GREY, "Вы не можете повысить до ранга, выше вашего/до вашего ранга!");
    if(User[playerid][pFamilyRank] < User[params[0]][pFamilyRank]) return SCM(playerid, COLOR_GREY, "Вы не можете повысить/понизить старшего по рангу!");

	QUERY [ 0 ] = EOS ;
	for ( new i = 0; i < 5 ; i ++ )
	{
		new line_string [ 72 ] ;
		format ( line_string, 72, "{"#cGR"}%i. {"#cWH"}%s\n", i + 1, family_rank [ User [ playerid ] [ pFamilyMember ] ] [ i ] ) ;
		strcat ( QUERY, line_string ) ;
	}
	ShowPlayerDialogEx ( playerid, d_family_rank, DIALOG_STYLE_LIST, "{"#cBL"}Семейный статус", QUERY, "Выбрать", "Назад" ) ;

	SetPVarInt ( playerid, "pl_setrank_id", params [ 0 ] ) ;
	return 1 ;
}
CMD:finvite(playerid, params[])
{
	if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
	if(!istext(User[playerid][pName],FamilyInfo[User[playerid][pFamilyMember]][famLeader])) return SendClientMessage(playerid,COLOR_GREY,"Доступно только владельцу семьи!");
	new targetid;
	if(sscanf(params, "d", targetid)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /finvite [id игрока]");
	else if(targetid == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок не в онлайне");
	else if(!User[targetid][pLogin]) return SendClientMessage(playerid, COLOR_GREY, "Игрок не авторизован");
	else if(User[targetid][pFamilyMember] > 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок уже находится в семье!");
	else if(IsPlayerInAnyVehicle(targetid)) return SendClientMessage(playerid, COLOR_GREY, "Игрок не должен находиться в транспорте!");
	//else if(!IsPlayerStream(8.0, playerid, targetid, 1)) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
	else if(GetDistanceBetweenPlayers(playerid, targetid) > 5.0) return SCM(playerid, COLOR_GREY, "Вы слишком далеко!");

	new string[256];
	format(string,sizeof(string),"{DCD45C}%s {FFFFFF}предлагает вам присоединиться к семье {DCD45C}\"%s\"\n\n{FFFFFF}Вы согласны?",Name(playerid),FamilyInfo[User[playerid][pFamilyMember]][famName]);
	ShowPlayerDialogEx(targetid, dInviteFamily, 0, "{F1C33A}Вступление в семью",string,"Да","Нет");
	SCMF(playerid,0xDCD45CFF,"Вы предложили %s присоединиться к Вашей семье",Name(targetid));

	SetPVarInt(targetid, "familyid", User[playerid][pFamilyMember]);
	SetPVarInt(targetid, "familyidwhoinvite", playerid);
	return 1;
}

