		{
		    ShowPlayerDialogEx(playerid, D_ITEMS_BUY_PLAYER, DIALOG_STYLE_LIST, ""COLOR_LOGO"Магазин аксесуаров", "[1] Кепки\n[2] Шапки\n[3] Банданы\n[4] Очки", "Купить", "Закрыть");
