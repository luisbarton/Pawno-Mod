	FarmInfo[i][fProds], FarmInfo[i][fProds_Price], FarmInfo[i][fDeputy_1], FarmInfo[i][fDeputy_2], FarmInfo[i][fDeputy_3], FarmInfo[i][fFarmer_1], FarmInfo[i][fFarmer_2], FarmInfo[i][fFarmer_3],
	FarmInfo[i][fFarmer_4], FarmInfo[i][fFarmer_5], FarmInfo[i][fAuctions], FarmInfo[i][fAuctionName], FarmInfo[i][fID]);
