CMD:question(playerid,params[])
{
	if(sscanf(params, "s[80]",params[0])) return SendClientMessage(playerid, -1, "Введите: /question [текст]");
	new str[121];
    format(str, sizeof(str), "-> Вопрос %s[%d]: %s", User[playerid][pName], playerid, params[0]);
    SendClientMessage(playerid, COLOR_YELLOW, str);
    HelperMessage(0xD97700AA, str);
	return true;
}
CMD:dropmoney(playerid,params[])
{
	if(sscanf(params, "dd",params[0], params[1])) return SendClientMessage(playerid, -1, "Введите: /dropmoney [тип] [сумма]");
	if(params[1] > 9999999 || params[1] < 1) return SendClientMessage(playerid, COLOR_RED, "Неверная сумма");
	switch(params[0])
	{
		case 0:
		{
			if(params[1] > User[playerid][pCash]) return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно денег");
			User[playerid][pCash] -= params[1];
			LogingTargetMoney(playerid, playerid, params[1], "Уничтожил деньги наличка(/drop)");
		}
		case 1:
		{
			if(params[1] > User[playerid][pBank]) return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно денег");
			User[playerid][pBank] -= params[1];
			LogingTargetMoney(playerid, playerid, params[1], "Уничтожил деньги банк(/drop)");
		}
		default: return SendClientMessage(playerid, COLOR_GREY, "Укажите правильный тип. 0 - кошелек. 1 - банк");
	}
	new strdropmoney[31];
	format(strdropmoney, sizeof(strdropmoney), "Вы уничтожили %d вирт", params[1]);
	SendClientMessage(playerid, -1, strdropmoney);
	return true;
}
CMD:stats(playerid, params[])
{
	ShowStats(playerid, playerid);
	return true;
}
CMD:report(playerid, params[])
{
	if(sscanf(params, "us[60]",params[0],params[1])) return SendClientMessage(playerid, -1, "Введите: /report [playerid] [текст]");
	else if(!IsPlayerConnected(params[0]) || User[params[0]][pLogin] == 0) return 1;//SendClientMessage(playerid, COLOR_GREY, "Игрок не найден");
	else if(GetPVarInt(playerid, "AntiReport") != 0) return SCM(playerid,COLOR_GREY,"Писать в репорт можно раз в 1 минуту");
	else if(User[playerid][pMutedr] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан репорта!"); return true; }
	//new string[110];
	format(YCMDstr, sizeof(YCMDstr), "-> Жалоба на %s[%d]: %s",User[params[0]][pName],params[0],params[1]);
	SendClientMessage(playerid, COLOR_YELLOW, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "{E75D5D}Жалоба от %s[%d] на %s[%d]: {FFFFFF}%s", User[playerid][pName], playerid, User[params[0]][pName], params[0], params[1]);
	SendAdminMessage(-1, YCMDstr);
	SetPVarInt(playerid,"AntiReport",60);
	return true;
}
