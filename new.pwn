	//}
	return 1;
}
forward OnCheatDetected(playerid, ip_address[], type, code);
public OnCheatDetected(playerid, ip_address[], type, code)
{
    if(User[playerid][pAdmin] > 0) return EnableAntiCheatForPlayer(playerid, code, 0);
    if(GetPVarInt(playerid,"KickCheat") == 1) return true;
    new ACName[53][] = {
	"AirBreak (onfoot) [#000]","AirBreak (in vehicle) [#001]","AirBreak/Teleport [#002]","Teleport hack (in vehicle) [#003]","Teleport hack (into/between vehicles) [#004]",
	"Teleport hack (vehicle to player) [#005]","Teleport hack (pickups) [#006]","FlyHack [#007]","FlyHack (in vehicle) [#008]","SpeedHack (onfoot) [#009]",
	"SpeedHack (in vehicle) [#010]","Repair Car [#011]","Health hack [#012]","Armour hack [#013]","Money hack [#014]","Weapon hack [#015]",
	"Ammo Hack [#016]","Ammo Hack [#017]","Special actions hack [#018]","GodMode [#019]","GodMode [#020]",
	"Invisible hack [#021]","lagcomp-spoof [#022]","Tuning hack [#023]","Parkour mod [#024]","Quick turn [#025]","Rapid fire [#026]",
	"FakeSpawn [#027]","FakeKill [#028]","Pro Aim [#029]","CJ run [#030]","CarShot [#031]","CarJack [#032]","UnFreeze [#033]",
	"AFK Ghost [#034]","Full Aiming [#035]","Fake NPC [#036]","Reconnect [#037]","High ping [#038]","Dialog hack [#039]","Protection from the sandbox [#040]",
	"Protection against an invalid version [#041]","Rcon hack [#042]","Tuning crasher [#043]","Invalid seat crasher [#044]","Dialog crasher [#045]",
	"Attached object crasher [#046]","Weapon Crasher [#047]","Flood protection connects to one slot [#048]","flood callback functions [#049]",
	"flood change seat [#050]","Ddos [#051]","NOP's [#052]" };
	switch(code)
	{
		case 22,26,28,43,45,46,49: // Варнинг
		{
		    if(GetPVarInt(playerid, "AntiCheat") > gettime()) return true;
			format(YCMDstr, sizeof(YCMDstr), " <Warning> %s[%d]: Возможно %s",Name(playerid),playerid,ACName[code]);
			SendAdminMessage(COLOR_REDD, YCMDstr);
		    SetPVarInt(playerid, "AntiCheat", gettime()+10);
		    return true;
		}
		case 8: SendWarningCheatMessageToAdmin(playerid,"Fly Hack - В машине");
		case 9: SendWarningCheatMessageToAdmin(playerid,"Speed Hack - Пешком");
		case 10: SendWarningCheatMessageToAdmin(playerid,"Speed Hack - В машине");
		case 31: SendWarningCheatMessageToAdmin(playerid,"Car Shot");
		case 32:
  		{
    		new Float:x, Float:y, Float:z;
      		AntiCheatGetPos(playerid, x, y, z);
        	SetPlayerPos(playerid, x, y, z);
         	return 1;
    	}
		case 1,2,3,4,7,18,21,23,24,25,27,29,30,33,34,35,40,42,44,47: // Кик
		{
			SCMF(playerid, COLOR_LIGHTRED,"Вы были кикнуты по подозрению в читерстве. Причина: %s.",ACName[code]);
			//
  			KickEx(playerid, ACName[code]);
  			SetPVarInt(playerid, "KickCheat", 1);
  			return true;
		}
		default: return true;
	}
	return true;
}
publics: CheckDGgun(playerid, weaponid, slot)
{
	new weapons[2], string_[128];
	GetPlayerWeaponData(playerid, slot, weapons[0], weapons[1]);
	if (GetPlayerWeapon(playerid) == weapons[0] && !weapons[1])
	{
		printf("Dgun: %s[%d] Slotid: %d OldWeapon: %d NewWeapon: %d NewAmmo: %d", User[playerid][pName], playerid, slot, weaponid, weapons[0], weapons[1]);
		format(string_, sizeof string_, "<Warning> %s[%d]: Возможно D_GUN(CheckDGgun)", User[playerid][pName], playerid);
		ABroadCast(COLOR_REDD,string_, 9);
		KickEx(playerid, "CheckDGgun");
	}
}
kLibUpdatePlayerWeapons(playerid)
{
	for (new i = 0; i <= 12; i++)
	{
		User[playerid][kLibWeapon][kLibWeaponid][i] = User[playerid][ac_Weapon][i];
		User[playerid][kLibWeapon][kLibAmmo][i] = User[playerid][ac_Ammo][i];
	}
	new query_[256];
	format(query_,sizeof(query_),"UPDATE `accounts` SET `pWeapons` = '%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d', `pAmmos` = '%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d' WHERE `Name` = '%s'",
	User[playerid][kLibWeapon][kLibWeaponid][0], User[playerid][kLibWeapon][kLibWeaponid][1], User[playerid][kLibWeapon][kLibWeaponid][2], User[playerid][kLibWeapon][kLibWeaponid][3],
	User[playerid][kLibWeapon][kLibWeaponid][4], User[playerid][kLibWeapon][kLibWeaponid][5], User[playerid][kLibWeapon][kLibWeaponid][6], User[playerid][kLibWeapon][kLibWeaponid][7],
	User[playerid][kLibWeapon][kLibWeaponid][8], User[playerid][kLibWeapon][kLibWeaponid][9], User[playerid][kLibWeapon][kLibWeaponid][10], User[playerid][kLibWeapon][kLibWeaponid][11],
	User[playerid][kLibWeapon][kLibWeaponid][12],
	User[playerid][kLibWeapon][kLibAmmo][0], User[playerid][kLibWeapon][kLibAmmo][1],User[playerid][kLibWeapon][kLibAmmo][2], User[playerid][kLibWeapon][kLibAmmo][3],
	User[playerid][kLibWeapon][kLibAmmo][4], User[playerid][kLibWeapon][kLibAmmo][5],User[playerid][kLibWeapon][kLibAmmo][6], User[playerid][kLibWeapon][kLibAmmo][7],
	User[playerid][kLibWeapon][kLibAmmo][8], User[playerid][kLibWeapon][kLibAmmo][9],User[playerid][kLibWeapon][kLibAmmo][10], User[playerid][kLibWeapon][kLibAmmo][11],
	User[playerid][kLibWeapon][kLibAmmo][12], User[playerid][pName]);
	mysql_tquery(dbHandle, query_, "", "");
}
stock LogingTargetMoney(playerid, targetid, amount, reason[])
{
	new l_query[512], ip[16], tip[16];
	GetPlayerIp(playerid, ip,sizeof(ip));
	GetPlayerIp(playerid, tip, sizeof tip);
	format(l_query, sizeof l_query, "INSERT INTO `log_money` (`aID`, `aName`, `aCash`, `aBank`, `aIP`, `Amount`, `tID`, `tName`, `tCash`, `tBank`, `tIP`, `Reason`, `Date`) VALUES ('%d', '%s', '%d', '%d', '%s', '%d', '%d', '%s', '%d', '%d', '%s', '%s', NOW())",
	PlayerIDs[playerid], User[playerid][pName], User[playerid][pCash], User[playerid][pBank], ip, amount, PlayerIDs[targetid], User[targetid][pName], User[targetid][pCash], User[targetid][pBank], tip, reason);
	return mysql_tquery(dbHandle, l_query, "", "");
}
