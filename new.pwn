	if(CarInfo[c][carVehcom_6][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_6][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_6][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_7][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_7][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_7][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_8][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_8][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_8][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_9][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_9][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_9][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_10][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_10][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_10][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_11][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_11][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_11][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_12][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_12][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_12][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_13][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_13][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_13][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_14][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_14][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_14][GetPVarInt(c,"SelectCar")] = 0;
