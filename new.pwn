stock SendFamilyMessage(family, color, text[])
{
    foreach(new i : Player)
	{
        if(GetPVarInt(i,"Fraction_Duty"))
        {
            if(GetPVarInt(i,"chats") != 1)
            {
                if(User[i][pMember] == family || GetPVarInt(i,"Atisper") == family || GetPVarInt(i, "TipsterFracOn") == family && GetPVarInt(i, "TipsterListen") == 1)
                {
                    SendClientMessage(i, color, text);
                }
            }
        }
        else if(GetPVarInt(i,"Atisper") == family)
        {
            SendClientMessage(i, color, text);
        }
    }
}
