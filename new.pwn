CMD:funinvite(playerid, params[])
{
    if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
	if(!istext(User[playerid][pName],FamilyInfo[User[playerid][pFamilyMember]][famLeader])) return SendClientMessage(playerid,COLOR_GREY,"Доступно только владельцу семьи!");
	new targetid, reason[32];
	if(sscanf(params, "ds[32]", targetid, reason)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /funinvite [id игрока] [причина]");
	else if(targetid == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок не в онлайне");
	else if(!User[targetid][pLogin]) return SendClientMessage(playerid, COLOR_GREY, "Игрок не авторизован");
	else if(User[targetid][pFamilyMember] != User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Игрок не состоит в Вашей семье!");
	else if(playerid == targetid) return SendClientMessage(playerid, COLOR_GREY, "Самого себя нельзя выгнать!");

	new string[256];
	format(string,sizeof(string),"[FAMILY | %s] %s выгнал%s %s из семьи. Причина: %s",FamilyInfo[User[playerid][pFamilyMember]][famName],Name(playerid),(User[playerid][pSex]==1)?(""):("а"),Name(targetid),reason);
	SendFAMMes(User[playerid][pFamilyMember], 0xDCD45CFF, string);

	SCMF(targetid, COLOR_BLUE, "Вы были изгнаны из семьи '%s'. Причина: %s",FamilyInfo[User[playerid][pFamilyMember]][famName], reason);
	LeaveFamilyPlayer(targetid);
	SendClientMessage(targetid, COLOR_GREEN, "[Подсказка] {FFFFFF}Местом спавна автоматически назначен вокзал. Изменить место спавна /spawnchange");
	return 1;
}

CMD:funinviteoff(playerid, params[])
{
    if(!User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в семье");
	if(!istext(User[playerid][pName],FamilyInfo[User[playerid][pFamilyMember]][famLeader])) return SendClientMessage(playerid,COLOR_GREY,"Доступно только владельцу семьи!");
    new playername[MAX_PLAYER_NAME];
    if(sscanf(params, "s[24]", playername)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /funinviteoff [ник игрока]");
    else if(GetPlayerID(playername) != INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок в сети, используйте команду /funinvite");
    YCMDstr[0] = EOS;
	format(YCMDstr, sizeof(YCMDstr), "SELECT `fam_m` FROM accounts WHERE `name` = '%s' LIMIT 1", playername);
    mysql_tquery(dbHandle, YCMDstr, "@OfflineFUninvite", "is", playerid, playername);
	return 1;
}
