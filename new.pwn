	return 1;
}
stock SavePlayerPInt(playerid, field[], var) {
	new query_[128];
	format(query_, sizeof query_, "UPDATE `accounts` SET `%s` = '%d' WHERE `Name` = '%s'", field, var, User[playerid][pName]);
	mysql_tquery(dbHandle, query_, "", "");
	print("SavePlayerPInt | Good");
	return 1;
}
stock SendFAMMes(family, color, str[])
{
	foreach(new i : Player)
	{
		if(!User[i][pLogin]) continue;
		if(User[i][pFamilyMember] == family) SendClientMessage(i, color, str);
	}
	return 1;
}
stock LeaveFamilyPlayer(playerid)
{
	User[playerid][pFamilyMember] = User[playerid][pSpawnChange] = 0;
	UpdatePlayerData(playerid, "fam_m", User[playerid][pFamilyMember]);
	if(User[playerid][pFamilyText] != Text3D:INVALID_3DTEXT_ID)
	{
		DestroyDynamic3DTextLabel(User[playerid][pFamilyText]);
		User[playerid][pFamilyText] = Text3D:INVALID_3DTEXT_ID;
	}
	//mysql_query_string[0] = EOS;
	//format(mysql_query_string, 256, "UPDATE "T_ACCOUNTS" SET `fam_m` = '0', `spawnchange` = '0' WHERE `name` = '%s'", User[playerid][pName]);
	//mysql_tquery(dbHandle, mysql_query_string, "", "");
	return 1;
}
@OfflineFUninvite(playerid, playername[]);
@OfflineFUninvite(playerid, playername[])
{
	new rows;
    cache_get_row_count(rows);
    if(!rows) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден!");

    new famid;
    cache_get_value_index_int(0, 0, famid);
    if(famid != User[playerid][pFamilyMember]) return SendClientMessage(playerid, COLOR_GREY, "Игрок не состоит в Вашей семье!");

    YCMDstr[0] = EOS;
	format(YCMDstr, 256, "UPDATE accounts SET `fam_m` = '0',`spawnchange` = '0' WHERE `name` = '%s' LIMIT 1", playername);
	mysql_tquery(dbHandle, YCMDstr, "", "");

	new string[128];
	format(string,sizeof(string),"[FAMILY | %s] %s выгнал%s %s из семьи в оффлайне.",FamilyInfo[User[playerid][pFamilyMember]][famName],Name(playerid),(User[playerid][pSex]==1)?(""):("а"),playername);
	SendFAMMes(User[playerid][pFamilyMember], 0xDCD45CFF, string);
	return 1;
}
@LoadFamily();
@LoadFamily()
{
    new time = GetTickCount();
    new rows;
	cache_get_row_count(rows);
	if(rows)
	{
	    for(new i = 1; i <= rows; i++)
		{
		    cache_get_value_index_int(i-1, 0, FamilyInfo[i][famID]);
		    cache_get_value_name(i-1, "name", FamilyInfo[i][famName], 20);
			cache_get_value_name(i-1, "leader", FamilyInfo[i][famLeader], MAX_PLAYER_NAME);
			cache_get_value_index_int(i-1, 3, FamilyInfo[i][famSpawn]);
			cache_get_value_index_int(i-1, 4, FamilyInfo[i][famSklad]);
			cache_get_value_index_int(i-1, 5, FamilyInfo[i][famMoney]);
			cache_get_value_index_int(i-1, 6, FamilyInfo[i][famDrugs]);
			cache_get_value_index_int(i-1, 7, FamilyInfo[i][famChatColor]);
			
			cache_get_value_name(i-1, "cars", FamilyInfo[i][famCars], 32);
			sscanf(FamilyInfo[i][famCars], "p<,>a<i>[5]",FamilyInfo[i][famCar]);
			
			QUERY [ 0 ] = EOS ;
			cache_get_value_name ( i-1, "ranks", QUERY, 372 ) ;
			sscanf ( QUERY, "p<|>s[30]s[30]s[30]s[30]s[30]s[30]",
			family_rank [ i ] [ 0 ], family_rank [ i ] [ 1 ], family_rank [ i ] [ 2 ], family_rank [ i ] [ 3 ],
			family_rank [ i ] [ 4 ], family_rank [ i ] [ 5 ] ) ;
			
			TOTALFAMILY++;
        }
    }
	printf("[Загружено семей]: <%i>. Потрачено: <%i ms>.", TOTALFAMILY, GetTickCount() - time);
	return 1;
}

@CreateFamily(playerid, inputtext[]);
@CreateFamily(playerid, inputtext[])
{
    new rows;
	cache_get_row_count(rows);
	if(rows)
	{
	    SendClientMessage(playerid, COLOR_GREY, "Указанное название семьи занято");

	    QUERY[0] = EOS;
        format(QUERY, 300, "\
			{FFFFFF}Всего семей: {FFA200}%d\n\
			{FFFFFF}Создание семьи стоит: {3AA94C}1500000$\n\n\
			{FFFFFF}Введите название семьи:\n\n\
			{AFAFAF}Допустимое значение количества символов от 3 до 20", TOTALFAMILY);
		return ShowPlayerDialogEx(playerid, dCreateFamily, DIALOG_STYLE_INPUT, " ", QUERY, "Принять", "Назад");
	}
	if(User[playerid][pFamilyText] == Text3D:INVALID_3DTEXT_ID) // есть ли фама у игрока
	{
	    format(YCMDstr,sizeof(YCMDstr),"{%s}%s", family_chat_color[FamilyInfo[User[playerid][pFamilyMember]][famChatColor]], FamilyInfo[User[playerid][pFamilyMember]][famName]);//??? ???
		User[playerid][pFamilyText] = CreateDynamic3DTextLabel(YCMDstr, -1, 0.0, 0.0, 0.4, 6.0,  playerid, INVALID_VEHICLE_ID, 1 );
	}
    TOTALFAMILY++;
    User[playerid][pCash] -= 1500000;
    User[playerid][pFamilyMember] = TOTALFAMILY;
    User[playerid][pFamilyRank] = 6;

    //mysql_query_string[0] = EOS;
	//format(mysql_query_string, 300, "UPDATE "T_ACCOUNTS" SET credits = %d, fam_m = %d WHERE id = %d", User[playerid][pDonateAccount], User[playerid][pFamilyMember], User[playerid][pID]);
	//mysql_tquery(dbHandle, mysql_query_string, "", "");

    QUERY[0] = EOS;
    format(QUERY, 300, "INSERT INTO "T_FAMILY" (id,name,leader) VALUES (%d,'%s','%s')", TOTALFAMILY, inputtext, Name(playerid));
    mysql_tquery(dbHandle, QUERY, "", "");

    FamilyInfo[User[playerid][pFamilyMember]][famID] = TOTALFAMILY;
	FamilyInfo[User[playerid][pFamilyMember]][famSklad] = 1;
    FamilyInfo[User[playerid][pFamilyMember]][famSpawn] = FamilyInfo[User[playerid][pFamilyMember]][famMoney] = FamilyInfo[User[playerid][pFamilyMember]][famDrugs] = 0;
    format(FamilyInfo[User[playerid][pFamilyMember]][famName], 20, inputtext);
	format(FamilyInfo[User[playerid][pFamilyMember]][famLeader], MAX_PLAYER_NAME, Name(playerid));
	for(new i = 0; i < 5; i++) FamilyInfo[User[playerid][pFamilyMember]][famCar] [i] = 462;

	new string[128];
    format(string, sizeof(string), "[Информация] {FFFFFF}Вы успешно создали семью {46CA00}%s{FFFFFF}. Используйте {FFA200}/family {FFFFFF}для управления", FamilyInfo[User[playerid][pFamilyMember]][famName]);
    SendClientMessage(playerid, COLOR_YELLOW, string);
	return 1;
}

@ListFamily(playerid);
@ListFamily(playerid)
{
    new rows;
	cache_get_row_count(rows);
	if(!rows)
		return SendClientMessage(playerid, COLOR_GREY, "Ни одной семьи не зарегистрировано");

	new rows_page = GetPVarInt(playerid, "family_page") - 1;
	SetPVarInt(playerid, "family_rows", rows);

	new name[20],
		string[128],
		t;

	QUERY[0] = EOS;

	for(new i = rows_page * 15; i < rows_page * 15 + 15; i++)
	{
	    if(i >= rows)
	    	break;
    	cache_get_value_name(i, "name", name, 20);
	    format(string, sizeof(string), "%d. %s\n", i + 1, name);
	    strcat(QUERY, string);
	    t++;
	}

	SetPVarInt(playerid, "total_rows_one_page", t);

	if(rows_page > 0)
	{
	    SetPVarInt(playerid, "show_back_page", 1);
		strcat(QUERY, "\t{F63D00}Предыдущая страница\n");
	}
	if(t == 15)
		strcat(QUERY, "\t{46CA00}Следующая страница");

	ShowPlayerDialogEx(playerid, dListFamily, DIALOG_STYLE_LIST, "{F1C33A}Список семей", QUERY, "Выбрать", "Назад");
	return 1;
}

@RFamily(playerid);
@RFamily(playerid)
{
    new rows;
    cache_get_row_count(rows);
    if(!rows)
    {
        SendClientMessage(playerid, COLOR_RED, "Участников семьи не найдено!");
    }
    else
    {
        new name[24];
        cache_get_value_name(0, "Name", name, 24);
    	format(YCMDstr, sizeof(YCMDstr), "UPDATE `accounts` SET `fam_m` = '0' WHERE `Name` = '%s'",name);
		mysql_tquery(dbHandle, YCMDstr, "", "");
    	SendClientMessage(playerid, 0xDCD45CFF, "Вы расформировали свою семью за {3AA94C}250.000$");
    	User[playerid][pCash] -= 250000;
    }
    return 1;
}

@OfflineFamilyMember(playerid);
@OfflineFamilyMember(playerid)
{
    new rows;
	cache_get_row_count(rows);
	if(!rows) return SendClientMessage(playerid, COLOR_GREY, "В Вашей семье никого не обнаружено.");

	new fname[24],stringr[32];
	QUERY[0] = EOS;
	for(new i; i < rows; i++)
    {
		cache_get_value_name(i, "Name", fname, 24);
		format(stringr, sizeof(stringr), "%i. %s\n",i+1,fname);
    	strcat(QUERY, stringr);
	}

	ShowPlayerDialogEx(playerid, 0, DIALOG_STYLE_LIST, "{F1C33A}Общий список членов семьи", QUERY, "Закрыть", "");
	return 1;
}

forward callback_employment_history(const id_player, const name_wbook[]);
public callback_employment_history(const id_player, const name_wbook[])
{
    new
        rows,
        data_invite_in_organization[15],
        data_unvite_from_organization[15],
        rang_in_organization,
        organization[50],
        organization_position[50];

    cache_get_row_count(rows);
    static const caption_employment_history[] = "{FFCC00}Трудовая книга %s";
    new str_callback_employment_history[sizeof(caption_employment_history) + MAX_PLAYER_NAME + 1];
    format(str_callback_employment_history, sizeof(str_callback_employment_history), caption_employment_history, name_wbook);
    if(!rows)
    {
        static text_dialog_employment_history[] =
        {
            "{ffffff}В трудовой книге отсутствуют записи. Первая запись появится после ухода из организации: \n\n\
               1. Если у Вас был 3 ранг и выше;\n\
             2. Если Вы провели в организации 15 дней и более."
        };
        return ShowPlayerDialogEx(id_player, 0, DIALOG_STYLE_MSGBOX, str_callback_employment_history, text_dialog_employment_history, "Закрыть",""), 0;
    }
    static title_dialog_employment_history[] = "Принятие\tУвольнение\tРанг\tОрганизация и должность";
    new string_text_to_dialog[sizeof(str_callback_employment_history) + sizeof(title_dialog_employment_history) + sizeof(data_invite_in_organization) + sizeof(data_unvite_from_organization) + 20 + sizeof(organization) + sizeof(organization_position)];
    new string_original[1200];
    strcat(string_original, title_dialog_employment_history);
    strcat(string_original, "\n\n");
    for(new r; r < rows; r++)
    {
        data_invite_in_organization[0] = EOS;
        data_unvite_from_organization[0] = EOS;
        organization[0] = EOS;
        organization_position[0] = EOS;
        //cache_get_field_content(r, "data_invite", data_invite_in_organization);
        cache_get_value_name(r, "data_invite", data_invite_in_organization, 15);
        //cache_get_field_content(r, "data_un_invite", data_unvite_from_organization);
        cache_get_value_name(r, "data_un_invite", data_unvite_from_organization, 15);
        //rang_in_organization = cache_get_field_content_int(r, "rang");
        cache_get_value_int(r, "rang", rang_in_organization);
        //cache_get_field_content(r, "organization", organization);
        cache_get_value_name(r, "organization", organization, 50);
        //cache_get_field_content(r, "organization_position", organization_position);
        cache_get_value_name(r, "organization_position", organization_position, 50);
        format(string_text_to_dialog, sizeof(string_text_to_dialog), "{ffffff}%s\t%s\t%d\t%s, %s", data_invite_in_organization, data_unvite_from_organization, rang_in_organization, organization, organization_position);
        strcat(string_original, string_text_to_dialog);
        strcat(string_original, "\n");
        string_text_to_dialog[0] = EOS;
    }
    ShowPlayerDialogEx(id_player, 0, DIALOG_STYLE_TABLIST_HEADERS, str_callback_employment_history, string_original, "Закрыть","");
    return (rows == 0) ? (rows) : (1);
}
stock ShowQuestList(playerid) // Общий диалог квестов // квесты
{
	QUERY = "{FFFFFF}Сюжетная линия\t{FFFFFF}Статус\n";
	for(new i; i < sizeof(quest_name); i++) {
		format(QUERY, sizeof(QUERY), "%s%i) %s\t%s\n", QUERY, i + 1, quest_name[i], (User[playerid][quest_store][i] == 100 ? ("{00FF00}Выполнено") : ("{FF0000}Не выполнено")));
	}
	return ShowPlayerDialogEx(playerid, 8439, DIALOG_STYLE_TABLIST_HEADERS, "{F1C33A}Сюжетные линии", QUERY, "Далее", "Закрыть");
}
stock UpdateQuestInfo(playerid, questid, value) // сохранение квестов
{
    static mysql_query_[512];
	User[playerid][quest_store][questid] = value;
	if(value == 100) SCMF(playerid, -1, "{00FF00}[Успешно] {FFFFFF}Сюжетная линия: \"%s\" завершена!", quest_name[_:questid]);

	format(YCMDstr, sizeof(YCMDstr), "%d, %d, %d, %d", User[playerid][quest_store][0], User[playerid][quest_store][1], User[playerid][quest_store][2], User[playerid][quest_store][3]);
	format(mysql_query_, sizeof(mysql_query_),"UPDATE `accounts` SET `quest_store` = '%s' WHERE `pID` = '%d'", YCMDstr, PlayerIDs[playerid]);
    mysql_tquery(dbHandle, mysql_query_, "", "");
  	return true;
}
stock StartQuest(playerid, listitem)
{
    switch(listitem)
	{
	    case 0:
		{
		    if(User[playerid][quest_store][0] < 20) {
				SCMF(playerid, COLOR_GREY, "{FFFFFF}Вы начали проходить сюжетную линию {FF0000}\"%s\" {FFFFFF}", quest_name[listitem]);
		    	SendClientMessage(playerid, COLOR_WHITE, "Добро пожаловать в штат {FFFF00}"FullServName"");
		    	SendClientMessage(playerid, COLOR_YELLOW, "[Подсказка]{FFFFFF} Соберите 20 кустов на ферме");
		    	UpdateQuestInfo(playerid, 0, 20);
		    }
		    if(User[playerid][quest_store][0] == 40)
			{
				SendClientMessage(playerid, COLOR_YELLOW,"[Подсказка] Вы купили вод права, теперь купите скин");
				//UpdateQuestInfo(playerid, 0, 60);
			}
			if(User[playerid][quest_store][0] == 60)
			{
				SendClientMessage(playerid, COLOR_YELLOW,"[Подсказка] Вы купили скин, теперь устройтесь на работу");
				//UpdateQuestInfo(playerid, 0, 80);
			}
		    	
		}
		case 1:
		{
		    SCMF(playerid, COLOR_GREY, "{FFFFFF}Вы начали проходить сюжетную линию {FF0000}\"%s\" {FFFFFF}", quest_name[listitem]);
				
   			SendClientMessage(playerid, COLOR_YELLOW, "[Подсказка]{FFFFFF} Получите 5 уровень таксиста /taxiskill");
	    	UpdateQuestInfo(playerid, 1, 20);
        }
        case 2:
		{
		    if(IsAGang(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Данный квест не доступен для тех, кто уже в банде");
			SCMF(playerid, COLOR_GREY, "{FFFFFF}Вы начали проходить сюжетную линию {FF0000}\"%s\" {FFFFFF}", quest_name[listitem]);
			SendClientMessage(playerid, COLOR_YELLOW, "Говорят, самые мощные ребята сидят в бандах");
			SendClientMessage(playerid, COLOR_YELLOW, "Пришло время познать жизнь ганстера");
			SendClientMessage(playerid, COLOR_YELLOW, "[Подсказка]{FFFFFF} Вступите в любую банду");
			UpdateQuestInfo(playerid, 2, 20);
		}
		case 3:
		{
		    SCMF(playerid, COLOR_GREY, "{FFFFFF}Вы начали проходить сюжетную линию {FF0000}\"%s\" {FFFFFF}", quest_name[listitem]);
			SendClientMessage(playerid, COLOR_YELLOW, "Прокачайте скилл дальнобойщика до 25 и получите приз 200000");
			SendClientMessage(playerid, COLOR_YELLOW, "[Подсказка]{FFFFFF} Устройтесь работать дальнобойщиком");
			UpdateQuestInfo(playerid, 3, 20);
		}
	}
	return true;
}
stock QuestNagrada(playerid) {
	ShowPlayerDialogEx(playerid, 0, DIALOG_STYLE_MSGBOX,"{00BFFF}Квест", "{FFFFFF}Поздравляем, Вы успешно прошли сюжетную линию", "Закрыть", "");
	SendClientMessage(playerid, COLOR_WHITE, "Ваш счет был пополнен на {FFFF00}10000 $ + 2 EXP");
	User[playerid][pExp] += 2;
	User[playerid][pCash] += 10000;
}
