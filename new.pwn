CMD:clist(playerid, params[])
{
    if(GetPVarInt(playerid,"mafiawar")) return SendClientMessage(playerid,COLOR_GREY, "Нельзя использовать во время войны");
    if(GetPVarInt(playerid,"capture_on")) return SendClientMessage(playerid,COLOR_GREY, "Нельзя использовать во время войны");
    if(sscanf(params, "d",params[0]))
    {
	    new dialog[512];
		strcat(dialog, "[0]	Выключить цвет\n[1]	Зелёный\n[2]	Светло зелёный\n[3]	Ярко зелёный\n[4]	Бирюзовый\n[5]	Жёлто-зелёный\n[6]	Тёмно-зелёный\n[7]	Серо-зелёный\n[8]	Красный\n[9]	Ярко-красный\n[10]	Оранжевый\n[11]	Коричневый\n[12]	Тёмно-красный\n[13]	Cеро-красный\n[14]	Жёлто-оранжевый\n[15]	Малиновый\n[16]	Розовый\n[17]	Синий\n[18]	Голубой\n[19]	Синяя сталь\n[20]	Сине-зелёный\n[21]	Тёмно-синий\n[22]	Фиолетовый\n");
		strcat(dialog, "[23]	Индиго\n[24]	Серо-синий\n[25]	Жёлтый\n[26]	Кукурузный\n[27]	Золотой\n[28]	Старое золото\n[29]	Оливковый\n[30]	Серый\n[31]	Серебро\n[32]	Чёрный\n[33]	Белый");
		return ShowPlayerDialogEx(playerid,2001,DIALOG_STYLE_LIST, "Цвет",dialog, "Выбрать", "Отмена");
	}
	else
	{
	    if(params[0] > 33) return SendClientMessage(playerid,COLOR_GREY, "Неверный цвет");
	    switch(params[0])
	    {
	        case 0: SetPlayerColor(playerid, TEAM_HIT_COLOR); case 1: SetPlayerColor(playerid,0x089401FF);
			case 2: SetPlayerColor(playerid,0x56FB4EFF); case 3: SetPlayerColor(playerid,0x49E789FF);
			case 4: SetPlayerColor(playerid,0x2A9170FF); case 5: SetPlayerColor(playerid,0x9ED201FF);
			case 6: SetPlayerColor(playerid,0x279B1EFF); case 7: SetPlayerColor(playerid,0x003366FF);
			case 8: SetPlayerColor(playerid,0xFF0606FF); case 9: SetPlayerColor(playerid,0xFF6600FF);
			case 10: SetPlayerColor(playerid,0xF45000FF); case 11: SetPlayerColor(playerid,0xBE8A01FF);
			case 12: SetPlayerColor(playerid,0xB30000FF); case 13: SetPlayerColor(playerid,0x954F4FFF);
			case 14: SetPlayerColor(playerid,0xE7961DFF); case 15: SetPlayerColor(playerid,0xE6284EFF);
			case 16: SetPlayerColor(playerid,0xFF9DB6FF); case 17: SetPlayerColor(playerid,0x110CE7FF);
			case 18: SetPlayerColor(playerid,0x0CD7E7FF); case 19: SetPlayerColor(playerid,0x139BECFF);
			case 20: SetPlayerColor(playerid,0x2C9197FF); case 21: SetPlayerColor(playerid,0x114D71FF);
			case 22: SetPlayerColor(playerid,0x8813E7FF); case 23: SetPlayerColor(playerid,0xB313E7FF);
			case 24: SetPlayerColor(playerid,0x758C9DFF); case 25: SetPlayerColor(playerid,0xFFDE24FF);
			case 26: SetPlayerColor(playerid,0xFFEE8AFF); case 27: SetPlayerColor(playerid,0xDDB201FF);
			case 28: SetPlayerColor(playerid,0xDDA701FF); case 29: SetPlayerColor(playerid,0xB0B000FF);
			case 30: SetPlayerColor(playerid,0x868484FF); case 31: SetPlayerColor(playerid,0xB8B6B6FF);
			case 32: SetPlayerColor(playerid,0x333333FF); case 33: SetPlayerColor(playerid,0xFAFAFAFF);
		}
	}
	return true;
}
CMD:enter(playerid, params[])
{
	for(new i = 1; i <= TotalHouse; i++)
	{
		if (PlayerToPoint(3, playerid,HouseInfo[i][hEntrancex], HouseInfo[i][hEntrancey], HouseInfo[i][hEntrancez]))
		{
			if(HouseInfo[i][hLock] == 0)
			{
				SetPlayerInterior(playerid,HouseInfo[i][hInt]);
				SetPlayerVirtualWorld(playerid, i+50);
				t_SetPlayerPos(playerid,HouseInfo[i][hExitx],HouseInfo[i][hExity],HouseInfo[i][hExitz]);
				return true;
			}
			else
			{
				GameTextForPlayer(playerid, "~r~CLOSED", 5000, 1);
      		}
		}
	}
	return true;
}
CMD:exit(playerid, params[])
{
    for(new i = 1; i <= TotalHouse; i++)
	{
		if(!PlayerToPoint(3, playerid,HouseInfo[i][hExitx], HouseInfo[i][hExity], HouseInfo[i][hExitz])) continue;
		if(GetPlayerVirtualWorld(playerid) == i+50)
		{
			PickupX[playerid] = HouseInfo[i][hEntrancex], PickupY[playerid] = HouseInfo[i][hEntrancey];
			oldpickup[playerid] = HouseInfo[i][hPickup];
			timepickup[playerid] = 3;
			SetPVarInt(playerid, "AntiBreik", 2);
			SetPlayerInterior(playerid,0);
			SetPlayerVirtualWorld(playerid,0);
			t_SetPlayerPos(playerid,HouseInfo[i][hEntrancex],HouseInfo[i][hEntrancey],HouseInfo[i][hEntrancez]);
		}
	}
	return true;
}
CMD:directory(playerid)
{
    if(User[playerid][pDirectory] == 0) return SendClientMessage(playerid, COLOR_GREY, "У вас нет телефонного справочника");
	ShowPlayerDialogEx(playerid,5454,DIALOG_STYLE_LIST, "Телефонный справочник", " Таксисты\n Механики\n Прорабы\n Медики\n Лидеры\n Адвокаты\n Развозчики продуктов\n Тренеры", "Просмотр", "Отмена");
	return 1;
}
CMD:mainmenu(playerid,params[])
{
    return ShowPlayerDialogEx(playerid, 9623, DIALOG_STYLE_LIST, "{F1C33A}Игровое меню", MainMenu, "Выбрать", "Выйти");//\n[8] Имущество
}

CMD:switchskin(playerid, params[])
{
    if(!IsAGang(playerid)) return true;
	if(!GetPVarInt(playerid, "Forma")) return SendClientMessage(playerid, COLOR_GREY, "У вас нет формы армейца");
	SetPlayerSkin(playerid,287);
	SetPlayerColor(playerid, COLOR_GREEN);
	DeletePVar(playerid, "Forma");
	SetPVarInt(playerid, "ProverkaForma", 1);
	return 1;
}
CMD:carm(playerid, params[])
{
    if(User[playerid][pMember] != 19 && !GetPVarInt(playerid, "ProverkaForma")) return true;
	new listitems[] = " [1] Загрузка\n [2] Разгрузить на гл.склад\n [3] Разгрузить на склад Армии ЛС\n [4] Разгрузить на склад Армии СФ\n [5] Разгрузить на склад ЛСПД\n [6] Разгрузить на склад ФБР\n [7] Разгрузить на склад СФПД\n [8] Разгрузить на склад ЛВПД\n [9] Разгрузить на склад бандам\n [10] Разгрузить на склад байкерам";
	ShowPlayerDialogEx(playerid, 9653, DIALOG_STYLE_LIST, "Развозка материалов", listitems, "Выбрать", "Отмена");
	return 1;
}
CMD:tie(playerid, params[])
{
    if(!IsAMafia(playerid)) return true;
	if(User[playerid][pRank] < 3) return SendClientMessage(playerid, COLOR_GREY, "Вы должны быть 3 рангом");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /tie [id]");
	if(!IsPlayerConnected(params[0]) || !IsPlayerInAnyVehicle(playerid) || !IsPlayerInAnyVehicle(params[0])) return true;
	if(PlayerTied[params[0]] > 0) return SendClientMessage(playerid, COLOR_GREY, "Человек уже связан!");
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	new car = GetPlayerVehicleID(playerid);
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Нельзя связать самого себя!"); return true; }
	if(IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == 2 && IsPlayerInVehicle(params[0], car))
	{
		format(YCMDstr, sizeof(YCMDstr), "Вас связал %s.",User[playerid][pName]);
		SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "%s связал %s", User[playerid][pName] ,User[params[0]][pName]);
		SendBeside(playerid, COLOR_PURPLE,YCMDstr,30.0);
		TogglePlayerControllable(params[0], 0);
		PlayerTied[params[0]] = 1;
	}
	else return SendClientMessage(playerid, COLOR_GREY, "Человек не в машине!");
	return true;
}
CMD:debtors(playerid, params[])
{
    if(!IsAMafia(playerid)) return true;
	if(User[playerid][pRank] < 6) return SendClientMessage(playerid, COLOR_GREY, "Вы должны быть 6 рангом");
	SendClientMessage(playerid, COLOR_YELLOW2, "Должники:");
	foreach(new i : Player)
	{
		if(User[playerid][pMember] == 6)
		{
			if(User[i][pKrisha] == User[playerid][pMember] && User[i][pMember] == 0)
			{
				format(YCMDstr, 256, "Должник: %s | Долг: %s",User[i][pName],User[i][pDolg]);
				SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
			}
		}
	}
	return true;
}
CMD:setdebt(playerid, params[])
{
    if(!IsAMafia(playerid)) return true;
	if(User[playerid][pRank] < 3) return SendClientMessage(playerid, COLOR_GREY, "Вы должны быть 3 рангом");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setdebt [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	if(User[params[0]][pJob] == 0) return SendClientMessage(playerid, COLOR_GREY, "Данный человек не работает");
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Нельзя себе!"); return true; }
	format(YCMDstr, sizeof(YCMDstr), "%s предлагает вам Крышу (( Введите: /accept debt, чтобы принять ))",User[playerid][pName]);
	SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "%s предлагает крышу %s'у", User[playerid][pName] ,User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE,YCMDstr,10.0);
	Krisha[params[0]] = User[playerid][pMember];
	KrishaOffer[params[0]] = playerid;
	return true;
}
CMD:getdebt(playerid, params[])
{
	if(!IsAMafia(playerid)) return true;
	if(User[playerid][pRank] < 3) return SCM(playerid, COLOR_GREY, "Доступно с 3 ранга!");
	if(sscanf(params, "u", params[0])) return SCM(playerid, COLOR_GREY, "Используйте: /getdebt [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	if(User[params[0]][pKrisha] == User[playerid][pMember])
	{
	    if(User[params[0]][pDolg] < 50) return SendClientMessage(params[0], COLOR_GREY, "Недостаточная сумма для возврата долга!");
	    if(User[params[0]][pCash] < User[params[0]][pDolg]) return SCM(playerid, COLOR_GREY, "У игрока недостаточно денег!");
		User[params[0]][pCash] -= User[params[0]][pDolg];
		SCM(playerid, -1, "Вы выбили долг из игрока!");
		SCM(params[0], -1, "С вас выбили долг!");
        switch(User[playerid][pKrisha])
		{
			case 6:
			{
				SendClientMessage(params[0], COLOR_YELLOW, "Долг был возвращён мафии Yakuza!");
				format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[params[0]][pName],User[params[0]][pDolg]);
				SendFamilyMessage(6,COLOR_YELLOW2, YCMDstr);
				MafiaBank[0][nYakuza] +=User[params[0]][pDolg] ;
				User[params[0]][pDolg] = 0;
			}
			case 5:
			{
				SendClientMessage(params[0], COLOR_YELLOW, "Долг был возвращён LCN!");
				format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[params[0]][pName],User[params[0]][pDolg]);
				SendFamilyMessage(5,COLOR_YELLOW2, YCMDstr);
				MafiaBank[0][nLcn] +=User[params[0]][pDolg];
				User[params[0]][pDolg] = 0;
			}
			case 14:
			{
				SendClientMessage(params[0], COLOR_YELLOW, "Долг был возвращён Русской мафии!");
				format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[params[0]][pName],User[params[0]][pDolg]);
				SendFamilyMessage(14,COLOR_YELLOW2, YCMDstr);
				MafiaBank[0][nRm] +=User[params[0]][pDolg] ;
				User[params[0]][pDolg] = 0;
			}
		}
	}
	return true;
}
CMD:hackbase(playerid, params[])
{
	if(!IsAMafia(playerid)) return true;
    if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 497 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 427 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 523 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 415
	&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 521 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 596 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 597 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 598
	&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 490 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 560) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в полицейской машине");
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /hackbase [id]");
	new str[128];
    if(IsPlayerConnected(params[0]))
    {
        if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Человек не найден!");
        if(User[params[0]][pWantedLevel] == 0) return SendClientMessage(playerid, COLOR_GREY, "Человек не находится в розыске!");
		format(str, sizeof(str), "Вы сняли уровни розыска у %s.", User[params[0]][pName]);
		SendClientMessage(playerid, 0x6495EDFF, str);
		format(str, sizeof(str), "Мафиози %s снял с Вас уровни розыска.", User[playerid][pName]);
		SendClientMessage(params[0], 0x6495EDFF, str);
		User[params[0]][pWantedLevel] = 0;
		SetPlayerWantedLevel(params[0], 0);
	}
	return true;
}
CMD:untie(playerid, params[])
{
    if(!IsAMafia(playerid) && User[playerid][pMember] != 2) return true;
	if(User[playerid][pRank] < 3) return SendClientMessage(playerid, COLOR_GREY, "Вы должны быть 3 рангом");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /untie [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(PlayerTied[params[0]] != 1) return SendClientMessage(playerid, COLOR_GREY, "Человек не связан!");
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Нельзя связать самого себя!"); return true; }
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	format(YCMDstr, sizeof(YCMDstr), "Вы были развязаны %s.",User[playerid][pName]);
	SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "%s развязал %s", User[playerid][pName] ,User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE,YCMDstr,10.0);
	TogglePlayerControllable(params[0], 1);
	PlayerTied[params[0]] = 0;
	return true;
}
CMD:showpass(playerid, params[])
{
	if(sscanf(params, "u",params[0])) return  	SendClientMessage(playerid, COLOR_GREY, "Используйте: /showpass [id]");
	if(IsPlayerConnected(params[0]))
	{
		if(params[0] != INVALID_PLAYER_ID)
		{
			if (ProxDetectorS(8.0, playerid, params[0]))
			{
			    new str[128];
				new jtext[32];
				if(User[playerid][pJob] == 1) { jtext = "Водитель автобуса"; }
				else if(User[playerid][pJob] == 2) { jtext = "Механик"; }
				else if(User[playerid][pJob] == 3) { jtext = "Продавец хотдогов"; }
				else if(User[playerid][pJob] == 4) { jtext = "Таксист"; }
				else if(User[playerid][pJob] == 6) { jtext = "Тренер"; }
				//else if(User[playerid][pJob] == 8) { jtext = "Инкассатор"; }
				else if(User[playerid][pJob] == 9) { jtext = "Прораб"; }
				else if(User[playerid][pJob] == 99) { jtext = "Дальнобойщик"; }
				else { jtext = "Безработный"; }
				new rangz[40];
				if(IsAGang(playerid) || IsAMafia(playerid) || !User[playerid][pMember]) rangz = "Неизвестно";
				else strmid(rangz,GetRank(playerid), 0, strlen(GetRank(playerid)), 32);
				new level = User[playerid][pLevel];
				new af[] = "---------===[PASSPORT]===---------";
				format(str, sizeof(str), af);
				SendClientMessage(params[0], 0x589A76FF, str);
				new msg[] = "Имя: %s";
				format(str, sizeof(str), msg, User[playerid][pName]);
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "Возраст: %i  Телефон: %i",level,User[playerid][pPnumber]);
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "Фракция: %s  Должность: %s", GetFractionName[User[playerid][pMember]],rangz);
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "Работа: %s   Разрешение на оружие: %s",jtext,(!User[playerid][pGunLic])?("Нет") : ("Есть"));
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "Преступлений: %i",User[playerid][pCrimes]);
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "Законопослушность: %i",User[playerid][pZakonp]);
				SendClientMessage(params[0], COLOR_WHITE, str);
				format(str, sizeof(str), "========================");
				SendClientMessage(params[0], 0x589A76FF, str);
				if(User[playerid][pWantedLevel] > 0) SendClientMessage(params[0], COLOR_REDD, "Внимание! Этот человек в розыске!");
				format(str, sizeof(str), "показал свой паспорт %s'у",User[params[0]][pName]);
				SetPlayerChatBubble(playerid,str,COLOR_PURPLE,30.0,10000);
				format(str, sizeof(str), "%s показал(a) свой паспорт", User[playerid][pName]);
				SendBeside(playerid, COLOR_PURPLE,str,10.0);
			}
			else
			{
				SendClientMessage(playerid, COLOR_GREY, "Вы слишком далеко!");
				return true;
			}
		}
	}
	else
	{
		SendClientMessage(playerid, COLOR_GREY, "Игрок не найден!");
		return true;
	}
	return true;
}
CMD:showudost(playerid, params[])
{
    if(!IsACop(playerid)) return true;
	if(sscanf(params, "u",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /showudost [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	new ttext[32];
	switch(User[playerid][pMember])
	{
		case 0: ttext = "Гражданин";
		case 1: ttext = "LSPD";
		case 2: ttext = "ФБР";
		case 10: ttext = "SFPD";
		case 21: ttext = "LVPD";
	}
	new rank = User[playerid][pRank];
	new level = User[playerid][pLevel];
	new msg[] = "Имя: %s\nТелефон: %i\nВозвраст: %i\nПодразделение: %s\nРанг: %i";
	format(YCMDstr, sizeof(YCMDstr), msg,User[playerid][pName],User[playerid][pPnumber],level,ttext,rank);
	ShowPlayerDialogEx(params[0], 69, DIALOG_STYLE_MSGBOX, "Удостоверение",YCMDstr, "Готово", "");
	format(YCMDstr, sizeof(YCMDstr), "%s показал своё удостоверение %s'у",User[playerid][pName],User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE,YCMDstr,30.0);
	format(YCMDstr,sizeof(YCMDstr), "показал своё удостоверение %s'у",User[params[0]][pName]);
	SetPlayerChatBubble(playerid,YCMDstr,COLOR_PURPLE,30.0,10000);
	return true;
}
CMD:setmbiz(playerid,params[])
{
    if(User[playerid][pLogin] == 0) return true;
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "dd", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setmbiz [BizID] [Mafia 5, 6, 14]");
    BizzInfo[params[0]][bMafia] = params[1];
    SendClientMessage(playerid, COLOR_WHITE, "Контроль бизнеса установлен");
    SaveServerBizz(params[0]);
	return true;
}
