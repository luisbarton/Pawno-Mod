CMD:warn(playerid, params[])
{
    if(Spectate[playerid]) StopSpectate(playerid);
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "us[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /warn [id/ник] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	new year, month,day;
	getdate(year, month, day);
	if(User[params[0]][pAdmin] && User[playerid][pAdmin] < 7) return BanAdmin(playerid);
	new null;
	if(User[params[0]][pDonateRank] == 0) null = 15;
 	//if(User[params[0]][pDonateRank] == 1) null = 10;
  	//if(User[params[0]][pDonateRank] == 2) null = 7;
   	if(User[params[0]][pDonateRank] == 1) null = 5;
	User[params[0]][pWarns] += 1;
	if(User[params[0]][pWarns] >= 3)
	{
		new ip[32];
		format(YCMDstr, sizeof(YCMDstr), "Администратор: %s забанил %s [3 предупреждения]. Причина: %s",User[playerid][pName],User[params[0]][pName],params[1]);
		SendClientMessageToAll(COLOR_LIGHTRED, YCMDstr);
		GetPlayerIp(params[0],ip,sizeof(ip));
		format(YCMDstr, sizeof(YCMDstr), "   Nik [%s]  R-IP [%s]  L-IP [%s]  IP [%s]",User[params[0]][pName],User[params[0]][pIpReg],User[params[0]][pvIp],ip);
		ABroadCast(COLOR_LIGHTRED,YCMDstr,2);
		User[params[0]][pMember] = 0;
		User[params[0]][pLeader] = 0;
		User[params[0]][pJob] = 0;
		mysql_format(dbHandle,QUERY, 256, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('3 WARNS', '%s', '%s', '%i/%i/%i', '%i')",User[params[0]][pName],User[playerid][pName],day,month,year,mktime(5,0,0,day+null,month,year));
		mysql_tquery(dbHandle,QUERY,"","");
		KickEx(params[0], "Warn admin > 3");
		return true;
	}
	format(YCMDstr, sizeof(YCMDstr), "Администратор: %s выдал warn %s. Причина: %s",User[playerid][pName],User[params[0]][pName],params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	User[params[0]][pMember] = 0;
	User[params[0]][pLeader] = 0;
	User[params[0]][pJob] = 0;
	User[params[0]][punWarns] = mktime(0,0,0,day+null,month,year);
	KickEx(params[0], "Warn admin");
	AdminInfo[playerid][admWarned]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET warned = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admWarned], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:unwarn(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /unwarn [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pWarns] <= 0) {SendClientMessage(playerid, COLOR_RED, "Варнов нет"); return true;}
	User[params[0]][pWarns] = 0;
	User[params[0]][punWarns] = 0;
	format(YCMDstr, sizeof(YCMDstr), "Admin: %s unwarned: %s",User[playerid][pName],User[params[0]][pName]);
	ABroadCast(0xFFFF00AA,YCMDstr,1);
	return true;
}
CMD:ban(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
    if(Spectate[playerid]) StopSpectate(playerid);
	if(sscanf(params, "us[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /ban [id/ник] [причина]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок оффлайн!");
	new ip[15];
	new null;
	new year, month,day;
	getdate(year, month, day);
    if(User[params[0]][pAdmin] && User[playerid][pAdmin] < 7) return BanAdmin(playerid);
	format(YCMDstr, sizeof(YCMDstr), "Администратор: %s забанил %s. Причина: %s ",User[playerid][pName],User[params[0]][pName],params[1]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	GetPlayerIp(params[0],ip,sizeof(ip));
	format(YCMDstr, sizeof(YCMDstr), "   Nik [%s]  R-IP [%s]  L-IP [%s]  IP [%s]",User[params[0]][pName],User[params[0]][pIpReg],User[params[0]][pvIp],ip);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,2);
	if(User[params[0]][pDonateRank] == 0) null = 30;
	//if(User[params[0]][pDonateRank] == 1) null = 21;
	//if(User[params[0]][pDonateRank] == 2) null = 14;
	if(User[params[0]][pDonateRank] == 1) null = 7;
	mysql_format(dbHandle,QUERY, 300, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('%s', '%s', '%s', '%i/%i/%i', '%i')",params[1],User[params[0]][pName],User[playerid][pName],day,month,year, mktime(5,0,0,day+null,month,year));
	mysql_tquery(dbHandle,QUERY,"","");
	KickEx(params[0], "Ban admin");
	AdminInfo[playerid][admBaned]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET baned = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admBaned], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
