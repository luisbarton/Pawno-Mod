publics: OnMySQL_QUERY(idx, playerid, str[])
{
    new r, x;
	cache_get_row_count(r);
	switch(idx)
	{
	    case 0:
	    {

		}
		case 1:
		{
			if(!r)
	        {
				if(GetPVarInt(playerid, "wrongPass") == 2) return SendClientMessage(playerid,COLOR_LIGHTRED,"Неверный пароль. Используйте /q для выхода."), KickEx(playerid, "Error pass");
				SetPVarInt(playerid, "wrongPass", GetPVarInt(playerid, "wrongPass")+1);
				format(QUERY,256, "{FF6347}Внимание! Вы ввели неверный пароль!\n\tУ вас осталось (%i) попытки\nПосле вы будете кикнуты.",3-GetPVarInt(playerid, "wrongPass"));
				ShowPlayerDialogEx(playerid,1,DIALOG_STYLE_MSGBOX, "Ошибка!",QUERY, "Повтор", "Восстановить");
				PlayerPlaySound(playerid, 1150, 0.0, 0.0, 0.0);
				SCM(playerid, 0xDCD45CFF, " Для восстановления доступа перейдите в окно ошибочного ввода и кликните по 'Восстановить'");
				return true;
			}
			else
			{
				cache_get_value_name_int(0, "pGoogle", User[playerid][pGoogle]);
				cache_get_value_name(0, "pGoogleAuth", User[playerid][pGoogleAuth], 17);
				if(User[playerid][pGoogle] != 0) return ShowPlayerDialogEx(playerid, 9650, DIALOG_STYLE_INPUT, "Подтверждение Google Auth", "{FFFFFF}Для захода в аккаунт, введите код из приложения Google Authenticator в поле ниже.\n", "Далее", "Выйти"), SetPVarInt(playerid, "KeyIP", 1);
				static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%e' LIMIT 1";
				new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
				mysql_format(dbHandle,query,sizeof(query),fmt_query,User[playerid][pName]);
				mysql_tquery(dbHandle, query, "OnMySQL_QUERY", "iis", 2, playerid, "");
			}
		}
		case 2:
		{
			DeletePVar(playerid,"time_logged");
