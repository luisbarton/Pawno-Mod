			SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		case 18:
		{
			if(User[playerid][pCash] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!"); return true; }
			FracBank[0][fRifa] += params[0];
			User[playerid][pCash] -= params[0];
			format(YCMDstr, sizeof(YCMDstr), "Вы положили в банк Rifa: %i вирт", params[0]);
			SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
	}
	return true;
}
CMD:shtrafnews(playerid,params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params,"dd",params[0],params[1])) return SCM(playerid,-1,"Введите /shtrafnews [id] [сумма] (1 - LS , 2 - SF, 3 - LV)");
	if(params[0] < 1 || params[0] > 3) return SCM(playerid,-1,"Неверное число");
	if(params[1] < 1 || params[1] > 100000) return SCM(playerid,-1,"Неверная сумма");
	switch(params[0])
	{
	    case 1:
	    {
	        if(FracBank[0][fLsnews] < params[1]) return SendClientMessage(playerid, COLOR_GREY, "В банке LS NEWS нет столько денег");
			FracBank[0][fLsnews] -= params[1];
	    }
	    case 2:
	    {
	        if(FracBank[0][fSfnews] < params[1]) return SendClientMessage(playerid, COLOR_GREY, "В банке SF NEWS нет столько денег");
			FracBank[0][fSfnews] -= params[1];
	    }
	    case 3:
	    {
	        if(FracBank[0][fLvnews] < params[1]) return SendClientMessage(playerid, COLOR_GREY, "В банке LV NEWS нет столько денег");
		 	FracBank[0][fLvnews] -= params[1];
	    }
	}
	return true;
}
CMD:newsbank(playerid, params[])
{
    switch(User[playerid][pMember])
	{
		case 9: format(YCMDstr, sizeof(YCMDstr), "В банке SF NEWS: %i вирт", FracBank[0][fSfnews]);
		case 16: format(YCMDstr, sizeof(YCMDstr), "В банке LS NEWS: %i вирт", FracBank[0][fLsnews]);
		case 20: format(YCMDstr, sizeof(YCMDstr), "В банке LV NEWS: %i вирт", FracBank[0][fLvnews]);
		default:return true;
	}
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	return true;
}
CMD:newswithdraw(playerid, params[])
{
	if(User[playerid][pLeader] == 9 || User[playerid][pLeader] == 16 || User[playerid][pLeader] == 20)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /newswithdraw [количество]");
	if(params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
	if(User[playerid][pMember] == 9 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fSfnews] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке SF NEWS нет денег"); return true; }
		if(FracBank[0][fSfnews] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке SF NEWS нет столько денег"); return true; }
		FracBank[0][fSfnews] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка SF NEWS: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 16 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fLsnews] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке LS NEWS нет денег"); return true; }
		if(FracBank[0][fLsnews] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке LS NEWS нет столько денег"); return true; }
		FracBank[0][fLsnews] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка LS NEWS: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 20 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fLvnews] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке LV NEWS нет денег"); return true; }
		if(FracBank[0][fLvnews] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке LV NEWS нет столько денег"); return true; }
		FracBank[0][fLvnews] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка LV NEWS: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	return true;
}
CMD:mafiabalance(playerid, params[])
{
    switch(User[playerid][pMember])
	{
		case 6: format(YCMDstr, sizeof(YCMDstr), "В банке мафии Yakuza: %i вирт", MafiaBank[0][nYakuza]);
		case 14: format(YCMDstr, sizeof(YCMDstr), "В банке Русской мафии: %i вирт", MafiaBank[0][nRm]);
		case 5: format(YCMDstr, sizeof(YCMDstr), "В банке мафии LCN: %i вирт", MafiaBank[0][nLcn]);
