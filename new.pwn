	format(t_query, sizeof(t_query), "UPDATE `farms` SET `owner` = '%s',`bank` = '%d',`landtax` = '%d',`zp` = '%d',`grain_price` = '%d',`grain` = '%d',`grain_sown` = '%d', \
	`prods_selling` = '%d',`prods` = '%d',`prods_price` = '%d',`deputy_1` = '%s',`deputy_2` = '%s',`deputy_3` = '%s',`farmer_1` = '%s',`farmer_2` = '%s',`farmer_3` = '%s', \
	`farmer_4` = '%s',`farmer_5` = '%s',`auctions` = '%s',`auction_name` = '%s' WHERE `id` = '%d'",
