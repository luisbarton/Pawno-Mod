	ABroadCast(COLOR_LIGHTRED,YCMDstr,2);
	mysql_format(dbHandle,QUERY, 300, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('IBAN:  %s', '%s', '%s', '%i/%i/%i', '%i')",params[1],User[params[0]][pName],User[playerid][pName],day,month,year, mktime(5,0,0,day,month,2037));
	mysql_tquery(dbHandle,QUERY,"","");
	KickEx(params[0], "Iban admin");
	AdminInfo[playerid][admBaned]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET baned = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admBaned], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:sban(playerid, params[])
{
    if(Spectate[playerid]) StopSpectate(playerid);
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "us[128]",params[0],params[1])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /sban [id/ник] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	//if(GetPlayerState(params[0]) != 1 && GetPlayerState(params[0]) != 2 && GetPlayerState(params[0]) != 3) return SendClientMessage(playerid, COLOR_GRAD1, "Игрок оффлайн / не залогинен");
	new ip[15];
	new year1, month1, day1, hour1, minute1, second1;
	getdate(year1, month1, day1);
	gettime(hour1, minute1, second1);
	GetPlayerIp(params[0],ip,15);
	if(User[params[0]][pAdmin] && User[playerid][pAdmin] < 7) return BanAdmin(playerid);
	format(YCMDstr, sizeof(YCMDstr), "SBan[забанил: %s][забанен: %s][причина: %s][%i/%i/%i  %i:%i]",User[playerid][pName], User[params[0]][pName], params[1], day1,month1,year1,hour1, minute1);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	format(YCMDstr, sizeof(YCMDstr), "   Nik [%s]  R-IP [%s]  L-IP [%s]  IP [%s]",User[params[0]][pName],User[params[0]][pIpReg],User[params[0]][pvIp],ip);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,2);
	new null;
	if(User[params[0]][pDonateRank] == 0) null = 30;
	//if(User[params[0]][pDonateRank] == 1) null = 21;
	//if(User[params[0]][pDonateRank] == 2) null = 14;
	if(User[params[0]][pDonateRank] == 1) null = 7;
	KickEx(params[0], "Sban admin");
	mysql_format(dbHandle,QUERY, 300, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('SBAN:  %s', '%s', '%s', '%i/%i/%i', '%i')",params[1],User[params[0]][pName],User[playerid][pName],day1,month1,year1, mktime(5,0,0,day1+null,month1,year1));
	mysql_tquery(dbHandle,QUERY,"","");
	AdminInfo[playerid][admBaned]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET baned = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admBaned], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	return true;
}
CMD:freeze(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /freeze [playerid]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pAdmin] > User[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GREY, "Его нельзя");
	TogglePlayerControllable(params[0], 0);
	format(YCMDstr, sizeof(YCMDstr), "%s был заморожен администратором %s",User[params[0]][pName],User[playerid][pName]);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	return true;
}
CMD:unfreeze(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /unfreeze [playerid]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pAdmin] > User[playerid][pAdmin]) return SendClientMessage(playerid, COLOR_GREY, "Его нельзя");
	TogglePlayerControllable(params[0], 1);
	format(YCMDstr, sizeof(YCMDstr), "Администратор: %s разморозил %s",User[playerid][pName],User[params[0]][pName]);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	return true;
}
CMD:camera(playerid, params[])
{
    if(User[playerid][pMember] != 19) return SendClientMessage(playerid, COLOR_GREY, "Вы не состоите в рядах Зоны 51");
	if(!PlayerToPoint(2.0,playerid,212.2816,1812.2374,21.8672)) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не у точки наблюдения");
	new listitems[] = "Сектор - 1\nСектор - 2\nСектор - 3\nСектор - 4";
	ShowPlayerDialogEx(playerid, 7724, DIALOG_STYLE_LIST, "Выберите камеру", listitems, "Выбрать", "Закрыть");
	return true;
}
CMD:cameraoff(playerid, params[])
