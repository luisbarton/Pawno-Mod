{
    return true;
}
public OnVehicleMod(playerid, vehicleid, componentid)
{
	new vehicleide = GetVehicleModel(vehicleid);
	new modok = IsLegalCarMod(vehicleide, componentid);
	if(!modok) KickEx(playerid, "OnVehicleMod");
	return true;
}
stock AdvertList(playerid)
{
	new full, str[90], strrr[600];
	switch(User[playerid][pMember])
	{
	case 16: full = 0;
	case 9: full = 1;
	case 20: full = 2;
	}
	for(new i = 1; i <= TOTALADVERT[full];i++)
	{
		format(str, sizeof(str), " [%i] Прислал: %s, Номер: %i\n",i, AdvertInfo[i][full][adName], AdvertInfo[i][full][adPhone]);
		strcat(strrr, str);
	}
	if(TOTALADVERT[full] == 0) return ShowPlayerDialogEx(playerid, 69, 0, "Объявления", "    Новых объявлений нет", "Назад", "");
	return ShowPlayerDialogEx(playerid, 11518, 2, "Объявления", strrr, "Принять", "Отмена");
}
