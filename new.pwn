//new KillsAmount[15];
//new MafiaWarTimer;
new GzCheckTimer;//, GzCheckTimerSF;
new GzCheckOn = 0;//, GzCheckOnSF = 0;
new captures = 0;//, capturessf = 0;
// ----------------------------------------------------------------

new TotalGzR;
new TotalGzA;
new TotalGzB;
new TotalGzG;
new TotalGzV;
new OnZONE[131][20];
new ZoneOnBattle[131];
//new ZoneOnBattleSF[56];
new allowedfactions[] = {12,13,15,17,18};
//new allowedfactionsSF[] = {34,35,36};
new GZSafeTime[131];
//new GZSafeTimeSF[56];
enum GzoneInfo
{
	gID,
	gZone,
	Float:gCoords[4],
	gFrakVlad,
	gNapad
}
new GZInfo[131][GzoneInfo], TOTALGZ;
new FrakCD[20];

publics: GzCheck()
{
	new str[144];
	for(new i = 1; i <= TOTALGZ; i++)
	{
		if(!ZoneOnBattle[i]) continue;
  		if(GZSafeTime[i] > 0) GZSafeTime[i] --;
		foreach(new x : Player)
		{
			if(!User[x][pLogin]) continue;
			new y = User[x][pMember];
			if(y == GZInfo[i][gNapad] || y == GZInfo[i][gFrakVlad])
			{
				if(!GetPVarInt(x,"capture_on"))
				{
					CaptureTextDrawss(x);

				    PlayerTextDrawColor(x, CaptureG[x][2], GetGangColor(GZInfo[i][gNapad]));
				    PlayerTextDrawColor(x, CaptureG[x][4], GetGangColor(GZInfo[i][gFrakVlad]));

				    PlayerTextDrawShow(x, CaptureG[x][0]);
        			PlayerTextDrawShow(x, CaptureG[x][1]);
           			PlayerTextDrawShow(x, CaptureG[x][2]);
           			PlayerTextDrawShow(x, CaptureG[x][3]);
           			PlayerTextDrawShow(x, CaptureG[x][4]);
           			PlayerTextDrawShow(x, CaptureG[x][5]);
					SetPVarInt(x,"capture_on",1);
					SetPlayerToTeamColor(x);
				}
				if(GZSafeTime[i] > 0)
				{
					format(YCMDstr,36,"TIME:           %s",Convert(GZSafeTime[i]));
					if(GZSafeTime[i] < 60) format(YCMDstr,36,"TIME:           ~r~%s",Convert(GZSafeTime[i]));
					PlayerTextDrawSetString(x,CaptureG[x][1],YCMDstr);
				}

				format(YCMDstr,36,"%s          %d",GetGangName(GZInfo[i][gNapad]),CountOnZone[GZInfo[i][gNapad]]);
				PlayerTextDrawSetString(x,CaptureG[x][3],YCMDstr);
				format(YCMDstr,36,"%s          %d",GetGangName(GZInfo[i][gFrakVlad]), CountOnZone[GZInfo[i][gFrakVlad]]);
				PlayerTextDrawSetString(x,CaptureG[x][5],YCMDstr);
				if(PlayerToKvadrat(x,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3])) OnZONE[i][y] ++;
			}
		}
		new asd;
		for(new x =0;x<20;x++)
		{
			if(OnZONE[i][x] > 0 && IsInAllowedF(x) && GZSafeTime[i] <= 0) asd++;
		}
		if(asd == 1)
		{
			for(new x =0;x<20;x++)
			{
				if(OnZONE[i][x] > 0)
				{
					if(GZInfo[i][gFrakVlad] == x)
					{
						SendFamilyMessage(GZInfo[i][gFrakVlad],0x00B953AA,"Вы отстояли свою территорию");
						SendFamilyMessage(GZInfo[i][gNapad],0xC56565AA,"Вам не удалось захватить территорию");
						CountOnZone[GZInfo[i][gFrakVlad]] = 0;
						CountOnZone[GZInfo[i][gNapad]] = 0;
						foreach(new y : Player)
						{
							if(User[y][pMember] == GZInfo[i][gNapad] || User[y][pMember] == GZInfo[i][gFrakVlad])
							{
								DeletePVar(y,"capture_on");
								for(new t = 0x0; t != 6;t++) PlayerTextDrawHide(y,CaptureG[y][t]);
								for(new i_ = 0; i_ < 5; i_++) { SendDeathMessageToPlayer(y,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0); }
							}
						}
					}
					else
					{
						CountOnZone[GZInfo[i][gFrakVlad]] = 0;
						CountOnZone[GZInfo[i][gNapad]] = 0;
						SendFamilyMessage(GZInfo[i][gNapad], 0x00B953AA,"Вы взяли под свой контроль новую территорию");
						for(new y = 1; y <= TOTALGZ; y++)
						{
							if(GZInfo[y][gFrakVlad] == 12) TotalGzB++;
							if(GZInfo[y][gFrakVlad] == 13) TotalGzV++;
							if(GZInfo[y][gFrakVlad] == 15) TotalGzG++;
							if(GZInfo[y][gFrakVlad] == 17) TotalGzA++;
							if(GZInfo[y][gFrakVlad] == 18) TotalGzR++;
						}
						switch(GZInfo[i][gNapad])
						{
							case 12: format(str, sizeof(str), "Теперь ваша банда будет получать каждый час %i вирт",TotalGzB*50);
							case 13: format(str, sizeof(str), "Теперь ваша банда будет получать каждый час %i вирт",TotalGzV*50);
							case 15: format(str, sizeof(str), "Теперь ваша банда будет получать каждый час %i вирт",TotalGzG*50);
							case 17: format(str, sizeof(str), "Теперь ваша банда будет получать каждый час %i вирт",TotalGzA*50);
							case 18: format(str, sizeof(str), "Теперь ваша банда будет получать каждый час %i вирт",TotalGzR*50);
						}
						SendFamilyMessage(GZInfo[i][gFrakVlad], 0xC56565AA,"Вы потеряли контроль одной из своих территорий");
						foreach(new y : Player)
						{
							if(User[y][pMember] == GZInfo[i][gNapad] || User[y][pMember] == GZInfo[i][gFrakVlad])
							{
								DeletePVar(y,"capture_on");
								for(new t = 0x0; t != 6;t++) PlayerTextDrawHide(y,CaptureG[y][t]);
								for(new i_ = 0; i_ < 5; i_++) { SendDeathMessageToPlayer(y,INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0); }
							}
						}
						GZInfo[i][gFrakVlad] = GZInfo[i][gNapad];
						SendFamilyMessage(GZInfo[i][gNapad], 0x00B953AA, str);
					}
					captures--;
					ClearTotalGz();
					ZoneOnBattle[i] = 0;
					GangZoneStopFlashForAll(GZInfo[i][gZone]);
					GangZoneHideForAll(GZInfo[i][gZone]);
					GangZoneShowForAll(GZInfo[i][gZone],GetGangZoneColor(i));
					GZInfo[i][gNapad] = 0;
					UpdateTable("gangzone","gang_owner",GZInfo[i][gFrakVlad],"id",GZInfo[i][gID]);
					if(captures == 0) KillTimer(GzCheckTimer), GzCheckOn = 0;
					break;
				}
			}
		}
	}
	for(new i = 1; i <= TOTALGZ; i++)
	{
		for(new z = 0;z<20;z++)
		{
			OnZONE[i][z] =0;
		}
	}
	return true;
}

stock IsInAllowed(playerid)
{
	for(new i = 0; i < sizeof(allowedfactions); i++)
	{
		if(User[playerid][pMember] == allowedfactions[i]&&User[playerid][pRank] >= 7) return true;
	}
	return false;
}

stock IsAPlane(carid){switch(GetVehicleModel(carid)){case 592,577,511,512,593,520,553,476,519,460,513,548,417,487,488,497,563,447,469,425:return true;}return false;}
publics: IsAGunsCar(carid)
{
	if(carid == gunscar[0]
			||carid == gunscar[1]
			||carid == gunscar[2]
			||carid == gunscar[3]
			||carid == gunscar[4]
			||carid == gunscar[5])
	{
		return true;
	}
	return false;
}
