stock SaveOtherServer()
{
	new t_query[512];
    format(t_query, sizeof(t_query), "UPDATE `others` SET `bank_lsnews` = '%d', `bank_sfnews` = '%d', `bank_lvnews` = '%d', `bank_ballas` = '%d', \
	`bank_vagos` = '%d', `bank_grove` = '%d', `bank_aztec` = '%d', `bank_exchequer` = '%d', `bank_ssmc` = '%d',  `bank_hamc` = '%d', \
	`bank_omc` = '%d', `bank_wmc` = '%d', `bank_hwmc` = '%d', `bank_fsmc` = '%d', `bank_pmc` = '%d', `bank_mmc` = '%d', `bank_vmc` = '%d', `bank_bmc` = '%d'",
	FracBank[0][fLsnews],FracBank[0][fSfnews],FracBank[0][fLvnews],FracBank[0][fBallas],FracBank[0][fVagos],
	FracBank[0][fGrove],FracBank[0][fAztek],FracBank[0][fKazna],FracBank[0][fSsmc],FracBank[0][fHamc],
	FracBank[0][fOmc],FracBank[0][fWmc],FracBank[0][fHwmc],FracBank[0][fFsmc],FracBank[0][fPmc],
	FracBank[0][fMmc],FracBank[0][fVmc],FracBank[0][fBmc]);
	mysql_tquery(dbHandle, t_query, "", "");
	t_query = "";
	format(t_query, sizeof(t_query),"UPDATE `others` SET `heal_ballas`= '%d',`heal_grove`= '%d',`heal_vagos`= '%d',`heal_aztec`= '%d',`heal_rifa`= '%d',`adprice_ls`= '%d', \
	`adprice_sf`= '%d',`adprice_lv`= '%d',`healprice`= '%d',`heal_yakuza`= '%d',`heal_lcn`= '%d',`heal_rm`= '%d', \
	`mats_lsa`= '%d',`mats_lva`= '%d',`mats_sfa`= '%d',`mats_hamc`= '%d'",
	ballashel,groovhel,vagoshel,aztekhel,rifahel,addd[0],addd[1],addd[2],healpric,yakuzahel,lcnhel,rmhel,FracStore[LSaStore],FracStore[LVaStore],FracStore[SFaStore],FracStore[HellsAngels]);
	mysql_tquery(dbHandle, t_query, "", "");
	t_query = "";
	format(t_query, sizeof(t_query),"UPDATE `others` SET `mats_wmc`= '%d',`mats_pmc`= '%d', \
	`mats_rifa`= '%d',`mats_ballas`= '%d',`mats_aztec`= '%d',`mats_vagos`= '%d',`mats_grove`= '%d',`mats_lspd`= '%d', \
	`mats_fbi`= '%d',`mats_yakuza`= '%d',`mats_rm`= '%d',`mats_lcn`= '%d',`mats_sfpd`= '%d',`mats_lvpd`= '%d'",
	FracStore[Warlocks],FracStore[Pagans],FracStore[Rifa],FracStore[Ballas],FracStore[Aztec],FracStore[Vagos],
	FracStore[Grove],FracStore[LSPD],FracStore[FBI],FracStore[Yakuza],FracStore[RM],FracStore[LCN],FracStore[SFPD],FracStore[LVPD]);
	mysql_tquery(dbHandle, t_query, "", "");
	t_query = "";
	format(t_query, sizeof(t_query),"UPDATE `others` SET `bank_lcn`= '%d',`bank_yakuza`= '%d',`bank_rm`= '%d',`rifasklad` = '%d',`ballassklad`= '%d', \
	`grovesklad`= '%d',`vagossklad`= '%d',`azteksklad`= '%d',`nalog` = '%d'",MafiaBank[0][nLcn],MafiaBank[0][nYakuza],MafiaBank[0][nRm],
	FracStore[RifaStatus], FracStore[BallasStatus], FracStore[GroveStatus], FracStore[VagosStatus], FracStore[AztecStatus], nalog);
	mysql_tquery(dbHandle, t_query, "", "");
	t_query = "";
	format(t_query, sizeof(t_query),"UPDATE `others` SET `MOROZ_BALLAS`= '%d',`MOROZ_VAGOS`= '%d',`MOROZ_GROVE`= '%d',`MOROZ_RIFA` = '%d',`MOROZ_AZTECAS`= '%d', \
	`Conf`= '%d',`mats_crips`= '%d',`mats_triada`= '%d',`mats_bloods`= '%d'",fracmoroz[0],fracmoroz[1],fracmoroz[2],fracmoroz[3], fracmoroz[4], Conf, FracStore[Crips], FracStore[Triada], FracStore[Bloods]);
	mysql_tquery(dbHandle, t_query, "", "");
	print("[Save Other] Good!");
	return 1;
}
