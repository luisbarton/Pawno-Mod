CMD:arrest(playerid, params[])
{
	if(GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 1 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 10 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 21)
	if(PlayerToPoint(6.0, playerid, 268.3327,77.8972,1001.0391) || PlayerToPoint(6.0, playerid, 227.7436,114.5075,999.0156) || PlayerToPoint(6.0, playerid, 198.1339,158.4835,1003.0234)|| PlayerToPoint(6.0, playerid, 218.2263,114.9286,999.0156) || PlayerToPoint(6.0, playerid, 198.3940,157.9389,1003.0234))
	{
		if(sscanf(params, "d",params[0])) return SCM(playerid, COLOR_GREY, "Используйте: /arrest [id игрока]");
		if(params[0] == playerid) return SCM(playerid, COLOR_GREY, "Вы указали свой ID");
		if(!IsPlayerConnected(params[0])) return true;
		if(!ProxDetectorS(4.0, playerid, params[0])) return true;
		if(User[playerid][pKeys] == 0) return SCM(playerid, COLOR_GREY, "У Вас нету ключей от камеры!");
		if(User[params[0]][pWantedLevel] < 1) return SCM(playerid, COLOR_GREY, "Человек должен иметь хотя бы 1 уровень розыска!");
		format(YCMDstr, sizeof(YCMDstr), "Вы посадили в тюрьму %s на %d секунд",User[params[0]][pName],User[params[0]][pWantedLevel]*600);
		SCM(playerid, COLOR_BLUE, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Вас посадили в тюрьму %s на %d секунд",User[playerid][pName],User[params[0]][pWantedLevel]*600);
		SCM(params[0], COLOR_BLUE, YCMDstr);
		SCM(params[0],-1,"Ваша узнаваемость понизилась");
		User[playerid][pPayCheck]+= 200*User[params[0]][pWantedLevel];
		ResetPlayerWeaponsEx(params[0]);
		foreach(new i:Player)
		{
			if(User[i][pMember] == 1 ||User[i][pLeader] == 1 || User[i][pMember] == 10 ||User[i][pLeader] == 10 || User[i][pMember] == 2 ||User[i][pLeader] == 2 || User[i][pMember] == 21 || User[i][pLeader] == 21)
			{
				switch(User[playerid][pMember])
				{
							case 1,10,21: format(YCMDstr, sizeof(YCMDstr), "<< Офицер %s арестовал %s >>",User[playerid][pName],User[params[0]][pName]), SCM(i, COLOR_LIGHTRED,YCMDstr);
							case 2: format(YCMDstr, sizeof(YCMDstr), "<< Агент FBI %s арестовал %s >>",User[playerid][pName],User[params[0]][pName]), SCM(i, COLOR_LIGHTRED,YCMDstr);
				}
			}
		}
		SetPlayerSpecialAction(params[0],SPECIAL_ACTION_NONE);
		RemovePlayerAttachedObject(params[0],0);
		DeletePVar(params[0], "PlayerCuffed");
		DeletePVar(params[0], "PlayerCuffedTime");
		if(PlayerToPoint(15.0, playerid, 2413.9221,2488.2910,1563.6757))
		{
			t_SetPlayerPos(params[0],2416.1682,2488.2820,1563.6757);
			SetPlayerFacingAngle(params[0], 89.8888);
			SetCameraBehindPlayer(params[0]);
			User[params[0]][pJailTime] = User[params[0]][pWantedLevel]*600;
			User[params[0]][pWantedLevel] = 0;
			User[params[0]][pArrested] += 1;
			User[params[0]][pMestoJail] = 1;
			SetPlayerWantedLevel(params[0], 0);
			TogglePlayerControllable(params[0], 1);
			User[params[0]][PlayerFollow] = -1;
		}
		else if(PlayerToPoint(6.0, playerid, 218.2263,114.9286,999.0156))
		{
			SetPlayerInterior(params[0], 10);
			t_SetPlayerPos(params[0],219.5400,109.9767,999.0156);
			SetPlayerFacingAngle(params[0], 1.0000);
			User[params[0]][pJailTime] = User[params[0]][pWantedLevel]*600;
			User[params[0]][pWantedLevel] = 0;
			User[params[0]][pArrested] += 1;
			User[params[0]][pMestoJail] = 2;
			SetPlayerWantedLevel(params[0], 0);
			TogglePlayerControllable(params[0], 1);
			User[params[0]][PlayerFollow] = -1;
		}
		else if(PlayerToPoint(6.0, playerid, 198.3940,157.9389,1003.0234))
		{
			SetPlayerInterior(params[0], 3);
			t_SetPlayerPos(params[0],198.3642,161.8103,1003.0300);
			SetPlayerFacingAngle(params[0], 1.0000);
			User[params[0]][pJailTime] = User[params[0]][pWantedLevel]*600;
			User[params[0]][pWantedLevel] = 0;
			User[params[0]][pArrested] += 1;
			User[params[0]][pMestoJail] = 3;
			SetPlayerWantedLevel(params[0], 0);
			TogglePlayerControllable(params[0], 1);
			User[params[0]][PlayerFollow] = -1;
		}
	}
	return true;
}
CMD:fare(playerid)
{
    if(!User[playerid][pLogin] || User[playerid][pJob] != 4) return true;
	if(GetPVarInt(playerid,"TaxiDuty") > 0)
	{
	    SendClientMessage(playerid,COLOR_GREY, " Вы закончили рабочий день");
	    for ( new i = 0; i < 6 ; i ++ )
		{
			TextDrawHideForPlayer ( playerid, TaxiTD [ i ] ) ;
		}
		PlayerTextDrawHide(playerid, TaxiZP[playerid][0]);
		PlayerTextDrawHide(playerid, TaxiZP[playerid][1]);
		if(IsValidDynamic3DTextLabel(TaxiText3D[playerid])) DestroyDynamic3DTextLabel(TaxiText3D[playerid]);
		DeletePVar(playerid,"TaxiDuty");
		return true;
	}
	new Veh = GetPlayerVehicleID(playerid);
	if(Veh != GetPVarInt(playerid,"rentcar_job")) return SendClientMessage(playerid,COLOR_GREY, "Это не Ваш автомобиль");
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid,COLOR_GREY, "Вы должны находиться за рулем автомобиля!");
	if((Veh >= taxicar[0] && Veh <= taxicar[37]) || (Veh >= taxi5lvlcar[0] && Veh <= taxi5lvlcar[4]) || (Veh >= taxi10lvlcar[0] && Veh <= taxi10lvlcar[7]))
	{
	    for ( new i = 0; i < 6 ; i ++ )
		{
			TextDrawShowForPlayer ( playerid, TaxiTD [ i ] ) ;
		}
		PlayerTextDrawShow(playerid, TaxiZP[playerid][0]);
		PlayerTextDrawShow(playerid, TaxiZP[playerid][1]);
		new str[11];
		format(str,sizeof(str),"%d$",User[playerid][pPayCheck]);
		PlayerTextDrawSetString(playerid,TaxiZP[playerid][0],str);
	    SetPVarInt(playerid,"TaxiDuty",Veh);
		//JobText3D[Veh] = Create3DTextLabel("Бесплатное такси", 0xFFFF00FF, 9999.0, 9999.0, 9999.0, 30.0,0,1);
		//Attach3DTextLabelToVehicle(JobText3D[Veh], Veh, 0, 0, 1.5);
		if(!IsValidDynamic3DTextLabel(TaxiText3D[playerid])) TaxiText3D[playerid] = CreateDynamic3DTextLabel("{FFFFFF}[»] {FFFF00}Бесплатное такси", 0xFFFF00FF, 0.0, 0.0, 1.24, 40.0, INVALID_PLAYER_ID, GetPlayerVehicleID(playerid));
		
	}
	return true;
}
CMD:frisk(playerid, params[])
{
    if(!IsACop(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Вам недоступна данная команда");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /frisk [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(3.0, playerid, params[0])) return true;
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете обыскать себя!");
	format(YCMDstr, sizeof(YCMDstr), "Вещи %s", User[params[0]][pName]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " %s.",(User[params[0]][pDrugs])?("| Наркотики.") : ("| Пустой карман."));
	SendClientMessage(playerid, COLOR_GREY, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " %s.",(User[params[0]][pDrugs])?("| Материалы.") : ("| Пустой карман."));
	SendClientMessage(playerid, COLOR_GREY, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "%s обыскал %s", User[playerid][pName] ,User[params[0]][pName]);
	SetPlayerSpecialAction(params[0],SPECIAL_ACTION_HANDSUP);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	return true;
}
CMD:wanted(playerid, params[])
{
    new sctring[500];
    if(!IsACop(playerid) || !GetPVarInt(playerid, "Fraction_Duty")) return SendClientMessage(playerid, COLOR_GREY, "Вы не законник");
    foreach(new i : Player)
	{
		if(User[i][pWantedLevel] >= 1)
		{
  			format(YCMDstr,sizeof(YCMDstr), "%s\t|\tУровень розыска: %i\n",User[i][pName],User[i][pWantedLevel]);
			strcat(sctring,YCMDstr);
		}
	}
	if (strlen(sctring) > 1) ShowPlayerDialogEx(playerid, 11349,DIALOG_STYLE_MSGBOX, "Розыскиваются", sctring, "Закрыть", "");
	else SendClientMessage(playerid,-1,"Нет розыскиваемых");
	return true;
}
CMD:mdc(playerid, params[])
{
	if(!IsACop(playerid) || !GetPVarInt(playerid, "Fraction_Duty")) return SendClientMessage(playerid, COLOR_GREY, "Вы не полицейский!");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /mdc [id]");
	if(IsPlayerConnected(params[0]))
	{
		SendClientMessage(playerid, TEAM_BLUE_COLOR, "---======== МОБИЛЬНЫЙ КОМПЬЮТЕР ДАННЫХ ========---");
		format(YCMDstr, sizeof(YCMDstr), "Имя: %s", User[params[0]][pName]), SendClientMessage(playerid, COLOR_WHITE,YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Преступление: %s", PlayerCrime[params[0]][pAccusedof]), SendClientMessage(playerid, COLOR_GRAD2,YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Сообщил: %s", PlayerCrime[params[0]][pVictim]), SendClientMessage(playerid, COLOR_GRAD3,YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Уровень розыска: %i", User[params[0]][pWantedLevel]), SendClientMessage(playerid, COLOR_GRAD4,YCMDstr);
		SendClientMessage(playerid, TEAM_BLUE_COLOR, "---============================================---");
	}
	return true;
}
CMD:patrul(playerid, params[])
{
	new veh = GetPlayerVehicleID(playerid);
	if(!IsACop(playerid)) return SCM(playerid, COLOR_GREY, "Вам недоступна данная функция!");
	if(GetVehicleModel(veh) != 560 && GetVehicleModel(veh) != 596 && GetVehicleModel(veh) != 490 && GetVehicleModel(veh) != 597 && GetVehicleModel(veh) != 598) return SCM(playerid, COLOR_GREY, "Вы должны находится в патрульном автомобиле!");
	new Float: x, Float: y, Float: z;
	GetPlayerPos(playerid, x, y, z);
	foreach(new i : Player)
	{
		if(IsPlayerInRangeOfPoint(i, 150.0, x, y, z) && User[i][pWantedLevel] > 0)
		{
			GetPlayerPos(i, x, y, z);
			SetPlayerCheckpoint(playerid, x, y, z, 1.0);
			SetPVarInt(playerid, "Patrul", 1);
			SCM(playerid, COLOR_BLUE, "Преступник успешно найден!");
			break;
		}
	}
	if(!GetPVarInt(playerid, "Patrul")) SCM(playerid, COLOR_GREY, "Преступник не был найден!");
	return true;
}
CMD:megaphone(playerid, params[])
{
    if(!IsPlayerConnected(playerid) || !GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/m)egaphone [текст]");
	switch(User[playerid][pMember])
	{
		case 1,10,21:
		{
		    if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 427 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 523 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 596 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 497 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 598  && GetVehicleModel(GetPlayerVehicleID(playerid)) != 597) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не в полицейской машине");
			format(YCMDstr, sizeof(YCMDstr), "{{ Офицер %s: %s }}",User[playerid][pName],params[0]);
			SendBeside(playerid,COLOR_YELLOW,YCMDstr,80.0);
		}
		case 3,19:
		{
            new carid = GetPlayerVehicleID(playerid);
            if(GetVehicleModel(carid) != 425
            && GetVehicleModel(carid) != 470
            && GetVehicleModel(carid) != 433
            && GetVehicleModel(carid) != 432
            && GetVehicleModel(carid) != 520
            && GetVehicleModel(carid) != 500
            && GetVehicleModel(carid) != 497
            && GetVehicleModel(carid) != 548) return SendClientMessage(playerid, COLOR_GREY, "Вы не в солдатской машине");
			format(YCMDstr, sizeof(YCMDstr), "{{ Солдат %s: %s }}",User[playerid][pName],params[0]);
			SendBeside(playerid,COLOR_YELLOW,YCMDstr,80.0);
		}
		case 2:
		{
			if(GetPlayerVehicleID(playerid) >= fbicar[0] && GetPlayerVehicleID(playerid) <= fbicar[16])
			{
				format(YCMDstr, sizeof(YCMDstr), "{{ Агент FBI %s: %s }}",User[playerid][pName],params[0]);
				SendBeside(playerid,COLOR_YELLOW,YCMDstr,80.0);
			}
		}
	}
	return true;
}
CMD:amegaphone(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
    if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/am)egaphone [текст]");
	if(User[playerid][pAdmin] >= 3 && User[playerid][pAdmin] <= 10)
	{
	    format(YCMDstr, sizeof(YCMDstr), "{{ %s: %s }}",User[playerid][pName],params[0]);
	    SendBeside(playerid,COLOR_YELLOW,YCMDstr,80.0);
	}
	return true;
}
ALTX:vip("/v");
CMD:vip(playerid, params[])
{
	new string[170];
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата!");
	if(sscanf(params, "s[128]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/v)ip [текст]");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	if(User[playerid][pDonateRank] != 1) return true;
	format(string, sizeof(string), "[VIP-CHAT] %s: %s", User[playerid][pName], params[0]);
	SendVipMessage(COLOR_YELLOW2, string);
	return true;
}
ALTX:job("/j");
