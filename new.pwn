					{
						if(User[playerid][pCash] < BizzInfo[i][bEntranceCost])
						{
							SendClientMessage(playerid, COLOR_GRAD1, "У вас нет столько денег");
							return true;
						}
						PickupX[playerid] = BizzInfo[i][bExitX], PickupY[playerid] = BizzInfo[i][bExitY];
						oldpickup[playerid] = BizzInfo[i][bExitPic];
						timepickup[playerid] = 3;
						User[playerid][pCash] -=BizzInfo[i][bEntranceCost];
						BizzInfo[i][bTill] += BizzInfo[i][bEntranceCost], BizzPayForDay[i] += BizzInfo[i][bEntranceCost];
						BizzPay[i] += BizzInfo[i][bEntranceCost];
						SetPlayerInterior(playerid,BizzInfo[i][bInterior]);
						t_SetPlayerPos(playerid,BizzInfo[i][bExitX],BizzInfo[i][bExitY],BizzInfo[i][bExitZ]);
                        SetPlayerVirtualWorld(playerid,BizzInfo[i][bVirtualWorld]);
						enterbiz[playerid] = i;
						return true;
					}
				}
			}
			else
			{
				return true;
			}
		}
