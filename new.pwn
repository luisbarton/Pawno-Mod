				    format(YCMDstr, sizeof(YCMDstr), "UPDATE accounts SET pLeader = '0',pMember = '0',pRank = '0',pJobHealLeader = '0',pJobHeal = '0' WHERE Name = '%s'",str);
					mysql_tquery(dbHandle,YCMDstr,"","");
					SCM(playerid,COLOR_GREY,"Игрок был уволен (Если игрок был онлайн, увольнения не произойдет)");
					return true;
				}
			    else return SCM(playerid,COLOR_GREY,"Игрок не состоит в вашей организации");
			}
			else SCM(playerid, COLOR_GRAD1,"Не найдено совпадений");
		}
		case 40:
  		{
  			if(r)
	    	{
	    	    new donzach;
	    	    cache_get_value_name_int(0,"pDonZach",donzach);
                if(donzach <= 0) return SCM(playerid,COLOR_WHITE,"Пополнения счета аккаунта не найдены.");
                mysql_format(dbHandle, YCMDstr, sizeof(YCMDstr), "UPDATE `accounts` SET `pDonZach` = 0 WHERE `Name` = '%e'",Name(playerid));
				mysql_tquery(dbHandle,YCMDstr,"","");
				if(Conf == 1)
				{
					User[playerid][pDonateAccount] += donzach*2;
					format(QUERY, sizeof(QUERY), "~w~+%dRUB",donzach*2);
					GameTextForPlayer(playerid, QUERY, 1000, 1);
					format(QUERY, sizeof(QUERY), "{FFFFFF}Сумма была зачислена на Ваш аккаунт.\nВы успешно пополнили счет на {66CC00}%d.00 руб.\n\n{FFFFFF}Используйте /donate", donzach*2);
					ShowPlayerDialogEx(playerid,0,DIALOG_STYLE_MSGBOX,"{E5D81E}Счет пополнен",QUERY,"Закрыть","");
					return SCM(playerid, COLOR_YELLOW, "Ваша сумма была удвоена, на сервере действует акция х2 Донат");
				}
				User[playerid][pDonateAccount] += donzach;
				format(QUERY, sizeof(QUERY), "~w~+%dRUB",donzach);
				GameTextForPlayer(playerid, QUERY, 1000, 1);
				format(QUERY, sizeof(QUERY), "{FFFFFF}Сумма была зачислена на Ваш аккаунт.\nВы успешно пополнили счет на {66CC00}%d.00 руб.\n\n{FFFFFF}Используйте /donate", donzach);
				ShowPlayerDialogEx(playerid,0,DIALOG_STYLE_MSGBOX,"{E5D81E}Счет пополнен",QUERY,"Закрыть","");
			}
		}
		case 41:
		{
		    if(r)
		    {
		        new zachinfo;
				cache_get_value_name_int(0,"pDonZach",zachinfo);
		        format(QUERY,sizeof(QUERY), "%s%s%s%s%s\n{ffffff}Номер аккаунта:\t\t%d\nТекущее состояние счета:\t%d рублей",DonMes[0],DonMes[1],DonMes[2],DonMes[3],DonMes[4],PlayerIDs[playerid],User[playerid][pDonateAccount]);
				if(zachinfo > 0) strcat(QUERY, "\n\n{66CC00}Есть новые пополнения счета игрового аккаунта. Введите /donat");
				ShowPlayerDialogEx(playerid,9652,DIALOG_STYLE_MSGBOX, "{E5D81E}Дополнительно",QUERY, "Далее", "Назад");
			}
		}
		case 42:
		{
			if(!r)
			{
				return printf("[Error] Информация о машинах игрока в бд не найдена");
			}
			new temp[0x9e];
			for(x = 0; x < r; x++)
			{
				mysql_format(dbHandle, QUERY, sizeof(QUERY), "UPDATE `cars` SET ");
				format(temp,sizeof(temp),"`model`= '%i',",CarInfo[playerid][carModel][x]), 				strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`color_one`= '%i',",CarInfo[playerid][carColor_one][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`color_two`= '%i',",CarInfo[playerid][carColor_two][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`percent`= '%i',",CarInfo[playerid][carPercent][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`fuel`= '%f',",CarInfo[playerid][carFuel][x]), 					strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_1`= '%i',",CarInfo[playerid][carVehcom_1][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_2`= '%i',",CarInfo[playerid][carVehcom_2][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_3`= '%i',",CarInfo[playerid][carVehcom_3][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_4`= '%i',",CarInfo[playerid][carVehcom_4][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_5`= '%i',",CarInfo[playerid][carVehcom_5][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_6`= '%i',",CarInfo[playerid][carVehcom_6][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_7`= '%i',",CarInfo[playerid][carVehcom_7][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_8`= '%i',",CarInfo[playerid][carVehcom_8][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_9`= '%i',",CarInfo[playerid][carVehcom_9][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_10`= '%i',",CarInfo[playerid][carVehcom_10][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_11`= '%i',",CarInfo[playerid][carVehcom_11][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_12`= '%i',",CarInfo[playerid][carVehcom_12][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_13`= '%i',",CarInfo[playerid][carVehcom_13][x]), 		strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp),"`vehcom_14`= '%i'",CarInfo[playerid][carVehcom_14][x]), 			strcat(QUERY,temp,sizeof(QUERY));
				format(temp,sizeof(temp)," WHERE id = '%i'",CarInfo[playerid][carID][x]),					strcat(QUERY,temp,sizeof(QUERY));
				//mysql_function_query(dbHandle, QUERY, true, "", "");
				mysql_tquery(dbHandle, QUERY, "", "");
			}
			printf("[Сохранение] Автомобили %s | %i,%i,%i соханены", User[playerid][pName],CarInfo[playerid][carModel][0],CarInfo[playerid][carModel][1],CarInfo[playerid][carModel][2]);
		}
		case 43:
		{
			new unvipdate;//String[100];
		    if(r)
		    {
		        cache_get_value_name_int(0, "UNPremium", unvipdate);
		        if(gettime() >= unvipdate)
		        {
		            mysql_format(dbHandle,QUERY, 300, "DELETE FROM `"TABLE_Premium"` WHERE `Name` = '%s'", User[playerid][pName]);
					mysql_tquery(dbHandle,QUERY,"","");
		            User[playerid][pDonateRank] = 0;
		            SendClientMessage(playerid,0xFFFFFFAA,"Внимание!");
					SendClientMessage(playerid,0xFFFFFFAA,"Время вашего Премиум аккаунта истекло!");
					SendClientMessage(playerid,0xFFFFFFAA,"Премиум аккаунт был отключен!");
		            return true;
		        }
		        else
		        {
		        }
			}
		}
	}
	return true;
}
forward LoadPlayerCar(playerid);
public LoadPlayerCar(playerid)
{
	if(playerid == INVALID_PLAYER_ID) return 1;
	static const fmt_query[] = "SELECT * FROM `cars` WHERE `owner` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
    format(query, sizeof(query), fmt_query, User[playerid][pName]);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",33,playerid,"");
	return 1;
}

