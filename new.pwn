CMD:balance(playerid)
{
	new string[30];
    for(new i = 1; i <= TOTALATM; i++)
	{
	    if(!IsPlayerInRangeOfPoint(playerid, 2.0,ATMInfo[i][aX],ATMInfo[i][aY],ATMInfo[i][aZ]) || !IsABank(playerid)) continue;
	    format(string, sizeof(string), "Баланс: %d вирт", User[playerid][pBank]);
	    SendClientMessage(playerid, 0x6495EDFF, string);
	    return 1;
	}
	format(string, sizeof(string), "Баланс: %d вирт", User[playerid][pBank]);
	SendClientMessage(playerid, 0x6495EDFF, string);
	return 1;
}
CMD:inventory(playerid)
{
//    new wep,
   	new	    strinv[48],
        inventory[700];
    format(inventory, sizeof(inventory), "Key\tВещи\tКоличество\n");
	if(User[playerid][pDrugs] != 0) { format(strinv, sizeof(strinv), "A\tНаркотики\t%d\n", User[playerid][pDrugs]), strcat(inventory, strinv); }
	if(User[playerid][pMats] != 0) { format(strinv, 48, "B\tМатериалы\t%d\n", User[playerid][pMats]); strcat(inventory, strinv); }
    if(User[playerid][pDirectory] != 0) { format(strinv, 48, "С\tТелефонная книга\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pMusicPlay] != 0) { format(strinv, sizeof(strinv), "D\tCD-Player\t1\n"), strcat(inventory, strinv); }
    if(User[playerid][pFishes] != 0) { new Float:fishes = User[playerid][pFishes]; format(strinv, 48, "E\tРыба\t%.1f\n",fishes); strcat(inventory, strinv); }
    if(User[playerid][pFuel] == 1) { format(strinv, 48, "H\tКанистра с бензином\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pMushrooms] != 0) { format(strinv, 48, "J\tГрибы\t%d\n",User[playerid][pMushrooms]); strcat(inventory, strinv); }
    if(User[playerid][pCarLic] == 1) { format(strinv, 48, "K\tВодительские права\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pFlyLic] == 1) { format(strinv, 48, "L\tЛицензия пилота\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pBoatLic] == 1) { format(strinv, 48, "M\tЛицензия на лодки\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pFishLic] == 1) { format(strinv, 48, "N\tЛицензия на рыболовство\t1\n"); strcat(inventory, strinv); }
    if(User[playerid][pGunLic] == 1) { format(strinv, 48, "O\tЛицензия на оружие\t1\n"); strcat(inventory, strinv); }
	if(User[playerid][pFishesPach] > 0) { format(strinv, 48, "R\tГотовая рыба\t%d\n",User[playerid][pFishesPach]); strcat(inventory, strinv); }
	if(User[playerid][pKeys] > 0) { format(strinv, 48, "K\tКлючи от камеры\t%d\n",User[playerid][pKeys]); strcat(inventory, strinv); }
	//for(new i=0; i < 46; i++) if(Weapons[playerid][i] != 0) wep++;
    //if(wep != 0) { format(strinv, 48, "P\tОружие\t%d",wep); strcat(inventory, strinv); }
    ShowPlayerDialogEx(playerid,9999,DIALOG_STYLE_TABLIST_HEADERS,"{AFAFAF}Карманы",inventory,"Закрыть","");
	return 1;
}
CMD:aquestion(playerid,params[])
{
	if(sscanf(params, "s[80]",params[0])) return SendClientMessage(playerid, -1, "Введите: /aquestion [текст]");
	if(User[playerid][pMutedr] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан репорта!"); return true; }
	if(GetPVarInt(playerid, "AntiReport") != 0) return SCM(playerid,COLOR_GREY,"Писать в репорт можно раз в 1 минуту");
	new str[121];
	format(str, sizeof(str), "{E75D5D}Репорт от %s[%d]: {FFFFFF}%s", User[playerid][pName], playerid, params[0]);
	SendClientMessage(playerid, -1, str);
	SendClientMessage(playerid, COLOR_LIGHTRED, "Ваша жалоба была отправлена администрации");
	SendAdminMessage(-1,str);
	SetPVarInt(playerid,"AntiReport",60);
	return true;
}
