CMD:giverank(playerid, params[])
{
    if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
	new para1;
	new level;
	new giveplayer[MAX_PLAYER_NAME];
	if(sscanf(params, "ud",para1,level)) return    SendClientMessage(playerid, COLOR_GREY, "Используйте: /giverank [id] [ранг]");
	if(!PlayerInConnected(para1) || playerid == para1) return err(!"Ошибка: {ffffff} Человек не найден!");
	if(!GetPVarInt(playerid, "Fraction_Duty")) return   SendClientMessage(playerid, COLOR_WHITE, "Вам необходимо быть в рабочей форме!");
	if(User[playerid][pRank] <= User[para1][pRank]) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете повысить/понизить этого игрока");
	switch(User[playerid][pMember])
	{
		case 1,10,21:
		{
			if(User[playerid][pRank] < 11) return true;
			if((level > 11 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 11!"); return true; }
			if((level > 14 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 14!"); return true; }
		}
		case 3,19:
		{
			if(User[playerid][pRank] < 13) return true;
			if((level > 12 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 12!"); return true; }
			if((level > 14 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 14!"); return true; }
		}
		case 7:
		{
			if(User[playerid][pRank] < 4) return true;
			if((level > 3 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 3!"); return true; }
			if((level > 5 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 5!"); return true; }
		}
		case 8:
		{
			if(User[playerid][pRank] < 4) return true;
			if((level > 3 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 3!"); return true; }
			if((level > 4 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 4!"); return true; }
		}
		case 2,4,5,6,9,11,12,13,14,15,16,17,18,20,34,35,36:
		{
			if(User[playerid][pRank] < 7) return true;
			if((level > 6 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 6!"); return true; }
			if((level > 9 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 9!"); return true; }
		}
		case 24:
		{
			if(User[playerid][pRank] < 5) return true;
			if((level > 4 || level < 1) && User[playerid][pLeader] == 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 4!"); return true; }
			if((level > 5 || level < 1) && User[playerid][pLeader] > 0) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 и больше 5!"); return true; }
		}
	}
	if(!IsPlayerConnected(para1)) return true;
	if(User[playerid][pMember] != User[para1][pMember]) return SendClientMessage(playerid, COLOR_GREY, "Данный игрок не в вашей фракции!");
	if(para1 == INVALID_PLAYER_ID) return true;
	if(para1 == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы указали свой ID");
	if (User[para1][pLeader] >= 1) return SendClientMessage(playerid, COLOR_GREY, "Вы указали ID лидера");
	GetPlayerName(para1, giveplayer, sizeof(giveplayer));
	User[para1][pRank] = level;
	SCMF(para1, 0x6495EDFF, "Вы были повышены/понижены до %d ранга %s",level, Name(playerid));
	SCMF(playerid, 0x6495EDFF, "Вы повысили/понизили %s до %d ранга.", giveplayer,level);
	return true;
}
CMD:agiverank(playerid, params[])
{
	if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /agiverank [playerid] [ранг от 1 до 21]");
	if(params[1] > 22 || params[1] < 0) { SendClientMessage(playerid, COLOR_GREY, "Не мене 0 и не более 21!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	User[params[0]][pRank] = params[1];
	format(YCMDstr, sizeof(YCMDstr), "Вы были повышены/понижены в ранге администратором %s",User[playerid][pName]);
	SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Вы повысили/понизили %s до %i ранга.",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	return true;
}
