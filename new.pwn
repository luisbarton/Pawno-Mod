	`pVhodchas` = '%d',`pVhodminute` = '%d',`pCarLic` = '%d',`pFlyLic` = '%d',`pBoatLic` = '%d',`pFishLic` = '%d',`pGunLic` = '%d',`pBizLic` = '%d',`pZakonp` = '%d', \
	`pText` = '%d',`pAddiction` = '%d',`pNarcoLomka` = '%d',`pPayDayHad` = '%d',`pTut` = '%d',`pWarns` = '%d' WHERE `Name` = '%e'",
	User[i][pRank], User[i][pChars], User[i][pJob], User[i][pModel], User[i][pPnumber],User[i][pDirectory], User[i][pVhoddata], User[i][pVhodMes],
	User[i][pVhodchas], User[i][pVhodminute], User[i][pCarLic], User[i][pFlyLic], User[i][pBoatLic],User[i][pFishLic], User[i][pGunLic], User[i][pBizLic],
	User[i][pZakonp], User[i][pText], User[i][pAddiction], User[i][pNarcoLomka], User[i][pPayDayHad],User[i][pTut], User[i][pWarns], User[i][pName]);
	mysql_tquery(dbHandle, t_query, "", "");

