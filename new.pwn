				if(!strlen(inputtext))return ShowPlayerDialogEx(playerid,2929,DIALOG_STYLE_INPUT, "Перевод денег на счёт бизнеса","Введите сумму, которую вы хотите положить на счёт бизнеса", "Готово", "Отмена");
				new moneys;
				moneys = strval(inputtext);
				if(moneys < 1000 || moneys > 100000)
				{
					SendClientMessage(playerid, COLOR_GREY, "Минимальная сумма 1000 вирт, максимальная 100000 вирт");
					ShowPlayerDialogEx(playerid,2929,DIALOG_STYLE_INPUT, "Перевод денег на счёт бизнеса","Введите сумму, которую вы хотите положить на счёт бизнеса", "Готово", "Отмена");
					return true;
				}
				if(moneys+BizzInfo[bouse][bLandTax] > 55000) return SendClientMessage(playerid,COLOR_GREY,"Неверная сумма (уже имеется достаточная сумма)");
				if(User[playerid][pBank] < moneys) return	SendClientMessage(playerid, COLOR_GRAD1, "У вас нет столько денег!");
				User[playerid][pBank] -= moneys;
				BizzInfo[bouse][bLandTax] += moneys;
				format(str, sizeof(str), "Вы положили на счёт Вашего бизнеса %i вирт", moneys);
				SendClientMessage(playerid, 0x6495EDFF, str);
				SetPlayerChatBubble(playerid, "кладёт на счёт бизнеса",COLOR_PURPLE,30.0,10000);
				return true;
			}
			else
			{
				return true;
			}
		}
