public OnPlayerRequestClass(playerid, classid)
{
	if(GetPVarInt(playerid,"KeyIP")) return 1;
    if(User[playerid][pLogin] == 1)
    {
        SendClientMessage(playerid, COLOR_WHITE, " Сменить скин можно в магазинах 'Victim'. Используйте: /gps");
		SpawnPlayer(playerid);
	}
	else
	{
    	ResetNew(playerid);
    	LoadRecon(playerid);
    	CreateTextDraws(playerid);
    	CaptureTextDraws(playerid);
    	LoadTextDrawPlayers(playerid);
        new ip[16];
		GetPlayerIp(playerid,ip,16);
		SendClientMessage(playerid, 0xDCD45CFF, " Добро пожаловать на "FullServName"");
		
		SetPlayerVirtualWorld(playerid, playerid + 1);
		TogglePlayerControllable(playerid, 0);
		SetPlayerCameraPos(playerid,1834.136474, -1439.969360, 538.398376);
		SetPlayerCameraLookAt(playerid,1830.709594, -1440.002563, 534.757629);
		SetPlayerFacingAngle(playerid, 180.7816);
		
		static const fmt_query[] = "SELECT * FROM `banip` WHERE `IP` = '%s'";
		new query[sizeof(fmt_query)+(-2+16)];
    	mysql_format(dbHandle, query, sizeof(query), fmt_query, ip);
		mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",4,playerid,"");
	}
	return 1;
}
stock SetPlayerCriminal(playerid, killerid[], reason[])
{
	new str[144];
	User[playerid][pCrimes]++;
	strmid(PlayerCrime[playerid][pVictim], killerid, 0, strlen(killerid), 50);
	strmid(PlayerCrime[playerid][pAccusedof], reason, 0, strlen(reason), 50);
	if(User[playerid][pWantedLevel] > 6)
	{
	    User[playerid][pWantedLevel] = 6;
	}
	format(str,sizeof(str),"Вы совершили преступление: [%s]. Сообщает: %s.",reason, killerid);
	SendClientMessage(playerid,COLOR_LIGHTRED,str);
	format(str,sizeof(str),"Ваш уровень розыска: %i", User[playerid][pWantedLevel]);
	SendClientMessage(playerid,COLOR_YELLOW,str);
	foreach(new i : Player)
	{
		if((User[i][pMember] == 1 ||User[i][pLeader] == 1 || User[i][pMember] == 10 ||User[i][pLeader] == 10 || User[i][pMember] == 2 ||User[i][pLeader] == 2 || User[i][pMember] == 21 || User[i][pLeader] == 21) && GetPVarInt(i,"Fraction_Duty") == 1)
		{
			format(str,sizeof(str), "Рация: Cообщает: %s. Преступление: %s. Подозреваемый: %s. Розыскиваемость: %i",killerid,reason,User[playerid][pName],User[playerid][pWantedLevel]);
			SendClientMessage(i, 0xFEBC41AA,str);
		}
	}
	return 1;
}
stock AntiCheats()
{
	foreach(new playerid : Player)
	{
	    /******************************** Античит на пиздорванку *******************************/
	    new Float:xw, Float:yw, Float:zw;
		GetPlayerVelocity(playerid,xw,yw,zw);
		if(xw > 2.0 || yw > 2.0)
		{
			Pizdorvanka[playerid]++;
			if(Pizdorvanka[playerid] >= 3)
			{
				CheatKick(playerid,1117);
				Pizdorvanka[playerid] = 0;
			}
		}
		//
		//if(GetVehicleDistanceFromPoint(GetPlayerVehicleID(playerid),car_coord[GetPlayerVehicleID(playerid)][0],car_coord[GetPlayerVehicleID(playerid)][1],car_coord[GetPlayerVehicleID(playerid)][2]) > 15 && (IsVehicleOccupied(GetPlayerVehicleID(playerid)) != -1 && IsVehicleOccupied(GetPlayerVehicleID(playerid)) == playerid && GetPlayerState(IsVehicleOccupied(GetPlayerVehicleID(playerid))) != PLAYER_STATE_DRIVER)) GameTextForPlayer(playerid,"~r~CARSHOOT",1000,3);
		/******************************** Античит на игру без авторизации *******************************/
		if(!User[playerid][pLogin] && (xw > 0 || yw > 0 || zw > 0))
		{
			CheatKick(playerid,1118);
		}
		/********************************** Анти Нивидимость *************************************/
		if(User[playerid][pLogin] == 1 && GetPlayerState(playerid) == PLAYER_STATE_SPECTATING && User[playerid][pAdmin] <= 0)
		{
	 		CheatKick(playerid,1120);
		}
		/******************************** Античит на GUNS *******************************/
		/*new gun[] = {9,16,26,37,38,35,36,39,44,45};
		for(new g= 0;g<sizeof(gun);g++)
		{
			if(gun[g] == GetPlayerWeapon(playerid) && User[playerid][pAdmin] <= 0)
 			{
    			SendWarningCheatMessageToAdmin(playerid,"Использует запрещенное оружие");
    			SetPVarInt(playerid, "AC_Warning", GetPVarInt(playerid, "AC_Warning")+1);
            	if(GetPVarInt(playerid, "AC_Warning") >= 3) CheatKick(playerid,771);
    		}
  		}*/
		/*********************************** Антифлуд пикапами ***********************************/
	    if(oldpickup[playerid] != -1)
	    {
			new Float:z;
			GetPlayerPos(playerid, z, z, z);
			if(timepickup[playerid] > 0) timepickup[playerid]--;
			if(!IsPlayerInRangeOfPoint(playerid,5.0,PickupX[playerid],PickupY[playerid],z) && timepickup[playerid] == 0) oldpickup[playerid] = -1;
		}
		//GetPosPickup(playerid);
		/*********************************** Анти AFK ***********************************/
		new stringF[50];
		if(GetPVarInt(playerid,"AFK_Tick") > 10000) SetPVarInt(playerid,"AFK_Tick",1), SetPVarInt(playerid,"AFK_Check",0);
		if(GetPVarInt(playerid,"AFK_Check") < GetPVarInt(playerid,"AFK_Tick") && GetPlayerState(playerid)) SetPVarInt(playerid,"AFK_Check",GetPVarInt(playerid,"AFK_Tick")), SetPVarInt(playerid,"AFK_Time",0);
		if(GetPVarInt(playerid,"AFK_Check") == GetPVarInt(playerid,"AFK_Tick") && GetPlayerState(playerid))
		{
			SetPVarInt(playerid,"AFK_Time",GetPVarInt(playerid,"AFK_Time") + 1);
			if(GetPVarInt(playerid, "AFK_Time") > 2)
			{
                format(stringF,sizeof(stringF), "[AFK] [%s]",Convert(GetPVarInt(playerid, "AFK_Time")-2));
				SetPlayerChatBubble(playerid, stringF, COLOR_GREEN, 30.0, 1200);
				AFKTimeLast[playerid]++;//проверка
            }
		}
		if(GetPVarInt(playerid,"AFK_Time") >= 2600 && User[playerid][pAdmin] < 2) SendClientMessage(playerid,COLOR_LIGHTRED, "Вы были отсоеденены от сервера! (AFK)"), KickEx(playerid, "AFK Time");

        /*********************************** Анти Armour ***********************************/
		/*new Float:armour;
		GetPlayerArmour(playerid, armour);
		if(Armour[playerid] < armour) SetPlayerArmour(playerid, Armour[playerid]);
		else Armour[playerid] = armour;
		if(HealthOn[playerid] == 0)
		{
			new Float: Health;
			GetPlayerHealth(playerid, Health);
			if(User[playerid][pHP] < Health) SetPlayerHealth(playerid, User[playerid][pHP]);
			else User[playerid][pHP] = Health;
		}
		else HealthOn[playerid] = 0;*/
		////////////////////
		if (User[playerid][pAdmin] || User[playerid][acDied])
			continue;

		if (User[playerid][acWeaponTick] == 0)
		{
			new weapons[13][2], string_[128];
			for (new i = 0; i <= 12; i++)
			{
				GetPlayerWeaponData(playerid, i, weapons[i][0], weapons[i][1]);
				if (weapons[i][0] == 46 || weapons[i][0] == 2 || weapons[i][0] == 3 || weapons[i][0] == 40)continue;
				if (weapons[i][0] && weapons[i][0] != User[playerid][ac_Weapon][i])
				{
					printf("WeaponHack: %s[%d] Slotid: %d NewWeaponid: %d NewAmmo: %d OldWeaponid: %d OldAmmo: %d", User[playerid][pName], playerid, i, weapons[i][0], weapons[i][1], User[playerid][ac_Weapon][i], User[playerid][ac_Ammo][i]);
                    format(string_, sizeof string_, "<Warning> %s[%d]: кикнут WeaponHack", User[playerid][pName], playerid);
					ABroadCast(COLOR_REDD,string_, 9);
					ResetPlayerWeaponsEx(playerid);
					KickEx(playerid, "WeaponHack");
					return 0;
				}
				if (User[playerid][ac_Ammo][i] < weapons[i][1])
				{
					printf("AmmoHack: %s[%d] Slotid: %d NewWeaponid: %d NewAmmo: %d OldWeaponid: %d OldAmmo: %d",
					User[playerid][pName],
					playerid,
					i,
					weapons[i][0],
					weapons[i][1],
					User[playerid][ac_Weapon][i],
					User[playerid][ac_Ammo][i]);
					format(string_, sizeof string_, "<Warning> %s[%d]: кикнут AmmoHack", User[playerid][pName], playerid);
					ABroadCast(COLOR_REDD,string_, 9);
					ResetPlayerWeaponsEx(playerid);
					KickEx(playerid, "AmmoHack");
					return 0;
				}
				if (weapons[i][0] && GetPlayerWeapon(playerid) == weapons[i][0] && !weapons[i][1])
				{
					SetTimerEx("CheckDGgun", 1000, false, "ddd", playerid, GetPlayerWeapon(playerid), i);
				}
			}
		}
		else User[playerid][acWeaponTick] --;
		/******************************** Античит на JETPACK *******************************/
   		if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
		{
			CheatKick(playerid, 1123);
		}
		/******************************** Античит на быструю езду на мопеде *******************************/
		/*if(IsPlayerInAnyVehicle(playerid) && GetVehicleModel(GetPlayerVehicleID(playerid)) == 462 && SpeedVehicle(playerid) > 110 && User[playerid][pAdmin] == 0 && GetPVarInt(playerid,"messagetimes") < gettime())
		{
		    SetPVarInt(playerid,"messagetimes",gettime()+15);
		    SendWarningCheatMessageToAdmin(playerid, "чит на быструю езду на мопеде");
		}*/
		//new animlib[30], animname[30];
		//GetAnimationName(GetPlayerAnimationIndex(playerid), animlib, sizeof(animlib), animname, sizeof(animname));
		/******************************** Античит на fly *******************************/
		/*if(SpeedVehicle(playerid) > 40 && strcmp(animlib, "SWIM", true) == 0 && strcmp(animname, "SWIM_crawl", true) == 0 && User[playerid][pAdmin] == 0 && !IsPlayerInAnyVehicle(playerid))
		{
			CheatKick(playerid, 1125);
		}*/
		/******************************** Античит на fly *******************************/
		/*if(SpeedVehicle(playerid) > 40 && GetPlayerWeapon(playerid) != 46 && strcmp(animname, "FALL_SKYDIVE_ACCEL", true) == 0 && User[playerid][pAdmin] == 0 && !IsPlayerInAnyVehicle(playerid))
		{
			CheatKick(playerid, 1126);
		}*/
		/******************************** Античит на езду без аренды *******************************/
		/*new newcar = GetPlayerVehicleID(playerid);
		if(newcar >= rentcarsf[0] && newcar <= rentcarsf[6])
		{
		    if(GetPVarInt(playerid, "Arenda") != newcar && SpeedVehicle(playerid) > 150)
			{
				CheatKick(playerid, 1127);
				SetVehicleToRespawn(newcar);
			}
		}*/
		/******************************** Античит на езду без аренды *******************************/
		/*if(newcar >= rentcarls[0] && newcar <= rentcarls[8])
		{
		    if(GetPVarInt(playerid, "Arenda") != newcar && SpeedVehicle(playerid) > 150)
			{
				CheatKick(playerid, 1127);
				SetVehicleToRespawn(newcar);
			}
		}*/
		/******************************** Античит на езду без аренды *******************************/
		/*if(newcar >= rentcarvip[0] && newcar <= rentcarvip[8])
		{
		    if(GetPVarInt(playerid, "Arenda") != newcar && SpeedVehicle(playerid) > 150)
			{
				CheatKick(playerid, 1127);
				SetVehicleToRespawn(newcar);
			}
		}*/
		/******************************** Античит на езду без аренды *******************************/
		/*if(newcar >= rentcarlv[0] && newcar <= rentcarlv[17])
		{
		    if(GetPVarInt(playerid, "Arenda") != newcar && SpeedVehicle(playerid) > 150)
			{
				CheatKick(playerid, 1127);
				SetVehicleToRespawn(newcar);
			}
		}*/
		/******************************** Античит на езду без аренды *******************************/
		/*if(newcar >= buscar[0] && newcar <= buscar[7])
		{
		    if(GetPVarInt(playerid, "rentcar_job") != newcar && SpeedVehicle(playerid) > 40)
			{
				CheatKick(playerid, 1127);
				SetVehicleToRespawn(newcar);
			}
		}*/
		/******************************** Античит на ТП по карте *******************************/
  		/*if(acstruct[playerid][checkmaptp] == 1 && User[playerid][pAdmin] <= 0)
		{
			new Float:dis = GetPlayerDistanceFromPoint(playerid, acstruct[playerid][maptp][0], acstruct[playerid][maptp][1], acstruct[playerid][maptp][2]);
			if(dis < 5.0)
			{
				new Float:disd = GetPlayerDistanceFromPoint(playerid, acstruct[playerid][LastOnFootPosition][0], acstruct[playerid][LastOnFootPosition][1], acstruct[playerid][LastOnFootPosition][2]);
				if(disd > 25.0) CheatKick(playerid,1114);
			}
			acstruct[playerid][checkmaptp] = 0;
		}*/
	}
	return true;
}
publics: Fresh()
{
    if(AntiChEndOK>0)
	{
	    new achstr[256]; format(achstr, 256, "Потерялся конец FreshTimer. Этап: %d", AntiChEndOK);
		printf(achstr);
		WriteLog("FreshLost.txt", achstr);
