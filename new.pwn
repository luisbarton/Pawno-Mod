                static const fmt_query[] = "UPDATE `accounts` SET pKeyip = '%e' WHERE name = '%e'";
                new query[sizeof(fmt_query)+(-2+40)+(-2+MAX_PLAYER_NAME)];
				mysql_format(dbHandle, query, sizeof(query), fmt_query, inputtext, User[playerid][pName]);
				mysql_query(dbHandle, query);
				User[playerid][pCheckip] = 1;
				format(str, sizeof(str), "Проверка по IP адресу включена. Ваш новый ключ безопасности: %s", inputtext);
				SendClientMessage(playerid, COLOR_GREEN, str);
				SendClientMessage(playerid, COLOR_GREEN, "Мы рекомендуем вам сделать скриншот. Клавиша F8");
				return true;
			}
			else return CallLocalFunction("OnPlayerCommandText", "is", playerid, "/mm");
		}
