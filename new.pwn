	{
		new suspect = GetClosestforeach(playerid);
		if(GetDistanceBetweenPlayers(playerid,suspect) < 2 && !IsPlayerInAnyVehicle(suspect) && !IsPlayerInAnyVehicle(playerid) && suspect != -1)
