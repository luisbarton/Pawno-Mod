				SendClientMessage(killerid,0x6495EDFF, "Вы посадили преступника на 3000 секунд!");
			}
			else if(User[playerid][pWantedLevel] >= 6)
			{
				//ResetPlayerWeaponsEx(playerid);
				User[playerid][pJailTime] = 3600;
				User[playerid][pWantedLevel] = 0;
				SetPlayerWantedLevel(playerid,User[playerid][pWantedLevel] );
