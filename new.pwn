							{
								SendClientMessage(playerid, COLOR_YELLOW,"[Подсказка] Вы купили скин, теперь устройтесь на работу");
								UpdateQuestInfo(playerid, 0, 80);
							}
						}*/
					}
				}
				
				format(QUERY, sizeof(QUERY), "Вешалка\tID скина\n\
				#1\t%d\n\
				#2\t%d\n\
				#3\t%d\n\
				#4\t%d\n\
				#5\t%d", User[playerid][pChar][0],
				User[playerid][pChar][1],
				User[playerid][pChar][2],
				User[playerid][pChar][3],
				User[playerid][pChar][4]);
				ShowPlayerDialogEx(playerid, 10400, DIALOG_STYLE_TABLIST_HEADERS, "{F1C33A}Ваш гардероб", QUERY, // и т.д.
				"Заменить", "");
				if(zips[playerid] == 1)
				{
				    SetPlayerVirtualWorld(playerid, 2);
				    //User[playerid][pChar][0] = GetPlayerSkin(playerid);//даём скин
				    TogglePlayerControllable(playerid, 1);//Размораживаем
				    t_SetPlayerPos(playerid,459.8446,-1501.9856,3001.0859);//тпкаем обратно в амгаз
					SetPlayerFacingAngle(playerid,358.5446);//Bla bla
				    SetPlayerInterior(playerid,5);//Даём инт. магазина
				    SetCameraBehindPlayer(playerid);//Включаем управление камерой
				    return true;
				}
				SetPlayerVirtualWorld(playerid, 1);
				
				TogglePlayerControllable(playerid, 1);//Размораживаем
				t_SetPlayerPos(playerid,459.8446,-1501.9856,3001.0859);//тпкаем обратно в амгаз
				SetPlayerFacingAngle(playerid,358.5446);//Bla bla
				SetPlayerInterior(playerid,5);//Даём инт. магазина
				SetCameraBehindPlayer(playerid);//Включаем управление камерой
			}
		case 3://если нажал Exit
			{
				if(zips[playerid] == 1)
				{
					SetPlayerVirtualWorld(playerid,2);
					SetPlayerSkin(playerid,User[playerid][pChar][0]);//Меняем скин на тот который был
					TogglePlayerControllable(playerid, 1);//Размораживаем
					t_SetPlayerPos(playerid,221.7944,-8.4229,1002.2109);//тпкаем обратно в амгаз
					SetPlayerFacingAngle(playerid,273.5792);//Bla bla
