stock BuyHouse(h)
{
    DestroyDynamicMapIcon(HouseInfo[h][hMIcon]);
	DestroyDynamicPickup(HouseInfo[h][hPickup]);
	DestroyDynamic3DTextLabel(HouseInfo[h][hExitText]);
	HouseInfo[h][hExitText] = CreateDynamic3DTextLabel("Чтобы выйти, нажмите клавишу '~k~~VEHICLE_ENTER_EXIT~'\nКупить/продать, нажмите клавишу '~k~~SNEAK_ABOUT~'",0x0076FCFF,HouseInfo[h][hExitx],HouseInfo[h][hExity],HouseInfo[h][hExitz]+1,5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,h+50);
	if(strcmp(HouseInfo[h][hOwner],"None",true) == 0)
	{
		HouseInfo[h][hPickup] = CreateDynamicPickup(1273, 23, HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez],-1);
		HouseInfo[h][hMIcon] = CreateDynamicMapIcon(HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez], 31, COLOR_WHITE, 0, -1, -1);
	}
	else
	{
		HouseInfo[h][hPickup] = CreateDynamicPickup(1272, 23, HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez],-1);
		HouseInfo[h][hMIcon] = CreateDynamicMapIcon(HouseInfo[h][hEntrancex], HouseInfo[h][hEntrancey], HouseInfo[h][hEntrancez], 32, COLOR_WHITE, 0, -1, -1);
	}
	return true;
}
stock Vehicleforeach(vehicleid)
{
	foreach(new i: Player)
 	{
		if(house_car[i] == vehicleid) return i;
	}
	return -1;
}
publics: HPCheck()
{
	foreach(new i : Player)
 	{
	    if(User[i][pLogin] == 0) continue;
	    GetVehicleParamsEx(GetPlayerVehicleID(i),engine,lights,alarm,doors,bonnet,boot,objective);
		if(!IsAPlane(GetPlayerVehicleID(i)) && !IsABoat(GetPlayerVehicleID(i)) && !IsABike(GetPlayerVehicleID(i)) && IsPlayerInAnyVehicle(i) && GetPlayerState(i) == PLAYER_STATE_DRIVER && engine == 1)
		{
		    if(Vehicleforeach(GetPlayerVehicleID(i)) != -1)
		    {
		        if(GetVehicleModel(GetPlayerVehicleID(i)) >= ShopCar[0][0] && GetVehicleModel(GetPlayerVehicleID(i)) <= ShopCar[56][0])
          		{
		        	switch(CarInfo[Vehicleforeach(GetPlayerVehicleID(i))][carPercent][0])
					{
		            	case 51..100: Fuell[GetPlayerVehicleID(i)] -= 2.0000;
		            	case 5..50: Fuell[GetPlayerVehicleID(i)] -= 4.0000;
		            	default: Fuell[GetPlayerVehicleID(i)] -= 6.0000;
					}
				}
				else
				{
				    switch(CarInfo[Vehicleforeach(GetPlayerVehicleID(i))][carPercent][0])
					{
		            	case 51..100: Fuell[GetPlayerVehicleID(i)] -= 4.0000;
		            	case 5..50: Fuell[GetPlayerVehicleID(i)] -= 8.0000;
		            	default: Fuell[GetPlayerVehicleID(i)] -= 16.0000;
					}
				}
				CarInfo[Vehicleforeach(GetPlayerVehicleID(i))][carFuel][GetPVarInt(i,"SelectCar")] = Fuell[GetPlayerVehicleID(i)];
			}
		    else Fuell[GetPlayerVehicleID(i)] -= 1.0000;
		}
		new Float:health;
		GetPlayerHealth(i,health);
		if(User[i][pTut] != 0 && health <= 10.0) SendClientMessage(i, COLOR_YELLOW, "У Вас сильно ухудшилось здоровье, вылечитесь у медика!");
		/*if(User[i][pSatiety] > 0) User[i][pSatiety] -= 1;
        if(User[i][pSatiety] == 49 || User[i][pSatiety] == 24) SendClientMessage(i,COLOR_ISPOLZUY, "Вы проголодались! Посетите бар, закусочную или купите ХотДог. Узнать свою «Сытость» можно командой /satiety");
		if(User[i][pSatiety] < 50) SetPlayerHealthAC(i, health - 1.0);
		else if(User[i][pSatiety] < 25) SetPlayerHealthAC(i, health - 2.0);*/
		User[i][pMin]++;
		if(User[i][pMin] >= 60) User[i][pChas]++, User[i][pMin] = 0;
	}
	return true;
}
publics: DerbyStartRacetwo()
{
	SendClientMessageToAll(TEAM_GROVE_COLOR,"Внимание! Начало гонок дерби через 2 минуты. Стадион Сан Фиерро. Регистрация на первом этаже");
	EndingderbyRound = 0;
	SetTimer("DerbyStartRace1", 120000, 0);
	return true;
}
publics: DerbyStartRace1()
{
	EndingderbyRound = 1;
	foreach(new i : Player)
 	{
		if(Playerderby[i] != 0)
		{
			new rands = random(sizeof(derby));
			GameTextForPlayer(i, "1", 1000, 3);
			new rand;
			rand = random(sizeof(DerbySpawns));
			t_SetPlayerPos(i,DerbySpawns[rand][0],DerbySpawns[rand][1],DerbySpawns[rand][2]);
			new carid = CreateVehicleAC(derby[rands], DerbySpawns[rand][0],DerbySpawns[rand][1],DerbySpawns[rand][2],DerbySpawns[rand][3], 3, 3, 60000);
			SetVehicleParamsEx(carid,false,false,false,false,false,false,false);
			CarHealth[carid] = float(1000);
			Fuell[carid] = 300;
			PutPlayerInVehicleEx(i, carid, 0);
			SetPlayerArmedWeapon(i,0);
			CreatedCars[CreatedCar] = carid;
			TogglePlayerControllable(i, 0);
			SetPlayerInterior(i,15);
			LinkVehicleToInterior(carid, 15);
		}
	}
	SetTimer("DerbyStartRace2", 1000, 0);
	return true;
}
publics: DerbyStartRace2()
{
	EndingderbyRound = 1;
	foreach(new i : Player)
 	{
	 	if(Playerderby[i] != 0) GameTextForPlayer(i,"2", 1000, 3);
	}
	SetTimer("DerbyStartRace3", 1000, 0);
	return true;
}
publics: DerbyStartRace3()
{
	EndingderbyRound = 1;
    foreach(new i : Player)
 	{
	 	if(Playerderby[i] != 0) GameTextForPlayer(i,"3", 1000, 3);
	}
	SetTimer("DerbyStartRace", 1000, 0);
	return true;
}
publics: DerbyStartRace()
{
	foreach(new i : Player)
 	{
		if(DerbyPlayers < 2)
		{
			SendClientMessageToAll(TEAM_GROVE_COLOR,"Внимание! Гонка дерби прервана из-за не достаточного колличества участников");
			EndingderbyRound = 1;
			Playerderby[i] = 0;
			DerbyPlayers = 0;
			DisablePlayerRaceCheckpoint(i);
			if(Playerderby[i] != 0)
			{
				SetPlayerInterior(i, 1);
				t_SetPlayerPos(i,-2159.0461,640.3610,1052.3817);
				SetPlayerFacingAngle(i, 76.4112);
				DestroyVehicle(GetPlayerVehicleID(i));
			}
			return true;
		}
		if(IsPlayerConnected(i))
		{
			if(Playerderby[i] != 0)
			{
				GameTextForPlayer(i, "~r~GO! GO! GO!", 5000, 3);
				PlayerPlaySound(i, 3201, 0.0, 0.0, 0.0);
				TogglePlayerControllable(i, 1);
				Playerderby[i] = 1;
				SetVehicleParamsEx(GetPlayerVehicleID(i) ,true,true,alarm,doors,bonnet,boot,objective);
			}
		}
	}
	SendClientMessageToAll(TEAM_GROVE_COLOR,"Внимание! Гонки дерби начались. Стадион Сан Фиерро");
	SetTimer("DerbyRaceEnded", 300000, 0);
	foreach(new i : Player)
 	{
		if(Playerderby[i] != 0)
		{
			winner[i] = SetTimerEx("DerbyRaceWinner", 10000, 1, "d",i);
		}
	}
	EndingderbyRound = 1;
	return true;
}
publics: DerbyRaceEnded()
{
	new name[24];
	GetSVarString("DerbyWinner", name, sizeof(name));
	format(YCMDstr, sizeof(YCMDstr), "Внимание! Гонки дерби окончены. (( Победитель: %s ))", name);
	SendClientMessageToAll(TEAM_GROVE_COLOR, YCMDstr);
	DeleteSVar("DerbyWinner");
	foreach(new i : Player)
 	{
		DisablePlayerCheckpoint(i);
		//SendClientMessageToAll(TEAM_GROVE_COLOR,"Внимание! Гонки дерби окончены");
		if(Playerderby[i] != 0) DestroyVehicle(GetPlayerVehicleID(i));
		Playerderby[i] = 0;
		EndingderbyRound = 1;
		DerbyPlayers = 0;
		return true;
	}
	return true;
}
publics: DerbyRaceWinner(playerid)
{
	if(Playerderby[playerid] != 0)
	{
		if(DerbyPlayers <= 1)
		{
		    SetSVarString("DerbyWinner", Name(playerid));
			SendClientMessage(playerid, TEAM_AZTECAS_COLOR, "Поздравляем вы заняли 1е место.");
			User[playerid][pCash] += 20000;
			Playerderby[playerid] = 0;
			EndingderbyRound = 1;
			Playerderby[playerid] = 0;
			DerbyPlayers = 0;
			derbychet[playerid] = 0;
			TogglePlayerControllable(playerid, 1);
			SetPlayerInterior(playerid, 0);
			t_SetPlayerPos(playerid,-2113.5208,-442.3560,38.2776);
			SetPlayerFacingAngle(playerid, 76.4112);
			Playerderby[playerid] = 0;
			KillTimer(winner[playerid]);
		}
	}
}
stock GivePlayerPPCash(playerid, money)
{
	PCash[playerid] = PCash[playerid] + money;
	ResetPlayerMoney(playerid);
	GivePlayerMoney(playerid,PCash[playerid]);
	return PCash[playerid];
}
public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	SetPVarInt(playerid, "NoAB", 1);
	SetPVarInt(playerid, "GunCheckTime", 2);
	SetPlayerArmedWeapon(playerid,0);
	SetPVarInt(playerid,"not_engine",0);
 	SetPVarInt(playerid,"not_engine_",0);
	if(usemats[playerid] > 0)
	{
	    if(usemats[playerid] == 1) FracStore[SFaStore] += 250;
	    if(usemats[playerid] == 2) FracStore[LSaStore] += 250;
	    if(usemats[playerid] == 3) FracStore[LVaStore] += 250;
	    usemats[playerid] = 0;
		RemovePlayerAttachedObject(playerid, 1);
		SendClientMessage(playerid, COLOR_REDD,"Вы уронили ящик");
		SetPlayerSpecialAction (playerid, SPECIAL_ACTION_NONE);
	}
	if(User[playerid][PlayerWorks] == true && User[playerid][PlayerUseMesh] == true)
	{
		SCM(playerid,COLOR_REDD,"Вы уронили мешок!");
		if(IsPlayerAttachedObjectSlotUsed(playerid, ATTACHED_SLOT_JOB_OBJ)) RemovePlayerAttachedObject(playerid, ATTACHED_SLOT_JOB_OBJ);
		DisablePlayerCheckpoint(playerid);
		User[playerid][PlayerUseMesh] = false;
		ClearAnimations(playerid);
		SetPlayerSpecialAction (playerid, SPECIAL_ACTION_NONE);
		SetPlayerCheckpoint(playerid,2824.4697,-2444.2490,12.1610,2.0);
	}
	/*if((GetTickCount() - GetPVarInt(playerid, "MassCarSpawn")) > 1000)
	{
    	SetPVarInt(playerid, "MassCarSpawn", GetTickCount());
	}*/
	PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
	Refueling[playerid] = 0;
	VehicleEnters[playerid]=vehicleid;
	VehicleID[playerid] = vehicleid;
	if(!ispassenger){
	    if(CarLic(vehicleid))
		{
			if(!User[playerid][pCarLic])
			{
			    if(TakingLesson[playerid] == 0){
					SCM(playerid, COLOR_WHITE, !"У Вас отсутствует данный тип лицензии {828282}(( /gps >> [1] Важные места >> [1] Автошкола ))");
					ClearAnimations(playerid);
					TogglePlayerControllable(playerid, 0);
    				SetTimerEx("UnFreeze" , 1000, false, "i", playerid);
				}
			}
		}
		if(IsABoat(vehicleid))
		{
			if(!User[playerid][pBoatLic])
			{
				SCM(playerid, COLOR_WHITE, !"У Вас отсутствует данный тип лицензии {828282}(( /gps >> [1] Важные места >> [1] Автошкола ))");
				ClearAnimations(playerid);
				TogglePlayerControllable(playerid, 0);
				SetTimerEx("UnFreeze" , 1000, false, "i", playerid);
			}
		}
		if(IsAPlane(vehicleid))
		{
			if(!User[playerid][pFlyLic])
			{
			    if(TakingLesson[playerid] == 0){
					SCM(playerid, COLOR_WHITE, !"У Вас отсутствует данный тип лицензии {828282}(( /gps >> [1] Важные места >> [1] Автошкола ))");
					ClearAnimations(playerid);
					TogglePlayerControllable(playerid, 0);
    				SetTimerEx("UnFreeze" , 1000, false, "i", playerid);
				}
			}
		}
		return 1;
	}
	return true;
}
publics: IsAMedic(playerid)
{
	if(!IsPlayerConnected(playerid)) return false;
	new leader = User[playerid][pLeader];
	new member = User[playerid][pMember];
	if(member == 4 || member == 22 || member == 23 || member == 33) return true;
	else if(leader == 4 || leader == 22 || leader == 23 || leader == 33) return true;
	return false;
}
publics: IsAMayor(playerid)
{
	if(!IsPlayerConnected(playerid)) return false;
	new leader = User[playerid][pLeader];
	new member = User[playerid][pMember];
	if(member == 7 || leader == 7) return true;
	return false;
}
