	format(QUERY, sizeof(QUERY), "Слот\tНазвание\tСостояние\tТопливо\n\
	#1\t%s\t%d\t%f\n\
	#2\t%s\t%d\t%f\n\
	#3\t%s\t%d\t%f", VehicleNames[CarInfo[playerid][carModel][0]-400], CarInfo[playerid][carPercent][0], CarInfo[playerid][carFuel][0],
	VehicleNames[CarInfo[playerid][carModel][1]-400], CarInfo[playerid][carPercent][1], CarInfo[playerid][carFuel][1],
	VehicleNames[CarInfo[playerid][carModel][2]-400], CarInfo[playerid][carPercent][2], CarInfo[playerid][carFuel][2]);
	ShowPlayerDialogEx(playerid, 2200, DIALOG_STYLE_TABLIST_HEADERS, "{F1C33A}Выбор транспорта", QUERY, // и т.д.
	"Выбрать", "Отмена");
