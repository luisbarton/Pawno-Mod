ALTX:skill("/myskill");
CMD:skill(playerid, params[])
{
	if(GetPVarInt(playerid,"anti_flood_sk") > gettime()) return SendClientMessage(playerid, COLOR_WHITE, "Подождите 10 секунд.");
	if(sscanf(params, "d", params[0]))
	{
		show_skill(playerid, playerid);
		return true;
	}
	if(!IsPlayerConnected(params[0])) return true;
	if(GetPlayerState(params[0]) == PLAYER_STATE_SPECTATING) return SCM(playerid, COLOR_GRAD1, "Игрок слишком далеко!");
	if(params[0] == INVALID_PLAYER_ID) return SCM(playerid, COLOR_GREY, "Игрок не найден!");
	if(!ProxDetectorS(3.0, playerid, params[0])) return SCM(playerid, COLOR_GREY, "Игрок слишком далеко!");
	format(YCMDstr, sizeof(YCMDstr), "%s достал(а) выписку из тира и показал(а) их %s", Name(playerid), Name(params[0]));
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	show_skill(params[0], playerid);
	SetPVarInt(playerid, "anti_flood_sk", gettime()+10);
	return true;
}
CMD:pskill(playerid, params[])
{

	if(User[playerid][pJob] != 5) return true;
	new stringskill[512];
	new points[1],percent[2] = "%";
	points[0] = 100 - User[playerid][pPProc];
	format(stringskill,sizeof(stringskill), "{FFFFFF}Уровень: %d\n{2E8F1A}Опыт:\t[%s]%i%s\n{FFFFFF}Максимальный груз: %d",
	User[playerid][pPSkill],
	ToDevelopSkills(User[playerid][pPProc],points[0]),User[playerid][pPProc],percent,
	User[playerid][pPMGruz]);
	ShowPlayerDialogEx(playerid,1100,DIALOG_STYLE_MSGBOX, "{F1C33A}Статистика",stringskill, "Готово", "");
	return true;
}
CMD:atune(playerid, params[])
{
    if (User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid, COLOR_GREY, "Вы не за рулем");
	ShowPlayerDialogEx(playerid, 8004, 2, "Тюнинг меню", "Диски \nГидравлика \nАрхангел Тюнинг \nЦвет \nВинилы \nАзот", "Выбрать", "Назад");
	return true;
}
CMD:setskill(playerid, params[])
{
    if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "udd",params[0],params[1],params[2]))
	{
		SendClientMessage(playerid, COLOR_GRAD1, "Введите: /setskill [playerid/часть ника] [номер] [количество]");
		SendClientMessage(playerid, COLOR_GRAD4, "[0] Slinced Pistol |[1] Desert Eagle |[2] ShotGun |[3] MP5 |[4] AK47 |[5] M4A1");
		return true;
	}
	if(params[0] == INVALID_PLAYER_ID) return SCM(playerid, COLOR_GREY, "Игрок не найден!");
	if(params[1] > 6 || params[1] < 0) return SCM(playerid,COLOR_GREY,"Неизвестное значение");
	if(params[2] > 100 || params[2] < 0) return SCM(playerid,COLOR_GREY,"Кол-во от 0 до 100");
	if(!IsPlayerConnected(params[0])) return true;
	User[params[0]][pGunSkill][params[1]] = params[2];
	SendClientMessage(playerid, COLOR_GRAD1, "Уровень владения оружием игроку установлен");
	return true;
}
CMD:sellgrib(playerid, params[])
{
    for(new i = 1; i <= TotalBizz; i++)
	{
		if(User[playerid][pMushrooms] == 0) return SendClientMessage(playerid, COLOR_GREY, "У Вас нет грибов");
		if (PlayerToPoint(10, playerid,BizzInfo[i][bBarX], BizzInfo[i][bBarY], BizzInfo[i][bBarZ]) && BizzInfo[i][bType] == 2 && GetPlayerVirtualWorld(playerid) == BizzInfo[i][bVirtualWorld])
		{
			User[playerid][pCash] +=User[playerid][pMushrooms]*25;
			BizzInfo[i][bProducts]+=User[playerid][pMushrooms];
			format(YCMDstr,sizeof(YCMDstr), "Вы продали %i грибов. Выручка: %i вирт",User[playerid][pMushrooms],User[playerid][pMushrooms]*25);
			SendClientMessage(playerid,COLOR_WHITE,YCMDstr);
			User[playerid][pMushrooms] = 0;
		}
	}
	return true;
}
CMD:paint(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(paint_info[1] == 1) return SendClientMessage(playerid,COLOR_GREY, "Пейнтболл уже запущен");
	paint_info[0] = 121;
	paint_info[1] = 1;
	foreach(new i : Player) DeletePVar(i, "player_paint");
	return true;
}
CMD:arace(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(race_info[1] == 1) return SendClientMessage(playerid,COLOR_GREY, "Гонка уже запущена");
	race_info[0] = 121;
	race_info[1] = 1;
	return true;
}
CMD:drace(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(EndingderbyRound == 0) return SendClientMessage(playerid,COLOR_GREY, "Дерби Гонка уже начата!");
	SendClientMessageToAll(TEAM_GROVE_COLOR,"Внимание! Начало гонок дерби через 5 минут. Стадион Сан Фиерро. Регистрация на первом этаже");
	EndingderbyRound = 0;
	SetTimer("DerbyStartRacetwo", 180000, 0);
	return true;
}
