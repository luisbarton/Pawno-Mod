CMD:findhouse(playerid, params[])
{
    if(User[playerid][pJob] != 7 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 && User[playerid][pRank] > 3) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /findhouse [дом]");
	SetPlayerCheckpoint(playerid,HouseInfo[params[0]][hEntrancex], HouseInfo[params[0]][hEntrancey], HouseInfo[params[0]][hEntrancez], 4.0);
	SendClientMessage(playerid, COLOR_WHITE, "Метка на карте установлена");
	DeletePVar(playerid, "GPSMark");
	return true;
}
CMD:home(playerid, params[])
{

    if(HGet(playerid))
    {
		SetPlayerCheckpoint(playerid,HouseInfo[GetPVarInt(playerid,"House")][hEntrancex], HouseInfo[GetPVarInt(playerid,"House")][hEntrancey], HouseInfo[GetPVarInt(playerid,"House")][hEntrancez], 4.0);
		SendClientMessage(playerid, 0xF0E79CFF, "Ваш дом обозначен на карте {FF4500}красной меткой");
		gPlayerCheckpointStatus[playerid] = 12;
	}
	else if(KGet(playerid))
	{
	    new i = GetPVarInt(playerid,"Kvart");
	    SetPlayerCheckpoint(playerid,PodeezdInfo[kvartinfo[i][virtmir]][podPicX], PodeezdInfo[kvartinfo[i][virtmir]][podPicY], PodeezdInfo[kvartinfo[i][virtmir]][podPicZ], 4.0);
	    format(YCMDstr,sizeof(YCMDstr),"Ваш подъезд обозначен на карте {FF4500}красной меткой. {F0E79C}Номер подъезда: %i",kvartinfo[i][virtmir]-1);
		SendClientMessage(playerid, 0xF0E79CFF,YCMDstr);
		gPlayerCheckpointStatus[playerid] = 12;
	}
	return true;
}
CMD:clear(playerid, params[])
{
	new str[128];
    if((User[playerid][pMember] == 1 && User[playerid][pRank] >= 10) || (User[playerid][pMember] == 10 &&  User[playerid][pRank] >= 10) || (User[playerid][pMember] == 21 &&  User[playerid][pRank] >= 2) || (User[playerid][pMember] == 2 &&  User[playerid][pRank] >= 2))
    {
        if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 497 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 427 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 523 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 415
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 521 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 596 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 597 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 598
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 490 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 560) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в полицейской машине");
        if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /clear [id]");
        if(IsPlayerConnected(params[0]))
        {
            if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Человек не найден!");
			if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете снять розыск себе!");
            if(User[params[0]][pWantedLevel] == 0) return SendClientMessage(playerid, COLOR_GREY, "Человек не находится в розыске!");
			format(str, sizeof(str), "Вы сняли уровни розыска у %s.", User[params[0]][pName]);
			SendClientMessage(playerid, 0x6495EDFF, str);
			format(str, sizeof(str), "Офицер %s снял с Вас уровни розыска.", User[playerid][pName]);
			SendClientMessage(params[0], 0x6495EDFF, str);
			User[params[0]][pWantedLevel] = 0;
			SetPlayerWantedLevel(params[0], 0);
			format(str, sizeof(str), "[Clear] %s удалил из розыскиваемых %s", User[playerid][pName], User[params[0]][pName]);
			foreach(new i : Player)
			{
				if((User[i][pMember] == 1 || User[i][pMember] == 10 || User[i][pMember] == 21 || User[i][pMember] == 2) && GetPVarInt(i,"Fraction_Duty") == 1)
				{
					SendClientMessage(i, 0xFEBC41AA, str);
		  		}
			}
		}
    }
	return true;
}
CMD:ticket(playerid, params[])
{
	if(!IsACop(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не полицейский!");
	if(sscanf(params, "uds[54]",params[0],params[1],params[2])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /ticket [id] [цена] [причина]");
	if(params[1] < 1 || params[1] > 10000) { SendClientMessage(playerid, COLOR_GREY, "Штраф не должен привышать 10000$ и не должен быть меньше 0$!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	if(!ProxDetectorS(5.0, playerid, params[0])) return true;
	if(GetSRVMoney(params[0]) < params[1]) 	return 	SendClientMessage(playerid, COLOR_GREY, "У данного игрока нет столько денег!");
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы указали свой ID"); return true; }
	format(YCMDstr, sizeof(YCMDstr), "Вы выписали штраф в размере %i вирт %s. Причина: %s",params[1],User[params[0]][pName],params[2]);
	SendClientMessage(playerid, COLOR_BLUE, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Офицер %s выписал вам штраф в размере %i вирт. Причина: %s",User[playerid][pName],params[1],params[2]);
	SendClientMessage(params[0], COLOR_BLUE, YCMDstr);
	SendClientMessage(params[0], COLOR_WHITE, "(( Введите: /accept ticket, чтобы оплатить штраф ))");
	TicketOffer[params[0]] = playerid;
	TicketMoney[params[0]] = params[1];
	return true;
}
