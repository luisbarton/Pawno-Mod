CMD:bizwithdraw(playerid)
{
    if(!IsPlayerConnected(playerid)) return true;
	if(!BGet(playerid))  return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	new bouse = GetPVarInt(playerid,"Bizz");
	new till = BizzInfo[bouse][bTill];
	if(!PlayerToPoint(100, playerid,BizzInfo[bouse][bEntranceX],BizzInfo[bouse][bEntranceY],BizzInfo[bouse][bEntranceZ]))
	{
		SendClientMessage(playerid, COLOR_GRAD2, "Нужно находится рядом с бизнесом");
		return 1;
	}
	else
	{
 		User[playerid][pCash] += till;
 		format(YCMDstr, sizeof(YCMDstr), "Вы сняли %i вирт со счёта вашего бизнеса. Остаток: 0 вирт ",BizzInfo[bouse][bTill]);
        SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
        format(YCMDstr, sizeof(YCMDstr), "Игрок %s снял %i вирт со счёта бизнеса", Name(playerid), till);
        WriteLog("Bizwithdraw.txt", YCMDstr);
		BizzInfo[bouse][bTill] = 0;
		return true;
	}
}
CMD:bizbalance(playerid)
{
	if(!BGet(playerid))  return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	new bouse = GetPVarInt(playerid,"Bizz");
	format(YCMDstr, sizeof(YCMDstr), "На банковском счету вашего бизнеса %i вирт",BizzInfo[bouse][bTill]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	return 1;
}
CMD:getbizstats(playerid, params[])
{
    new bizz[40];
    if(sscanf(params, "s[40]", bizz)) return SendClientMessage(playerid,COLOR_WHITE,"Введите: /getbizstats [название]");
	for(new h = 1; h <= TotalBizz; h++)
	{
		if(PlayerToPoint(3.0, playerid,BizzInfo[h][bEntranceX], BizzInfo[h][bEntranceY], BizzInfo[h][bEntranceZ]) && !strcmp(bizz,BizzInfo[h][bMessage],true)) return PrintBizInfo(playerid,h);
	}
	return SendClientMessage(playerid,COLOR_GREY,"Вы должны находиться возле бизнеса / неверное название бизнеса");
}
CMD:getcampos(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pAdmin] < 8 || !GetPVarInt(playerid, "Dostup")) return true;
	new Float:x1,Float:y1,Float:z1;
	GetPlayerCameraLookAt(playerid,x1,y1,z1);
	format(YCMDstr, sizeof(YCMDstr), "GetPlayerCameraLookAt %f,%f,%f",x1,y1,z1);
	SendClientMessage(playerid,COLOR_GREY,YCMDstr);
	GetPlayerCameraPos(playerid,x1,y1,z1);
	format(YCMDstr, sizeof(YCMDstr), "GetPlayerCameraPos %f,%f,%f",x1,y1,z1);
	SendClientMessage(playerid,COLOR_GREY,YCMDstr);
	return true;
}
CMD:spwcar(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /spwcar [id]");
	SetVehicleToRespawn(params[0]);
	return true;
}
CMD:endlesson(playerid, params[])
{
    if(TakingLesson[playerid] == 0) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не начинали урок");
	LessonCar[playerid] = 0;
	LessonStat[playerid] = 0;
	TakingLesson[playerid] = 0;
	DisablePlayerRaceCheckpoint(playerid);
	RemovePlayerFromVehicleAC(playerid);
	return true;
}
CMD:bizstats(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(!BGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете бизнесом!");
	PrintBizInfo(playerid,GetPVarInt(playerid,"Bizz"));
	return true;
}
