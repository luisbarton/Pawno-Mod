CMD:srvpass(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /srvpass (0 - убрать, 1 - поставить)");
	if(params[0] == 0)
	{
	    SendRconCommand("password 0");
	    SCM(playerid, COLOR_RED, "Пароль сервера успешно удалён");
	    return 1;
	}
	else if( params[0] == 1)
	
	{
		SendRconCommand("password 4786");
		SCM(playerid, COLOR_RED, "Пароль успешно изменен на: 4786");
	}
	return 1;
}
CMD:sethousepos(playerid, params[])
{
    if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /sethousepos [дом]");
	new Float: lwx, Float:lwy, Float:lwz;
	GetPlayerPos(playerid, lwx, lwy, lwz);
	HouseInfo[params[0]][hEntrancex] = lwx;
	HouseInfo[params[0]][hEntrancey]= lwy;
	HouseInfo[params[0]][hEntrancez] = lwz;
	BuyHouse(params[0]);
	return true;
}
CMD:setkvartpos(playerid, params[])
{
    if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setkvartpos [квартира]");
	if(params[0] < 1) return SendClientMessage(playerid,COLOR_GREY,"Номер квартиры не может быть менее 1");
	new Float: lwx, Float:lwy, Float:lwz;
	GetPlayerPos(playerid, lwx, lwy, lwz);
	kvartinfo[params[0]][pXpic] = lwx;
	kvartinfo[params[0]][pYpic] = lwy;
	kvartinfo[params[0]][pZpic] = lwz;
	kvartinfo[params[0]][kworld] = GetPlayerVirtualWorld(playerid);
    kvartinfo[params[0]][virtmir] = GetPVarInt(playerid, "podeezd");
    DestroyDynamic3DTextLabel(kvartinfo[params[0]][dtext]);
    format(YCMDstr, sizeof(YCMDstr),"{0076FC}Комната #%i\nПродается: 100000 вирт\nЧтобы войти, нажмите клавишу 'ENTER'",params[0]);
    kvartinfo[params[0]][dtext]     =    CreateDynamic3DTextLabel(YCMDstr,0x0076FCFF,kvartinfo[params[0]][pXpic],kvartinfo[params[0]][pYpic],kvartinfo[params[0]][pZpic]+1,5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,kvartinfo[params[0]][kworld]);
    updatekvar(params[0]);
	return true;
}
CMD:setkvartcarpos(playerid, params[])
{
    if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setkvartcarpos [подъезд]");
	new Float: lwx, Float:lwy, Float:lwz,Float:a;
	GetPlayerPos(playerid, lwx, lwy, lwz);
	GetPlayerFacingAngle(playerid,a);
	if(params[0] < 1) return SendClientMessage(playerid,COLOR_GREY,"Номер подъезда не может быть менее 1");
	PodeezdInfo[params[0]][carX] = lwx;
	PodeezdInfo[params[0]][carY]= lwy;
	PodeezdInfo[params[0]][carZ] = lwz;
	PodeezdInfo[params[0]][carC] = a;
	SendClientMessage(playerid, COLOR_GREY, "Координаты машины установлены");
	return true;
}
