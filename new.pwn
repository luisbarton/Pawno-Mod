publics: PrintBizInfo(playerid,targetid)
{
	new mafiatext[15],
	    opn[7],
		lic[5],
		strbiz[270];

	if(BizzInfo[targetid][bMafia] == 5) mafiatext = "LCN";
	else if(BizzInfo[targetid][bMafia] == 6) mafiatext = "Yakuza";
	else if(BizzInfo[targetid][bMafia] == 14) mafiatext = "Russian Mafia";
	else mafiatext = "Нет";

	if(BizzInfo[targetid][bLocked] == 0) opn = "Открыт";
	else opn = "Закрыт";

	if(BizzInfo[targetid][bLicense] == 0) lic = "Нет";
	else lic = "Есть";

	format(strbiz,sizeof(strbiz),"Название\t%s\nМафия\t%s\nБаланс\t%i вирт\nПрибыль за час\t%i вирт\nПродукты\t%i/%i\nЦена за товар\t%i вирт\nЦена за продукт\t%i вирт\nЦена за вход\t%i вирт\nСостояние\t%s\nЭлектроэнергия\t%i/%i\nЛицензия\t%s",
	BizzInfo[targetid][bMessage],mafiatext,BizzInfo[targetid][bTill],BizzPay[targetid],BizzInfo[targetid][bProducts],BizzMaxProds[targetid],BizzInfo[targetid][bPrice],BizzInfo[targetid][bProdPrice],BizzInfo[targetid][bEntranceCost],opn,BizzInfo[targetid][bLandTax],(BizzLandTax[targetid]*720)-BizzInfo[targetid][bLandTax],lic);
	return ShowPlayerDialogEx(playerid,0,DIALOG_STYLE_TABLIST, "{F1C33A}Статистика бизнеса",strbiz, "Закрыть", "");
}
