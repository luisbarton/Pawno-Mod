public OnPlayerRequestSpawn(playerid)
{
	return 0;
}
stock HGet(playerid)
{
	new house = 0;
	for(new i = 1; i <= TotalHouse;i++)
	{
		if(strcmp(HouseInfo[i][hOwner],User[playerid][pName],false) == 0 && strcmp(HouseInfo[i][hOwner],"None",true) != 0) house++, SetPVarInt(playerid, "House", i);
	}
	return house;
}
stock BGet(playerid)
{
	new house = 0;
	for(new i = 1; i <= TotalBizz;i++)
	{
		if(strcmp(BizzInfo[i][bOwner],User[playerid][pName],false) == 0 && strcmp(BizzInfo[i][bOwner],"None",true) != 0) house++, SetPVarInt(playerid, "Bizz", i);
	}
	return house;
}
stock WGet(playerid)
{
	new house = 0;
	for(new i = 1; i <= TOTALSHOPS;i++)
	{
		if(strcmp(WorkshopInfo[i][wOwner],User[playerid][pName],false) == 0 && strcmp(WorkshopInfo[i][wOwner],"None",true) != 0) house++, SetPVarInt(playerid, "wShop", i);
	}
	return house;
}
stock KGet(playerid)
{
	new house = 0;
	for(new i = 1; i <= ALLKVARTIRI; i++)
	{
	    if(strcmp(kvartinfo[i][vladelec],User[playerid][pName],false) == 0 && strcmp(kvartinfo[i][vladelec],"None",true) != 0) house++, SetPVarInt(playerid, "Kvart", i);
	}
	return house;
}
stock FGet(playerid)
{
    new house = 0;
	for(new i = 1; i <= TOTALFARM; i++)
	{
	    if(strcmp(FarmInfo[i][fOwner],User[playerid][pName],false) == 0 && strcmp(FarmInfo[i][fOwner],"None",true) != 0) house++, SetPVarInt(playerid, "Farm", i);
	}
	return house;
}
stock GetKvart()
{
    for(new k = 1; k <= ALLKVARTIRI; k++)
	{
	    if(!strcmp(kvartinfo[k][vladelec],"None",true)) continue;
	    if(kvartinfo[k][plata] < 50)
	    {
	        if(GetPlayerID(kvartinfo[k][vladelec]) != INVALID_PLAYER_ID) SetPVarInt(GetPlayerID(kvartinfo[k][vladelec]), "GetKvart", 1);
	    	kvartinfo[k][aptek] = 0;
      		kvartinfo[k][lock] = 0;
         	kvartinfo[k][plata] = 0;
            strmid(kvartinfo[k][vladelec], "None", 0, strlen("None"), 10);
           	updatekvar(k);
		}
		else kvartinfo[k][plata]-=50;
	}
	return true;
}
stock GetBizz()
{
    for(new i = 1; i <= TotalBizz; i++)
	{
	    if(BizzInfo[i][bStavka] > 0 && strcmp(BizzInfo[i][bOwner],"None",true) == 0 && BizzInfo[i][bTimeStavka] > 0) BizzInfo[i][bTimeStavka]--;
	    if(BizzInfo[i][bTimeStavka] == 0 && BizzInfo[i][bStavka] > 0)
	    {
	        mysql_format(dbHandle,QUERY,256,"SELECT `Name` FROM `accounts` WHERE `Name` = '%s'",BizzInfo[i][bNameStavka]);
			mysql_tquery(dbHandle,QUERY,"OnMySQL_QUERY","iis",12,i,"");
		}
		//if(strcmp(BizzInfo[i][bOwner],"None",true) != 0) continue;
		if(BizzInfo[i][bLandTax] < BizzLandTax[i] || BizzInfo[i][bLocked] == 1 && BizzInfo[i][bLockTime] > 12) ClearBizz(i);
		else
		{
			if(BizzInfo[i][bProducts] <= 0)
			{
			    BizzInfo[i][bLocked] = 1;
				if(IsPlayerConnected(GetPlayerID(BizzInfo[i][bOwner])))
				{
					if(BizzInfo[i][bLockTime] == 0) SetPVarInt(GetPlayerID(BizzInfo[i][bOwner]), "_GetBizz_", 1);
				}
			}
			if(BizzInfo[i][bLocked] == 1)BizzInfo[i][bLockTime]++;
			if(BizzInfo[i][bLockTime] > 1 && BizzInfo[i][bLockTime] < 12) if(IsPlayerConnected(GetPlayerID(BizzInfo[i][bOwner]))) SetPVarInt(GetPlayerID(BizzInfo[i][bOwner]), "GetBizz_", 1);
			BizzInfo[i][bLandTax] -= BizzLandTax[i];
            BizzPay[i] = 0;
			if(BizzInfo[i][bMafia] == 6) MafiaBank[0][nYakuza] += 500;
			if(BizzInfo[i][bMafia] == 14) MafiaBank[0][nRm] += 500;
			if(BizzInfo[i][bMafia] == 5) MafiaBank[0][nLcn] += 500;
		}
	}
	return true;
}
stock GetHouseOplata(idx)
{
	switch(HouseInfo[idx][hKlass])
	{
 		case 0,4: return 50;
   		case 1,3: return 100;
    	case 2: return 150;
	    case 5: return 0;
	}
	return -1;
}
stock GetHome()
{
	for(new i = 1; i <= TotalHouse; i++)
	{
        if(strcmp("None",HouseInfo[i][hOwner],true) == 0) continue;
		if(HouseInfo[i][hTakings] < GetHouseOplata(i))
		{
			if(GetPlayerID(HouseInfo[i][hOwner]) != INVALID_PLAYER_ID)
			{
			    User[GetPlayerID(HouseInfo[i][hOwner])][pHousecash] += HouseInfo[i][hValue]/2;
			    SetPVarInt(GetPlayerID(HouseInfo[i][hOwner]), "GetHome", 1);
			}
			else
			{
			    mysql_format(dbHandle,QUERY,300, "UPDATE `accounts`  SET pHousecash = 'pHousecash+%i', pText = '1' WHERE Name = '%s'",HouseInfo[i][hValue]/2,HouseInfo[i][hOwner]);
				mysql_tquery(dbHandle, QUERY, "", "");
			}
			strmid(HouseInfo[i][hOwner],"None",0,strlen("None"),MAX_PLAYER_NAME);
			HouseInfo[i][hTakings] = 0;
			HouseInfo[i][hLock] = 1;
			HouseInfo[i][hHel] = 0;
			for(new h = 0; h < 10; h++) HouseInfo[i][hSafe][h] = 0;
			BuyHouse(i);
		}
		else HouseInfo[i][hTakings] -= GetHouseOplata(i);
		robhouse[i] = false;
	}
	return true;
}
stock GetShop()
{
	for(new i = 1; i <= TOTALSHOPS; i++)
	{
	    if(WorkshopInfo[i][wAuction][0] > 0 && strcmp(WorkshopInfo[i][wOwner],"None",true) == 0 && WorkshopInfo[i][wAuction][2] > 0) WorkshopInfo[i][wAuction][2]--;
	    if(WorkshopInfo[i][wAuction][2] == 0 && WorkshopInfo[i][wAuction][0] > 0)
	    {
	        mysql_format(dbHandle,QUERY,256,"SELECT `Name` FROM `accounts` WHERE `Name` = '%s'",WorkshopInfo[i][wAuctionName]);
			mysql_tquery(dbHandle,QUERY,"OnMySQL_QUERY","iis",24,i,"");
		}
        if(strcmp("None",WorkshopInfo[i][wOwner],true) == 0) continue;
       // new null = WorkshopInfo[i][wAuction][4];
		if(WorkshopInfo[i][wLandTax] < 500)
		{
			if(GetPlayerID(WorkshopInfo[i][wOwner]) != INVALID_PLAYER_ID)
			{
				SetPVarInt(GetPlayerID(WorkshopInfo[i][wOwner]), "GetShop", 1);
				User[GetPlayerID(WorkshopInfo[i][wOwner])][pBank] += WorkshopInfo[i][wBank]+WorkshopInfo[i][wLandTax];
			}
			else
			{
			    mysql_format(dbHandle,QUERY,300, "UPDATE `accounts`  SET pBank = 'pBank+%i' WHERE Name = '%s'",WorkshopInfo[i][wBank]+WorkshopInfo[i][wLandTax],WorkshopInfo[i][wOwner]);
				mysql_tquery(dbHandle, QUERY, "", "");
			}
			strmid(WorkshopInfo[i][wOwner],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wDeputy1],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wDeputy2],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wDeputy3],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wMechanic1],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wMechanic2],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wMechanic3],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wMechanic4],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(WorkshopInfo[i][wMechanic5],"None",0,strlen("None"),MAX_PLAYER_NAME);
			WorkshopInfo[i][wAuction][0] = 0;
			WorkshopInfo[i][wAuction][1] = 0;
			WorkshopInfo[i][wAuction][2] = 0;
			WorkshopInfo[i][wAuction][3] = 0;
			//WorkshopInfo[i][wAuction][4] = 0;
			WorkshopInfo[i][wLandTax] = 0;
			WorkshopInfo[i][wBank] = 0;
			WorkshopInfo[i][wProds] = 0;
			WorkshopInfo[i][wPriceProds] = 50;
			WorkshopInfo[i][wZp] = 5;
		}
		else
		{
			WorkshopInfo[i][wLandTax] -= 500;
			if(WorkshopInfo[i][wProds] < 20000 && WorkshopInfo[i][wBank] > 2*(20000-WorkshopInfo[i][wProds])) WorkshopInfo[i][wProds] = 20000, WorkshopInfo[i][wBank]-=2*(20000-WorkshopInfo[i][wProds]);
		}
	}
	return true;
}
stock GetFarm()
{
	for(new i = 1; i <= TOTALFARM; i++)
	{
	    if(FarmInfo[i][fAuction][0] > 0 && strcmp(FarmInfo[i][fOwner],"None",true) == 0 && FarmInfo[i][fAuction][2] > 0) FarmInfo[i][fAuction][2]--;
	    if(FarmInfo[i][fAuction][2] == 0 && FarmInfo[i][fAuction][0] > 0)
	    {
	        mysql_format(dbHandle,QUERY,256,"SELECT `Name` FROM `accounts` WHERE `Name` = '%s'",FarmInfo[i][fAuctionName]);
			mysql_tquery(dbHandle,QUERY,"OnMySQL_QUERY","iis",29,i,"");
		}
        if(strcmp("None",FarmInfo[i][fOwner],true) == 0) continue;
        //new null = FarmInfo[i][fAuction][4];
		if(FarmInfo[i][fLandTax] < 500)
		{
			if(GetPlayerID(FarmInfo[i][fOwner]) != INVALID_PLAYER_ID)
			{
				SetPVarInt(GetPlayerID(FarmInfo[i][fOwner]), "GetFarm", 1);
				User[GetPlayerID(FarmInfo[i][fOwner])][pBank] += FarmInfo[i][fBank]+FarmInfo[i][fLandTax];
			}
			else
			{
			    static const fmt_query[] = "UPDATE `accounts` SET `pBank` = 'pBank + %d' WHERE `Name` = '%s'";
			    new query[sizeof(fmt_query)+(-2+16)+(-2+MAX_PLAYER_NAME)];
			    mysql_format(dbHandle, query, sizeof(query), fmt_query,FarmInfo[i][fBank]+FarmInfo[i][fLandTax],FarmInfo[i][fOwner]);
				mysql_tquery(dbHandle, query, "", "");
			}
			strmid(FarmInfo[i][fOwner],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(FarmInfo[i][fDeputy_1],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(FarmInfo[i][fDeputy_2],"None",0,strlen("None"),MAX_PLAYER_NAME);
			strmid(FarmInfo[i][fDeputy_3],"None",0,strlen("None"),MAX_PLAYER_NAME);
			FarmInfo[i][fAuction][0] = 0;
			FarmInfo[i][fAuction][1] = 0;
			FarmInfo[i][fAuction][2] = 0;
			FarmInfo[i][fAuction][3] = 0;
			FarmInfo[i][fAuction][4] = 0;
			FarmInfo[i][fLandTax] = 0;
			FarmInfo[i][fBank] = 0;
			FarmInfo[i][fProds] = 0;
			FarmInfo[i][fZp] = 30;
			FarmInfo[i][fGrain_Price] = 5;
			FarmInfo[i][fGrain] = 0;
			FarmInfo[i][fGrain_Sown] = 0;
			FarmInfo[i][fProds_Selling] = 1;
			FarmInfo[i][fProds_Price] = 21;
		}
		else FarmInfo[i][fLandTax] -= 500;
	}
	return true;
}
stock ShowDetals(playerid,targetid,idx)
{
    new dstirng[90],str[1500],count = 3;
    new till = WorkshopInfo[idx][wPriceProds];
    SetPVarInt(playerid,"installation_",targetid);
    strcat(str,"1. Ремонт двигателя\n");
    format(dstirng, sizeof(dstirng),"2. Перекраска\t\t\"%i вирт\"\n",till*500);
    strcat(str,dstirng);
    for(new i;i<MAX_VEHICLE_COMPONENT;i++)
    {
        if(!IsVehicleUpgradeCompatible(GetVehicleModel(house_car[targetid]),AllTuningComponentsInfo[i][idcomp])) continue;
        format(dstirng, sizeof(dstirng), "%i. %s\t\t\"%s\"\t\t\"%i вирт\"\n",count,AllTuningComponentsInfo[i][Type], AllTuningComponentsInfo[i][Name], till*AllTuningComponentsInfo[i][Cost]);
        strcat(str,dstirng);
        AwtomasMassiveID[playerid][count-3] = i;
        count++;
    }
    ShowPlayerDialogEx(playerid,6500,2,"Доступные детали",str,"Далее","Закрыть");
    return 1;
}
stock GetFarmjob(playerid, idx)
{
    if(strcmp(User[playerid][pName],FarmInfo[idx][fDeputy_1],true) == 0 || strcmp(User[playerid][pName],FarmInfo[idx][fDeputy_2],true) == 0 || strcmp(User[playerid][pName],FarmInfo[idx][fDeputy_3],true) == 0) return 2;
    if(strcmp(User[playerid][pName],FarmInfo[idx][fFarmer_1],true) == 0 || strcmp(User[playerid][pName],FarmInfo[idx][fFarmer_2],true) == 0 || strcmp(User[playerid][pName],FarmInfo[idx][fFarmer_3],true) == 0
    || strcmp(User[playerid][pName],FarmInfo[idx][fFarmer_4],true) == 0 || strcmp(User[playerid][pName],FarmInfo[idx][fFarmer_5],true) == 0) return true;
    return false;
}
stock GetWorkshop(playerid, idx)
{
	if(strcmp(User[playerid][pName],WorkshopInfo[idx][wDeputy1],true) == 0 || strcmp(User[playerid][pName],WorkshopInfo[idx][wDeputy2],true) == 0 || strcmp(User[playerid][pName],WorkshopInfo[idx][wDeputy3],true) == 0) return 2;
    if(strcmp(User[playerid][pName],WorkshopInfo[idx][wMechanic1],true) == 0 || strcmp(User[playerid][pName],WorkshopInfo[idx][wMechanic2],true) == 0 || strcmp(User[playerid][pName],WorkshopInfo[idx][wMechanic3],true) == 0
    || strcmp(User[playerid][pName],WorkshopInfo[idx][wMechanic4],true) == 0 || strcmp(User[playerid][pName],WorkshopInfo[idx][wMechanic5],true) == 0) return true;
    return false;
}
stock LoadTuning(c,carid)
{
    if(CarInfo[c][carVehcom_1][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_1][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_2][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_2][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_3][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_3][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_4][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_4][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_5][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_5][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_6][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_6][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_7][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_7][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_8][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_8][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_9][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_9][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_10][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_10][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_11][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_11][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_12][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_12][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_13][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_13][GetPVarInt(c,"SelectCar")]);
	if(CarInfo[c][carVehcom_14][GetPVarInt(c,"SelectCar")]!=0) AddVehicleComponent(carid, CarInfo[c][carVehcom_14][GetPVarInt(c,"SelectCar")]);
}
stock SaveTuning(playerid,i)
{
	CarInfo[playerid][carVehcom_1][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_SPOILER);
	CarInfo[playerid][carVehcom_2][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_HOOD);
	CarInfo[playerid][carVehcom_3][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_ROOF);
	CarInfo[playerid][carVehcom_4][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_SIDESKIRT);
	CarInfo[playerid][carVehcom_5][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_LAMPS);
	CarInfo[playerid][carVehcom_6][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_NITRO);
	CarInfo[playerid][carVehcom_7][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_EXHAUST);
	CarInfo[playerid][carVehcom_8][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_WHEELS);
	CarInfo[playerid][carVehcom_9][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_STEREO);
	CarInfo[playerid][carVehcom_10][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_HYDRAULICS);
	CarInfo[playerid][carVehcom_11][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_FRONT_BUMPER);
	CarInfo[playerid][carVehcom_12][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_REAR_BUMPER);
	CarInfo[playerid][carVehcom_13][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_VENT_RIGHT);
	CarInfo[playerid][carVehcom_14][GetPVarInt(playerid,"SelectCar")]=GetVehicleComponentInSlot(i, CARMODTYPE_VENT_LEFT);
}
stock RemoveTuning(c,carid)
{
    if(CarInfo[c][carVehcom_1][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_1][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_1][GetPVarInt(c,"SelectCar")] = 0;
	if(CarInfo[c][carVehcom_2][GetPVarInt(c,"SelectCar")]!=0) RemoveVehicleComponent(carid, CarInfo[c][carVehcom_2][GetPVarInt(c,"SelectCar")]), CarInfo[c][carVehcom_2][GetPVarInt(c,"SelectCar")] = 0;
