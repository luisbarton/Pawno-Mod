CMD:booston(playerid, params[])
{
	if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return 1;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /booston [days]");
	new year, month, day;
	getdate(year, month, day);
	static const fmt_query[] = "INSERT INTO `boost` (`Text`, `boosttime`) VALUES ('BoostTime', '%d')";
	new query[sizeof(fmt_query)+(-2+60)+(-2+40)];
	mysql_format(dbHandle, query, sizeof(query), fmt_query, mktime(4, 58, 0, day + params[0], month, year));
	mysql_query(dbHandle, query);
	booston = true;
	for(new i = 1; i <= ALLKVARTIRI; i++) updatekvar(i);
	return SendClientMessage(playerid,COLOR_WHITE,"Бонусы включены");
}
CMD:boostoff(playerid, params[])
{
	if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return 1;
	mysql_query(dbHandle, "DELETE FROM `boost` WHERE `Text` = 'BoostTime'");
	booston = false;
	for(new i = 1; i <= ALLKVARTIRI; i++) updatekvar(i);
	return SendClientMessage(playerid,COLOR_WHITE,"Бонусы отключены");
}
CMD:getdonate(playerid)
{
    if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
    static const fmt_query[] = "SELECT * FROM accounts WHERE Name = '%s' AND pFreeDonate!='0'";
    new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	format(query, sizeof(query), fmt_query, User[playerid][pName]);
 	mysql_tquery(dbHandle, query, "CheckDonate", "d", playerid);
	return 1;
}
