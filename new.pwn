		if(User[i][pLeader] == 1 || User[i][pMember] == 1 || User[i][pLeader] == 10 || User[i][pMember] == 10 || User[i][pLeader] == 21 || User[i][pMember] == 21) SendClientMessage(i, color, str);
	}
}
