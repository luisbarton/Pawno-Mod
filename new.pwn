CMD:carmat(playerid)
{
	if((User[playerid][pMember] != 3 && User[playerid][pMember] != 19) || !GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(VertMats[playerid] > 0) return true;
	if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 548) return SendClientMessage(playerid,COLOR_GREY, "Вы не в загрузочном вертолёте!");
	SetPlayerCheckpoint(playerid,-1420.4194,1485.6796,11.8084,14.0);
	SendClientMessage(playerid,COLOR_WHITE, "Отправляйтесь на корабль, для загрузки Оружия");
	VertMats[playerid] = 1;
	return true;
}
CMD:gbalance(playerid, params[])
{
    switch(User[playerid][pMember])
	{
		case 15:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Grove: %i вирт", FracBank[0][fGrove]);
			return SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		case 12:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Ballas: %i вирт", FracBank[0][fBallas]);
			return SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		case 13:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Vagos: %i вирт", FracBank[0][fVagos]);
			return SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		case 17:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Aztec: %i вирт", FracBank[0][fAztek]);
			return SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		case 18:
		{
			format(YCMDstr, sizeof(YCMDstr), "В банке Rifa: %i вирт", FracBank[0][fRifa]);
			return SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		}
		default: SendClientMessage(playerid, COLOR_GREY, "Вам недоступна данная команда!'");
	}
	return true;
}
CMD:gbankwithdraw(playerid, params[])
{
    if(User[playerid][pLogin] == 0) return true;
	if(User[playerid][pLeader] == 15 || User[playerid][pLeader] == 12 || User[playerid][pLeader] == 13 || User[playerid][pLeader] == 17 || User[playerid][pLeader] == 18)
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /gbankwithdraw [количество]");
	if(User[playerid][pMember] == 12 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fBallas] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Ballas нет денег"); return true; }
		if(FracBank[0][fBallas] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Ballas нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
		FracBank[0][fBallas] -= params[0];
		User[playerid][pCash] += params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка банды Ballas: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 13 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fVagos] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Vagos нет денег"); return true; }
		if(FracBank[0][fVagos] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Vagos нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
		FracBank[0][fVagos] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка банды Vagos: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 15 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fGrove] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Grove нет денег"); return true; }
		if(FracBank[0][fGrove] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Grove нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
		FracBank[0][fGrove] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка банды Grove: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 17 && User[playerid][pRank] == 10)
	{
		if(FracBank[0][fAztek] == 0) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Aztec нет денег"); return true; }
		if(FracBank[0][fAztek] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "В банке банды Aztec нет столько денег"); return true; }
		if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный количество денег!"); return true; }
		FracBank[0][fAztek] -= params[0];
		User[playerid][pCash] +=params[0];
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли с банка банды Aztec: %i вирт", params[0]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	}
	else if(User[playerid][pMember] == 18 && User[playerid][pRank] == 10)
