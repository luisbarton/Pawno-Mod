stock UpdateFish(playerid)
{
	new str[128];
	if(GetPVarInt(playerid,"fish_sonar")) format(str,sizeof(str),"~y~Tackle: ~w~%i~n~~y~Worms: ~w~%i~n~~y~Sonar: ~w~%.2f~n~~n~~y~Press: ~g~L.ALT",GetPVarInt(playerid,"fish_gear"),GetPVarInt(playerid,"fish_worms"),Sonar[IsAtFishPlace(playerid)]);
	else format(str,sizeof(str),"~y~Tackle: ~w~%i~n~~y~Worms: ~w~%i~n~~n~~y~Press: ~g~L.ALT",GetPVarInt(playerid,"fish_gear"),GetPVarInt(playerid,"fish_worms"));
	PlayerTextDrawSetString(playerid,FishingText[playerid],str);
	return true;
}
stock ShowLoginDialog(playerid) {
    //printf("(Stock) go 1",User[playerid][pName]);
	new temp[300];
	format(temp,sizeof(temp),"{FFFFFF}Добро пожаловать на {F1C33A}"FullServName"{FFFFFF}\n\nАккаунт {589A76}%s {FFFFFF}найден в базе данных\n\nВведите пароль от аккаунта:", User[playerid][pName]);
	ShowPlayerDialogEx(playerid,1,DIALOG_STYLE_PASSWORD, "{F1C33A}Авторизация",temp, "Войти", "Отмена");
	if(!GetPVarInt(playerid,"time_logged")) SetPVarInt(playerid,"time_logged",30);
	return 1;
}
stock ShowRegisterDialog(playerid) {
	new temp[400];
	format(temp,sizeof(temp), "{FFFFFF}Добро пожаловать на {F1C33A}"FullServName"{FFFFFF}\n\nАккаунт {589A76}%s {FFFFFF}не найден в базе данных\n\nПридумайте пароль для аккаунта и введите его:",User[playerid][pName]);
	ShowPlayerDialogEx(playerid,2,DIALOG_STYLE_INPUT, "{F1C33A}Регистрация",temp, "Готово", "Отмена");
	SetPVarInt(playerid,"time_logged",180);
	return 1;
}
publics: CheckPlayerRegistered(playerid, race_check)
{
    if(!IsPlayerConnected(playerid)) return 1;
    if(race_check != gMysqlRaceCheck[playerid]) return KickEx(playerid, "BUG REGISTER/Autor#1");
	new rows;
	cache_get_row_count(rows);
	if(rows) ShowLoginDialog(playerid);
	else ShowRegisterDialog(playerid);
	return 1;
}

public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	new gun,ammo;
	new gunname[32];
	switch(dialogid)
	{
	    case d_family_rank:
		{
			if ( ! response ) return DeletePVar ( playerid, "pl_setrank_id" ) ;
			new _pl_id = GetPVarInt ( playerid, "pl_setrank_id" ) ;

			if ( ! IsPlayerConnected ( _pl_id )  || _pl_id == playerid ) return SendClientMessage ( playerid, COLOR_GREY, "Игрок не найден." ) ;
			if ( User [ _pl_id ] [ pFamilyMember ] != User [ playerid ] [ pFamilyMember ] ) return SendClientMessage ( playerid, COLOR_GREY, "Игрок не состоит в Вашей семье." ) ;
			if ( listitem + 1 > User [ playerid ] [ pFamilyRank ] && User [ playerid ] [ pFamilyRank ] > User [ _pl_id ] [ pFamilyRank ] )
			{
				QUERY [ 0 ] = EOS ;
				for ( new i = 0; i < 6 ; i ++ )
				{
					new line_string [ 72 ] ;
					format ( line_string, 72, "{"#cGR"}%i. {"#cWH"}%s\n", i + 1, family_rank [ User [ playerid ] [ pFamilyMember ] ] [ i ] ) ;
					strcat ( QUERY, line_string ) ;
				}
				ShowPlayerDialogEx ( playerid, d_family_rank, DIALOG_STYLE_LIST, "{"#cBL"}Семейный статус", QUERY, "Выбрать", "Назад" ) ;
				return SendClientMessage ( playerid, COLOR_GREY, "Вы не можете назначить игрока на статус выше Вашего." ) ;
			}
			User [ _pl_id ] [ pFamilyRank ] = listitem + 1 ;
			//update_int_sql ( _pl_id, "u_family_rank", User [ _pl_id ] [ family_rang ]  ) ;


			new _text_string [ 128 ] ;
			format ( _text_string, 128, "{"#cWH"}Вы назначили %s на статус {"#cGN"}%s(%d)", User [ _pl_id ] [ pName ], family_rank [ User [ _pl_id ] [ pFamilyMember ] ] [ listitem ], listitem + 1 ) ;
			SendClientMessage ( playerid, -1, _text_string ) ;
			format ( _text_string, 128, "%s {"#cWH"}назначил Вас на статус {"#cGN"}%s(%d)", User [ playerid ] [ pName ], family_rank [ User [ _pl_id ] [ pFamilyMember ] ] [ listitem ], listitem + 1 ) ;
			SendClientMessage ( _pl_id, COLOR_GREEN, _text_string ) ;
		}
	    case d_main_accessories:
		{
			if ( ! response ) return cmd::mainmenu(playerid, "");
			if ( listitem == 0 )
			{
				new line_string [ 42 ] ;
				QUERY [ 0 ] = EOS ;
				strcat ( QUERY, "{"#cBL"}Выберите слот аксессуара\n" ) ;
				for ( new j = 0 ; j < 8 ; j ++ )
				{
					if ( User [ playerid ] [ accessories ] [ j ] == 0 )
					{
						strcat ( QUERY, "{"#cGR"}- Пусто\n" ) ;
					}
					else
					{
						format ( line_string, 42, "{ffffff}- %s\n", get_accessorie_name ( User [ playerid ] [ accessories ] [ j ] ) ) ;
						strcat ( QUERY, line_string ) ;
					}
				}
				ShowPlayerDialogEx ( playerid, d_main_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", QUERY, "Выбрать", "Назад" ) ;
				return 1 ;
			}
			if ( User [ playerid ] [ accessories ] [ listitem - 1 ] == 0 )
			{
				SendClientMessage ( playerid, COLOR_GREY, "Данный слот аксессуаров пуст." ) ;
				new line_string [ 42 ] ;
				QUERY [ 0 ] = EOS ;
				strcat ( QUERY, "{"#cBL"}Выберите слот аксессуара\n" ) ;
				for ( new j = 0 ; j < 8 ; j ++ )
				{
					if ( User [ playerid ] [ accessories ] [ j ] == 0 )
					{
						strcat ( QUERY, "{"#cGR"}- Пусто\n" ) ;
					}
					else
					{
						format ( line_string, 42, "{ffffff}- %s\n", get_accessorie_name ( User [ playerid ] [ accessories ] [ j ] ) ) ;
						strcat ( QUERY, line_string ) ;
					}
				}
				ShowPlayerDialogEx ( playerid, d_main_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", QUERY, "Выбрать", "Назад" ) ;
				return 1 ;

			}
			SetPVarInt ( playerid, "acc_listitem", listitem - 1 ) ;
			ShowPlayerDialogEx ( playerid, d_use_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", "{"#cGR"}- {"#cWH"}Надеть\n{"#cGR"}- {"#cWH"}Снять\n{"#cGR"}- {"#cWH"}Выбросить", "Выбрать", "Назад" ) ;

		}
		case d_use_accessories:
		{
			if ( ! response )
			{
				DeletePVar ( playerid, "acc_listitem" ) ;
				new line_string [ 42 ] ;
				QUERY [ 0 ] = EOS ;
				strcat ( QUERY, "{"#cBL"}Выберите слот аксессуара\n" ) ;
				for ( new j = 0 ; j < 8 ; j ++ )
				{
					if ( User [ playerid ] [ accessories ] [ j ] == 0 )
					{
						strcat ( QUERY, "{"#cGR"}- Пусто\n" ) ;
					}
					else
					{
						format ( line_string, 42, "{ffffff}- %s\n", get_accessorie_name ( User [ playerid ] [ accessories ] [ j ] ) ) ;
						strcat ( QUERY, line_string ) ;
					}
				}
				ShowPlayerDialogEx ( playerid, d_main_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", QUERY, "Выбрать", "Назад" ) ;
				return 1 ;
			}
			new item_id = GetPVarInt ( playerid, "acc_listitem" ) ;
			switch ( listitem )
			{
				case 0:
				{
					User [ playerid ] [ accessories_used ] [ item_id ] = 1 ;
					GiveItem ( playerid, User [ playerid ] [ accessories ] [ item_id ] ) ;
					new _query [ 136 ] ;
					format ( _query, sizeof ( _query ), "UPDATE `accounts` SET `u_accessories_used`='%d|%d|%d|%d|%d%d|%d|%d' WHERE `pID` = '%d'",
					User [ playerid ] [ accessories_used ] [ 0 ], User [ playerid ] [ accessories_used ] [ 1 ], User [ playerid ] [ accessories_used ] [ 2 ],
					User [ playerid ] [ accessories_used ] [ 3 ], User [ playerid ] [ accessories_used ] [ 4 ], User [ playerid ] [ accessories_used ] [ 5 ], User [ playerid ] [ accessories_used ] [ 6 ],
					User [ playerid ] [ accessories_used ] [ 7 ], PlayerIDs[playerid] ) ;
					mysql_tquery ( dbHandle, _query ) ;
					SendClientMessage ( playerid, COLOR_GREY, "* Аксессуар успешно надет на персонажа.") ;
				}
				case 1:
				{
					User [ playerid ] [ accessories_used ] [ item_id ] = 0 ;
					for ( new i = 5; i < 10 ; i ++ )
					{
						if ( IsPlayerAttachedObjectSlotUsed ( playerid, i ) ) RemovePlayerAttachedObject ( playerid, i ) ;
					}
					for ( new j = 0 ; j < 8 ; j ++ )
					{
						if ( User [ playerid ] [ accessories_used ] [ j ] == 0 ) continue ;
						GiveItem ( playerid, User [ playerid ] [ accessories ] [ j ] ) ;
					}

					new _query [ 136 ] ;
					format ( _query, sizeof ( _query ), "UPDATE `accounts` SET `u_accessories_used`='%d|%d|%d|%d|%d%d|%d|%d' WHERE `pID` = '%d'",
					User [ playerid ] [ accessories_used ] [ 0 ], User [ playerid ] [ accessories_used ] [ 1 ], User [ playerid ] [ accessories_used ] [ 2 ],
					User [ playerid ] [ accessories_used ] [ 3 ], User [ playerid ] [ accessories_used ] [ 4 ], User [ playerid ] [ accessories_used ] [ 5 ], User [ playerid ] [ accessories_used ] [ 6 ],
					User [ playerid ] [ accessories_used ] [ 7 ], PlayerIDs[playerid] ) ;
					mysql_tquery ( dbHandle, _query ) ;
					SendClientMessage ( playerid, COLOR_GREY, "* Аксессуар успешно снят с персонажа.") ;
				}
				case 2:
				{
					User [ playerid ] [ accessories_used ] [ item_id ] = 0 ;
					User [ playerid ] [ accessories ] [ item_id ] = 0 ;
					for ( new i = 5; i < 10 ; i ++ )
					{
						if ( IsPlayerAttachedObjectSlotUsed ( playerid, i ) ) RemovePlayerAttachedObject ( playerid, i ) ;
					}
					for ( new j = 0 ; j < 8 ; j ++ )
					{
						if ( User [ playerid ] [ accessories_used ] [ j ] == 0 ) continue ;
						GiveItem ( playerid, User [ playerid ] [ accessories ] [ j ] ) ;
					}

					new _query [ 136 ] ;
					format ( _query, sizeof ( _query ), "UPDATE `accounts` SET `u_accessories_used`='%d|%d|%d|%d|%d%d|%d|%d' WHERE `pID` = '%d'",
					User [ playerid ] [ accessories_used ] [ 0 ], User [ playerid ] [ accessories_used ] [ 1 ], User [ playerid ] [ accessories_used ] [ 2 ],
					User [ playerid ] [ accessories_used ] [ 3 ], User [ playerid ] [ accessories_used ] [ 4 ], User [ playerid ] [ accessories_used ] [ 5 ], User [ playerid ] [ accessories_used ] [ 6 ],
					User [ playerid ] [ accessories_used ] [ 7 ], PlayerIDs[playerid] ) ;
					mysql_tquery ( dbHandle, _query ) ;
					format ( _query, sizeof ( _query ), "UPDATE `accounts` SET `u_accessories`='%d|%d|%d|%d|%d%d|%d|%d' WHERE `pID` = '%d'",
					User [ playerid ] [ accessories ] [ 0 ], User [ playerid ] [ accessories ] [ 1 ], User [ playerid ] [ accessories ] [ 2 ],
					User [ playerid ] [ accessories ] [ 3 ], User [ playerid ] [ accessories ] [ 4 ], User [ playerid ] [ accessories ] [ 5 ], User [ playerid ] [ accessories ] [ 6 ],
					User [ playerid ] [ accessories ] [ 7 ], PlayerIDs[playerid] ) ;
					mysql_tquery ( dbHandle, _query ) ;

					SendClientMessage ( playerid, COLOR_GREY, "* Вы успешно выбросили аксессуар.") ;
				}
			}
			DeletePVar ( playerid, "acc_listitem" ) ;
			new line_string [ 42 ] ;
			QUERY [ 0 ] = EOS ;
			strcat ( QUERY, "{"#cBL"}Выберите слот аксессуара\n" ) ;
			for ( new j = 0 ; j < 8 ; j ++ )
			{
				if ( User [ playerid ] [ accessories ] [ j ] == 0 )
				{
					strcat ( QUERY, "{"#cGR"}- Пусто\n" ) ;
				}
				else
				{
					format ( line_string, 42, "{ffffff}- %s\n", get_accessorie_name ( User [ playerid ] [ accessories ] [ j ] ) ) ;
					strcat ( QUERY, line_string ) ;
				}
			}
			ShowPlayerDialogEx ( playerid, d_main_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", QUERY, "Выбрать", "Назад" ) ;
		}
		case d_unik_accessories:
		{
			if ( ! response ) return 1;
			
			switch ( listitem )
			{
				/*case 0:
				{
					//гитары 19319, 19318, 19317
					if ( User [ playerid ] [ pCash ] < 50000 )return SendClientMessage ( playerid, COLOR_GREY, "У Вас недостаточно средств для приобретения аксессуара.") ;
					User [ playerid ] [ pCash ] -= 50000;
					User [ playerid ] [ accessories_used ] [ 5 ] = 0;
					new rand = random(3);
					switch (rand)
					{
                    	case 0: User [ playerid ] [ accessories ] [ 5 ] = 19319;
                    	case 1: User [ playerid ] [ accessories ] [ 5 ] = 19318;
                    	case 2: User [ playerid ] [ accessories ] [ 5 ] = 19317;
                    }
                    SendClientMessage(playerid, -1, "{"#cGN"}* {"#cWH"}Вы успешно приобрели аксессуар. Панель управления аксессуарами находится в личном меню." ) ;
                    //User [ playerid ] [ accessories_used ] [ listitem - 1 ] = 0 ;
					//User [ playerid ] [ accessories ] [ listitem - 1 ] = accessories_items [ GetPVarInt ( playerid, "p_acc_listitem" ) - 1 ] [ GetPVarInt ( playerid, "p_acc_id" ) ] ;
				}*/
				case 0:
				{
				    if ( User [ playerid ] [ pCash ] < 50000 )return SendClientMessage ( playerid, COLOR_GREY, "У Вас недостаточно средств для приобретения аксессуара.") ;
					User [ playerid ] [ pCash ] -= 50000;
