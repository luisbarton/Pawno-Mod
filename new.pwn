			if(hour >= 12 && minute == 10 && second == 0) startaddiction[i] = 1;
			if(User[i][pMutedr] > 1) User[i][pMutedr] --;
			if(User[i][pMutedr] == 1) User[i][pMutedr] = 0, SendClientMessage(i,COLOR_LIGHTRED, "Вам включили репорт. Пожалуйста соблюдайте правила");
			if(User[i][pMuted] > 1) User[i][pMuted] --;
			if(User[i][pMuted] == 1) User[i][pMuted] = 0, SendClientMessage(i,COLOR_LIGHTRED, "Вам включили чат. Пожалуйста соблюдайте правила");
			if(User[i][pJailTime] > 0)
			{
				if(User[i][pJailTime] > 1) User[i][pJailTime]--;
				if(User[i][pJailTime] == 1)
				{
					if(User[i][pMestoJail] == 1) SetPlayerInterior(i, 0), t_SetPlayerPos(i,1553.4962,-1675.2714,16.1953), SetPlayerFacingAngle(i, 95.0636);
					if(User[i][pMestoJail] == 2) SetPlayerInterior(i, 0), t_SetPlayerPos(i,-1607.1873,721.3649,12.2721), SetPlayerFacingAngle(i, 2.3026);
					if(User[i][pMestoJail] == 3) SetPlayerInterior(i, 0), t_SetPlayerPos(i,2334.8467,2454.9456,14.9688), SetPlayerFacingAngle(i, 115.7874);
					if(User[i][pMestoJail] == 4) SetPlayerWorldBounds(i,20000.0000,-20000.0000,20000.0000,-20000.0000), SetPlayerInterior(i, 0), t_SetPlayerPos(i, 86.9821,1181.0541,18.6641);
					User[i][pJailTime] = 0;
					DeletePVar(i, "PlayerCuffed");
					SendClientMessage(i, COLOR_ISPOLZUY, "Вы заплатили свой долг обществу, теперь вы свободны!");
					User[i][pMestoJail] = 0;
					User[i][pWantedLevel] = 0;
					SetPlayerWantedLevel(i, 0);
					SetPlayerVirtualWorld(i, 0);
					GameTextForPlayer(i,"~g~Freedom", 5000, 1);
				}
			}
			if(PlayerTazeTime[i] >= 1) PlayerTazeTime[i] += 1;
			if(PlayerTazeTime[i] >= 15) PlayerTazeTime[i] = 0, TogglePlayerControllable(i, 1);
			if(GetPVarInt(i, "PlayerCuffed") == 1)
			{
				if(GetPVarInt(i, "PlayerCuffedTime") <= 0)
				{
					TogglePlayerControllable(i, 1);
					DeletePVar(i, "PlayerCuffed");
					DeletePVar(i, "PlayerCuffedTime");
					PlayerTazeTime[i] = 1;
				}
				else
				{
					SetPVarInt(i, "PlayerCuffedTime", GetPVarInt(i, "PlayerCuffedTime") - 1);
				}
			}
			if(GetPVarInt(i, "PlayerCuffed") == 2)
			{
				if(GetPVarInt(i, "PlayerCuffedTime") <= 0)
				{
					TogglePlayerControllable(i, 1);
					DeletePVar(i, "PlayerCuffed");
					DeletePVar(i, "PlayerCuffedTime");
				}
				else SetPVarInt(i, "PlayerCuffedTime", GetPVarInt(i, "PlayerCuffedTime") - 1);
			}
			SetPVarInt(i, "SatietyTime", GetPVarInt(i, "SatietyTime") + 1);
			if(GetPVarInt(i, "SatietyTime") == 15)
			{
				SetPVarInt(i, "SatietyTime", 0);
				new Float:hppp;
				GetPlayerHealth(i,hppp);
				User[i][Satiety] -= 1.0;
				if(User[i][Satiety] < 50) SetPlayerHealth(i, hppp - 0.5);
				else if(User[i][Satiety] < 25) SetPlayerHealth(i, hppp - 1.0);
				//if(User[i][PlayerSettings] & setShowEatBar)
				//{
				SetPlayerProgressBarValue(i, EatBar[i],User[i][Satiety]);
				//}
				if(User[i][Satiety] <= 0)
				{
					User[i][Satiety] = 0;
				}
				if(User[i][Satiety] == 24 || User[i][Satiety] == 49)
				{
					SCM(i,COLOR_ISPOLZUY, !"Вы проголодались! Посетите бар, закусочную или купите ХотДог. Узнать свою «Сытость» можно командой /satiety");
				}
			}
			AntiChEndOK=20;
		}
	}
