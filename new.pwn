CMD:apanel(playerid)
{
	if(!GetPVarInt(playerid, "Dostup")) return true;
	else if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup"))  return SendClientMessage(playerid, COLOR_GREY, "[A] Вы не авторизованы. Используйте {33CCFF}/alogin");
  	QUERY[0] = EOS;
	strcat(QUERY, "1 | VIP игроки\t\t\t\t{63BD4E}[Online]{ffffff}\n");
	strcat(QUERY, "1 | Администраторы\t\t\t{63BD4E}[Online]{ffffff}\n");
	strcat(QUERY, "1 | Команды администратора\n");
	if(User[playerid][pAdmin] >= 5)
	{
	    strcat(QUERY, "5 | Удобства для МП\n");
	}
	if(User[playerid][pAdmin] >= 6)
	{
	    strcat(QUERY, "6 | Список всех администраторов\n");
	    strcat(QUERY, "6 | Статистика администратора\n");
	}
	if(User[playerid][pAdmin] >= 8)
	{
		strcat(QUERY, "8 | Промокоды\n");
		strcat(QUERY, "8 | Вкл/выкл акцию X2\n");
	}
	if(User[playerid][pAdmin] >= 10)
	{
		strcat(QUERY, "10 | Сменить название hostname");
	}
   	ShowPlayerDialogEx(playerid, dAdminPanel, 2, "{F1C33A}Панель администратора", QUERY, "Выбрать", "Отмена");
	return 1;
}
CMD:mp(playerid)
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	QUERY[0] = EOS;
	format(QUERY, sizeof(QUERY), "\
		1. %s {FFFFFF}телепорт на мероприятие\n\
		2. Указать количество участников\n\
		3. {63BD4E}Выдать {FFFFFF}здоровье в радиусе\n\
		4. {63BD4E}Выдать {FFFFFF}броню в радиусе\n\
		5. {63BD4E}Выдать {FFFFFF}оружие в радиусе\n\
		6. {F04245}Забрать {FFFFFF}броню в радиусе\n\
		7. {F04245}Забрать {FFFFFF}оружие в радиусе\n\
		8. Заспавнить игроков в радиусе\n\
		9. Выдать временные скиллы в радиусе",
		(!gEvent[eventStatus])?("{63BD4E}Открыть"):("{F04245}Закрыть"));
	ShowPlayerDialogEx(playerid, dEvent, DIALOG_STYLE_LIST, "{F1C33A}Управление мероприятием", QUERY, "Далее", "Закрыть");
	return 1;
}

CMD:gomp(playerid)
{
	if(!gEvent[eventStatus]) return 0;
	else if(gEventIn[playerid] != -1) return SendClientMessage(playerid, COLOR_GREY, "Вы уже телепортировались на мероприятие!");
	else if(User[playerid][pJailTime]) return SendClientMessage(playerid, COLOR_GREY, "Заключённым нельзя телепортироваться!");
	if(!Works[playerid])
	{
	    gEventIn[playerid] = 1;
	   // if(gEvent[eventVirtualWorld] == 30 || gEvent[eventVirtualWorld] == 31)
		t_SetPlayerPos(playerid, gEvent[eventPos][0], gEvent[eventPos][1], gEvent[eventPos][2]);
		TogglePlayerControllable(playerid, false);
		SetTimerEx("UnFreeze", (GetPlayerPing(playerid)>100?(3500):(2000)), false, "d", playerid);
	    SetPlayerVirtualWorld(playerid, gEvent[eventVirtualWorld]);
	    SetPlayerInterior(playerid, gEvent[eventInterior]);
		SendClientMessage(playerid, COLOR_YELLOW, "[Информация] {FFFFFF}Вы успешно телепортировались на место проведения мероприятия");
	}
	else SendClientMessage(playerid, COLOR_GREY, "Необходимо завершить все начатые работы и активные действия!");
	return 1;
}
CMD:awarehouse(playerid, params[])
{
	new str[128];
	if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	format(str, sizeof(str), "На складе Зоны 51: %i/300000 матов", FracStore[LVaStore]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе армии Авианосца: %i/300000 матов", FracStore[SFaStore]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе FBI %i матов", FracStore[FBI]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе LSPD %i/50000 матов", FracStore[LSPD]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе SFPD %i/50000 матов", FracStore[SFPD]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе LVPD %i/50000 матов", FracStore[LVPD]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе мафии Якудза %i/50000 матов", FracStore[Yakuza]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе мафии LCN %i/50000 матов", FracStore[LCN]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	format(str, sizeof(str), "На складе Русской Мафии %i/50000 матов", FracStore[RM]);
	SendClientMessage(playerid, COLOR_GRAD1, str);
	return true;
}
CMD:payday(playerid, params[])
{
	if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return true;
	PayDay();
	return true;
}
CMD:gcontract(playerid, params[])
{
	if(User[playerid][pLogin] == 0) return true;
	new giveplayerid;
	if(Prorab[playerid] == false) return SCM(playerid,COLOR_GREY, "Вы должны переодеться");
	if(!IsPlayerInRangeOfPoint(playerid,10.0,2805.8594,-2439.1484,13.6293)) return SCM(playerid,COLOR_GREY, "Вы должны находиться на работе грузчика");
	if(sscanf(params, "u", giveplayerid)) return SCM(playerid,-1, " {AFAFAF}Введите: /gcontract [ID].");
	if(giveplayerid == playerid) return SCM(playerid,COLOR_GREY, "Вы указали свой ID");
	if(Prorab[giveplayerid] == true) return SCM(playerid,COLOR_GREY, "Вы не можете заключать контракт с прорабом");
	if(Works[giveplayerid] == true) return SCM(playerid,COLOR_GREY, "Этот игрок уже работает.");
	if(!IsPlayerConnected(giveplayerid)) return SCM(playerid,COLOR_GREY, "Игрок не в сети");
	if(!ProxDetectorS(5.0, playerid, giveplayerid)) return SCM(playerid,COLOR_GREY, "Ошибка. Игрок должен находиться рядом с Вами");
	if(JobOffer[giveplayerid] == playerid) return SCM(playerid,COLOR_GREY, "Вы уже предложили игроку контракт.");
	JobOffer[giveplayerid] = playerid;
	format(YCMDstr, 128, " Вы предложили %s работать под Вашим начальством.",User[giveplayerid][pName]);
	SCM(playerid, 0x81DA99AA, YCMDstr);
	format(YCMDstr, 128, " %s предложил работать под его начальством /accept gcontract", User[playerid][pName]);
	SCM(giveplayerid, 0x81DA99AA, YCMDstr);
	return true;
}
CMD:givepayday(playerid, params[])
{
    if(Prorab[playerid] == false) return SendClientMessage(playerid,0xFFFFFFFF, "Чтобы использвать команду, необходимо выйти на работу.");
    new giveplayerid;
	if(sscanf(params, "u", giveplayerid)) return SendClientMessage(playerid,COLOR_GREY, "Введите: /gpayday [id игрока].");
	if(Employer[giveplayerid] != playerid) return SendClientMessage(playerid,COLOR_GREY, "Этот игрок не работает на Вас.");
	if(Works[giveplayerid] == false) return SendClientMessage(playerid,COLOR_GREY, "Этот игрок не на работе.");
	if(JobAmmount[giveplayerid] == 0) return SendClientMessage(playerid,COLOR_GREY, "Этот игрок не перенёс ни одного мешка.");
	if(!IsPlayerConnected(giveplayerid)) return SendClientMessage(playerid,COLOR_GREY, "Этот игрок не в сети.");
	if(!ProxDetectorS(5.0, playerid, giveplayerid)) return SendClientMessage(playerid,COLOR_GREY, "Игрок не возле Вас.");
	format(YCMDstr,128, "Игрок получил {228B22}%i вирт{FFFFFF} за свою работу.",JobAmmount[giveplayerid]*50);
	SendClientMessage(playerid,0xFFFFFFFF,YCMDstr);
	GiveMoney(giveplayerid,JobAmmount[giveplayerid]*50);
	format(YCMDstr,128, "Ты получил {228B22}%i вирт{FFFFFF} от работы %s.",JobAmmount[giveplayerid]*50, User[playerid][pName]);
	SendClientMessage(giveplayerid, COLOR_WHITE,YCMDstr);
	JobAmmount[giveplayerid] = 0;
	return true;
}
CMD:repaydebt(playerid, params[])
{
    if(User[playerid][pJob] == 0) return true;
    if(User[playerid][pDolg] < 50) return SendClientMessage(playerid, COLOR_GREY, "Недостаточная сумма для возврата долга!");
	switch(User[playerid][pKrisha])
	{
		case 6:
		{
			SendClientMessage(playerid, COLOR_YELLOW, "Долг был возвращён мафии Yakuza!");
			format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[playerid][pName],User[playerid][pDolg]);
			SendFamilyMessage(6,COLOR_YELLOW2, YCMDstr);
			MafiaBank[0][nYakuza] +=User[playerid][pDolg] ;
			User[playerid][pDolg] = 0;
		}
		case 5:
		{
			if(User[playerid][pDolg] < 50) return SendClientMessage(playerid, COLOR_GREY, "Недостаточная сумма для возврата долга!");
			SendClientMessage(playerid, COLOR_YELLOW, "Долг был возвращён LCN!");
			format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[playerid][pName],User[playerid][pDolg]);
			SendFamilyMessage(5,COLOR_YELLOW2, YCMDstr);
			MafiaBank[0][nLcn] +=User[playerid][pDolg];
			User[playerid][pDolg] = 0;
		}
		case 14:
		{
			if(User[playerid][pDolg] < 50) return SendClientMessage(playerid, COLOR_GREY, "Недостаточная сумма для возврата долга!");
			SendClientMessage(playerid, COLOR_YELLOW, "Долг был возвращён Русской мафии!");
			format(YCMDstr, sizeof(YCMDstr), "%s вернул долг в размере %s вирт",User[playerid][pName],User[playerid][pDolg]);
			SendFamilyMessage(14,COLOR_YELLOW2, YCMDstr);
			MafiaBank[0][nRm] +=User[playerid][pDolg] ;
			User[playerid][pDolg] = 0;
		}
	}
	return true;
}
