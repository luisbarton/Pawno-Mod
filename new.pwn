CMD:busdrivers(playerid)
{
	new null[13], str[3000];
	foreach(new i : Player)
	{
		if(GetPVarInt(i,"TypeBus")) null[GetPVarInt(i,"TypeBus")]++, null[0]++;
	}
	if(!null[0]) return SendClientMessage(playerid,COLOR_GREY, "Нет водителей автобуса!");
	null[7] = 100 / null[0] * null[1];
	null[8] = 100 / null[0] * null[2];
	null[9] = 100 / null[0] * null[3];
	null[10] = 100 / null[0] * null[4];
	null[11] = 100 / null[0] * null[5];
	null[12] = 100 / null[0] * null[6];
	format(str,sizeof(str),			"Всего водителей: %i человек\n\n\
									ВнутриГородской ЛС\t\t\t\t[%s]%i%% %i человек\n\
									ВнутриГородской СФ\t\t\t\t[%s]%i%% %i человек\n\
									ВнутриГородской ЛВ\t\t\t\t[%s]%i%% %i человек\n", null[0],
									ToDevelopSkills(null[7], 100 - null[7]), null[7], null[1],
									ToDevelopSkills(null[8], 100 - null[8]), null[8], null[2],
									ToDevelopSkills(null[9], 100 - null[9]), null[9], null[3]);
	format(str,sizeof(str),			"%sАвтоВокзал LS << >> Автошкола SF\t\t[%s]%i%% %i человек\n\
									АвтоВокзал LS << >> АвтоВокзал LV\t\t[%s]%i%% %i человек\n\
									АвтоВокзал LS << >> Заводы\t\t\t[%s]%i%% %i человек", str,
									ToDevelopSkills(null[10], 100 - null[10]), null[10], null[4],
									ToDevelopSkills(null[11], 100 - null[11]), null[11], null[5],
									ToDevelopSkills(null[12], 100 - null[12]), null[12], null[6]);
	return ShowPlayerDialogEx(playerid,9999,DIALOG_STYLE_MSGBOX," ",str,"Готово","");
}
CMD:ratingnews(playerid, params[])
{
    new radioall = 0;
    new Float: points[3];
	new string_[412];
	new ratingGNews = 0;
	new ratingLNews = 0;
	new ratingLvNews = 0;
	new Float: procls = 0, Float: procsf = 0, Float: proclv = 0;

	foreach(Player,i)
	{
		if(gNews[i] == false) ratingGNews++, radioall++;
		if(lNews[i] == false) ratingLNews++, radioall++;
		if(LvNews[i] == false) ratingLvNews++, radioall++;
	}
	if(radioall && ratingLNews)
		procls = 100 / radioall * ratingLNews;
	if(radioall && ratingGNews)
		procsf = 100 / radioall * ratingGNews;
	if(radioall && ratingLvNews)
		proclv = 100 / radioall * ratingLvNews;
	points[0] = 100 - procls;
	points[1] = 100 - procsf;
	points[2] = 100 - proclv;
	format(string_, sizeof string_,"\t\t<< Количество слушателей >>\n\n\
	LS News:\t[%s]%d%%\n\
	SF News:\t[%s]%d%%\n\
	LV News:\t[%s]%d%%\n",
	ToDevelopSkills(floatround(procls), floatround(points[0])), floatround(procls),
	ToDevelopSkills(floatround(procsf), floatround(points[1])), floatround(procsf),
	ToDevelopSkills(floatround(proclv), floatround(points[2])), floatround(proclv));
	return ShowPlayerDialog(playerid, 0, DIALOG_STYLE_MSGBOX," ", string_,"Готово","");
}

CMD:spcar(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
	SetVehicleToRespawn(GetPlayerVehicleID(playerid));
	return true;
}
CMD:spcars(playerid, params[])
{
	if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",params[0])) return SCM(playerid, COLOR_GREY, "Используйте: /spcars [расстояние]");
	if(params[0] < 1 && params[0] > 100) SCM(playerid,COLOR_GREY, "Радиус должен быть не менее 1 и не более 100 метров");
	if(GetVehiclePoolSize()>=MAX_VEHICLES) return SendClientMessage(playerid,-1,"pizda");
	new Float:car_x,Float:car_y,Float:car_z;
	for(new i = 1, j = GetVehiclePoolSize(); i <= j; i++)
	{
	    if(GetVehicleModel(i) > 399)
		{
			GetVehiclePos(i,car_x,car_y,car_z);
			if(IsPlayerInRangeOfPoint(playerid,params[0]+2,car_x,car_y,car_z)) SetVehicleToRespawn(i);
		}
	}
	SCM(playerid,COLOR_BLUE,"Машины заспавнены");
	format(YCMDstr,sizeof(YCMDstr),"Администратор: %s заспавнил машины",User[playerid][pName]);
	SendAdminMessage(COLOR_LIGHTRED, YCMDstr);
	return 1;//ProxDetector(params[0], playerid, YCMDstr, COLOR_LIGHTRED,COLOR_LIGHTRED,COLOR_LIGHTRED,COLOR_LIGHTRED,COLOR_LIGHTRED);
}
CMD:cc(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	for(new i = 0; i < 60; i++) SendClientMessageToAll(COLOR_WHITE, "");
	SendClientMessageToAll(-1,"Игровой чат очищен администрацией сервера");
	return true;
}
CMD:free(playerid, params[])
{
    if(User[playerid][pMember] != 7 || User[playerid][pRank] != 2 || !GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /free [id] [цена]");
    if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Вы слишком далеко.");
	if(User[params[0]][pJailTime] < 1) return SendClientMessage(playerid, COLOR_GREY, "Человек не в тюрьме!");
	if(params[1] < 100 || params[1] > 50000) { SendClientMessage(playerid, COLOR_GREY, "Цена не может быть меньше 100 и больше 50000!"); return true; }
	if(params[1] == playerid)  return  SendClientMessage(playerid,COLOR_GREY, "Вы указали свой ID");
	format(YCMDstr, sizeof(YCMDstr), "[Адвокат] Вы предложили %s выпустить его за %i вирт",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "[Адвокат] %s предлагает Вам свободу за %i вирт",User[playerid][pName],params[1]);
	SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
	ShowPlayerDialogEx(params[0],6622,DIALOG_STYLE_MSGBOX, "Адвокатские услуги", "Выберите способ оплаты:", "Наличные", "Банк");
	FreeOffer[params[0]] = playerid;
	FreePrice[params[0]] = params[1];
	SposobOffer[params[0]] = 0;
	return true;
}
CMD:selleat(playerid, params[])
{
    if(!User[playerid][pLogin] || User[playerid][pJob] != 3) return true;
	if(sscanf(params, "u", params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /selleat [playerid]");
    if((GetPlayerVehicleID(playerid) < hotdogcar[0] || GetPlayerVehicleID(playerid) > hotdogcar[1]) && !GetPVarInt(playerid,"h_stall")) return SendClientMessage(playerid,COLOR_GREY, "Вы не можете продать хот-дог");
	if(!GetPVarInt(playerid,"h_contract")) return SendClientMessage(playerid,COLOR_GREY, "Вы не заключили контракт с закусочной");
	if(GetPlayerVehicleID(playerid) != GetPVarInt(playerid,"rentcar_job") && !GetPVarInt(playerid,"h_stall")) return SendClientMessage(playerid,COLOR_GREY, "Это не Ваш автомобиль");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid,COLOR_GREY, "Игрок должен находиться рядом с вами");
	new string[145];
	f(string, "Вы предложили %s ХотДог за %i вирт",User[params[0]][pName],GetPVarInt(playerid,"h_price"));
	SCM(playerid, 0x6495EDFF, string);
	f(string, "%s предлагает Вам ХотДог за %i вирт. (( Введите: /(ac)cept hotdog для покупки ХотДога ))",User[playerid][pName],GetPVarInt(playerid,"h_price"));
	SCM(params[0], 0x6495EDFF, string);
	SetPVarInt(params[0],"h_id",playerid+1);
	return true;
}
CMD:rename(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /rename [id]");
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(strlen(WantNickChange[params[0]]) < 3) return SendClientMessage(playerid,-1, "Этот игрок не хочет менять ник");
	format(YCMDstr,sizeof(YCMDstr), " %s одобрил заявку на смену ника: %s >> %s",Name(playerid),Name(params[0]),WantNickChange[params[0]]);
	SendClientMessageToAll(COLOR_LIGHTRED,YCMDstr);
	WriteLog("ChangeName.txt", YCMDstr);
	SCM(playerid,-1," Ник одобрен");
	static const fmt_query[] = "SELECT `Name` FROM `accounts` WHERE `Name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle, query, sizeof(query), fmt_query, WantNickChange[params[0]]);
	mysql_tquery(dbHandle, query, "OnMySQL_QUERY", "iis", 15, params[0], playerid);
	printf("Администратор %s одобрил заявку на смену ника: %s >> %s", Name(playerid), Name(params[0]),WantNickChange[params[0]]);
	return true;
}
CMD:cname(playerid, params[])
{
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /cname [id]");
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(User[playerid][pLeader] != 7) return SendClientMessage(playerid,COLOR_GREY,"Функция доступна только мэру");
	//if(!IsAMayor(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Функция доступна только мэру, и секретарю");
	if(strlen(WantNickChange[params[0]]) < 3) return SendClientMessage(playerid,-1, "Этот игрок не подавал заявку на смену ника");
	format(YCMDstr,sizeof(YCMDstr), " %s одобрил заявку на смену ника: %s >> %s",Name(playerid),Name(params[0]),WantNickChange[params[0]]);
	SendClientMessageToAll(COLOR_YELLOW,YCMDstr);
	WriteLog("ChangeName.txt", YCMDstr);
	SCM(playerid,-1," Ник одобрен");
	static const fmt_query[] = "SELECT `Name` FROM `accounts` WHERE Name= '%e'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle, query, sizeof(query), fmt_query, WantNickChange[params[0]]);
	mysql_tquery(dbHandle, query, "OnMySQL_QUERY", "iis", 15, params[0], playerid);
	printf("[CNAME] Мэр %s одобрил заявку на смену ника: %s >> %s", Name(playerid), Name(params[0]),WantNickChange[params[0]]);
	return true;
}
CMD:forceskin(playerid, params[])
{
	if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "u", params[0])) return SCM(playerid, -1, "Введите: /forceskin [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(User[params[0]][pMember] < 1) return SCM(playerid, COLOR_GREY, "Игрок не состоит в организации");
	SCM(params[0], 0x6BB3FFAA,"Вы были допущены к изменению скина администратором Rise RP");
	format(YCMDstr, sizeof(YCMDstr), "Вы допустили %s к изменению скина", User[params[0]][pName]);
	SCM(playerid, 0x6BB3FFAA, YCMDstr);
	SCM(params[0], COLOR_RED, "Используйте клавишу 'Быстрый бег' (пробел по умолчанию)");
	SCM(params[0], COLOR_RED, "Используйте клавишу 'Вверх,вниз' (W,S по умолчанию)");
	if(!IsValidMenu(ChoseSkin[0]))
	{
	    ChoseSkin[0] = CreateMenu("Victim", 1, 50.0, 160.0, 110.0);
		SetMenuColumnHeader(ChoseSkin[0], 0, "Choose Skin");
		AddMenuItem(ChoseSkin[0], 0, ">> Next");
		AddMenuItem(ChoseSkin[0], 0, "<< Previous");
		AddMenuItem(ChoseSkin[0], 0, "Done");
	}
	ShowMenuForPlayer(ChoseSkin[0],params[0]);
	SetPlayerInterior(params[0],5);
	OldSkin[params[0]] = GetPlayerSkin(params[0]);
	ChosenSkin[params[0]] = OldSkin[params[0]];
	SetPlayerVirtualWorld(params[0],playerid+1002);
	new rand = 0;
	t_SetPlayerPos(params[0], gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
	SetPlayerFacingAngle(params[0], gInviteSpawns[rand][3]);
	SetPlayerCameraPos(params[0],gInviteSpawns[rand][0] + 3, gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
	SetPlayerCameraLookAt(params[0],gInviteSpawns[rand][0], gInviteSpawns[rand][1], gInviteSpawns[rand][2]);
	TogglePlayerControllable(params[0], 0);
	SelectChar[params[0]] = 255;
	SelectCharID[params[0]] = User[params[0]][pMember];
	SelectCharPlace[params[0]] = 1;
	return true;
}
CMD:setskin(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setskin [id скина]");
	if(params[0] > 311 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный ID скина!"); return true; }
	User[playerid][pChar][0] = params[0];
	SetPlayerSkin(playerid, User[playerid][pChar][0]);
	return true;
}
CMD:setplayerskin(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setplayerskin(/spskin) [id игрока/ник] [id скина]");
	if(params[1] > 311 || params[1] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильный ID скина!"); return true; }
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	User[params[0]][pChar][0] = params[1];
	format(YCMDstr, sizeof(YCMDstr), "Вы изменили скин %s на номер: %i",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	SetPlayerSkin(params[0], User[params[0]][pChar][0]);
	return true;
}
CMD:pay(playerid, params[])
{
    if(sscanf(params, "ud", params[0],params[1])) return	SendClientMessage(playerid, COLOR_GRAD1, "Используйте: /pay [id] [сумма]");
	if(params[1] > 1000 && User[playerid][pLevel] < 2) return SendClientMessage(playerid, COLOR_GREY, "У Вас должен быть 2 уровень, чтобы передать больше 1000$!");
	if(params[1] < 1 || params[1] > 50000) return SendClientMessage(playerid, COLOR_GREY, "Нельзя передать меньше 1$ и больше 50000$.");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid,COLOR_GREY, "Такого игрока нет");
	if(params[0] == playerid) return SCM(playerid, COLOR_WHITE, "Вы не можете передать деньги самому себе!");
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Вы слишком далеко.");
	if(GetSRVMoney(playerid) < params[1]) return true;
	User[params[0]][pCash] += params[1];
	User[playerid][pCash] -= params[1];
	LogingTargetMoney(playerid, params[0], params[1], "Передал деньги (/pay)");
	format(YCMDstr, sizeof(YCMDstr), "Вы передали %s[%i] %i$",User[params[0]][pName],params[0],params[1]);
	PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
	SendClientMessage(playerid, COLOR_GRAD1, YCMDstr);
	format(YCMDstr,sizeof(YCMDstr),"~r~-%i$",params[1]);
	GameTextForPlayer(playerid,YCMDstr, 5000, 3);
	format(YCMDstr, sizeof(YCMDstr), "Вы получили %i$ от %s[%i]",params[1],User[playerid][pName], playerid);
	SendClientMessage(params[0], COLOR_GRAD1, YCMDstr);
	PlayerPlaySound(params[0], 1052, 0.0, 0.0, 0.0);
	format(YCMDstr,sizeof(YCMDstr),"~g~+%i$",params[1]);
	GameTextForPlayer(params[0],YCMDstr, 5000, 3);
	format(YCMDstr,sizeof(YCMDstr), "достал бумажник и передал деньги %s",User[params[0]][pName]);
	SetPlayerChatBubble(playerid,YCMDstr,COLOR_PURPLE,30.0,10000);
	format(YCMDstr, sizeof(YCMDstr), "[PAY] %s передал %s %i вирт", User[playerid][pName], User[params[0]][pName], params[1]);
	WriteLog("Pay.txt", YCMDstr);
	return true;
}
CMD:setferm(playerid, params[])
{
	if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "ddd", params[0],params[1],params[2]))
	{
		SendClientMessage(playerid, COLOR_WHITE, "Введите: /setferm [id ferm] [number] [количество]");
		SendClientMessage(playerid, COLOR_WHITE, " [0] - Урожай, [1] - зернo, [2] - Продукты");
		return 1;
	}
	switch (params[1])
	{
		case 0:
		{
			FarmInfo[params[0]][fGrain_Sown] = params[2];
			err(!"Ошибка: {ffffff}Good");
		}
		case 1:
		{
			FarmInfo[params[0]][fGrain] = params[2];
			err(!"Ошибка: {ffffff}Good");
		}
		case 2:
		{
			FarmInfo[params[0]][fProds] = params[2];
			err(!"Ошибка: {ffffff}Good");
		}
	}
	//SaveFermID(params[0]);
	SaveServerFarms(params[0]);
	return 1;
}
