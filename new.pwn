CMD:eat(playerid, params[])
{
    for(new h = 1; h <= TotalBizz; h++)
	{
		if(!PlayerToPoint(10, playerid,BizzInfo[h][bBarX], BizzInfo[h][bBarY], BizzInfo[h][bBarZ]) || BizzInfo[h][bType] != 2 || GetPlayerVirtualWorld(playerid) != BizzInfo[h][bVirtualWorld]) continue;
		if(GetPlayerInterior(playerid) == 10 || GetPlayerInterior(playerid) == 4) format(YCMDstr,sizeof(YCMDstr), "Бургер\t[%i вирт]  [30 хп]\nРыбный суп\t[%i вирт]  [30 хп]\nБольшой бургер\t[%i вирт]  [60 хп]\nКотлеты\t[%i вирт]  [60 хп]\
		\nПельмени\t[%i вирт]  [90 хп]\nГамбургер\t[%i вирт]  [90 хп]",BizzInfo[h][bPrice],BizzInfo[h][bPrice],BizzInfo[h][bPrice]*2,BizzInfo[h][bPrice]*2,BizzInfo[h][bPrice]*3,BizzInfo[h][bPrice]*3);
		else format(YCMDstr,sizeof(YCMDstr), "Пицца маленькая\t[%i вирт]  [30 хп]\nПицца с грибами\t[%i вирт]  [30 хп]\nПицца с сыром\t[%i вирт]  [60 хп]\nПицца большая\t[%i вирт]  [60 хп]\
		\nПицца с ветчиной\t[%i вирт]  [90 хп]\nПицца с куринным мясом\t[%i вирт]  [90 хп]",BizzInfo[h][bPrice],BizzInfo[h][bPrice],BizzInfo[h][bPrice]*2,BizzInfo[h][bPrice]*2,BizzInfo[h][bPrice]*3,BizzInfo[h][bPrice]*3);
        ShowPlayerDialogEx(playerid, 3389, DIALOG_STYLE_TABLIST, "Меню", YCMDstr, "Выбрать", "Отмена");
	}
	return true;
}
CMD:buy(playerid, params[])
{
    //new str[300];
    for(new i = 1; i <= TotalBizz; i++)
	{
	    if(!PlayerToPoint(10, playerid,BizzInfo[i][bBarX], BizzInfo[i][bBarY], BizzInfo[i][bBarZ]) || BizzInfo[i][bType] != 3 || GetPlayerVirtualWorld(playerid) != BizzInfo[i][bVirtualWorld]) continue;
	    if(BizzInfo[i][bProducts] <= 0) return SendClientMessage(playerid,COLOR_GREY, "В бизнесе нет продуктов"), BizzInfo[i][bProducts] = 0;
		format(QUERY,sizeof(QUERY),"Товар\tЦена\nНомер телефона\t{33AAFF}%i {ffffff}вирт\nЗажигалка\t{33AAFF}%i {ffffff}вирт\nСигареты\t{33AAFF}%i {ffffff}вирт\nСправочник\t{33AAFF}%i {ffffff}вирт\nАптечки(25шт.)\t{33AAFF}%i {ffffff}вирт\nФотоаппарат\t{33AAFF}%i {ffffff}вирт\nЦветы\t{33AAFF}%i {ffffff}вирт\nУдочка\t%i вирт\nСнасти(10шт.)\t%i вирт\nСонар\t%i вирт\nАптечка\t%i вирт",BizzInfo[i][bPrice],BizzInfo[i][bPrice],BizzInfo[i][bPrice],BizzInfo[i][bPrice]*2,
		BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*4,BizzInfo[i][bPrice]*4,BizzInfo[i][bPrice]*6);
		ShowPlayerDialogEx(playerid, 5589,DIALOG_STYLE_TABLIST_HEADERS, "{FFA500}>>> {FFFFFF}24/7", QUERY, "Купить", "Отмена");
	}
	return true;
}
CMD:drink(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	for(new i = 1; i <= TotalBizz; i++)
	{
	    if(!PlayerToPoint(2, playerid,BizzInfo[i][bBarX], BizzInfo[i][bBarY], BizzInfo[i][bBarZ]) || BizzInfo[i][bType] != 1 || GetPlayerVirtualWorld(playerid) != BizzInfo[i][bVirtualWorld]) continue;
		format(YCMDstr,sizeof(YCMDstr), "Вода\t\t[%i$]\nСода\t\t[%i$]\nТоник\t\t[%i$]\nКока-кола\t[%i$]\nПиво\t\t[%i$]\nСаке\t\t[%i$]\nВодка\t\t[%i$]\nВино\t\t[%i$]\nВиски\t\t[%i$]\nКоньяк\t\t[%i$]\nАбсент\t\t[%i$]",
		BizzInfo[i][bPrice],BizzInfo[i][bPrice],BizzInfo[i][bPrice],BizzInfo[i][bPrice]*2,BizzInfo[i][bPrice]*2,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*3,BizzInfo[i][bPrice]*4,BizzInfo[i][bPrice]*5,BizzInfo[i][bPrice]*5,BizzInfo[i][bPrice]*6);
		ShowPlayerDialogEx(playerid, 2289, DIALOG_STYLE_LIST, "{F1C33A}Меню Бара", YCMDstr, "Купить", "Отмена");
	}
	return true;
}
CMD:gps(playerid)
{
    //if(GetPVarInt(playerid, "Work") != 0) return true;
	if(GetPVarInt(playerid, "GPSMark"))
	{
	    PlayerTextDrawHide(playerid,GPS_ON[playerid][0]);
	    PlayerTextDrawHide(playerid,GPS_ON[playerid][1]);
 		DisablePlayerCheckpoint(playerid);
		DeletePVar(playerid, "GPSMark");
	}
	if(MatsArmyCar[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "У Вас уже установлена метка!");
	if(VertMats[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "У Вас уже установлена метка!");
    ShowPlayerDialogEx(playerid, 10000, DIALOG_STYLE_LIST, "{2641FE}- GPS -", "[1] Важные места\n[2] По работе\n[3] Развлечения\n[4] Автосалоны\n[5] Базы организаций\n[6] Дальнобойщики\n[7] Автомастерские\n[8] Фермы", "Выбрать", "Отмена");
	return true;
}
CMD:ooc(playerid, params[])
{
	if(User[playerid][pMuted] > 0)
	{
		format(YCMDstr, sizeof(YCMDstr), "У Вас бан чата! До снятия: %i секунд(ы)",User[playerid][pMuted]);
		SendClientMessage(playerid, COLOR_LIGHTRED, YCMDstr);
		return true;
	}
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/o)oc [текст]");
	if((!noooc) && User[playerid][pAdmin] < 1) return SendClientMessage(playerid, COLOR_GRAD1, "Общий чат отключен админом!");
	else if(!GetPVarInt(playerid, "Dostup") && User[playerid][pAdmin] >= 1) return true;
	if(User[playerid][pAdmin] == 0 && gettime() < antioocsend) return SendClientMessage(playerid, COLOR_GREY, "Антифлуд ООС чата");
	antioocsend = gettime()+antiooc;
	static const fmt_query[] = "<< %s[%i]: %s >>";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)+(-2+4)+(-2+128)];
	format(query, sizeof(query), fmt_query,User[playerid][pName], playerid, params[0]);
	SendClientMessageToAll(COLOR_OOC, query);
	return 1;
}
CMD:olimit(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "d",antiooc)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /olimit [секунды]");
	new string[130];
	f(string, "Установлен лимит для OOC чата на %i секунд",antiooc);
	SCM(playerid, 0xFFFFFFFF, string);
	return 1;
}
CMD:noooc(playerid, params[])
{
    if (User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	if (noooc != 0) return noooc = 0, SendClientMessageToAll(COLOR_WHITE, "Общий чат отключен админом!");
	if(sscanf(params, "s[128]", params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /noooc [1 включить / 0 отключить]");
	noooc = params[0], SendClientMessageToAll(COLOR_WHITE, "Общий чат включен админом!");
	return true;
}
CMD:goverment(playerid, params[])
{
	if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
	if(IsACop(playerid) || IsAArm(playerid) || IsAMayor(playerid) || IsAMedic(playerid) || IsALicenser(playerid))
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
	{
		if(User[playerid][pMuted] > 0)
		{
		    new string[156];
		    f(string, "У Вас бан чата! До снятия: %d секунд(ы)", User[playerid][pMuted]);
			SendClientMessage(playerid, COLOR_LIGHTRED, string);
			return true;
		}
		new text[128];
		if(sscanf(params, "s[128]", text)) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: (/gov)erment [текст]");
		AntiReklama(playerid,text,"GOV");
		if(GetPVarInt(playerid, "antireklamka") == 1)
		{
	    	SetPVarInt(playerid, "antireklamka", 0);
	    	return true;
		}
		if(User[playerid][pMember] == 1 || User[playerid][pLeader] == 1)
		{
		    if(User[playerid][pRank] < 14) return true;
		}
		else if(User[playerid][pMember] == 2 || User[playerid][pLeader] == 2)
		{
		    if(User[playerid][pRank] < 9) return true;
		}
		else if(User[playerid][pMember] == 3 || User[playerid][pLeader] == 3)
		{
		    if(User[playerid][pRank] < 14) return true;
		}
		else if(User[playerid][pMember] == 4 || User[playerid][pLeader] == 4 || User[playerid][pJobHealLeader] > 0)
		{
		    if(User[playerid][pRank] < 9) return true;
		}
		else if(User[playerid][pMember] == 7 || User[playerid][pLeader] == 7)
		{
		    if(User[playerid][pRank] < 5) return true;
		}
		else if(User[playerid][pMember] == 10 || User[playerid][pLeader] == 10)
		{
		    if(User[playerid][pRank] < 14) return true;
		}
		else if(User[playerid][pMember] == 11 || User[playerid][pLeader] == 11)
		{
		    if(User[playerid][pRank] < 7) return true;
		}
		else if(User[playerid][pMember] == 19 || User[playerid][pLeader] == 19)
		{
		    if(User[playerid][pRank] < 14) return true;
		}
		else if(User[playerid][pMember] == 21 || User[playerid][pLeader] == 21)
		{
		    if(User[playerid][pRank] < 14) return true;
		}
		else { return true; }
		SendClientMessageToAll(COLOR_WHITE, "---========== Государственные Новости ==========---");
		//format(YCMDstr, sizeof(YCMDstr), "{2641ED}Новости: %s: %s", User[playerid][pName], params[0]);
		//SendClientMessageToAll(0x110CE7FF, YCMDstr);
		if(strlen(text) >= 80)
		{
		    new string[128];
		    new mess[128];
		    strmid(string,text,64,128,128);
		    strdel(text,64,128);
		    format(text, 104, "{2641ED}Новости: %s: %s ...", User[playerid][pName], text);
		    SendClientMessageToAll(0x110CE7FF, text);
		    format(mess, 88, " ... {2641ED}%s",string);
		    SendClientMessageToAll(0x110CE7FF, mess);
		}
		else
		{
		    format(text, 104, "{2641ED}Новости: %s: %s", User[playerid][pName], text);
		    SendClientMessageToAll(0x110CE7FF, text);
		}
	}
	return true;
}
CMD:fstyle(playerid, params[])
{
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid,COLOR_GREY, "Используйте: /fstyle [0-3]");
	if(params[0] < 0 || params[0] > 3) return SendClientMessage(playerid,COLOR_GREY, "Используйте: /fstyle [0-3]");
	if(params[0] == 0)
	{
		SetPlayerFightingStyle (playerid, FIGHT_STYLE_NORMAL);
		SendClientMessage(playerid, COLOR_WHITE, "Обычный стиль");
	}
	else if(params[0] == 1)
	{
		if(User[playerid][pBoxSkill] >= 5000) SetPlayerFightingStyle (playerid, FIGHT_STYLE_BOXING), SendClientMessage(playerid, COLOR_LIGHTGREEN, "Вы установили новый стиль боя");
		else return SendClientMessage(playerid,COLOR_GREY,"Вы не изучали этот стиль боя");
	}
	else if(params[0] == 2)
	{
		if(User[playerid][pKongfuSkill] >= 5000) SetPlayerFightingStyle (playerid, FIGHT_STYLE_KUNGFU), SendClientMessage(playerid, COLOR_LIGHTGREEN, "Вы установили новый стиль боя");
		else return SendClientMessage(playerid,COLOR_GREY,"Вы не изучали этот стиль боя");
	}
	else if(params[0] == 3)
	{
		if(User[playerid][pKickboxSkill] >= 5000) SetPlayerFightingStyle (playerid, FIGHT_STYLE_KNEEHEAD), SendClientMessage(playerid, COLOR_LIGHTGREEN, "Вы установили новый стиль боя");
		else return SendClientMessage(playerid,COLOR_GREY,"Вы не изучали этот стиль боя");
	}
	return true;
}
CMD:duel(playerid,params[])
{
	new string[64+MAX_PLAYER_NAME];
	if(sscanf(params, "ud", params[0], params[1])) return	SendClientMessage(playerid, COLOR_GRAD2, "/duel [ID] [сумма]");
    //if(sscanf(params, "i", params[0])) return SCM(playerid,-1,"/duel [ID]");

    if(params[0] == INVALID_PLAYER_ID) return SCM(playerid, -1, "{AFAFAF}Человек не найден!");
    if(!ProxDetectorS(8.0, playerid, params[0])) return SCM(playerid, COLOR_GREY, "Человек не рядом с вами!");
    if(GetSRVMoney(playerid) < params[1]) return	SendClientMessage(playerid, COLOR_GRAD1, "У Вас нет столько денег!");
    if(GetSRVMoney(params[0]) < params[1]) 	return 	SendClientMessage(playerid, COLOR_GRAD1, "У данного игрока нет столько денег!");
    if(params[0] == playerid ) return SendClientMessage(playerid,COLOR_GRAD1, "{AFAFAF}Вы указали свой ID");
    if(GetPVarInt(params[0],"DuelTarget"))  return SendClientMessage(playerid,COLOR_GRAD1, "{AFAFAF}Игрок уже записан. Подождите..");
    if(GetPVarInt(playerid,"DuelTarget"))  return SendClientMessage(playerid,COLOR_GRAD1, "{AFAFAF}Вы уже записаны. Подождите..");
	if(params[1] < 1000 || params[1] > 50000) return SendClientMessage(playerid, -1, "{AFAFAF}Нельзя меньше 1000, и больше 50000 вирт");
	if(IsPlayerInRangeOfPoint(playerid,10,2038.9906,-1917.1375,3001.0859))
	{
		if(IsAGang(playerid) && IsAGang(params[0]))
		{
			SetPVarInt(playerid,"DuelTarget",params[0]);
			SetPVarInt(params[0],"DuelTarget",playerid);
			//price
			SetPVarInt(playerid,"DuelPrice",params[1]);
			SetPVarInt(params[0],"DuelPrice",params[1]);
			format(string,sizeof(string),"{FFFFFF}Дуэль с {"#cORANGE"}%s{FFFFFF} | Выбор оружия",User[params[0]][pName]);
			ShowPlayerDialogEx(playerid,391,DIALOG_STYLE_LIST,string,"1. Desert Eagle\n2. Shotgun\n3. M4","Выбрать","Отмена");
		}
		else return SCM(playerid,COLOR_WHITE,"{AFAFAF}Вы и Ваш аппонент должны быть бандитами");
	}
	else return SCM(playerid,COLOR_WHITE,"{AFAFAF}Вы слишком далеко");
	return 1;
}

ALTX:priz("/roulette_priz");
CMD:priz(playerid)
{
    new Query[128];
	format(Query, sizeof(Query), "SELECT * FROM `ucp_drop_roulette` WHERE `p_user` = '%s'", Name(playerid));
	mysql_tquery(dbHandle, Query, "priz_callback", "d", playerid);
	return 1;
}
publics: priz_callback(playerid)
{
	new rows;
	cache_get_row_count(rows);
	if(!rows) return SendClientMessage(playerid, COLOR_GREY, "В базе данных не найдено ваших призов");
	new priz_number, priz_id, priz_vaule;
	cache_get_value_index_int(0, 0, priz_number);
	cache_get_value_index_int(0, 3, priz_vaule);
    cache_get_value_index_int(0, 4, priz_id);
    rows -=1;
	if(priz_id == 1) // cash
	{
	    User[playerid][pCash] += priz_vaule;
	    format(YCMDstr, sizeof(YCMDstr), "DELETE FROM `ucp_drop_roulette` WHERE `p_number` = '%d'", priz_number);
		mysql_tquery(dbHandle, YCMDstr, "", "");
	//	cache_get_row_count(rows);
		if(rows) SCMF(playerid, COLOR_GREEN, " Вам еще доступно призов: (%d). {FFFFFF}Введите еще раз команду /priz", rows);
		return SCMF(playerid, -1, " Вы получили %d$ с рулетки", priz_vaule);
	}
	else if(priz_id == 3) // car
	{
	    SetPVarInt(playerid, "CarGift", priz_vaule);
	    new strs[128];
	    for(new i = 0; i < 3; i++)
	    {
     		new str[32];
       		format(str, sizeof(str), "[%i] %s\n", i, VehicleNames[CarInfo[playerid][carModel][i]-400]);
	        strcat(strs, str, sizeof(strs));
	    }
		ShowPlayerDialogEx(playerid,14014,DIALOG_STYLE_LIST,"Замена авто",strs,"Заменить","Продать");
	    format(YCMDstr, sizeof(YCMDstr), "DELETE FROM `ucp_drop_roulette` WHERE `p_number` = '%d'", priz_number);
		mysql_tquery(dbHandle, YCMDstr, "", "");
	//	cache_get_row_count(rows);
		if(rows) SCMF(playerid, COLOR_GREEN, " Вам еще доступно призов: (%d). {FFFFFF}Введите еще раз команду /priz", rows);
		return SCMF(playerid, -1, " Вы получили машину [id: %d] с рулетки", priz_vaule);
	}
	else if(priz_id == 4) // skin
	{
	    SetPVarInt(playerid, "SkinGift", priz_vaule);
		SetPlayerSkin(playerid, priz_vaule);
		format(QUERY, sizeof(QUERY), "\n\n{FFFFFF}Вы действительно хотите заменить ваш скин {FFFF00}ID: %d {FFFFFF} на новый {FFFF00}ID: %d\n\n",
		User[playerid][pChar][0], priz_vaule);

		ShowPlayerDialogEx(playerid,14013,DIALOG_STYLE_MSGBOX, "Уникальный скин с рулетки",QUERY, "Заменить", "Нет");
	    format(YCMDstr, sizeof(YCMDstr), "DELETE FROM `ucp_drop_roulette` WHERE `p_number` = '%d'", priz_number);
		mysql_tquery(dbHandle, YCMDstr, "", "");
	//	cache_get_row_count(rows);
		if(rows) SCMF(playerid, COLOR_GREEN, " Вам еще доступно призов: (%d). {FFFFFF}Введите еще раз команду /priz", rows);
		return SCMF(playerid, -1, " Вы получили скин: [%d] с рулетки", priz_vaule);
	}
	else if(priz_id == 5) // exp
	{
	    User[playerid][pExp] += priz_vaule;
	    if(User[playerid][pExp] >= ((User[playerid][pLevel]+1)*4)-1)
		{
			User[playerid][pLevel] ++, User[playerid][pExp] = 0;
			SendClientMessage(playerid, COLOR_YELLOW, "Поздравляем! Ваш уровень повысился!");
			SetPlayerScore(playerid, User[playerid][pLevel]);
		}
	    format(YCMDstr, sizeof(YCMDstr), "DELETE FROM `ucp_drop_roulette` WHERE `p_number` = '%d'", priz_number);
		mysql_tquery(dbHandle, YCMDstr, "", "");
	//	cache_get_row_count(rows);
		if(rows) SCMF(playerid, COLOR_GREEN, " Вам еще доступно призов: (%d). {FFFFFF}Введите еще раз команду /priz", rows);
		return SCMF(playerid, -1, " Вы получили %d EXP с рулетки", priz_vaule);
	}
	else if(priz_id == 2) // donat
	{
	    User[playerid][pDonateAccount] += priz_vaule;
	    format(YCMDstr, sizeof(YCMDstr), "DELETE FROM `ucp_drop_roulette` WHERE `p_number` = '%d'", priz_number);
		mysql_tquery(dbHandle, YCMDstr, "", "");
	//	cache_get_row_count(rows);
		if(rows) SCMF(playerid, COLOR_GREEN, " Вам еще доступно призов: (%d). {FFFFFF}Введите еще раз команду /priz", rows);
		return SCMF(playerid, -1, " Вы получили %d доната с рулетки", priz_vaule);
	}
	return 1;
}
CMD:donat(playerid)
{
    if(User[playerid][pLogin] == 0) return true;
    mysql_format(dbHandle, YCMDstr, sizeof(YCMDstr), "SELECT * FROM `accounts` WHERE `Name` = '%e'", Name(playerid));
    mysql_tquery(dbHandle,YCMDstr,"OnMySQL_QUERY","iis",40,playerid,Name(playerid));
    return true;
}
CMD:donate(playerid, params[])
{
    if(User[playerid][pLogin] == 0) return true;
    mysql_format(dbHandle, YCMDstr, sizeof(YCMDstr), "SELECT * FROM `accounts` WHERE `Name` = '%e'", Name(playerid));
    mysql_tquery(dbHandle,YCMDstr,"OnMySQL_QUERY","iis",41,playerid,Name(playerid));
 	return true;
}
CMD:dddonate(playerid)
{
    if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
    if(Conf>0)SendClientMessage(playerid,COLOR_YELLOW,"[Объявление] {FFFFFF}На сервере проходит акция, включены х2 Донат");
    ShowPlayerDialogEx(playerid, 9121, DIALOG_STYLE_TABLIST, "Донат",
	"{ffffff}Виртуальная валюта\t$1500 = 1 рубль\n\
	{ffffff}Пак лицензий\t100 рублей\n\
	{ffffff}Все скиллы 100%\t100 рублей\n\
	{ffffff}Снять варн\t150 рублей\n\
	{ffffff}Отключение ограничителя спидометра\t30 рублей\n\
	{ffffff}+1 подарочное вращение\t30 рублей\n\
	{ffffff}Смена ника\t350 рублей\n\
	{ffffff}Премиум {ffff00}аккаунт {ffffFF}на неделю\t150 рублей\n\
	{ffffff}Премиум {ffff00}аккаунт {ffffFF}на месяц\t500 рублей\n\
	{ffffff}Премиум {ffff00}аккаунт {ffffFF}навсегда\t2000 рублей\n\
	{ffff00}Проверить баланс",
	"Выбрать", "Закрыть");
	return true;
}
