CMD:buybiz(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	//new sstring[10];
	new full, full_;
	if(BGet(playerid))  return SendClientMessage(playerid, COLOR_GREY, "У Вас уже есть бизнес, введите /sellbiz чтобы его продать.");
	for(new bizz = 1; bizz <= TotalBizz; bizz++)
	{
		if(IsPlayerInRangeOfPoint(playerid, 5.0, BizzInfo[bizz][bEntranceX], BizzInfo[bizz][bEntranceY], BizzInfo[bizz][bEntranceZ]))
		{
  			full++;
			if(!strcmp(BizzInfo[bizz][bOwner],"None",true))
     		{
     		    full_++;
				if(User[playerid][pCash] < BizzInfo[bizz][bBuyPrice]) return SendClientMessage(playerid, COLOR_GREY, "Недостаточно денег на руках");
				else
				{
					new query[256];
					User[playerid][pCash] -= BizzInfo[bizz][bBuyPrice];
					BizzInfo[bizz][bLastStavka] = BizzInfo[bizz][bBuyPrice];
					GameTextForPlayer(playerid, "The busines was bought", 3000, 5);
					f(query, "{F0E79C}Вы приобрели бизнес за {3AA94C}%i$ {F0E79C}/ Остаток средств на руках: {FF6347}%i$",BizzInfo[bizz][bBuyPrice], User[playerid][pCash]);
					SCM(playerid, -1, query);
					SCM(playerid, 0xF0E79CFF, "Не забывайте пополнять счёт бизнеса, иначе его отнимут за неуплату.");

					strmid(BizzInfo[bizz][bOwner],Name(playerid), 0, strlen(Name(playerid)), MAX_PLAYER_NAME);
				//format(query, sizeof(query), "UPDATE "TABLE_BIZZ" SET owner = '%s', buyprice = %i WHERE id = '%d' LIMIT 1", BizzInfo[idx][bOwner], BizzInfo[idx][bBuyPrice], idx);
				//mysql_query(query);
					UpdateBizz(bizz);
					BizzInfo[bizz][bLandTax] = 12000;
				}
   			}
   			else full_++;
   		}
    }
	if(full == 0) return SendClientMessage(playerid, COLOR_GREY, "Вы должны находится рядом с бизнесом!");
	if(full_ == 0) return SendClientMessage(playerid, COLOR_GREY, "Бизнес уже имеет владельца!");
	return 1;
}
CMD:buytune(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	new str[10];
	if(WGet(playerid))  return SendClientMessage(playerid, COLOR_GREY, "У вас уже есть автомастерская");
	for(new i = 1; i <= TOTALSHOPS; i++)
	{
		if(!PlayerToPoint(5.0, playerid, WorkshopInfo[i][wEntr][0], WorkshopInfo[i][wEntr][1], WorkshopInfo[i][wEntr][2]) || strcmp(WorkshopInfo[i][wOwner],"None",true) != 0) continue;
		bizselect[playerid] = i;
  		if(WorkshopInfo[bizselect[playerid]][wAuction][1] == 0) f(str,"%i",WorkshopInfo[bizselect[playerid]][wAuction][0]);
    	else f(str,"Скрыта");
	    format(YCMDstr,sizeof(YCMDstr),"{FFFF00}Бизнес: СТО [%i].\tДо окончания: %i час(а/ов)\n{ffffff}Предыдущая ставка: %i\n{ffffff}Текущая ставка: %s\n{33AA33}Сделать ставку",WorkshopInfo[bizselect[playerid]][wID]-1,WorkshopInfo[bizselect[playerid]][wAuction][2],WorkshopInfo[bizselect[playerid]][wAuction][1], str);
	    ShowPlayerDialogEx(playerid,1691,DIALOG_STYLE_LIST,"{F1C33A}Аукцион бизнесов",YCMDstr, "Далее", "Отмена");
    	break;
	}
	return true;
}
CMD:buyfarm(playerid, params[])
{
	new str[10];
    if(!IsPlayerConnected(playerid)) return true;
	if(FGet(playerid))  return SendClientMessage(playerid, COLOR_GREY, "У вас уже есть ферма");
	for(new i = 1; i <= TOTALFARM; i++)
	{
		if(!PlayerToPoint(10.0, playerid, FarmInfo[i][fMenu][0], FarmInfo[i][fMenu][1], FarmInfo[i][fMenu][2]) || strcmp(FarmInfo[i][fOwner],"None",true) != 0) continue;
		bizselect[playerid] = i;
		if(FarmInfo[bizselect[playerid]][fID]-1 == 1 || FarmInfo[bizselect[playerid]][fID]-1 == 3) continue;
		new stext[29];
		if(FarmInfo[bizselect[playerid]][fID]-1 == 0) stext = "LS";
		else if(FarmInfo[bizselect[playerid]][fID]-1 == 2) stext = "SF";
		else if(FarmInfo[bizselect[playerid]][fID]-1 == 4) stext = "LV";
  		if(FarmInfo[bizselect[playerid]][fAuction][1] == 0) format(str,9,"%i",FarmInfo[bizselect[playerid]][fAuction][0]);
    	else format(str,16,"Скрыта");
	    format(YCMDstr,sizeof(YCMDstr),"{FFFF00}Бизнес: Ферма [%s].\tДо окончания: %i час(а/ов)\n{ffffff}Предыдущая ставка: %i\n{ffffff}Текущая ставка: %s\n{33AA33}Сделать ставку",stext,FarmInfo[bizselect[playerid]][fAuction][2],FarmInfo[bizselect[playerid]][fAuction][1], str);
	    ShowPlayerDialogEx(playerid,1693,DIALOG_STYLE_LIST,"{F1C33A}Аукцион бизнесов",YCMDstr, "Далее", "Отмена");
    	break;
	}
	return true;
}
CMD:selltune(playerid, params[])
{
	new str[40];
	if(!WGet(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Вы не владеете автомастерской!");
	new i = GetPVarInt(playerid,"wShop");
	if(!PlayerToPoint(5.0, playerid, WorkshopInfo[i][wEntr][0], WorkshopInfo[i][wEntr][1], WorkshopInfo[i][wEntr][2])) return SendClientMessage(playerid,COLOR_GREY,"Необходимо находиться возле автомастерской!");
	User[playerid][pBank] += WorkshopInfo[i][wBank]+WorkshopInfo[i][wLandTax];
	format(str,sizeof(str),"~w~workshop in sold~n~~g~$%i",WorkshopInfo[i][wBank]+WorkshopInfo[i][wLandTax]);
	GameTextForPlayer(playerid,str, 5000, 3);
	strmid(WorkshopInfo[i][wOwner],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wDeputy1],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wDeputy2],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wDeputy3],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wMechanic1],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wMechanic2],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wMechanic3],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wMechanic4],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(WorkshopInfo[i][wMechanic5],"None",0,strlen("None"),MAX_PLAYER_NAME);
	WorkshopInfo[i][wAuction][0] = 0;
	WorkshopInfo[i][wAuction][1] = 0;
	WorkshopInfo[i][wAuction][2] = 0;
	WorkshopInfo[i][wAuction][3] = 0;
	//WorkshopInfo[i][wAuction][4] = 0;
	WorkshopInfo[i][wLandTax] = 0;
	WorkshopInfo[i][wBank] = 0;
	WorkshopInfo[i][wProds] = 0;
	WorkshopInfo[i][wPriceProds] = 50;
	WorkshopInfo[i][wZp] = 5;
	DeletePVar(playerid,"wShop");
	new stra_[128];
	f(stra_,"Бизнес СТО [%d] выставлен на аукцион!",i-1);
	SCM(playerid,0x4B00B0AA,stra_);
	return 1;
}
CMD:sellfarm(playerid, params[])
{
	new str[40];
	if(!FGet(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Вы не владеете фермой!");
	new i = GetPVarInt(playerid,"Farm");
	if(GetPVarInt(playerid,"farm_id") == i) return SendClientMessage(playerid,COLOR_GREY,"Для начала переоденьтесь!");
	if(!PlayerToPoint(10.0, playerid, FarmInfo[i][fMenu][0], FarmInfo[i][fMenu][1], FarmInfo[i][fMenu][2])) return SendClientMessage(playerid,COLOR_GREY,"Необходимо находиться возле фермы!");
	User[playerid][pBank] += FarmInfo[i][fBank]+FarmInfo[i][fLandTax];
	format(str,sizeof(str),"~w~farm in sold~n~~g~$%i",FarmInfo[i][fBank]+FarmInfo[i][fLandTax]);
	GameTextForPlayer(playerid,str, 5000, 3);
	strmid(FarmInfo[i][fOwner],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fDeputy_1],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fDeputy_2],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fDeputy_3],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fFarmer_1],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fFarmer_2],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fFarmer_3],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fFarmer_4],"None",0,strlen("None"),MAX_PLAYER_NAME);
	strmid(FarmInfo[i][fFarmer_5],"None",0,strlen("None"),MAX_PLAYER_NAME);
	FarmInfo[i][fAuction][0] = 0;
	FarmInfo[i][fAuction][1] = 0;
	FarmInfo[i][fAuction][2] = 0;
	FarmInfo[i][fAuction][3] = 0;
	FarmInfo[i][fAuction][4] = 0;
	FarmInfo[i][fLandTax] = 0;
	FarmInfo[i][fBank] = 0;
	FarmInfo[i][fProds] = 0;
	FarmInfo[i][fZp] = 30;
	FarmInfo[i][fGrain_Price] = 5;
	FarmInfo[i][fGrain] = 0;
	FarmInfo[i][fGrain_Sown] = 0;
	FarmInfo[i][fProds_Selling] = 1;
	FarmInfo[i][fProds_Price] = 21;
	DeletePVar(playerid,"Farm");
	new stra_[128];
	f(stra_,"Бизнес Ферма [%i] выставлен на аукцион!",i-1);
	SCM(playerid,0x4B00B0AA,stra_);
	return 1;
}
CMD:healaddict(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pMember] != 4) return SendClientMessage(playerid,COLOR_GREY, "Вы не медик!");
	if(sscanf(params, "u", params[0]))  return SendClientMessage(playerid, COLOR_GREY, "Используйте: /healaddict [id/name]");
	if(!PlayerToPoint(40.0,playerid,1179.8942,-1327.2719,3001.0859) && !PlayerToPoint(40.0,playerid,366.9755,-60.1330,1076.4773)) return true;
	if(!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Вы слишком далеко.");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	if(seans[params[0]] == 1)return SendClientMessage(playerid,COLOR_GREY, "Следущий сеанс можно провести через час");
	if(User[params[0]][pAddiction] <1000)return SendClientMessage(playerid,COLOR_GREY, "У пациента меньше чем 1000 зависимости");
	if(params[0] == playerid)return SendClientMessage(playerid,COLOR_GREY, "Вы указали свой ID");
	User[params[0]][pAddiction] -=500;
	format(YCMDstr,sizeof(YCMDstr), "Медик %s провёл с вами сеанс от наркозависимости",User[playerid][pName]);
	SendClientMessage(params[0],COLOR_GREEN,YCMDstr);
	format(YCMDstr,sizeof(YCMDstr), "Вы провели сеанс от наркозависимости с %s",User[params[0]][pName]);
	SendClientMessage(playerid,COLOR_GREEN,YCMDstr);
	seans[params[0]] = 1;
	User[params[0]][pNarcoLomka] = 0;
	return true;
}
CMD:usedrugs(playerid, params[])
{
    if(GetPVarInt(playerid,"DuelTarget"))  return SendClientMessage(playerid,COLOR_GREY, "Во время проведения дуэли нельзя использовать наркотики.");
    if(PlayerToPoint(40.0,playerid,-430.3993,2233.1570,42.4297)) return SendClientMessage(playerid,COLOR_GREY, "В данном месте нельзя использовать наркотики");
	if(sscanf(params, "i", params[0]))
	{
		if(User[playerid][pAddiction] < 2000) params[0] = 5;
		else if(User[playerid][pAddiction] < 5000) params[0] = 10;
		else if(User[playerid][pAddiction] > 5000) params[0] = 15;
	}
	new Float:health;
	GetPlayerHealth(playerid, health);
	if(User[playerid][pDrugs] < params[0]) return SCM(playerid, COLOR_GREY, "Недостаточно наркотиков");
	if(params[0] < 1) return SCM(playerid,COLOR_GREY,"Неверное кол-во");
	if(User[playerid][pAddiction] < 2000 && params[0] > 3) return SCM(playerid,COLOR_GREY, "Не более 3 грамм");
	else if(User[playerid][pAddiction] < 5000 && params[0] > 10) return SCM(playerid,COLOR_GREY, "Не более 10 грамм");
	else if(params[0] > 15) return SCM(playerid,COLOR_GREY, "Не более 15 грамм");
	if(User[playerid][pAddiction] < 2000 && health+ 10.0*params[0] > 120)
	{
		if(GetPVarInt(playerid,"drug_time") < gettime()) SCM(playerid,COLOR_WHITE,"(( Здоровье пополнено до: 120 ))"), SetPlayerHealthAC(playerid,120);
		else SCM(playerid,COLOR_WHITE,"(( Здоровье можно пополнить не чаще, чем раз в 2 минуты ))");
		SetPlayerTime(playerid,17,0);
		SetPlayerWeather(playerid, -67);
		SetTimerEx("AddictionTimer", 20000, false, "i", playerid);
	}
	else if(User[playerid][pAddiction] < 5000 && health+ 10.0*params[0] > 140)
	{
		if(GetPVarInt(playerid,"drug_time") < gettime()) SCM(playerid,COLOR_WHITE,"(( Здоровье пополнено до: 140 ))"), SetPlayerHealthAC(playerid,140);
		else SCM(playerid,COLOR_WHITE,"(( Здоровье можно пополнить не чаще, чем раз в 1 минуту ))");
	}
	else if(User[playerid][pAddiction] > 5000 && health+10.0*params[0] > 160)
	{
		if(GetPVarInt(playerid,"drug_time") < gettime()) SCM(playerid,COLOR_WHITE,"(( Здоровье пополнено до: 160 ))"), SetPlayerHealthAC(playerid,160);
		else SCM(playerid,COLOR_WHITE,"(( Здоровье можно пополнить не чаще, чем раз в 1 минуту ))");
	}
	else
	{
		if(GetPVarInt(playerid,"drug_time") < gettime())
		{
		    new string[60];
		    f(string, "(( Здоровье пополнено до: %.0f ))",health+10*params[0]);
	 		SCM(playerid, -1, string);
	 		SetPlayerHealthAC(playerid, health + 10.0*params[0]);
		}
		else SCM(playerid,COLOR_WHITE,"(( Здоровье можно пополнить не чаще, чем раз в 1 минуту ))");
		if(User[playerid][pAddiction] < 2000)
		{
			SetPlayerTime(playerid,17,0);
			SetPlayerWeather(playerid, -68);
			SetTimerEx("AddictionTimer", 10000, false, "i", playerid);
		}
	}
	User[playerid][pNarcoLomka] = 0;
	switch(booston)
	{
	case 0:SetPVarInt(playerid,"drug_time", gettime() + 60);
	case 1:SetPVarInt(playerid,"drug_time", gettime() + 39);
	}
	User[playerid][pDrugs] -= params[0];
	ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0,1);
	SetPlayerChatBubble(playerid,"употребил(a) наркотик",COLOR_PURPLE,30.0,10000);
	format(YCMDstr,sizeof(YCMDstr), "%s употребил(a) наркотик",User[playerid][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,10.0);
	User[playerid][pAddiction] += 4*params[0];
	if(startaddiction[playerid] == 1)
	{
		startaddiction[playerid] = 0;
		ApplyAnimation(playerid,"SMOKING","M_smk_drag",4.1,0,0,0,0,0,1);
		User[playerid][pNarcoLomka] = 0;
	}
	return true;
}
CMD:gunlist(playerid, params[])
{
    if(!IsAGang(playerid) && !IsABiker(playerid)) return true;
	ShowPlayerDialogEx(playerid,8321,DIALOG_STYLE_MSGBOX, "Cписок оружия", "\tИмя\t\t Матов за патрон\t\t Матов за обойму\n__________________________________________________________________\n\n[ID: 23] Sdpistol\t\t1м\t\t\t\t15м\n[ID: 24] Deagle\t\t\t3м\t\t\t\t21м\n[ID: 25] Shotgun\t\t3м\t\t\t\t-\n[ID: 29] SMG\t\t\t2м\t\t\t\t60м\n[ID: 30] AK-47\t\t\t3м\t\t\t\t90м\n[ID: 31] M4A1\t\t\t3м\t\t\t\t150м\n[ID: 33] Rifle\t\t\t5м\t\t\t\t-", "Закрыть", "");
	return true;
}
CMD:bsellgun(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
	if(!IsABiker(playerid)) return true;
	new gunname[22];
	if(sscanf(params, "s[18]ddu",gunname,params[0],params[1],params[2]))
	{
		SendClientMessage(playerid, COLOR_WHITE,"Введите: /bsellgun [название оружия] [патроны] [цена] [playerid]");
		SendClientMessage(playerid, COLOR_WHITE,"Введите: /gunlist - название оружия и расходы материалов");
		SendClientMessage(playerid, COLOR_WHITE, "Минимальная цена 5 вирт!");
		return true;
	}
	if(params[1] > 50000 || params[1] < 4 || params[0] < 0) return SendClientMessage(playerid,COLOR_GREY,"Неверная цена/патроны");
	if(!ProxDetectorS(5.0, playerid, params[2])) return SendClientMessage(playerid, COLOR_GREY, "Человек должен быть рядом с вами");
	if(strcmp(gunname,"sdpistol", true) == 0) SetPVarInt(params[2],"Sell_Gun",23), SetPVarInt(params[2],"Sell_GunMats",1);
	else if(strcmp(gunname,"deagle", true) == 0) SetPVarInt(params[2],"Sell_Gun",24), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"shotgun", true) == 0) SetPVarInt(params[2],"Sell_Gun",25), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"smg", true) == 0) SetPVarInt(params[2],"Sell_Gun",29), SetPVarInt(params[2],"Sell_GunMats",2);
	else if(strcmp(gunname,"ak47", true) == 0) SetPVarInt(params[2],"Sell_Gun",30), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"m4", true) == 0) SetPVarInt(params[2],"Sell_Gun",31), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"rifle", true) == 0) SetPVarInt(params[2],"Sell_Gun",33), SetPVarInt(params[2],"Sell_GunMats",5);
	else return SendClientMessage(playerid,COLOR_GREY,"Неизвестное оружие");
	if(User[playerid][pMats] < (GetPVarInt(playerid,"Sell_GunMats")*params[0])) return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно материалов!");
	if(playerid == params[2])
	{
		GiveWeapon(playerid,GetPVarInt(params[2],"Sell_Gun"),params[0]);
		User[playerid][pMats] -= (GetPVarInt(playerid,"Sell_GunMats")*params[0]);
  		format(YCMDstr, sizeof(YCMDstr), "%s сделал себе оружие из материалов",User[playerid][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,10.0);
		SCMF(playerid, -1, "У вас осталось %d материалов.", User[playerid][pMats]);
		return true;
	}
	SetPVarInt(params[2],"Sell_GunId",playerid);
	SetPVarInt(params[2],"Sell_GunAmmo",params[0]);
	SetPVarInt(params[2],"Sell_GunPrice",params[1]);
	SetPVarInt(params[2],"Sell_GunMats",GetPVarInt(params[2],"Sell_GunMats")*params[0]);
	new string[128];
	f(string, "%s предлагает вам купить оружие %s. Патроны: %i",User[playerid][pName],gunname,params[0]);
	SCM(params[2],COLOR_BLUE, string);
	SendClientMessage(params[2],COLOR_BLUE,"Введите: /accept gun для покупки оружия");
	SendClientMessage(playerid, 0x6495EDFF, "Вы предложили купить оружие!");
	return true;
}
CMD:sellgun(playerid, params[])
{
    if(!IsAGang(playerid)) return SendClientMessage(playerid,COLOR_GREY,"Вам недоступна данная команда!");
	new gunname[22];
	if(sscanf(params, "s[18]ddu",gunname,params[0],params[1],params[2]))
	{
		SendClientMessage(playerid, COLOR_WHITE,"Введите: /sellgun [название оружия] [патроны] [цена] [playerid]");
		SendClientMessage(playerid, COLOR_WHITE,"Введите: /gunlist - название оружия и расходы материалов");
		SendClientMessage(playerid, COLOR_WHITE, "Минимальная цена 5 вирт!");
		return true;
	}
	if(params[1] > 50000 || params[1] < 4) return SCM(playerid,COLOR_WHITE,"Цена не может быть менее 4 и более 50 000");
	if(params[0] < 1 || params[0] > 100) return SCM(playerid, COLOR_GRAD1, "Нельзя больше 100 патронов!");
	if(!ProxDetectorS(5.0, playerid, params[2])) return SendClientMessage(playerid, COLOR_GREY, "Человек должен быть рядом с вами");
	if(strcmp(gunname,"sdpistol", true) == 0) SetPVarInt(params[2],"Sell_Gun",23), SetPVarInt(params[2],"Sell_GunMats",1);
	else if(strcmp(gunname,"deagle", true) == 0) SetPVarInt(params[2],"Sell_Gun",24), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"shotgun", true) == 0) SetPVarInt(params[2],"Sell_Gun",25), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"smg", true) == 0) SetPVarInt(params[2],"Sell_Gun",29), SetPVarInt(params[2],"Sell_GunMats",2);
	else if(strcmp(gunname,"ak47", true) == 0) SetPVarInt(params[2],"Sell_Gun",30), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"m4", true) == 0) SetPVarInt(params[2],"Sell_Gun",31), SetPVarInt(params[2],"Sell_GunMats",3);
	else if(strcmp(gunname,"rifle", true) == 0) SetPVarInt(params[2],"Sell_Gun",33), SetPVarInt(params[2],"Sell_GunMats",5);
	else return SendClientMessage(playerid,COLOR_GREY,"Неизвестное оружие");
	if(User[playerid][pMats] < (GetPVarInt(playerid,"Sell_GunMats")*params[0])) return SendClientMessage(playerid, COLOR_GREY, "У вас недостаточно материалов!");
	if(IsAGang(playerid))
	{
		for(new idx = 1; idx <= TOTALGZ; idx++)
		{
			if(PlayerToKvadrat(playerid,GZInfo[idx][gCoords][0], GZInfo[idx][gCoords][1],GZInfo[idx][gCoords][2],GZInfo[idx][gCoords][3]) && User[playerid][pMember] == GZInfo[idx][gFrakVlad])
			{
  				if(playerid == params[2])
				{
					GiveWeapon(playerid,GetPVarInt(params[2],"Sell_Gun"),params[0]);
					//else if(booston == true) GiveWeapon(playerid,GetPVarInt(params[2],"Sell_Gun"),params[0]*3);
					User[playerid][pMats] -= (GetPVarInt(playerid,"Sell_GunMats")*params[0]);
                	format(YCMDstr, sizeof(YCMDstr), "%s сделал себе оружие из материалов",User[playerid][pName]);
					SendBeside(playerid,COLOR_PURPLE,YCMDstr,10.0);
					SCMF(playerid, -1, "У вас осталось %d материалов.", User[playerid][pMats]);
					return true;
				}
   				SetPVarInt(params[2],"Sell_GunId",playerid);
				SetPVarInt(params[2],"Sell_GunAmmo",params[0]);
				SetPVarInt(params[2],"Sell_GunPrice",params[1]);
				SetPVarInt(params[2],"Sell_GunMats",GetPVarInt(params[2],"Sell_GunMats")*params[0]);
				new string[128];
				f(string, "%s предлагает вам купить оружие %s. Патроны: %i",User[playerid][pName],gunname,params[0]);
				SCM(params[2],COLOR_BLUE, string);
				SendClientMessage(params[2],COLOR_BLUE,"Введите: /accept gun для покупки оружия");
				SendClientMessage(playerid, 0x6495EDFF, "Вы предложили купить оружие!");
				break;
			}
		}
	}
	/*else if(IsAGangSF(playerid))
	{
 		for(new idx = 0; idx <= sizeof(GZInfoSF); idx++)
   		{
			if(PlayerToKvadrat(playerid,GZInfoSF[idx][gCoords][0], GZInfoSF[idx][gCoords][1],GZInfoSF[idx][gCoords][2],GZInfoSF[idx][gCoords][3]) && User[playerid][pMember] == GZInfoSF[idx][gFrakVlad])
			{
  				if(playerid == params[2])
				{
					if(booston == false) GiveWeapon(playerid,GetPVarInt(params[2],"Sell_Gun"),params[0]);
					else if(booston == true) GiveWeapon(playerid,GetPVarInt(params[2],"Sell_Gun"),params[0]*3);
					User[playerid][pMats] -= (GetPVarInt(playerid,"Sell_GunMats")*params[0]);
                	format(YCMDstr, sizeof(YCMDstr), "%s сделал себе оружие из материалов",User[playerid][pName]);
					ProxDetector(10.0, playerid,YCMDstr, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
					SCMF(playerid, -1, "У вас осталось %d материалов.", User[playerid][pMats]);
					return true;
				}
   				SetPVarInt(params[2],"Sell_GunId",playerid);
				SetPVarInt(params[2],"Sell_GunAmmo",params[0]);
				SetPVarInt(params[2],"Sell_GunPrice",params[1]);
				SetPVarInt(params[2],"Sell_GunMats",GetPVarInt(params[2],"Sell_GunMats")*params[0]);
				new string[128];
				f(string, "%s предлагает вам купить оружие %s. Патроны: %i",User[playerid][pName],gunname,params[0]);
				SCM(params[2],COLOR_BLUE, string);
				SendClientMessage(params[2],COLOR_BLUE,"Введите: /accept gun для покупки оружия");
				SendClientMessage(playerid, 0x6495EDFF, "Вы предложили купить оружие!");
				break;
			}
		}
	}*/
	return true;
}
