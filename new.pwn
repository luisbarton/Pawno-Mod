publics: GetClosestforeach(p1)
{
	new Float:dis,Float:dis2,player;
	player = -1;
	dis = 99999.99;
	foreach(new x : Player)
	{
		if(x != p1)
		{
			dis2 = GetDistanceBetweenPlayers(x,p1);
			if(dis2 < dis && dis2 != -1.00)
			{
				dis = dis2;
				player = x;
			}
		}
	}
	return player;
}
stock PayChecks(i)
{
    if(User[i][pZakonp] < 100) User[i][pZakonp]++;
    if(!GetPVarInt(i,"Fraction_Duty")) return 0;
    switch(User[i][pMember])
	{
		case 1..4,7,10,11,19,22,21:
		{
			if(FracBank[0][fKazna] <=0)
			{
				SendClientMessage(i, COLOR_GREY, "[Мэрия] Казна штата пуста, зарплаты нет...");
				return 0;
			}
		}
	}
	if(User[i][pMember] == 7)
	{
	    switch(User[i][pRank])
	    {
	        case 1,2: return 6000; case 3: return 8000;
			case 4: return 10000; case 5: return 16000;
	        case 6: return 20000;
		}
	}
	else if(User[i][pMember] == 2)
	{
	    switch(User[i][pRank])
	    {
	        case 1: return 6000;
			case 2..10: return 6000+(User[i][pRank]*1000);
		}
	}
	else if(User[i][pMember] == 1 || User[i][pMember] == 10 || User[i][pMember] == 21) return 4500+(User[i][pRank]*500);
	else if(User[i][pMember] == 3 || User[i][pMember] == 19) return 2500+(User[i][pRank]*500);
	else if(User[i][pMember] == 4)
	{
	    switch(User[i][pRank])
	    {
	        case 1..8: return 2000+(User[i][pRank]*500);
	        case 9: return 8000;
	        case 10: return 10000;
		}
	}
	else if(IsAMafia(i)) return 2500+(User[i][pRank]*1000);
	else if(User[i][pMember] == 11 || User[i][pMember] == 9 || User[i][pMember] == 16 || User[i][pMember] == 20) return 1500*User[i][pRank];
	else if(IsAGang(i))
	{
	    new null = 0;
        for(new idx = 1; idx <= TOTALGZ; idx++) if(GZInfo[idx][gFrakVlad] == User[i][pMember]) null++;
        return null*50;
	}
	return 0;
}
stock PayDay()
{
	new str[160];
	for(new i = 0; i < 20; i++) FrakCD[i] = 0;
	for(new i = 1; i <= TOTALGZ; i++)
	{
		if(GZInfo[i][gFrakVlad] == 12) TotalGzB++;
		if(GZInfo[i][gFrakVlad] == 13) TotalGzV++;
		if(GZInfo[i][gFrakVlad] == 15) TotalGzG++;
		if(GZInfo[i][gFrakVlad] == 17) TotalGzA++;
		if(GZInfo[i][gFrakVlad] == 18) TotalGzR++;
	}
	FracBank[0][fBallas] += TotalGzB*50;
	FracBank[0][fVagos] += TotalGzV*50;
	FracBank[0][fGrove] += TotalGzG*50;
	FracBank[0][fRifa] += TotalGzR*50;
	FracBank[0][fAztek] += TotalGzA*50;
	ClearTotalGz();
	for(new i; i <= TotalBizz; i++)
	{
		switch(BizzInfo[i][bMafia])
		{
			case 5: MafiaBank[0][nLcn] += 1000; // La Cosa Nostra
			case 6: MafiaBank[0][nYakuza] += 1000; // Yakuza
			case 14: MafiaBank[0][nRm] += 1000; // Russian Mafia
		}
	}
	SetSVarInt("capture", gettime() + 300);
	//
	GetBizz();
	GetHome();
	GetShop();
	GetKvart();
	GetFarm();
	//
	if(FracStore[LVaStore] < 0) FracStore[LVaStore] = 0;
	if(FracStore[SFaStore] < 0) FracStore[SFaStore] = 0;
	foreach(new i : Player)
	{
	    if(User[i][pLogin] == 0) continue;

	    User[i][pPayCheck]+=PayChecks(i);
	    DeletePVar(i,"_Hel");

		User[i][ptaxiexp] += taxiexpp[i];
		if(User[i][pDonateRank]) User[i][pExp]+=EXPS;
		else User[i][pExp] ++;
		if(booston == true && User[i][pLevel] < 6) User[i][pExp] ++;

		new checks = User[i][pPayCheck];
		if(User[i][pDonateRank] > 0)
		{
			GameTextForPlayer(i, "PayDay", 5000, 1);
			SendClientMessage(i, COLOR_GOLD, "--------===[ VIP КЛИЕНТ БАНКА SA ]===-------");
		}
		else
		{
			GameTextForPlayer(i, "~w~PayDay", 5000, 1);
			SendClientMessage(i, COLOR_GRAD1, "--------===[ КЛИЕНТ БАНКА SA ]===-------");
		}
		if(!NoNalog(i))
		{
			if(checks >= 500)
			{
				format(str,sizeof(str), " Налог государству: {FF6347}-%d$",nalog);
				SendClientMessage(i, 0xF1C33AFF, str);
				User[i][pBank] -= nalog;//User[i][pPayCheck]/10;
				FracBank[0][fKazna] += nalog;//checks/10;
			}
			else SendClientMessage(i, 0xF1C33AFF, " Налог государству: {FF6347}-0$");
		}
		if(User[i][pBank] > 50 && User[i][pKrisha] != 0) User[i][pBank] -= 50, User[i][pDolg] += 50;
		if(User[i][pCash] > 50 && User[i][pKrisha] != 0) User[i][pCash] -= 50, User[i][pDolg] += 50;

		format(str,sizeof(str), " Счёт за телефон: {FF6347}-%i${F1C33A}", User[i][pMobile]);
		SendClientMessage(i, 0xF1C33AFF, str);

		User[i][pBank]-=User[i][pMobile];
		User[i][pMobile] = 0;
		SendClientMessage(i, -1, " ");

		switch(User[i][pMember])
		{
			case 1,10,21: format(str,sizeof(str), " {FFFFFF}Зарплата Полиции: {3AA94C}%i", checks);
			case 3,19: format(str,sizeof(str), " {FFFFFF}Зарплата Армии: {3AA94C}%i$", checks);
			case 2: format(str,sizeof(str), " {FFFFFF}Зарплата ФБР: {3AA94C}%i$", checks);
			case 7: format(str,sizeof(str), " {FFFFFF}Зарплата Мэрии: {3AA94C}%i$", checks);
			case 4: format(str,sizeof(str), " {FFFFFF}Зарплата Медиков: {3AA94C}%i$", checks);
			case 11: format(str,sizeof(str), " {FFFFFF}Зарплата Автошколы: {3AA94C}%i$", checks);
			case 5,6,14: format(str,sizeof(str), " {FFFFFF}Зарплата организации: {3AA94C}%i$", checks);
			case 12,13,15,17,18: format(str,sizeof(str), " {FFFFFF}Зарплата Бандитов: {3AA94C}%i$", checks);
			default: format(str,sizeof(str), " {FFFFFF}Зарплата: {3AA94C}%i$", checks);
		}
		if(User[i][pAdmin] > 0)
		{
		    SendClientMessage(i, -1, " {FFFFFF}Зарплата администрации: {3AA94C}20000$");
		    User[i][pBank] += 20000;
		}
		if(User[i][pHelper] > 0)
		{
		    SendClientMessage(i, -1, " {FFFFFF}Зарплата саппорта: {3AA94C}10000$");
		    User[i][pBank] += 10000;
		}
		if(User[i][pDonateRank] > 0) SendClientMessage(i, COLOR_GOLD, str);
		else SendClientMessage(i, COLOR_WHITE, str);
		User[i][pBank] += checks;
		if(User[i][pDonateRank] > 0) format(str,sizeof(str), " {FFFFFF}Текущий баланс: {3AA94C}%i$", User[i][pBank]), SendClientMessage(i, COLOR_GOLD, str);
		else format(str,sizeof(str), " {FFFFFF}Текущий баланс: {3AA94C}%i$", User[i][pBank]), SendClientMessage(i, COLOR_WHITE, str);
		if(HGet(i))
		{
			new cost_home[128];
			if(User[i][pDonateRank]) f(cost_home," {FFFFFF}Домашний счёт: {3AA94C}%d$", HouseInfo[GetPVarInt(i,"House")][hTakings]), SCM(i,COLOR_GOLD,cost_home);
			else f(cost_home," {FFFFFF}Домашний счёт: {3AA94C}%d$", HouseInfo[GetPVarInt(i,"House")][hTakings]), SCM(i,-1,cost_home);
		}
  		if(BGet(i))
		{
		    new strings[128];
		    for(new x = 1;x <= TotalBizz; x++)
		    {
		        if(GetPVarInt(i,"Bizz") == x)
		        {
			        f(strings, " {F1C33A}Плата за электроэнергию: {FF6347}-%i$", BizzLandTax[x]);
					if(User[i][pDonateRank])
					{
						SCM(i,COLOR_GOLD, strings);
					}
					else
					{
						SCM(i,COLOR_WHITE, strings);
					}
					BizzInfo[x][bLandTax] -= BizzLandTax[x];
					//BizzPayForDay[x] += BizzPay[x];
					printf("BIZDAYS: %d | BIZPAY %d",BizzPayForDay[x], BizzPay[x]);
					BizzPay[x] = 0;
				}
			}
		}
		if(User[i][pDonateRank] >= 1) SendClientMessage(i, COLOR_GOLD, "================================");
		else SendClientMessage(i,COLOR_GRAD1, "================================");
		/*if(User[i][pLevel] == 1)
		{
		    SendClientMessage(i,0xF0E79CFF,"Вам зачислено {3AA94C}2000$"),User[i][pCash] += 2000;
		    SendClientMessage(i,0xF0E79CFF,"Спасибо за то, что выбрали Retentive Role Play!");
		}*/
		if(User[i][pExp] >= ((User[i][pLevel]+1)*4)-1)
		{
			User[i][pLevel] ++, User[i][pExp] = 0;
		 	SendClientMessage(i, COLOR_YELLOW, "Поздравляем! Ваш уровень повысился!");
		 	SetPlayerScore(i, User[i][pLevel]);
		 	SendClientMessage(i,0xF0E79CFF,"Спасибо за то, что выбрали Rise Role Play!");
		 	SendClientMessage(i,0xF0E79CFF,"Вам зачислено {3AA94C}2000$"),User[i][pCash] += 2000;
			/*if(User[i][pLevel] == 5 && User[i][pExp] == 0)
			{
				static const fmt_query[] = "SELECT `pDrug` FROM `accounts` WHERE `Name` = '%s'";
				new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
				mysql_format(dbHandle, query, sizeof(query), fmt_query,User[i][pName]);
	  			mysql_tquery(dbHandle, query, "OnMySQL_QUERY", "iis", 13, i, "");
	  			if(!strcmp(User[i][pDrug], "#matick", false) || !strcmp(User[i][pDrug], "#Monster", false) || !strcmp(User[i][pDrug], "#Raylon", false) || !strcmp(User[i][pDrug], "#chester", false) || !strcmp(User[i][pDrug], "#nambovan", false) || !strcmp(User[i][pDrug], "#rolton", false))
				{
					SendClientMessage(i,COLOR_BLUE,"Спасибо за то, что приняли участие в развитии проекта");
					switch(booston)
					{
					case 0:SendClientMessage(i,COLOR_BLUE,"Вам зачислено 300000 вирт"),User[i][pCash] += 300000;
					case 1: SendClientMessage(i,COLOR_BLUE,"Вам зачислено 600000 вирт"),User[i][pCash] += 600000;
					}
					SendClientMessage(i,COLOR_GREEN,"Рекомендуется: Сменить пароль на более сложный ( /mm >>> [6] Смена пароля )");
					SendClientMessage(i,COLOR_GREEN,"Рекомендуется: Поставить проверку по IP и SuperKey ( /mm >>> [10] Безопасность )");
				}
			}*/
		}

        if(GetPVarInt(i, "Milosti") > 2400)
		{
		    ClearAnimations(i);
		    SendClientMessage(i,0xF0E79CFF,"Вам зачислено {3AA94C}2000$ {F0E79C} за милостыню"),User[i][pCash] += 2000;
			DeletePVar(i, "Milosti");
		}

		if(GetPVarInt(i, "_GetBizz_") > 0 && BGet(i))
		{
			SendClientMessage(i, COLOR_LIGHTRED, " Ваш бизнес был закрыт по причине: отсутствие продуктов");
			SendClientMessage(i, COLOR_LIGHTRED, " Если по истечению {ffffff}12 {FF6347}часов бизнес будет закрыт, он будет продан гос-ву");
			DeletePVar(i, "_GetBizz_");
		}
		if(GetPVarInt(i, "GetBizz_") > 0 && GetPVarInt(i, "_GetBizz_") == 0 && BGet(i))
		{
  			format(str,sizeof(str), " Ваш бизнес закрыт уже {ffffff}%i {FF6347}час(а/ов)",BizzInfo[GetPVarInt(i, "PlayerBizz")][bLockTime]);
			SendClientMessage(i, COLOR_LIGHTRED,str);
			SendClientMessage(i, COLOR_LIGHTRED, " Если по истечению {ffffff}12 {FF6347}часов бизнес будет закрыт, он будет продан государству");
			DeletePVar(i, "GetBizz_");
		}
		if(GetPVarInt(i, "GetBizz") > 0)
		{
			SendClientMessage(i, COLOR_LIGHTRED," Ваш бизнес был продан государству за неуплату налогов");
			SendClientMessage(i, COLOR_LIGHTRED," Ваши деньги за бизнес были перечислены на ваш счет");
			DeletePVar(i, "Bizz");
			DeletePVar(i, "GetBizz");
		}
		if(GetPVarInt(i, "GetHome") > 0)
		{
			SendClientMessage(i, COLOR_LIGHTRED," Вы были выселены за неуплату квартплаты");
			SendClientMessage(i, COLOR_LIGHTRED," Деньги за дом Вы можете получить в банке");
			DeletePVar(i, "GetHome");
			DeletePVar(i, "House");
			User[i][pSpawnChange] = 0;
		}
		if(GetPVarInt(i, "GetKvart") > 0)
		{
		    SendClientMessage(i, COLOR_LIGHTRED," Вы были выселены за неуплату квартплаты");
			DeletePVar(i, "GetKvart");
			DeletePVar(i, "Kvart");
			User[i][pSpawnChange] = 0;
		}
		if(GetPVarInt(i, "GetShop") > 0)
		{
			SendClientMessage(i, COLOR_LIGHTRED," Ваша автомастерская была выставлена на аукцион за неуплату налогов");
			SendClientMessage(i, COLOR_LIGHTRED," Деньги с банка автомастерской были перечислены на Ваш счет");
			DeletePVar(i, "wShop");
			DeletePVar(i, "GetShop");
		}
		if(GetPVarInt(i, "GetFarm") > 0)
		{
			SendClientMessage(i, COLOR_LIGHTRED," Ваша ферма была выставлена на аукцион за неуплату налогов");
			SendClientMessage(i, COLOR_LIGHTRED," Деньги с банка автомастерской были перечислены на Ваш счет");
			DeletePVar(i, "Farm");
			DeletePVar(i, "GetFarm");
		}
		seans[i] = 0;
		User[i][pRobHouse] = 0;
		User[i][pPayCheck] = 0;
		User[i][pPayDayHad] ++;
		if(User[i][quest_store][1] == 20 && User[i][ptaxilvl] == 5)
		{
			SendClientMessage(i, COLOR_YELLOW,"[Подсказка] Вы получили 5 уровень таксиста, теперь вам нужно поработать на работе автобусника");
			UpdateQuestInfo(i, 1, 40);
		}
		if(User[i][quest_store][1] == 40 && User[i][pJob] == 1 && checks > 10000)
		{
			SendClientMessage(i, COLOR_YELLOW,"[Подсказка] Вы заработали денег на работе автобусника, теперь вам нужно купить дом");
			UpdateQuestInfo(i, 1, 60);
		}
		if(User[i][quest_store][2] == 20 && User[i][ptaxilvl] > 249)
		{
			SendClientMessage(i, COLOR_YELLOW,"[Подсказка] У вас больше 250 опыта автоугонщика, вы прошли квест!");
			UpdateQuestInfo(i, 2, 100);
			QuestNagrada(i);
		}
		if(User[i][quest_store][3] == 20 && User[i][pDLevel] > 24)
		{
			SendClientMessage(i, COLOR_YELLOW,"[Подсказка] У вас больше 24 опыта дальнобойщика!");
			UpdateQuestInfo(i, 3, 100);
			User[i][pCash] += 200000;
			QuestNagrada(i);
		}
		SavePlayer(i);
		SaveCar(i);
	}
	return true;
}
stock split(const strsrc[], strdest[][], delimiter)
{
	new i, li;
	new aNum;
	new len;
	while(i <= strlen(strsrc))
	{
		if(strsrc[i] == delimiter || i == strlen(strsrc))
		{
			len = strmid(strdest[aNum], strsrc, li, i, 128);
			strdest[aNum][len] = 0;
			li = i+1;
			aNum++;
		}
		i++;
	}
	return true;
}
publics: ABroadCast(color,const str[],level)
{
    foreach(new i : Player)
    {
        if(User[i][pAdmin] < level || !GetPVarInt(i, "Dostup")) continue;
        SendClientMessage(i, color, str);
    }
}
