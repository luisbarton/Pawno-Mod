	}
	return 0xFEFEFEAA;
}*/
stock GetGangZoneColor(gangzonex)
{
	switch(GZInfo[gangzonex][gFrakVlad])
	{
		case 12: return 0xd200ff99;
		case 13: return 0xcfbe0899;
		case 15: return 0x06b50699;
		case 17: return 0x03c3b899;
		case 18: return 0x007fffAA;
	}
	return 0xFEFEFEAA;
