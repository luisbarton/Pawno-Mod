}
CMD:setstat(playerid, params[])
{
    if(User[playerid][pAdmin] < 8 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "udd",params[0],params[1],params[2]))
	{
		SendClientMessage(playerid, COLOR_GREY, "Используйте: /setstat [id] [номер] [количество]");
		SendClientMessage(playerid, COLOR_GRAD4, "[1] Уровень|[2] Законопослушность|[3] Материалы|[4] Скин|[5] Преступлений");
		SendClientMessage(playerid, COLOR_GRAD3, "[6] Номер телефона|[7] Exp|[8] Ключ от дома |[9] Номер бизнеса");
		SendClientMessage(playerid, COLOR_GRAD2, "[10] VIP [1-3]|[11] Работа игрока|[12] Сытость|[13] Деньги в банке");
		SendClientMessage(playerid, COLOR_GRAD2, "[14] Счёт мобильного|[15] Деньги|[16] Варны|[17] Наркотики");
		SendClientMessage(playerid, COLOR_GRAD2, "[18] Член орг|[19] Донат счётчик");
		SendClientMessage(playerid, COLOR_GRAD2, "[20] Box|[21] Kong Fu|[22] Kick Box");
		SendClientMessage(playerid, COLOR_GRAD2, "[23] Машина|[24] Цвет авто 1|[25] Цвет авто 2|[26] Наркозависимость");
		SendClientMessage(playerid, COLOR_GRAD2, "[27] Модель игрока|[28] Помолвлен на|[29] Проценты Авто|[30] Мастерская");
		return true;
	}
	new str[128];
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == INVALID_PLAYER_ID) return true;
	switch (params[1])
	{
		case 1:
		{
			User[params[0]][pLevel] = params[2];
			format(str, sizeof(str), "LVL игрока изменён на: %i", params[2]);
   			SetPlayerScore(params[0], User[params[0]][pLevel]);
		}
		case 2:
		{
			User[params[0]][pZakonp] = params[2];
			format(str, sizeof(str), "Законопослушность: %i", params[2]);
		}
        case 3:
		{
			User[params[0]][pMats] = params[2];
			format(str, sizeof(str), "Материалы: %i", params[2]);
		}
		case 4:
		{
			User[params[0]][pChar][0] = params[2];
			format(str, sizeof(str), "Скин игрока установлен на: %i", params[2]);
		}
		case 5:
		{
			User[params[0]][pCrimes] = params[2];
			format(str, sizeof(str), "Преступлений: %i", params[2]);
		}
		case 6:
		{
			User[params[0]][pPnumber] = params[2];
			format(str, sizeof(str), "Номер телефона игрока изменён на: %i", params[2]);
		}
		case 7:
		{
			User[params[0]][pExp] = params[2];
			format(str, sizeof(str), "EXP игрока изменены на: %i", params[2]);
		}
		case 8:
		{
			format(str, sizeof(str), "Дом: %i", params[2]);
		}
		case 9:
		{
			format(str, sizeof(str), "Бизнес: %i", params[2]);
		}
		case 10:
		{
			User[params[0]][pDonateRank] = params[2];
			format(str, sizeof(str), "VIP аккаунт уровня: %i", params[2]);
		}
		case 11:
		{
			User[params[0]][pJob] = params[2];
			format(str, sizeof(str), "Работа: %i", params[2]);
		}
		case 12:
		{
			if(User[params[0]][Satiety] + params[2] > 1000) SetPlayerSatiety(params[0], 1000);
	 		else GivePlayerSatiety(params[0], params[2]);
			format(str, sizeof(str),"Сытость игрока: %d", params[2]);
		}
		case 13:
		{
			User[params[0]][pBank] = params[2];
			format(str, sizeof(str), "Деньги в банке изменены на: %i вирт", params[2]);
		}
		case 14:
		{
			User[params[0]][pMobile] = params[2];
			format(str, sizeof(str), "Счёт мобильного: %i вирт", params[2]);
		}
		case 15:
		{
			User[params[0]][pCash] = params[2];
			format(str, sizeof(str), "Деньги изменены на: %i вирт", params[2]);
		}
		case 16:
		{
			User[params[0]][pWarns] = params[2];
			format(str, sizeof(str), "Количество варнов изменено на: %i", params[2]);
		}
		case 17:
		{
			User[params[0]][pDrugs] = params[2];
			format(str, sizeof(str), "Количество наркотиков изменено на: %i", params[2]);
		}
		case 18:
		{
			User[params[0]][pMember] = params[2];
			User[params[0]][pRank] = 1;
			format(str, sizeof(str), "Организация: %i", params[2]);
		}
		case 19:
		{
			User[params[0]][pDonateAccount] = params[2];
			format(str, sizeof(str), "Донат счётчик изменён на: %i вирт", params[2]);
		}
		case 20:
		{
			User[params[0]][pBoxSkill] = params[2];
			format(str, sizeof(str), "Уровень боевых искусств Box: %i", params[2]);
		}
		case 21:
		{
			User[params[0]][pKongfuSkill] = params[2];
			format(str, sizeof(str), "Уровень боевых искусств Kong Fu: %i", params[2]);
		}
		case 22:
		{
			User[params[0]][pKickboxSkill] = params[2];
			format(str, sizeof(str), "Уровень боевых искусств Kick Box: %i", params[2]);
		}
		case 23:
		{
			CarInfo[params[0]][carModel][0] = params[2];
			CarInfo[params[0]][carPercent][0] = 100;
			format(str, sizeof(str), "Машина: %i", params[2]);
		}
		case 24:
		{
			CarInfo[params[0]][carColor_one][0] = params[2];
			format(str, sizeof(str), "Цвет 1: %i", params[2]);
		}
		case 25:
		{
			CarInfo[params[0]][carColor_two][0] = params[2];
			format(str, sizeof(str), "Цвет 2: %i", params[2]);
		}
		case 26:
		{
			User[params[0]][pAddiction] = params[2];
			format(str, sizeof(str), "Зависимость %i", params[2]);
		}
		case 27:
		{
			User[params[0]][pModel] = params[2];
			format(str, sizeof(str), "Модель игрока: %i", params[2]);
		}
		case 28:
		{
			format(str, sizeof(str),"Временно отключено");
		}
		case 29:
		{
			CarInfo[params[0]][carPercent][0] = params[2];
			format(str, sizeof(str), "Проценты Автмобиля: %i", params[2]);
		}
		case 30:
		{
			User[params[0]][pAvtomas] = params[2];
			format(str, sizeof(str), "Мастерская игрока: %i", params[2]);
		}
	}
	/*format(YCMDstr, sizeof(YCMDstr), "Администратор %s установил %s stats [ID: %i] [VALUE: %i]", Name(playerid), Name(params[0]), params[1], params[2]);
	WriteLog("SetStat.txt", YCMDstr);*/
	SendClientMessage(playerid, COLOR_GRAD1, str);
	return true;
}
