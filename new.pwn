			CellTime[caller] = 0;
			CellTime[playerid] = 0;
			Mobile[caller] = 999;
		}
		Mobile[playerid] = 999;
		CellTime[playerid] = 0;
	}
	if(IsAGang(killerid) && IsAGang(playerid) && killerid != INVALID_PLAYER_ID)
	{
    	for(new i = 1; i <= TOTALGZ; i++)
		{
			if(ZoneOnBattle[i] == 1)
			{
		    	if(User[killerid][pMember] != User[playerid][pMember])
		    	{
					if(User[killerid][pMember] == GZInfo[i][gNapad] || User[killerid][pMember] == GZInfo[i][gFrakVlad])
					{
						if(User[playerid][pMember] == GZInfo[i][gNapad] || User[playerid][pMember] == GZInfo[i][gFrakVlad])
						{
							CountOnZone[User[killerid][pMember]] ++;
		 					foreach(new idx : Player)
			 				{
   								if(User[idx][pMember] == GZInfo[i][gNapad] || User[idx][pMember] == GZInfo[i][gFrakVlad]) SendDeathMessageToPlayer(idx, killerid, playerid, reason); }
							SetPlayerToTeamColor(killerid);
							SetPlayerToTeamColor(playerid);
							break;
						}
					}
				}
			}
		}
	}
	/*if(IsAGangSF(killerid) && IsAGangSF(playerid) && killerid != INVALID_PLAYER_ID)
	{
    	for(new i; i < sizeof(GZInfoSF); i++)
		{
