stock RentFaggio(playerid)
{
    if(User[playerid][pLevel] != 1) return SendClientMessage(playerid, 0xC21D00AA, "Доступно только новичкам (1 ур.)");
    if(User[playerid][pAreaskut] == 1) return SCM(playerid,COLOR_RED,"Вы уже производили аренду скутера");
	//if(User[playerid][pCash] < 99) return SendErrorMessage(playerid,"Необходимо 100 долларов!");
	new Float:X, Float:Y, Float:Z, Float:R;
    GetPlayerPos(playerid, X,Y,Z);
	new faggiorent = CreateVehicleAC(462, X,Y,Z,R,random(100), random(100), 300);
	PutPlayerInVehicleEx(playerid, faggiorent, 0);
	TogglePlayerControllable(playerid, 1);
	SetPVarInt(playerid, "FaggioRent", faggiorent);
	SCM(playerid,COLOR_BLUE," Вы арендовали скутер и он у Вас закрыт (/rlock)");
	SCM(playerid,-1," Отменить аренду скутера (/unrent)");
	//LockCar(faggiorent);
	//IsLocked[faggiorent] = 1;
	SetPVarInt(playerid, "Arenda", faggiorent);
	LockCar(playerid,faggiorent);
	Fuell[faggiorent] = 200;
	SetVehicleParamsEx(GetPlayerVehicleID(playerid) ,true,true,false,false,false,false,false);
	CarHealth[faggiorent] = float(1000);
	//User[playerid][pCash] -= 100;
    User[playerid][pAreaskut] += 1;
	return true;
}
stock SendWarningCheatMessageToAdmin(playerid,namecheat[])
{
    if(User[playerid][pAdmin] >= 1) return true;
    if(GetPVarInt(playerid,"messagetime") < gettime())
    {
        SetPVarInt(playerid,"messagetime",gettime()+15);
        format(YCMDstr,128," <Warning> %s[%d]: Возможно %s",User[playerid][pName],playerid,namecheat);
        ABroadCast(0xFF0000FF,YCMDstr,2);
    }
    return true;
}
stock DonateLog(playerid, cena, name[])
{
	mysql_format(dbHandle, YCMDstr, 164, "INSERT INTO `"TABLE_DLOGS"` (`NamePlayer`, `Price`, `Name`, `Date`) VALUES ('%s', '%d', '%s', NOW())", User[playerid][pName],cena,name);
	mysql_tquery(dbHandle,YCMDstr,"","");
	return 1;
}
public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	acstruct[playerid][checkmaptp] = 1; acstruct[playerid][maptplastclick] = GetTickCount();
	acstruct[playerid][maptp][0] = fX; acstruct[playerid][maptp][1] = fY; acstruct[playerid][maptp][2] = fZ;
	SetPVarInt(playerid, "AntiBreik", 2);
	if(User[playerid][pAdmin] >= 1)
	{
	    new vehicleid = GetPlayerVehicleID(playerid); // Узнаем ID машины в которой сидит игрок
        if(vehicleid > 0 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) // Если игрок в транспорте и он водитель
        {
                SetVehiclePos(vehicleid, fX, fY, fZ); // Телепорт транспорта
        }
        else // Если игрок НЕ находится в транспорте
        {
                SetPlayerPos(playerid, fX, fY, fZ); // Телепорт игрока
        }
        SendClientMessage(playerid, -1, "Вы были успешно телепортированы."); // Сообщение о успешном телепорте
	}
	return true;
}
