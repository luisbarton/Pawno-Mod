						t_SetPlayerPos(playerid, -787.3533,503.4622,1381.5991);
						SetPlayerInterior(playerid,1);
						SetPlayerVirtualWorld(playerid, 10);
						return true;
					}
				case 25:
					{
						if (GetPlayerState(playerid) == 2)
						{
							t_SetVehiclePos(tmpcar, 2031.4806,1014.9394,10.8203);
							User[ playerid ][ pPos_x ] = -1077.7568;
				    		User[ playerid ][ pPos_y ] = -2305.7173;
				    		User[ playerid ][ pPos_z ] = 52.3192;
				    		SetPVarInt(playerid, "AntiBreik", 2);
							TelePos[playerid][0] = 0.0;TelePos[playerid][1] = 0.0;
							return true;
						}
						else t_SetPlayerPos(playerid, 2031.4806,1014.9394,10.8203);
						SetPlayerInterior(playerid,0);
						SetPlayerVirtualWorld(playerid,0);
						return true;
					}
				case 26:
					{
						if (GetPlayerState(playerid) == 2)
						{
							t_SetVehiclePos(tmpcar, 2150.9121,1675.8231,10.8203);
							User[ playerid ][ pPos_x ] = -1077.7568;
				    		User[ playerid ][ pPos_y ] = -2305.7173;
				    		User[ playerid ][ pPos_z ] = 52.3192;
				    		SetPVarInt(playerid, "AntiBreik", 2);
							TelePos[playerid][0] = 0.0;TelePos[playerid][1] = 0.0;
							return true;
						}
						else t_SetPlayerPos(playerid, 2150.9121,1675.8231,10.8203);
						SetPlayerInterior(playerid,0);
						SetPlayerVirtualWorld(playerid,0);
						return true;
					}
				case 27:
					{
						if (GetPlayerState(playerid) == 2)
						{
							t_SetVehiclePos(tmpcar, 1779.5966,-1908.7085,13.3890);
							User[ playerid ][ pPos_x ] = -1077.7568;
				    		User[ playerid ][ pPos_y ] = -2305.7173;
				    		User[ playerid ][ pPos_z ] = 52.3192;
				    		SetPVarInt(playerid, "AntiBreik", 2);
							TelePos[playerid][0] = 0.0;TelePos[playerid][1] = 0.0;
