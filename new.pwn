CMD:follow(playerid, params[])
{
    if(!GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(!IsACop(playerid)) return err(!"Ошибка: {ffffff}Вы не можете это использовать.");
	if(sscanf(params, "u", params[0])) return SCM(playerid,COLOR_WHITE, !"Введите: /follow [playerid]");
	if(!PlayerInConnected(params[0]) || playerid == params[0]) return err(!"Ошибка: {ffffff} Человек не найден!");
	if(GetDistanceBetweenPlayers(playerid,params[0]) > 3.0) return err(!"Ошибка: {ffffff}Этот игрок далеко от вас.");
	YCMDstr[0] = EOS;
	if(User[params[0]][PlayerFollow] != -1)
	{
	    User[params[0]][PlayerFollow] = -1;
	    TogglePlayerControllable(params[0], 0);
	    format(YCMDstr,80, "%s отцепил(а) наручники %s от себя",User[playerid][pName],User[params[0]][pName]);
	    //SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	    SendBeside(playerid, COLOR_PURPLE, YCMDstr, 30.0);
     	return 1;
	}
	if(GetPVarInt(params[0], "PlayerCuffed") != 2) return err(!"Ошибка: {ffffff}Игрок должен быть в наручниках.");
	User[params[0]][PlayerFollow] = playerid;
	format(YCMDstr,80, "%s прицепил(а) наручниками к себе %s",User[playerid][pName],User[params[0]][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	return 1;
}
CMD:breathalyser(playerid, params[])
{
	if(!IsPlayerConnected(playerid)) return true;
	if(User[playerid][pMember] != 1 || User[playerid][pLeader] != 1) return true;
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, -1, "Введите: (/bh) /breathalyser [ид]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок оффлайн");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Необходимо находиться рядом друг с другом");
	new bh[64], patrol[144];
	if(GetPlayerDrunkLevel(params[0]) > 0) format(bh, sizeof(bh), "%s пьяный", User[params[0]][pName]);
	else format(bh, sizeof(bh), "%s трезвый", User[params[0]][pName]);
	SendClientMessage(playerid, 0x6ab1ffaa, bh), SendClientMessage(params[0], 0x6ab1ffaa, bh);
	format(patrol, sizeof(patrol), "Патрульный %s протянул(а) %s алкометр для проверки", User[playerid][pName], User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE, patrol, 20.0);
	return true;
}
CMD:cuff(playerid, params[])
{
	if(GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 1 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 10 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 21)
	{
		if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /cuff [id]");
		if(!IsPlayerConnected(params[0]) || !ProxDetectorS(8.0, playerid, params[0])) return true;
		if(User[params[0]][pWantedLevel] == 0) return SCM(playerid, COLOR_GREY, "Вы не можете надеть наручники на человека, который не находиться в розыске");
		if(IsACop(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете надеть наручники на законника");
		if(GetPVarInt(params[0], "PlayerCuffed") == 2) return SendClientMessage(playerid, COLOR_GREY, "Игрок уже в наручниках");
		if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете надеть наручники на самого себя"); return true; }
		format(YCMDstr, sizeof(YCMDstr), "%s надел вам наручники",User[playerid][pName]);
		SendClientMessage(params[0], 0x6495EDFF, YCMDstr);
		GameTextForPlayer(params[0],"~r~cuffed", 5000, 3);
		format(YCMDstr, sizeof(YCMDstr), "Вы надели наручники на %s", User[params[0]][pName]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "%s надел наручники на %s",User[playerid][pName], User[params[0]][pName]);
		SetPlayerAttachedObject(params[0], 0, 19418, 6, -0.011000, 0.028000, -0.022000, -15.600012, -33.699977, -81.700035, 0.891999, 1.000000, 1.168000);
		SetPlayerSpecialAction(params[0],SPECIAL_ACTION_CUFFED);
		SendBeside(playerid, COLOR_PURPLE,YCMDstr, 20.0);
		TogglePlayerControllable(params[0], 0);
		SetPVarInt(params[0], "PlayerCuffed", 2);
		SetPVarInt(params[0], "PlayerCuffedTime", 3600);
	}
	return true;
}
CMD:uncuff(playerid, params[])
{
	if(GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 1 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 10 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 21)
	{
		if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /uncuff [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(IsACop(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете снять наручники с законника");
		if(GetPVarInt(params[0], "PlayerCuffed") != 2) return    SendClientMessage(playerid, COLOR_GREY, "Игрок не в наручниках");
		if(!ProxDetectorS(8.0, playerid, params[0])) return true;
		if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете снять наручники с самого себя"); return true; }
		GameTextForPlayer(params[0],"~g~uncuffed", 5000, 3);
		format(YCMDstr, sizeof(YCMDstr), "Вы сняли наручники с %s", User[params[0]][pName]);
		SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
		TogglePlayerControllable(params[0], 1);
		SetPlayerSpecialAction(params[0],SPECIAL_ACTION_NONE);
		RemovePlayerAttachedObject(params[0],0);
		DeletePVar(params[0], "PlayerCuffed");
		DeletePVar(params[0], "PlayerCuffedTime");
		User[params[0]][PlayerFollow] = -1;
	}
	return true;
}
CMD:cput(playerid, params[])
{
    if(User[playerid][pRank] >= 1 && (User[playerid][pMember] == 1 || User[playerid][pMember] == 2 || User[playerid][pMember] == 10 ||User[playerid][pMember] == 21))
	{
		if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 497 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 427 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 523
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 415 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 560 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 596
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 490 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 597 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 598) return SendClientMessage(playerid, COLOR_GREY, "Вы не в патрульной машине");
		if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /cput [playerid]");
		if(!IsPlayerConnected(params[0])) return true;
		if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Человек не был найден");
		if (!ProxDetectorS(5.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Человек далеко от Вас");
		if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете затащить в машину самого себя");
		if(!User[params[0]][pWantedLevel]) return SendClientMessage(playerid, COLOR_GREY, "Человек не является преступником");
		if(GetPlayerState(params[0]) != PLAYER_STATE_ONFOOT) return SendClientMessage(playerid, COLOR_GREY, "Человек в автомобиле");
		new mesto2,vehicle=GetPlayerVehicleID(playerid);
		foreach(new i : Player)
		{
			if(IsPlayerInVehicle(i,vehicle))
			{
				mesto2 = GetPlayerVehicleSeat(i);
				if(mesto2==2) return SendClientMessage(playerid, COLOR_GREY, "Место в машине уже занято");
			}
		}
		PutPlayerInVehicleEx(params[0],vehicle,1);
		SetPlayerArmedWeapon(params[0],0);
		if(User[params[0]][PlayerFollow] != -1) User[params[0]][PlayerFollow] = -1, TogglePlayerControllable(params[0], 0);
		format(YCMDstr,sizeof(YCMDstr), "Вы были затащены в машину офицером / агентом FBI %s",User[playerid][pName]);
		SendClientMessage(params[0],0x64E96EDFF,YCMDstr);
		format(YCMDstr,sizeof(YCMDstr), "Вы затащили в машину преступника %s",User[params[0]][pName]);
		SendClientMessage(playerid,0x64E96EDFF,YCMDstr);
	}
	return true;
}
CMD:ceject(playerid, params[])
{
    if(GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 1 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 10 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 21)
	{
		if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 497 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 427 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 523
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 415 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 560 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 596
		&& GetVehicleModel(GetPlayerVehicleID(playerid)) != 597 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 598 && GetVehicleModel(GetPlayerVehicleID(playerid)) != 490) return SendClientMessage(playerid, COLOR_GREY, "Вы не в патрульной машине");
		if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /ceject [playerid]");
		if(!IsPlayerConnected(params[0])) return true;
		if(params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Человек не был найден");
		if(GetPlayerVehicleID(playerid) != GetPlayerVehicleID(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Человек не в Вашей машине");
		RemovePlayerFromVehicle(params[0]);
		new str[128];
		if(IsPlayerInRangeOfPoint(params[0],5.0,1568.6144,-1689.9901,6.2188))
		{
			SetPlayerInterior(params[0],6);
			t_SetPlayerPos(params[0],268.4186,77.6443,1001.0391);
			SetPlayerFacingAngle(params[0], 85.7670);
			format(str,sizeof(str), "Вы были высажены с машины офицером %s в участок Лос Сантоса",User[playerid][pName]);
			SendClientMessage(params[0],0x64E96EDFF,str);
			format(str,sizeof(str), "Вы высадили подозреваемого %s в полицейский участок Лос Сантоса",User[params[0]][pName]);
			SendClientMessage(playerid,0x64E96EDFF,str);
			format(str,sizeof(str), "Затолкал(а) подозреваемого %s в полицейский участок",User[params[0]][pName]);
			SetPlayerChatBubble(playerid,str,COLOR_PURPLE,30.0,10000);
			if(User[params[0]][PlayerFollow] != -1) User[params[0]][PlayerFollow] = -1, TogglePlayerControllable(params[0], 0);
		}
		else if(IsPlayerInRangeOfPoint(params[0],5.0,-1594.2096,716.1803,-4.9063))
		{
			SetPlayerInterior(params[0],10);
			t_SetPlayerPos(params[0],220.1259,114.6476,999.0156);
			SetPlayerFacingAngle(params[0], 95.3400);
			format(str,sizeof(str), "Вы были высажены с машины офицером %s в участок Сан Фиерро",User[playerid][pName]);
			SendClientMessage(params[0],0x64E96EDFF,str);
			format(str,sizeof(str), "Вы высадили подозреваемого %s в полицейский участок Сан Фиерро",User[params[0]][pName]);
			SendClientMessage(playerid,0x64E96EDFF,str);
			format(str,sizeof(str), "Затолкал(а) подозреваемого %s в полицейский участок",User[params[0]][pName]);
			SetPlayerChatBubble(playerid,str,COLOR_PURPLE,30.0,10000);
			if(User[params[0]][PlayerFollow] != -1) User[params[0]][PlayerFollow] = -1, TogglePlayerControllable(params[0], 0);
		}
		else if(IsPlayerInRangeOfPoint(params[0],5.0,2297.1138,2451.4346,10.8203))
		{
			SetPlayerInterior(params[0],3);
			SetPlayerVirtualWorld(params[0], 122);
			t_SetPlayerPos(params[0],198.1339,158.4835,1003.0234);
			SetPlayerFacingAngle(params[0], 354.8164);
			format(str,sizeof(str), "Вы были высажены с машины офицером %s в участок Лас Вентурас",User[playerid][pName]);
			SendClientMessage(params[0],0x64E96EDFF,str);
			format(str,sizeof(str), "Вы высадили подозреваемого %s в полицейский участок Лас Вентурас",User[params[0]][pName]);
			SendClientMessage(playerid,0x64E96EDFF,str);
			format(str,sizeof(str), "Затолкал(а) подозреваемого %s в полицейский участок",User[params[0]][pName]);
			SetPlayerChatBubble(playerid,str,COLOR_PURPLE,30.0,10000);
			if(User[params[0]][PlayerFollow] != -1) User[params[0]][PlayerFollow] = -1, TogglePlayerControllable(params[0], 0);
		}
		else
		{
			format(str,sizeof(str), "Вы были высажены с машины офицером/агентом ФБР %s",User[playerid][pName]);
			SendClientMessage(params[0],0x64E96EDFF,str);
			format(str,sizeof(str), "Вы вытащили с машины подозреваемого %s",User[params[0]][pName]);
			SendClientMessage(playerid,0x64E96EDFF,str);
			format(str,sizeof(str), "Вытащил(а) из машины подозреваемого %s",User[params[0]][pName]);
			SetPlayerChatBubble(playerid,str,COLOR_PURPLE,30.0,10000);
			if(User[params[0]][PlayerFollow] != -1) User[params[0]][PlayerFollow] = -1, TogglePlayerControllable(params[0], 0);
		}
	}
	return true;
}
CMD:find(playerid, params[])
{
    if(User[playerid][pMember] != 2)return SendClientMessage(playerid, COLOR_GREY, "Вы не агент FBI");
	if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /find [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы указали свой ID");
	if(CallInfo[params[0]][callused] == 0 || PhoneOnline[params[0]] > 0) return SendClientMessage(playerid,COLOR_GREY, "Не удается соединиться!");
	if(User[params[0]][pWantedLevel] < 1) return SendClientMessage(playerid, COLOR_GREY, "Этот человек не в розыске!");
	{
		SetPlayerCheckpoint(playerid, CallInfo[params[0]][callx],CallInfo[params[0]][cally],CallInfo[params[0]][callz], 6);
		SetPVarInt(playerid, "GPSMark", 1);
		PlayerTextDrawShow(playerid, GPS_ON[playerid][0]);
		PlayerTextDrawShow(playerid, GPS_ON[playerid][1]);
	}
	return true;
}
CMD:spy(playerid, params[])
{
	if(User[playerid][pMember] != 2) return true;
    if(User[playerid][pRank] < 6 && !GetPVarInt(playerid, "Fraction_Duty")) return SendClientMessage(playerid, -1, "Доступно с 6 ранга");
    if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Введите: /spy [id]");
    if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не найден");
    if(User[params[0]][pMember] != 2) return SendClientMessage(playerid, -1, "Разрешить шпионить можно только агентам FBI");
    SmenaSkina = params[0];
    format(YCMDstr, 80, "%s собирается дать %s возможность шпионить", User[playerid][pName], User[params[0]][pName]);
	SendFamilyMessage(2, 0x00b953ff, YCMDstr);
    ShowPlayerDialogEx(playerid, 50, DIALOG_STYLE_LIST, "Выберите фракцию", "Бомжи\nПолиция\nАрмия\nМЧС\nМэрия\nАвтошкола\nNews\nLCN\nYakuza\nRussian Mafia\nRifa\nGrove street\nBallas\nVagos\nAztec\nБайкеры", "Выбрать", "Отмена");
    return true;
}
CMD:spyoff(playerid, params[])
{
    if(User[playerid][pMember] != 2 || User[playerid][pRank] < 6) return SendClientMessage(playerid, -1, "Доступно с 6 ранга");
    if(User[params[0]][pMember] == 2) return SendClientMessage(playerid,COLOR_GREY, "Данный игрок не состоит в FBI");
    if(!GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "Введите: /spyoff [id]");
    if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не найден");
    format(YCMDstr, 80, "%s забрал у %s возможность шпионить", User[playerid][pName], User[params[0]][pName]);
	SendFamilyMessage(2, 0x00b953ff, YCMDstr);
	SetPlayerSkin(params[0], User[playerid][pModel]);
    SetPlayerToTeamColor(params[0]);
    return true;
}
CMD:tjail(playerid, params[])
{
    if(!IsPlayerConnected(playerid)) return true;
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /tjail [playerid]");
    if(!IsPlayerConnected(params[0]) || params[0] == INVALID_PLAYER_ID) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден");
    format(YCMDstr, 42, "Игрок выйдет из тюрьмы через %i секунд", User[params[0]][pJailTime]-10);
    SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
    return true;
}
CMD:atipster(playerid, params[])
{
    if(User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /atipster [id фракции]");
    if(params[0] > 36 || params[0] < 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 0 или больше 36");
    SetPVarInt(playerid,"Atisper",params[0]);
    if(params[0] == 0) SendClientMessage(playerid, COLOR_WHITE, "Прослушка отключена");
    else SendClientMessage(playerid, COLOR_WHITE, "Прослушка включена, для отключения введите /atisper 0");
    return 1;
}
CMD:tipster(playerid)
{
	if(User[playerid][pMember] != 2 || User[playerid][pRank] < 6) return SCM(playerid, COLOR_GREY, "Вам недоступна данная функция!");
	return ShowPlayerDialogEx(playerid, 1506, DIALOG_STYLE_LIST, "Жучок", "1. Взять жучок\n2. Прикрепить жучёк к игроку\n3. Деактивировать жучёк\n4. Начать прослушивание жучка", "Выбрать", "Закрыть");
}
CMD:cancel(playerid, params[])
{
	return ShowPlayerDialogEx(playerid,1756,DIALOG_STYLE_LIST,"Отмена","Продажа дома\nПокупка дома\nПродажа автомобиля\nПокупка автомобиля", "Выбор", "Закрыть");
}
CMD:accept(playerid, params[])
{
	new x_job[64];
	if(sscanf(params, "s[32]",x_job)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /(ac)cept [значение]");
	if(strcmp(x_job,"gun",true) == 0)
	{
	    new str[128];
	    if(GetPVarInt(playerid,"Sell_Gun") <= 0) return SendClientMessage(playerid,COLOR_GREY, "Вам не предлагали купить оружие!");
		if(!ProxDetectorS(4.0, playerid, GetPVarInt(playerid,"Sell_GunId"))) return SendClientMessage(playerid, COLOR_GREY, "Игрок слишком далеко!");
		if(User[playerid][pCash] < GetPVarInt(playerid,"Sell_GunPrice")) return SendClientMessage(playerid,COLOR_GREY, "У вас недостаточно денег");
		User[playerid][pCash]-=GetPVarInt(playerid,"Sell_GunPrice");
  		User[GetPVarInt(playerid,"Sell_GunId")][pCash]+=GetPVarInt(playerid,"Sell_GunPrice");
    	User[GetPVarInt(playerid,"Sell_GunId")][pMats]-=GetPVarInt(playerid,"Sell_GunMats");
		GiveWeapon(playerid,GetPVarInt(playerid,"Sell_Gun"),GetPVarInt(playerid,"Sell_GunAmmo"));
		//else if(booston == true) GiveWeapon(playerid,GetPVarInt(playerid,"Sell_Gun"),GetPVarInt(playerid,"Sell_GunAmmo")*3);
		format(str,sizeof(str), "%s сделал оружие из материалов %s",Name(GetPVarInt(playerid,"Sell_GunId")),User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, str, 10.0);
		DeletePVar(playerid,"Sell_Gun");
		DeletePVar(playerid,"Sell_GunId");
 		DeletePVar(playerid,"Sell_GunAmmo");
   		DeletePVar(playerid,"Sell_GunPrice");
	    DeletePVar(playerid,"Sell_GunMats");
		return true;
	}
	if(strcmp(x_job, "debt",true) == 0)
	{
		if(KrishaOffer[playerid] < 999)
		{
		    new str[128];
			format(str, sizeof(str), "Вы приняли крышу от %s'a", User[KrishaOffer[playerid]][pName]);
			SendClientMessage(playerid, 0x6495EDFF, str);
			format(str, sizeof(str), "%s согласился на вашу крышу", User[playerid][pName]);
			SendClientMessage(KrishaOffer[playerid], 0x6495EDFF, str);
			KrishaOffer[playerid] = 999;
			User[playerid][pUseKrisha] = 1;
			User[playerid][pKrisha] = Krisha[playerid];
			return true;
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Вам никто не предлагал крышу");
			return true;
		}
	}
	else if(strcmp(x_job, "marriage",true) == 0)
	{
		if(ProposeOffer[playerid] < 999)
		{
			if(!PlayerToPoint(10.0, playerid, -1988.6638,1117.8837,54.4726) && (!PlayerToPoint(10.0, playerid, -1954.7692,1118.8585,1332.1675) && GetPlayerInterior(playerid) != 1)) return SendClientMessage(playerid, COLOR_GREY, "Вы не у церкви в San Fierro!");
			if(IsPlayerConnected(ProposeOffer[playerid]))
			{
				if(ProxDetectorS(10.0, playerid, ProposeOffer[playerid]))
				{
				    new str[128];
					format(str, sizeof(str), "Вы приняли предложение от %s's", User[ProposeOffer[playerid]][pName]);
					SendClientMessage(playerid, 0x6495EDFF, str);
					format(str, sizeof(str), "%s приняла Ваш запрос быть Вашей Женой.", User[playerid][pName]);
					SendClientMessage(ProposeOffer[playerid], 0x6495EDFF, str);
					strmid (User[playerid][pMarriedTo], User[ProposeOffer[playerid]][pName], 0, strlen(User[ProposeOffer[playerid]][pName]), 32);
					strmid (User[ProposeOffer[playerid]][pMarriedTo],User[playerid][pName], 0, strlen(User[playerid][pName]), 32);
					User[ProposeOffer[playerid]][pCash] -= 100000;
					ProposedTo[playerid] = 999;
					ProposeOffer[playerid] = 999;
				}
				return true;
			}
			else
			{
				SendClientMessage(playerid, COLOR_GREY, "Жених/Невеста не рядом с Вам!");
				return true;
			}
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Вам ни кто не предлагал!");
			return true;
		}
	}
	else if(strcmp(x_job, "gcontract",true) == 0)
	{
		if(JobOffer[playerid] == 999) return SCM(playerid, COLOR_GREY, "Вам никто не предлагал контракт");
		if(Employer[playerid] != 999) return SCM(playerid, COLOR_GREY, "Вы уже заключили контракт");
		if(Prorab[JobOffer[playerid]] == false) return SCM(playerid,COLOR_GREY, " Ошибка. Прораб уже не на работе");
		if(!IsPlayerInRangeOfPoint(playerid,10.0,2127.5701,-2275.1938,20.6719)) SCM(playerid,-1, " Ошибка. Вы должны быть у раздевалки");
		if(!IsPlayerConnected(JobOffer[playerid])) return SCM(playerid,-1, " Игрок не в стеи");
		if(!ProxDetectorS(5.0, playerid, JobOffer[playerid])) return SCM(playerid,-1, " Ошибка. Вы должны находиться рядом с игроком");
		Employer[playerid] = JobOffer[playerid];
		JobOffer[playerid] = 0;
		format(YCMDstr, 128, " Вы приняли предложение %s", Name(Employer[playerid]));
		SCM(playerid, 0x6495EDFF, YCMDstr);
		format(YCMDstr, 128, " %s принял ваше предложение.", Name(playerid));
		SCM(Employer[playerid], 0x6495EDFF, YCMDstr);
		SCM(Employer[playerid], 0x6495EDFF, "(( /gpayday - выдать зарплату ))");

	}
	else if(strcmp(x_job, "taxi",true) == 0)
	{
		if(!GetPVarInt(playerid,"TaxiDuty")) return SendClientMessage(playerid, COLOR_GREY, "Вы не работаете таксистом");
		if(TaxiCallTime[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "Вы уже приняли вызов.!");
		if(TaxiCall < 999)
		{
			if(IsPlayerConnected(TaxiCall))
			{
			    new str[128];
				format(str, sizeof(str), "Вы приняли вызов от %s.",User[TaxiCall][pName]);
				SendClientMessage(playerid, 0x6495EDFF, str);
				format(str, sizeof(str), "Водитель такси %s принял ваш вызов, оставайтесь на месте.",User[playerid][pName]);
				SendClientMessage(TaxiCall, COLOR_GREEN, str);
				new Float:X, Float:Y, Float:Z;
				GetPlayerPos(TaxiCall, X, Y, Z);
				SetPlayerCheckpoint(playerid, X, Y, Z, 5);
				SetPVarInt(playerid, "GPSMark", 1);
				PlayerTextDrawShow(playerid, GPS_ON[playerid][0]);
				PlayerTextDrawShow(playerid, GPS_ON[playerid][1]);
				TaxiCall = 999;
				return true;
			}
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Нет Вызовов");
			return true;
		}
	}
	else if(strcmp(x_job, "ticket",true) == 0)
	{
		if(TicketOffer[playerid] < 999)
		{
			if(IsPlayerConnected(TicketOffer[playerid]))
			{
			    //if(User[playerid][pCash] > TicketMoney[playerid]) return SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!");
				if (ProxDetectorS(5.0, playerid, TicketOffer[playerid]))
				{
				    if(GetSRVMoney(playerid) < TicketMoney[playerid]) return SCM(playerid, COLOR_GRAD1, "У Вас нет столько денег!");
				    new str[128];
					format(str, sizeof(str), "Вы оплатили штраф в размере %i вирт офицеру %s.", TicketMoney[playerid], User[TicketOffer[playerid]][pName]);
					SendClientMessage(playerid, COLOR_BLUE, str);
					format(str, sizeof(str), "%s оплатил штраф в размере %i вирт.", User[playerid][pName], TicketMoney[playerid]);
					SendClientMessage(TicketOffer[playerid], COLOR_BLUE, str);
					User[playerid][pCash] -=TicketMoney[playerid];
					User[TicketOffer[playerid]][pCash] +=TicketMoney[playerid];
					TicketOffer[playerid] = 999;
					TicketMoney[playerid] = 0;
					return true;
				}
				else
				{
					SendClientMessage(playerid, COLOR_GREY, "Полицейский не рядом с вами!");
					return true;
				}
			}
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Вам не выписывали штраф!");
			return true;
		}
	}
	else if(strcmp(x_job, "drugs",true) == 0)
	{
		if(DrugOffer[playerid] < 999)
		{
			if(User[playerid][pCash] > DrugPrice[playerid])
			{
				if(User[playerid][pDrugs] < 7)
				{
					if(IsPlayerConnected(DrugOffer[playerid]))
					{
					    new str[128];
						format(str, sizeof(str), "Вы купили %i грамм наркотиков за %i вирт у %s.",DrugGram[playerid],DrugPrice[playerid],User[DrugOffer[playerid]][pName]);
						SendClientMessage(playerid, 0x6495EDFF, str);
						format(str, sizeof(str), "%s купил у вас %i грамм наркотиков за %i вирт",User[playerid][pName],DrugGram[playerid],DrugPrice[playerid]);
						SendClientMessage(DrugOffer[playerid], 0x6495EDFF, str);
						User[playerid][pCash] -=DrugPrice[playerid];
						GiveMoney(DrugOffer[playerid], DrugPrice[playerid]);
						User[playerid][pDrugs] += DrugGram[playerid];
						User[DrugOffer[playerid]][pDrugs] -= DrugGram[playerid];
						DrugOffer[playerid] = 999;
						return true;
					}
					return true;
				}
				else
				{
					SendClientMessage(playerid, COLOR_GREY, "У Вас и так достаточно наркотиков!");
					return true;
				}
			}
			else
			{
				SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!");
				return true;
			}
		}
		else
		{
			SendClientMessage(playerid, COLOR_GREY, "Вам никто не предлагал купить наркотики!");
			return true;
		}
	}
	else if(strcmp(x_job, "car",true) == 0)
	{
		if(GetPVarInt(playerid,"changecar"))
		{
		    new i = GetPVarInt(playerid,"changecar")-1;
		    if(!HGet(playerid) && !KGet(playerid)) return SendClientMessage(playerid,COLOR_GREY,"У вас нет дома!"), DeletePVar(playerid,"changecar_price"), DeletePVar(playerid,"changecar_"), DeletePVar(i,"_changecar"), DeletePVar(playerid,"changecar");
		    if(!HGet(i) && !KGet(playerid)) return SendClientMessage(playerid,COLOR_GREY,"У игрока нет дома!"), DeletePVar(playerid,"changecar_price"), DeletePVar(playerid,"changecar_"), DeletePVar(i,"_changecar"), DeletePVar(playerid,"changecar");
		    if(User[playerid][pPayDayHad] < 5) return SendClientMessage(playerid, COLOR_WHITE, "Необходимо отыграть 5 часов");
		    if(GetPVarInt(playerid,"changecar_")) return SendClientMessage(playerid,COLOR_GREY,"Вы уже подтвердили сделку!");
		    SetPVarInt(playerid,"changecar_",1);
		    SendClientMessage(playerid,0x6495EDFF,"Вы подтвердили сделку!");
		    SendClientMessage(i,0x6495EDFF,"Игрок подтвердил сделку!");
	     	SendClientMessage(i,0x6495EDFF,"(( Введите /(ac)cept car для продолжения! ))");
	     	return true;
		}
		else if(GetPVarInt(playerid,"_changecar"))
	    {
	        new i = GetPVarInt(playerid,"_changecar")-1;
	        if(!GetPVarInt(i,"changecar_")) return SendClientMessage(playerid,COLOR_GREY,"Игрок ещё не подтвердил сделку!");
	        if(!HGet(i) && !KGet(i)) return SendClientMessage(playerid,COLOR_GREY,"У игрока нет дома!"), DeletePVar(i,"changecar"), DeletePVar(i,"changecar_price"), DeletePVar(i,"changecar_"), DeletePVar(playerid,"_changecar");
	        if(!HGet(playerid) && !KGet(playerid)) return SendClientMessage(playerid,COLOR_GREY,"У игрока нет дома!"), DeletePVar(i,"changecar"), DeletePVar(i,"changecar_price"), DeletePVar(i,"changecar_"), DeletePVar(playerid,"_changecar");
	        format(QUERY, 400, "{ffffff}Вы предложили %s'у (ID: %i) обменять свой транспорт\t\t\n\n\n{ffffff}(Модель: %s, Доплата: %i)\n\n{ffffff}На его транспорт\n\n\n{ffffff}(Модель: %s)",
			Name(i), i, VehicleNames[GetVehicleModel(house_car[playerid])-400], GetPVarInt(i,"changecar_price"), VehicleNames[GetVehicleModel(house_car[i])-400]);
			ShowPlayerDialogEx(i, 0, 0, "Обменять транспорт", QUERY, "Закрыть", "");
	        format(QUERY, 400, "{FFFFFF}%s (ID: %i) предложил обменять свой транспорт\t\t\n\n\n{ffffff}(Модель: %s, Доплата: %i)\n\n{FFFFFF}На ваш транспорт\n\n\n{ffffff}(Модель: %s)\n\n{FFFF00}Вы согласны?",
			Name(playerid), playerid,VehicleNames[GetVehicleModel(house_car[playerid])-400], GetPVarInt(i,"changecar_price"), VehicleNames[GetVehicleModel(house_car[i])-400]);
			ShowPlayerDialogEx(playerid, 1566, 0, "Обменять транспорт", QUERY, "Да", "Нет");
			return true;
		}
	}
	else if(strcmp(x_job, "house",true) == 0)
	{
		if(GetPVarInt(playerid,"changehouse"))
		{
		    new i = GetPVarInt(playerid,"changehouse")-1;
		    if(!HGet(playerid)) return SendClientMessage(playerid,COLOR_GREY,"У вас нет дома!"), DeletePVar(playerid,"changehouse_price"), DeletePVar(playerid,"changehouse_"), DeletePVar(i,"_changehouse"), DeletePVar(playerid,"changehouse");
		    if(GetPVarInt(playerid,"changehouse_")) return SendClientMessage(playerid,COLOR_GREY,"Вы уже подтвердили сделку!");
		    SetPVarInt(playerid,"changehouse_",1);
		    SendClientMessage(playerid,0x6495EDFF,"Вы подтвердили сделку!");
		    SendClientMessage(i,0x6495EDFF,"Игрок подтвердил сделку!");
	     	SendClientMessage(i,0x6495EDFF,"(( Введите /(ac)cept house для продолжения! ))");
	     	return true;
		}
		else if(GetPVarInt(playerid,"_changehouse"))
	    {
	        new i = GetPVarInt(playerid,"_changehouse")-1;
	        if(!GetPVarInt(i,"changehouse_")) return SendClientMessage(playerid,COLOR_GREY,"Игрок ещё не подтвердил сделку!");
	        if(!HGet(i)) return SendClientMessage(playerid,COLOR_GREY,"У игрока нет дома!"), DeletePVar(i,"changehouse"), DeletePVar(i,"changehouse_price"), DeletePVar(i,"changehouse_"), DeletePVar(playerid,"_changehouse");
	        HGet(playerid);
		    new str[10], str_[10];
		    switch(HouseInfo[GetPVarInt(playerid,"House")][hKlass])
		    {
		        case 0: str = "Nope"; case 1: str = "D"; case 2: str = "C";
		        case 3: str = "B"; case 4: str = "A"; default: str = "S";
			}
			switch(HouseInfo[GetPVarInt(i,"House")][hKlass])
		    {
		        case 0: str_ = "Nope"; case 1: str_ = "D"; case 2: str_ = "C";
		        case 3: str_ = "B"; case 4: str_ = "A"; default: str_ = "S";
			}
		    if(HGet(playerid))
		    {
				new str5[250];
		    	format(str5,sizeof(str5),"Вы собираетесь обменяться домами с %s\n\nВаш дом:\n\tНомер дома: [%i]\n\tКласс дома: [%s]\n\nДом игрока:\n\tНомер дома: [%i]\n\tКласс дома: [%s]\n\tДоплата: [%i вирт]",User[playerid][pName],GetPVarInt(i,"House"),str_,GetPVarInt(playerid,"House"),str,GetPVarInt(i,"changehouse_price"));
	        	ShowPlayerDialogEx(i,0, 0,"Обмен домами",str5,"Закрыть","");
	        	format(str5,sizeof(str5),"Вы собираетесь обменяться домами с %s\n\nВаш дом:\n\tНомер дома: [%i]\n\tКласс дома: [%s]\n\nДом игрока:\n\tНомер дома: [%i]\n\tКласс дома: [%s]\n\tВаша доплата: [%i вирт]",User[i][pName],GetPVarInt(playerid,"House"),str,GetPVarInt(i,"House"),str_,GetPVarInt(i,"changehouse_price"));
