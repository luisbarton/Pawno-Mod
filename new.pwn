ALTX:licenses("/lic");
CMD:licenses(playerid, params[])
{
	if(sscanf(params, "d",params[0]))
	{
        SendClientMessage(playerid, 0x059BD3AA, "-----------===[ LICENSES ]===-----------");
		format(YCMDstr, sizeof(YCMDstr), " Водительские права:  %s",(!User[playerid][pCarLic])?("Отсутствует") : ("Есть"));
		SendClientMessage(playerid, 0xC5EEFEAA, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), " Лицензия пилота:  %s",(!User[playerid][pFlyLic])?("Отсутствует") : ("Есть"));
		SendClientMessage(playerid, 0xC5EEFEAA, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), " Лицензия на катера:  %s",(!User[playerid][pBoatLic])?("Отсутствует") : ("Есть"));
		SendClientMessage(playerid, 0xC5EEFEAA, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), " Лицензия рыболова:  %s",(!User[playerid][pFishLic])?("Отсутствует") : ("Есть"));
		SendClientMessage(playerid, 0xC5EEFEAA, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), " Лицензия на оружие:  %s",(!User[playerid][pGunLic])?("Отсутствует") : ("Есть"));
		SendClientMessage(playerid, 0xC5EEFEAA, YCMDstr);
		SendClientMessage(playerid, 0x059BD3AA, "=============================");
		return SendClientMessage(playerid, COLOR_GREY, "Используйте: /licenses(/lic) [id]. Чтобы показать кому-то");
	}
	
    if(!IsPlayerConnected(params[0])) return true;
	if(GetPlayerState(params[0]) == PLAYER_STATE_SPECTATING) return SCM(playerid, COLOR_GRAD1, "Игрок слишком далеко!");
	if(params[0] == INVALID_PLAYER_ID) return SCM(playerid, COLOR_GREY, "Игрок не найден!");
	if(!ProxDetectorS(3.0, playerid, params[0])) return SCM(playerid, COLOR_GREY, "Игрок слишком далеко!");
	format(YCMDstr, sizeof(YCMDstr), "-----------===[ LICENSES %s ]===-----------", User[playerid][pName]);
	SendClientMessage(params[0], 0x059BD3AA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Водительские права:  %s",(!User[playerid][pCarLic])?("Отсутствует") : ("Есть"));
	SendClientMessage(params[0], 0xC5EEFEAA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Лицензия пилота:  %s",(!User[playerid][pFlyLic])?("Отсутствует") : ("Есть"));
	SendClientMessage(params[0], 0xC5EEFEAA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Лицензия на катера:  %s",(!User[playerid][pBoatLic])?("Отсутствует") : ("Есть"));
	SendClientMessage(params[0], 0xC5EEFEAA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Лицензия рыболова:  %s",(!User[playerid][pFishLic])?("Отсутствует") : ("Есть"));
	SendClientMessage(params[0], 0xC5EEFEAA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Лицензия на оружие:  %s",(!User[playerid][pGunLic])?("Отсутствует") : ("Есть"));
	SendClientMessage(params[0], 0xC5EEFEAA, YCMDstr);
	SendClientMessage(params[0], 0x059BD3AA, "=============================");
	format(YCMDstr,sizeof(YCMDstr), "%s показал свои лицензии %s'у",User[playerid][pName],User[params[0]][pName]);
	SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	format(YCMDstr,sizeof(YCMDstr), "показал свои лицензии %s'у",User[params[0]][pName]);
	SetPlayerChatBubble(playerid,YCMDstr,COLOR_PURPLE,30.0,10000);
	return true;
}
CMD:divorce(playerid, params[])
{
	SendClientMessage(playerid, COLOR_GREY, "Вы развелись");
	ClearMarriage(playerid);
	return true;
}
CMD:propose(playerid, params[])
{
    if(User[playerid][pCash] < 100000) return SendClientMessage(playerid, COLOR_GREY, "Вам нужно 100000$ на свадьбу!");
	if(strcmp(User[playerid][pMarriedTo],"-",true) != 0) return SendClientMessage(playerid, COLOR_GREY, "Вы уже женаты/замужем!");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /propose [id]");
	if(!IsPlayerConnected(params[0])) return true;
	if(strcmp(User[params[0]][pMarriedTo],"-",true) != 0) return SendClientMessage(playerid, COLOR_GREY, "Человек уже состоит в браке!");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Человек не рядом с вами!");
	if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы указали свой ID"); return true; }
	format(YCMDstr, sizeof(YCMDstr), "Вы предложили руку и сердце %s.",User[params[0]][pName]);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "%s предлагает вам руку и сердце. (( Введите: /accept marriage, чтобы принять )).",User[playerid][pName]);
	SendClientMessage(params[0], COLOR_BLUE, YCMDstr);
	ProposeOffer[params[0]] = playerid;
	return true;
}
CMD:ram(playerid, params[])
{
    if(IsACop(playerid)|| IsAArm(playerid) || User[playerid][pAdmin] >= 1)
	{
		for(new i = 1; i <= TotalHouse; i++)
		{
			if (PlayerToPoint(3, playerid,HouseInfo[i][hEntrancex], HouseInfo[i][hEntrancey], HouseInfo[i][hEntrancez]))
			{
				SetPlayerVirtualWorld(playerid, i+50);
				SetPlayerInterior(playerid,HouseInfo[i][hInt]);
				t_SetPlayerPos(playerid,HouseInfo[i][hExitx],HouseInfo[i][hExity],HouseInfo[i][hExitz]);
			}
		}
	}
	return true;
}
CMD:take(playerid, params[])
{
	if(!GetPVarInt(playerid, "Fraction_Duty") || (!IsACop(playerid) && User[playerid][pMember] != 10) && User[playerid][pAdmin] < 2) return SCM(playerid, COLOR_GREY, "Вы не можете использовать данную команду!");
	return ShowPlayerDialogEx(playerid, 7779, DIALOG_STYLE_LIST, "Изъять", "Водительские права\nЛицензия пилота \nЛицензия на лодки\nЛицензия на рыбаловство\nЛицензия на оружие\nМатериалы\nНаркотики\nОружие\nКлючи от камеры", "Готово", "Отмена");
}
CMD:suspect(playerid, params[])
{
	if(sscanf(params, "uds[32]", params[0],params[1],params[2])) return SCM(playerid, COLOR_GREY, "Используйте: (/su)spect [id] [уровень розыска] [преступление]");
	if (GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 1 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pLeader] == 1
	||GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 2 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pLeader] == 2
	|| GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 10 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pLeader] == 10
	|| GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] == 21 || GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pLeader] == 21)
	{
		if(!IsPlayerConnected(params[0])) return true;
		if(params[0] == INVALID_PLAYER_ID) return true;
		if(User[params[0]][pJailTime] != 0) return true;
		if(User[params[0]][pWantedLevel] >= 6) return SCM(playerid, COLOR_GREY, "У данного игрока уже 6 уровней розыска!");
		if(IsACop(params[0]) || IsAArm(params[0])) return SCM(playerid, COLOR_GREY, "Вы не можете давать розыск законникам!");
		User[params[0]][pWantedLevel] +=params[1];
		SetPlayerWantedLevel(params[0],User[params[0]][pWantedLevel]);
		SetPlayerCriminal(params[0],User[playerid][pName], params[2]);
		return true;
	}
	return true;
}
CMD:spawnchange(playerid)
{
    ShowPlayerDialogEx(playerid, 211, DIALOG_STYLE_LIST, "{F1C33A}Изменение места появления", "1. На базе организации / вокзале\n2. В собственном доме\n3. В доме семьи", "Выбрать", "Отмена");
	return true;
}
