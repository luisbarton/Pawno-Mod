CMD:f(playerid, params[])
{
	new string[170];
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата!");
	if(sscanf(params, "s[128]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/f)amily [текст]");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	if(GetPVarInt(playerid,"farm_rank") > 1)
	{
	    switch(GetPVarInt(playerid,"farm_rank"))
	    {
	        case 2: format(string, sizeof(string), "[FARM %i] Фермер %s: %s",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], params[0]);
	        case 3: format(string, sizeof(string), "[FARM %i] Заместитель %s: %s",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], params[0]);
	        case 4: format(string, sizeof(string), "[FARM %i] Владелец %s: %s",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], params[0]);
		}
		foreach(new i : Player)
 		{
			if(GetPVarInt(i,"farm_id") == GetPVarInt(playerid,"farm_id") && GetPVarInt(i,"farm_rank") > 1) SendClientMessage(i,TEAM_AZTECAS_COLOR,string);
		}
		return true;
	}
	if(GetPVarInt(playerid,"CasinoRank"))
	{
	    for(new i = 1; i <= TOTALCASINO; i++)
		{
			if(!PlayerToPoint(300,playerid, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2])) continue;
			switch(GetPVarInt(playerid,"CasinoRank"))
			{
			    case 1: format(string, sizeof(string), "[CASINO] Крупье %s: %s", User[playerid][pName], params[0]);
			    default: format(string, sizeof(string), "[CASINO] Менеджер %s: %s", User[playerid][pName], params[0]);
			}
		}
		for(new i = 1; i <= TOTALCASINO; i++)
		{
			foreach(new idx : Player)
			{
				if(!PlayerToPoint(300,idx, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2]) || !GetPVarInt(idx,"CasinoRank")) continue;
				if(GetCasino(idx, i) && GetCasino(playerid, idx) && GetPVarInt(idx,"CasinoRank")) SendClientMessage(idx,TEAM_AZTECAS_COLOR,string);
			}
		}
		return true;
	}
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
 	if(User[playerid][pMember] != 5 && User[playerid][pMember] != 6 && User[playerid][pMember] != 8 && User[playerid][pMember] != 9
	&& User[playerid][pMember] != 16 && User[playerid][pMember] != 20 && User[playerid][pMember] != 11 && User[playerid][pMember] != 12
	&& User[playerid][pMember] != 13 && User[playerid][pMember] != 15 && User[playerid][pMember] != 14 && User[playerid][pMember] != 17
	&& User[playerid][pMember] != 18 && User[playerid][pMember] != 24 && User[playerid][pMember] != 26 && User[playerid][pMember] != 29
	&& User[playerid][pMember] != 34 && User[playerid][pMember] != 35 && User[playerid][pMember] != 36) return SendClientMessage(playerid, COLOR_GREY, "Вы не член какой-либо фракции!");
	format(string, sizeof(string), "[F] %s %s: %s",GetRank(playerid), User[playerid][pName], params[0]);
	SendFamilyMessage(User[playerid][pMember], TEAM_AZTECAS_COLOR, string);
	return true;
}
CMD:r(playerid, params[])
{
	new str[128];
	new result[128];
	if(sscanf(params, "s[128]",result)) return	SendClientMessage(playerid, COLOR_GRAD2, "Введите: (/r)adio [текст]");
	if(User[playerid][pMuted] > 0) return   SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	if(User[playerid][pMember] != 1 && User[playerid][pMember] != 2 && User[playerid][pMember] != 3 && User[playerid][pMember] != 4 &&
	User[playerid][pMember] != 7 && User[playerid][pMember] != 10 && User[playerid][pMember] != 19 && User[playerid][pMember] != 21) return true;
	format(str, sizeof(str), "[R] %s %s: %s",GetRank(playerid), User[playerid][pName], result);
	if(User[playerid][pMember] != 4) SendFamilyMessage(User[playerid][pMember], TEAM_BLUE_COLOR, str);
	if(User[playerid][pMember] == 4) SendFamilyMedicMessage(User[playerid][pMember], User[playerid][pJobHeal], TEAM_BLUE_COLOR, str);
	return true;
}
CMD:fb(playerid, params[])
{
	new str[170];
	new result[128];
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У Вас бан чата!");
	if(sscanf(params, "s[128]",result)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /fb [текст]");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	if(GetPVarInt(playerid,"farm_rank") > 1)
	{
	    switch(GetPVarInt(playerid,"farm_rank"))
	    {
	        case 2: format(str, sizeof(str), "[FARM %i] Фермер %s: (( %s ))",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], result);
	        case 3: format(str, sizeof(str), "[FARM %i] Заместитель %s: (( %s ))",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], result);
	        case 4: format(str, sizeof(str), "[FARM %i] Владелец %s: (( %s ))",GetPVarInt(playerid,"farm_id")-1, User[playerid][pName], result);
		}
		foreach(new i : Player)
 		{
			if(GetPVarInt(i,"farm_id") == GetPVarInt(playerid,"farm_id")) SendClientMessage(i,TEAM_AZTECAS_COLOR,str);
		}
		return true;
	}
	if(GetPVarInt(playerid,"CasinoRank"))
	{
	    for(new i = 1; i <= TOTALCASINO; i++)
		{
			if(!PlayerToPoint(300,playerid, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2])) continue;
			switch(GetPVarInt(playerid,"CasinoRank"))
			{
			    case 1: format(str, sizeof(str), "[CASINO] Крупье %s: (( %s ))", User[playerid][pName], result);
			    default: format(str, sizeof(str), "[CASINO] Менеджер %s: (( %s ))", User[playerid][pName], result);
			}
		}
		for(new i = 1; i <= TOTALCASINO; i++)
		{
			foreach(new idx : Player)
			{
				if(!PlayerToPoint(300,idx, CasinoInfo[i][caPos][0],CasinoInfo[i][caPos][1], CasinoInfo[i][caPos][2]) || !GetPVarInt(idx,"CasinoRank")) continue;
				if(GetCasino(idx, i) && GetCasino(playerid, idx) && GetPVarInt(idx,"CasinoRank")) SendClientMessage(idx,TEAM_AZTECAS_COLOR,str);
			}
		}
		return true;
	}
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
 	if(User[playerid][pMember] != 5 && User[playerid][pMember] != 6 && User[playerid][pMember] != 8 && User[playerid][pMember] != 9
	&& User[playerid][pMember] != 16 && User[playerid][pMember] != 20 && User[playerid][pMember] != 11 && User[playerid][pMember] != 12
	&& User[playerid][pMember] != 13 && User[playerid][pMember] != 15 && User[playerid][pMember] != 14 && User[playerid][pMember] != 17
	&& User[playerid][pMember] != 18 && User[playerid][pMember] != 24 && User[playerid][pMember] != 26 && User[playerid][pMember] != 29) return SendClientMessage(playerid, COLOR_GRAD2, "Вы не член какой-либо фракции!");
	format(str, sizeof(str), "[F] %s %s: (( %s ))",GetRank(playerid), User[playerid][pName], result);
	SendFamilyMessage(User[playerid][pMember], TEAM_AZTECAS_COLOR, str);
	return true;
}
CMD:rb(playerid, params[])
{
	new str[128];
	new result[128];
	if(sscanf(params, "s[128]",result)) return	SendClientMessage(playerid, COLOR_GRAD2, "Введите: /rb [текст]");
	if(User[playerid][pMuted] > 0) return   SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	if(Flood[playerid] > 0)
	{
		SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
  		if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood");
  		SendClientMessage(playerid, 0xFFD5BBAA, "Не флуди!");
  		return true;
	}
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
	Flood[playerid] = 2;
	SetPVarInt(playerid,"Flood",0);
	if(User[playerid][pMember] != 1 && User[playerid][pMember] != 2 && User[playerid][pMember] != 3 && User[playerid][pMember] != 4 &&
	User[playerid][pMember] != 7 && User[playerid][pMember] != 10 && User[playerid][pMember] != 19 && User[playerid][pMember] != 21) return true;
	format(str, sizeof(str), "[R] %s %s: (( %s ))",GetRank(playerid), User[playerid][pName], result);
	if(User[playerid][pMember] != 4) SendFamilyMessage(User[playerid][pMember], TEAM_BLUE_COLOR, str);
	if(User[playerid][pMember] == 4) SendFamilyMedicMessage(User[playerid][pMember], User[playerid][pJobHeal], TEAM_BLUE_COLOR, str);
	return true;
}
CMD:departments(playerid, params[])
{
	new str[128];
	new result[128];
	if(sscanf(params, "s[128]",result)) return SendClientMessage(playerid, COLOR_GREY, "Используйте: (/d)epartments [текст]");
	if(User[playerid][pMuted] > 0)
	{
		format(str, sizeof(str), "У Вас бан чата! До снятия: %i секунд(ы)",User[playerid][pMuted]);
		SendClientMessage(playerid, COLOR_LIGHTRED, str);
		return true;
	}
	if(User[playerid][pRank] < 2) return SendClientMessage(playerid, COLOR_GREY, "Вы не уполномочены писать в департамент!");
	if(!GetPVarInt(playerid,"Fraction_Duty")) return true;
	if(GetSVarInt("d_timer") > gettime()) return SendClientMessage(playerid, COLOR_GREY, "Посылать объявление можно раз в 10 секунд!");
	SetSVarInt("d_timer", gettime() + 10);
	switch(User[playerid][pMember])
	{
		case 1: format(str, sizeof(str), "LSPD %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 2: format(str, sizeof(str), "ФБР %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 3: format(str, sizeof(str), "ВМФ %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 4, 22, 33: format(str, sizeof(str), "Medic %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 7: format(str, sizeof(str), "Mayor %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 10: format(str, sizeof(str), "SFPD %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 19: format(str, sizeof(str), "СВ %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 21: format(str, sizeof(str), "LVPD %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		case 11: format(str, sizeof(str), "Instructors %s %s: %s",GetRank(playerid), User[playerid][pName], result);
		default: return SendClientMessage(playerid,COLOR_GREY,"Вам недоступна данная функция");
	}
    SendTeamMessage(User[playerid][pMember], COLOR_ALLDEPT, str);
	return true;
}
new strR[255][255]; // Глобальный двумерный массив
CMD:sms(playerid, params[])
{
    if(User[playerid][pPayDayHad] < 1) return SCM(playerid, COLOR_GREY, "Вы должны отыграть 1 час!");
    if(User[playerid][pLevel] <= 2 && sms_timer[playerid] > 0) return SendClientMessage(playerid, COLOR_GREY, "Для игроков с уровнем ниже 3, работает лимит 1 смс в 30 секунд!");
	if(sscanf(params, "ds[64]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /sms [playerid / phonenumber] [текст]");
	if(User[playerid][pMuted] > 0) return SendClientMessage(playerid, COLOR_LIGHTRED, "У вас бан чата!");
	AntiReklama(playerid,params[1],"SMS");
	if(GetPVarInt(playerid, "antireklamka") == 1)
	{
	    SetPVarInt(playerid, "antireklamka", 0);
	    return true;
	}
	new is1=1;
	new r=0;
	new string[256];
	while(strlen(params[is1]))
	{
		if('0'<=params[is1]<='9')
		{
			new is2=is1+1;
			new p=0;
			while(p==0)
			{
				if('0'<=params[is2]<='9'&&strlen(params[is2])) is2++;
				else
				{
					strmid(strR[r],params,is1,is2,255);
					if(strval(strR[r])<255) r++;
					is1=is2;
					p=1;
					sms_timer[playerid] = 30;
				}
			}
		}
		is1++;
	}
	if(r>=4)
	{
		format(string, sizeof(string), "SMS: Login: %s[%i] %s",User[playerid][pName],playerid,params[1]);
		ABroadCast(COLOR_LIGHTRED, string, 1);
		return 1;
	}
	if(Rekl[playerid] == 1 && strfind(params[1],"www",true)!=-1 || Rekl[playerid] == 1 && strfind(params[1],".ru",true)!=-1
			|| Rekl[playerid] == 1 && strfind(params[1],".net",true)!=-1 || Rekl[playerid] == 1 && strfind(params[1],".com",true)!=-1
			|| Rekl[playerid] == 1 && strfind(params[1],"http",true)!=-1)
	{
		format(string, sizeof(string), "SMS: Login: %s[%i] %s",User[playerid][pName],playerid,params[1]);
		ABroadCast(COLOR_LIGHTRED, string, 1);
		format(string,sizeof(string),"Вы получили бан чата на 3 часа. /mm - репорт");
		SendClientMessage(playerid, COLOR_LIGHTRED, string);
		User[playerid][pMuted] = 10800000;
		return 1;
	}
	GetPlayerPos(playerid,CallInfo[playerid][callx],CallInfo[playerid][cally],CallInfo[playerid][callz]);
	CallInfo[playerid][callused] = 1;
	switch (params[0])
	{
	case 11888:
		{
			if(smsls == 0) return SendClientMessage(playerid, COLOR_GREY, "Приём SMS отключен");
			format(string, sizeof(string), "[Эфир] %s. Отправитель: %s[%i]",params[1],User[playerid][pName], playerid);
			SendFamilyMessage(16, COLOR_YELLOW, string);
			format(string, sizeof(string), "SMS: %s. Получатель: LS NEWS",params[1]);
			SendClientMessage(playerid,  COLOR_YELLOW, string);
			User[playerid][pMobile] += smspricels;
			FracBank[0][fLsnews] += smspricels;
		}
	case 11555:
		{
			if(smssf == 0) return SendClientMessage(playerid, COLOR_GREY, "Приём SMS отключен");
			format(string, sizeof(string), "[Эфир] %s. Отправитель: %s[%i]",params[1],User[playerid][pName], playerid);
			SendFamilyMessage(9, COLOR_YELLOW, string);
			format(string, sizeof(string), "SMS: %s. Получатель: SF NEWS",params[1]);
			SendClientMessage(playerid,  COLOR_YELLOW, string);
			User[playerid][pMobile] += smspricesf;
			FracBank[0][fSfnews] += smspricesf;
		}
	case 11333:
		{
			if(smslv == 0) return SendClientMessage(playerid, COLOR_GREY, "Приём SMS отключен");
			format(string, sizeof(string), "[Эфир] %s. Отправитель: %s[%i]",params[1],User[playerid][pName], playerid);
			SendFamilyMessage(20, COLOR_YELLOW, string);
			format(string, sizeof(string), "SMS: %s. Получатель: SF NEWS",params[1]);
			SendClientMessage(playerid,  COLOR_YELLOW, string);
			User[playerid][pMobile] += smspricelv;
			FracBank[0][fLvnews] += smspricelv;
		}
	}
	foreach(new i : Player)
	{
		if(IsPlayerConnected(params[0]))
		{
			if(PhoneOnline[params[0]] > 0)
			{
				SendClientMessage(playerid, COLOR_GREY, "Телефон абонента выключен.");
				format(string, sizeof(string), "%s достает телефон",User[playerid][pName]);
				SendBeside(playerid,COLOR_PURPLE,string,5.0);
				return true;
			}
			format(string, sizeof(string), "SMS: %s. Отправитель: %s[%i]",params[1],User[playerid][pName], playerid);
			SendClientMessage(params[0], COLOR_YELLOW, string);
			PlayerPlaySound(params[0], 1052, 0.0, 0.0, 0.0);
			PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
			format(string, sizeof(string), "%s достает мобильник",User[playerid][pName]);
			SendBeside(playerid,COLOR_PURPLE,string,5.0);
			format(string, sizeof(string), "SMS: %s. Получатель: %s[%i]",params[1],User[params[0]][pName],params[0]);
			SendClientMessage(playerid,  COLOR_YELLOW, string);
			SendClientMessage(playerid,  COLOR_WHITE, "Сообщение доставлено");
			User[playerid][pMobile] += 2;
			return true;
		}
		else if(params[0] == User[i][pPnumber])
		{
			if(PhoneOnline[i] > 0)
			{
				SendClientMessage(playerid, COLOR_GREY, "Телефон абонента выключен.");
				format(string, sizeof(string), "%s достает телефон",User[playerid][pName]);
				SendBeside(playerid,COLOR_PURPLE,string,5.0);
				return true;
			}
			User[playerid][pMobile] +=20;
			format(string, sizeof(string), "SMS: %s. Отправитель: %s[%i]",params[1],User[playerid][pName], playerid);
			SendClientMessage(i, 0xFDE640AA, string);
			PlayerPlaySound(i, 1052, 0.0, 0.0, 0.0);
			PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
			format(string, sizeof(string), "SMS: %s. Получатель: %s[%i]",params[1],User[i][pName], i);
			SendClientMessage(playerid,  0xFDE640AA, string);
			SendClientMessage(playerid,  COLOR_WHITE, "- Сообщение доставлено");
			format(string, sizeof(string), "%s достает мобильник",User[playerid][pName]);
			SendBeside(playerid,COLOR_PURPLE,string,5.0);
			return true;
		}
	}
	return true;
}
CMD:pm(playerid, params[])
{
    if(User[playerid][pAdmin] == 0 && User[playerid][pHelper] == 0 || User[playerid][pHelper] == 2) return SendClientMessage(playerid, COLOR_GREY, "Вам недоступна эта функция");
    if(!GetPVarInt(playerid, "Dostup") && User[playerid][pHelper] == 0) return true;
    if(sscanf(params, "us[64]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /pm [ид] [текст]");
    if(!IsPlayerConnected(params[0])) return true;
    new string[256];
    if(User[playerid][pAdmin] >=1)
    {
        format(string, sizeof(string), "Ответ от %s[%d]: {FFFFFF}%s",User[playerid][pName],playerid,params[1]);
        SendClientMessage(params[0], 0xD97700AA, string);
        format(string, sizeof(string), "<- Ответ к %s[%d]: {FFFFFF}%s {D97700}(от: %s)", User[params[0]][pName], params[0], params[1], User[playerid][pName]);
        SendAdminMessage(0xD97700FF,string);
        AdminInfo[playerid][admAnsed]++;
        YCMDstr[0] = EOS;
		format(YCMDstr, 150, "UPDATE admin SET ansed = %i WHERE admid = %i LIMIT 1", AdminInfo[playerid][admAnsed], AdminInfo[playerid][admID]);
		mysql_tquery(dbHandle, YCMDstr, "", "");
    }
    else if(User[playerid][pHelper] >=1 || GetPVarInt(playerid, "SDuty"))
    {
        format(string, sizeof(string), "Ответ от помощника %s[%d]: {FFFFFF}%s",User[playerid][pName],playerid,params[1]);
        SendClientMessage(params[0], 0xD97700AA, string);
        format(string, sizeof(string), "<-%s[%d] to %s[%d]: {FFFFFF}%s",User[playerid][pName],playerid, User[params[0]][pName],params[0],params[1]);
        SendAdminMessage(0xFF8000AA,string);
        HelperMessage(0xFF8000AA,string);
    }
    return true;
}
CMD:sduty(playerid, params[])
{
    if(User[playerid][pHelper] != 1 && (User[playerid][pAdmin] < 2 || !GetPVarInt(playerid, "Dostup"))) return SendClientMessage(playerid,COLOR_GREY, "Вы не саппорт");
    if(!GetPVarInt(playerid, "SDuty")) SetPVarInt(playerid, "SDuty", 1), SendClientMessage(playerid,-1,"Рабочий день начат");
    else DeletePVar(playerid, "SDuty"), SendClientMessage(playerid,-1,"Рабочий день окончен");
	return 1;
}
CMD:yes(playerid, params[])
{
    if(fmcall[playerid] == true)
    if(User[playerid][pMember] == 16 || User[playerid][pMember] == 9 || User[playerid][pMember] == 20)
	{
		if(sscanf(params, "u",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /yes [id]");
		if(!IsPlayerConnected(params[0])) return true;
		if(zvonok[params[0]] !=1) return SendClientMessage(playerid, COLOR_GREY, "Этот человек не звонил в студию!");
  		new model = GetVehicleModel(GetPlayerVehicleID(playerid));
		if(model != 582 && model != 488 &&  !PlayerToPoint(30.0,playerid,2648.8855,1224.7946,41.0859) && !PlayerToPoint(30.0,playerid,-2052.6719,473.1645,191.0859) && !PlayerToPoint(30.0,playerid,1656.0978,-1623.1172,101.0859)) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в репортёрской машине / вертолёте / офисе!");
		format(YCMDstr, sizeof(YCMDstr), "Вы приняли звонок от %s",User[params[0]][pName]);
		SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
		Tel[params[0]] = 1;
		SendClientMessage(params[0], COLOR_YELLOW, "Вы попали в студию, говорите.");
		if(User[playerid][pMember] == 9)
		{
			TalkingLive[params[0]] = 1;
			User[params[0]][pMobile] += smspricesf;
			FracBank[0][fSfnews] += smspricesf;
		}
		if(User[playerid][pMember] == 16)
		{
			TalkingLivels[params[0]] = 1;
			User[params[0]][pMobile] += smspricesf;
			FracBank[0][fLsnews] += smspricesf;
		}
		if(User[playerid][pMember] == 20)
		{
			TalkingLivelv[params[0]] = 1;
			User[params[0]][pMobile] += smspricesf;
			FracBank[0][fLvnews] += smspricesf;
		}
	}
	return true;
}
CMD:off(playerid, params[])
