CMD:kvartira(playerid, params[])
{
    if(User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
    new Float:x, Float:y, Float:z;
    GetPlayerPos(playerid, x, y, z);
    if(GetPVarInt(playerid, "podeezd") <= 0) return SendClientMessage(playerid,COLOR_GREY,"Создать квартиру можно только в подъезде");
    format(YCMDstr, sizeof(YCMDstr), "INSERT INTO `kvart` (`pXpic`) VALUES ('%f')",x);
	mysql_query(dbHandle, YCMDstr);
    ALLKVARTIRI ++;
    kvartinfo[ALLKVARTIRI][pXpic] = x;
    kvartinfo[ALLKVARTIRI][kid] = ALLKVARTIRI;
    kvartinfo[ALLKVARTIRI][pYpic] = y;
    kvartinfo[ALLKVARTIRI][pZpic] = z;
    strmid(kvartinfo[ALLKVARTIRI][vladelec], "None", 0, 5, 5);
    kvartinfo[ALLKVARTIRI][lock] = 0;
    kvartinfo[ALLKVARTIRI][kworld] = GetPlayerVirtualWorld(playerid);
    kvartinfo[ALLKVARTIRI][virtmir] = GetPVarInt(playerid, "podeezd");
    new string[100];
    f(string,"{0076FC}Комната #%i\nПродается: 50000 вирт\nЧтобы войти, нажмите клавишу 'ENTER'",ALLKVARTIRI);
    kvartinfo[ALLKVARTIRI][dtext] = CreateDynamic3DTextLabel(string,0x0076FCFF,x,y,z+1,3.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,GetPlayerVirtualWorld(playerid));
	CreateDynamic3DTextLabel("Чтобы выйти, нажмите клавишу 'Enter'\nКупить/продать, нажмите клавишу 'ALT'",0x0076FCFF,-89.0304,1408.2255,1269.7360,5.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,GetPlayerVirtualWorld(playerid));
    return true;
}
CMD:podcrt(playerid, params[])
{
	new Float:X,Float:Y,Float:Z,Float:Angle;
	if(User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
	if(global[playerid] == 1)
	{
		GetVehiclePos(GetPlayerVehicleID(playerid), X,Y,Z);
     	GetVehicleZAngle(GetPlayerVehicleID(playerid), Angle);
      	DestroyVehicle(GetPlayerVehicleID(playerid));
       	PodeezdInfo[AllPODEZD][carX]        =    X;
        PodeezdInfo[AllPODEZD][carY]        =    Y;
        PodeezdInfo[AllPODEZD][carZ]       =   Z;
        PodeezdInfo[AllPODEZD][carC]       =   Angle;
        global[playerid] = 2;
        SendClientMessage(playerid,COLOR_WHITE,"Встаньте к месту входа подъезжа и введите /podcreate");
        return true;
	}
 	return true;
}
CMD:podcreate(playerid, params[])
{
	new Float:X,Float:Y,Float:Z;
 	if(User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
  	if(global[playerid] == 2)
   	{
    	global[playerid] = 0;
     	GetPlayerPos(playerid, X,Y,Z);
      	PodeezdInfo[AllPODEZD][podPicX]        =    X;
       	PodeezdInfo[AllPODEZD][podPicY]        =    Y;
        PodeezdInfo[AllPODEZD][podPicZ]        =    Z;
        PodeezdInfo[AllPODEZD][podPic]            =    CreateDynamicPickup(19132, 1, X, Y, Z);
        for(new b = 1; b <= PodeezdInfo[AllPODEZD][podEtazi]; b++)
        {
            ALLPODEZD++;
       		PodeezdInfo[AllPODEZD][podMir][b]   =   ALLPODEZD;
   		}
   		format(YCMDstr, 123,"Многоквартирный дом\nНомер подъезда: %i",AllPODEZD);
     	CreateDynamic3DTextLabel(YCMDstr,0x0076FCFF,PodeezdInfo[AllPODEZD][podPicX],PodeezdInfo[AllPODEZD][podPicY],PodeezdInfo[AllPODEZD][podPicZ]+1,5.0);
        return SendClientMessage(playerid, COLOR_WHITE, "Вы успешно создали подъезд!");
    }
 	return true;
}
CMD:tload(playerid, params[])
{
	new str[156];
	if(User[playerid][pJob] != 99)return SendClientMessage(playerid,COLOR_GREY, "Вы не Дальнобойщик");
	new maxguz = User[playerid][pDMgruz];
	if(!IsPlayerConnected(playerid)) return true;
	if(Gruz[playerid] != 0) return true;
	if(GetVehicleTrailer(GetPlayerVehicleID(playerid))) return true;
	if(!IsPlayerInAnyVehicle(playerid)) return true;
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /tload [количество]");
	if(params[0] <= 0) return SCM(playerid, COLOR_GREY, "Количество тонн не может быть равным 0!");
	if(IsPlayerInRangeOfPoint(playerid, 10.0, 256.4736,1414.5182,10.7075))
	{
		if(GetPVarInt(playerid, "togran") > gettime()) return SendClientMessage(playerid,COLOR_GREY,"Извините, мы вас немного задержим, нужно подготовить груз");
		if(params[0] > maxguz)
		{
			format(str, sizeof(str), "Слишком много товара,ваш максимум: %i т.",maxguz);
			SendClientMessage(playerid,COLOR_GREY,str);
			return true;
		}
		if(User[playerid][pCash] < params[0]*Benzbuy[0]) return SendClientMessage(playerid, 0x6495EDFF, "У вас нет столько денег!");
		User[playerid][pCash] -= params[0]*Benzbuy[0];
		User[playerid][pDgruz] += params[0];
		format(str, sizeof(str), "{00D26D}Загружено %i т.груза на сумму %i вирт", params[0],Benzbuy[0]*params[0]);
		SendClientMessage(playerid, 0x66FBA6FF, str);
		CreateVehicleAC(584, 249.1628,1420.7445,11.1698,269.4982,1,1, -1);
		DriverJob[playerid] = true;
		Gruz[playerid] = 1;
		bGruz[playerid] = 1;
		if(Benzbuy[0] != 900) Benzbuy[0] += 100;
		Benzbuy[1] -= 100;
		if(Benzbuy[0] == 900) {
			Benzbuy[1] = 200; }
		format(str, sizeof(str), "Нефтезавод №1\nЦена за тонну: %d",Benzbuy[0]);
		UpdateDynamic3DTextLabelText(GasZavod[0],0xFFFF00FF,str);
		format(str, sizeof(str), "Нефтезавод №2\nЦена за тонну: %d",Benzbuy[1]);
		UpdateDynamic3DTextLabelText(GasZavod[1],0xFFFF00FF,str);
		SetPVarInt(playerid, "togran", gettime()+180);
		return true;
	}
	else if(IsPlayerInRangeOfPoint(playerid, 10.0,-1046.7723,-670.7208,32.3516))
	{
		if(GetPVarInt(playerid, "togran") > gettime()) return SendClientMessage(playerid,COLOR_GREY,"Извините, мы вас немного задержим, нужно подготовить груз");
		if(params[0] > maxguz)
