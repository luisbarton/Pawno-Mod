CMD:ftazer(playerid, params[])
{
    if((User[playerid][pMember] != 2 && User[playerid][pLeader] != 2) || !GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(sscanf(params, "d",params[0])) return SendClientMessage(playerid,COLOR_WHITE,"Введите: /ftazer [1/2/3]");
	if(params[0] == 1)
	{
		format(YCMDstr, sizeof(YCMDstr), "Агент FBI %s оглушил всех",User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE,YCMDstr,20.0);
		foreach(new i : Player)
		{
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid,X,Y,Z);
			if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
			{
				TogglePlayerControllable(i,0);
				SendClientMessage(i,-1,"Вы заморожены на 10 секунд");
				SetPlayerSpecialAction(i,SPECIAL_ACTION_HANDSUP);
				SetTimerEx("UnFreeze", 10000, 0, "i", i);
			}
		}
	}
	else if(params[0] == 2)
	{
		format(YCMDstr, sizeof(YCMDstr), "Агент FBI %s оглушил всех рядомстоящих законников",User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, YCMDstr, 20.0);
		foreach(new i : Player)
		{
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid,X,Y,Z);
			if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
			{
				if(User[i][pMember] == 1 || User[i][pLeader] == 1 ||User[i][pMember] == 2 || User[i][pLeader] == 2 ||User[i][pMember] == 3 || User[i][pLeader] == 3)
				{
					TogglePlayerControllable(i,0);
					SendClientMessage(i,-1,"Вы заморожены на 10 секунд");
					SetPlayerSpecialAction(i,SPECIAL_ACTION_HANDSUP);
					SetTimerEx("UnFreeze", 10000, 0, "i", i);
				}
			}
		}
	}
	else if(params[0] == 3)
	{
		format(YCMDstr, sizeof(YCMDstr), "Агент FBI %s оглушил всех рядомстоящих жителей", User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, YCMDstr, 20.0);
		foreach(new i : Player)
		{
			new Float:X,Float:Y,Float:Z;
			GetPlayerPos(playerid,X,Y,Z);
			if(IsPlayerInRangeOfPoint(i,20,X,Y,Z) && i != playerid)
			{
				TogglePlayerControllable(i,0);
				SendClientMessage(i,-1,"Вы заморожены на 10 секунд");
				SetPlayerSpecialAction(i,SPECIAL_ACTION_HANDSUP);
				SetTimerEx("UnFreeze", 10000, 0, "i", i);
			}
		}
	}
	else return SendClientMessage(playerid,COLOR_GREY, "Неверное число");
	return true;
}
CMD:tazer(playerid, params[])
{
	if(!GetPVarInt(playerid, "Fraction_Duty")) return true;
	if(IsACop(playerid))
	{
	    if(NewTazer[playerid] == false)
	    {
			NewTazer[playerid] = true;
			SCM(playerid,COLOR_BLUE,"Вы поменяли пули на резиновые");
			//SCM(playerid,COLOR_BLUE,"Для быстрой смены пуль, зажмите клавишу ПРОБЕЛ");
		}
		else
		{
			NewTazer[playerid] = false;
			SCM(playerid,COLOR_BLUE,"Вы поменяли пули на обычные");
			//SCM(playerid,COLOR_BLUE,"Для быстрой смены пуль, зажмите клавишу ПРОБЕЛ");
		}
	}
	return true;
}
CMD:itazer(playerid, params[])
{
    if(User[playerid][pMember] == 11 && User[playerid][pRank] >= 1)
	{
		if(IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, COLOR_GREY, "Невозможно использовать в машине");
		new suspect = GetClosestforeach(playerid);
		if(GetPVarInt(suspect, "PlayerCuffed") > 0) return SendClientMessage(playerid, COLOR_GREY, "Игрок уже в наручниках!");
		if(GetDistanceBetweenPlayers(playerid,suspect) < 5)
		{
			if(IsACop(suspect)) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете ударить тазером законника");
			if(IsPlayerInAnyVehicle(suspect)) return SendClientMessage(playerid, COLOR_GREY, "Человек в машине!");
			format(YCMDstr, sizeof(YCMDstr), "Вас обездвижил электрошокером %s на 15 секунд",User[playerid][pName]);
			SendClientMessage(suspect, 0x6495EDFF, YCMDstr);
			format(YCMDstr, sizeof(YCMDstr), "Вы обездвижили электрошокером %s на 15 секунд",Name(suspect));
			SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
			format(YCMDstr, sizeof(YCMDstr), "Инуструктор %s обезвредил %s", User[playerid][pName] ,Name(suspect));
			SendBeside(playerid, COLOR_PURPLE, YCMDstr, 30.0);
			TogglePlayerControllable(suspect, 0);
			SetPlayerSpecialAction(suspect,SPECIAL_ACTION_HANDSUP);
			SetPVarInt(suspect, "PlayerCuffed", 1);
			SetPVarInt(suspect, "PlayerCuffedTime", 15);
		}
	}
	return true;
}
