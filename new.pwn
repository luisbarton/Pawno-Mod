	User[i][pMats], User[i][pSex], User[i][pArrested], User[i][pMuted], User[i][pCrimes], User[i][pExp], User[i][pCash], User[i][pWantedDeaths], User[i][pPayCheck], User[i][pJailTime],
	User[i][pDrugs], User[i][pLeader], User[i][pMember], User[i][pName]);
	mysql_tquery(dbHandle, t_query, "", "");

