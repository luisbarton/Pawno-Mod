			SetPlayerVirtualWorld(playerid, 0);
			return true;
		}
		t_SetPlayerPos(playerid, 1154.3717, -1769.2594, 16.5938);
		SetPlayerFacingAngle(playerid, 0.6853);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}
    else if(User[playerid][pLevel] == 2)
	{
		t_SetPlayerPos(playerid, 2232.1931,-1159.4896,25.8906);
		SetPlayerFacingAngle(playerid, 90.0967);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}
    else if(User[playerid][pLevel] >= 3 && User[playerid][pLevel] <= 5)
	{
		t_SetPlayerPos(playerid, -1967.2679,115.1929,27.6875);
		SetPlayerFacingAngle(playerid, 1.3365);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}*/
	if(strcmp(name, "Mirox_Escalade", true) == 0) return SetPlayerPos(playerid, 152.8685,1391.0281,925.0579); SetPlayerFacingAngle(playerid, 1.6093);
    if(User[playerid][pLevel] >= 1 && User[playerid][pLevel] <= 5)
	{
		new rand = random(4);
	    switch (rand)
		{
			case 0:
				{
					t_SetPlayerPos(playerid, 1754.1161,-1920.7211,13.5720);
					SetPlayerFacingAngle(playerid,332.2654);
				}
			case 1:
				{
					t_SetPlayerPos(playerid, 1756.5861,-1894.0916,13.5564);
					SetPlayerFacingAngle(playerid,272.0973);
				}
			case 2:
				{
					t_SetPlayerPos(playerid, 2231.7122,-1160.2023,25.8906);
					SetPlayerFacingAngle(playerid,47.6974);
				}
			case 3:
				{
					t_SetPlayerPos(playerid, 1109.0959,-1796.6702,16.5939);
					SetPlayerFacingAngle(playerid, 88.8172);
				}
		}
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}
	else if(User[playerid][pLevel] >= 5 && User[playerid][pLevel] <= 9)
	{
		t_SetPlayerPos(playerid, -1969.7723,159.9579,27.6875);
		SetPlayerFacingAngle(playerid, 180.6095);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}
	else if(User[playerid][pLevel] >= 10)
	{
		t_SetPlayerPos(playerid, 2852.9612,1290.3457,11.3906);
		SetPlayerFacingAngle(playerid, 86.5236);
		SetPlayerInterior(playerid,0);
		SetPlayerVirtualWorld(playerid, 0);
	}
	return true;
}
