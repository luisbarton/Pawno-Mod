						{
							CountOnZone[User[killerid][pMember]] ++;
		 					foreach(new idx : Player)
			 				{
		    					if(User[idx][pMember] == GZInfoSF[i][gNapad] || User[idx][pMember] == GZInfoSF[i][gFrakVlad]) SendDeathMessageToPlayer(idx, killerid, playerid, reason); }
							SetPlayerToTeamColor(killerid);
							SetPlayerToTeamColor(playerid);
							break;
						}
					}
				}
			}
		}
	}*/
	if(killerid != INVALID_PLAYER_ID)
    {
		if(ZoneTimer > 0 && mafia_frac_id[0] != 0 && mafia_frac_id[1] != 0)
		{
		    if(User[killerid][pMember] == mafia_frac_id[1] && User[playerid][pMember] == mafia_frac_id[0] ||
		    User[killerid][pMember] == mafia_frac_id[0] && User[playerid][pMember] == mafia_frac_id[1])
		    {
			    if(User[killerid][pMember] != User[playerid][pMember])
			    {
			        static const Float: coor_zone[3][4] = {
						{228.0, 2464.0, 370.0, 2539.0},
						{324.6, 833.3, 393.8, 983.9},
						{-789.8281,2015.9144, -662.7654,2083.9297}
					};
					new z_ = ZoneID-1;
					if(z_ < 0 || z_ > 2) return 1;
					if(IsPlayerToSquare(killerid,coor_zone[z_][0], coor_zone[z_][1],coor_zone[z_][2],coor_zone[z_][3]) || IsPlayerToSquare(playerid,coor_zone[z_][0], coor_zone[z_][1],coor_zone[z_][2],coor_zone[z_][3]))
					{
				        if(User[killerid][pMember] == mafia_frac_id[0]) kills_mafia[0]++;
						if(User[killerid][pMember] == mafia_frac_id[1]) kills_mafia[1]++;
						foreach(new idx: Player)//PlayerTeam[mafia_frac_id[0]],idx)
			 			{
			 			    /*format(cmdstr,MAX_STR,"%s: %d",GetMafiaName2(mafia_frac_id[0]),kills_mafia[0]);
							PlayerTextDrawSetString(idx,Capture[idx][5],cmdstr);
							format(cmdstr,MAX_STR,"%s: %d",GetMafiaName2(mafia_frac_id[1]),kills_mafia[1]);
							PlayerTextDrawSetString(idx,Capture[idx][6],cmdstr);*/
			 			    if(User[idx][pMember] == mafia_frac_id[0]) SendDeathMessageToPlayer(idx, killerid, playerid, reason);
			 			    else if(User[idx][pMember] == mafia_frac_id[1]) SendDeathMessageToPlayer(idx, killerid, playerid, reason);
					 	}
					 	/*foreach(PlayerTeam[mafia_frac_id[1]],idx)
					 	{
							SendDeathMessageToPlayer(idx, killerid, playerid, reason);
					 	}*/
						//new str_kills[62];
					    //format(str_kills,sizeof(str_kills),"~y~kills~n~~n~~g~%s:~w~ %d~n~~n~~r~%s:~w~ %d",GetMafiaName2(mafia_frac_id[0]),kills_mafia[0],GetMafiaName2(mafia_frac_id[1]),kills_mafia[1]);
					//	TextDrawSetString(CaptureMafia[2],str_kills);

					}
		 		}
	 		}
		}
	}
	if(IsAGang(killerid) && killerid != INVALID_PLAYER_ID)
	{
		if(User[playerid][pMember] == 3 && GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] != 0 || User[playerid][pLeader] == 3 && GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] != 0 || User[playerid][pMember] == 19 && GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] != 0 || User[playerid][pLeader] == 19 && GetPVarInt(playerid,"Fraction_Duty") && User[playerid][pMember] != 0)
		{
			for(new i = 1; i <= TOTALGZ; i++)
			{
				if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
				{
					if(User[playerid][pMember] == 3 && !GetPVarInt(killerid, "Forma"))
					{
					    if(GetPlayerSkin(playerid) == 252 || User[playerid][pModel] == 252) { }
			    		else
			    		{
							SetPVarInt(killerid, "Forma", 1);
							User[playerid][pModel] = 252;
							SendClientMessage(playerid,  COLOR_YELLOW, "Вы потеряли армейскую форму");
							SendClientMessage(killerid,  COLOR_YELLOW, "Вы cняли с армейца форму, введите /switchskin, чтобы переодеться");
							User[killerid][pZakonp] -= 2;
						}
					}
					if(User[playerid][pMember] == 19 && !GetPVarInt(killerid, "Forma"))
					{
					    if(GetPlayerSkin(playerid) == 252 || User[playerid][pModel] == 252) { }
			    		else
			    		{
							SetPVarInt(killerid, "Forma", 1);
							User[playerid][pModel] = 252;
							SendClientMessage(playerid,  COLOR_YELLOW, "Вы потеряли армейскую форму");
							SendClientMessage(killerid,  COLOR_YELLOW2, "Вы cняли с армейца форму, введите /switchskin, чтобы переодеться");
							User[killerid][pZakonp] -= 2;
						}
					}
				}
			}
		}
	}
	if(IsAGang(killerid) && killerid != INVALID_PLAYER_ID)
	{
		if(IsACop(playerid) && GetPVarInt(playerid,"Fraction_Duty") && User[killerid][pKeys] != 5)
		{
			if(User[playerid][pMember] != 2 || User[playerid][pLeader] != 2)
			{
				for(new i = 1; i <= TOTALGZ; i++)
				{
					if(PlayerToKvadrat(playerid,GZInfo[i][gCoords][0], GZInfo[i][gCoords][1],GZInfo[i][gCoords][2],GZInfo[i][gCoords][3]))
					{
					    if(User[playerid][pKeys] > 0)
					    {
					        User[playerid][pKeys]--;
							User[killerid][pKeys]++;
							SendClientMessage(playerid,  COLOR_YELLOW, "Вы потеряли ключи от камеры!");
							SendClientMessage(killerid,  COLOR_YELLOW, "Вы забрали у полицейского ключи от камеры!");
							User[killerid][pZakonp] -= 2;
						}
					}
				}
			}
		}
	}
	if(gPlayerCheckpointStatus[playerid] > 4 && gPlayerCheckpointStatus[playerid] < 11)
	{
		DisablePlayerCheckpoint(playerid);
		gPlayerCheckpointStatus[playerid] = 0;
	}
	if(killerid != INVALID_PLAYER_ID && GetPlayerState(killerid) == 2)
	{
		SendClientMessage(killerid, COLOR_LIGHTRED, "Убийство с водительского места запрещено!");
		User[killerid][pWantedLevel] += 1;
		SetPlayerWantedLevel(killerid,User[playerid][pWantedLevel]);
		SetPlayerCriminal(killerid,"Неизвестный", "Убийство с транспорта");
		new query[120];
		f(query, " <Warning> %s[%i]: Убил транспортом %s[%d]", User[killerid][pName], killerid, User[playerid][pName], playerid);
		ABroadCast(COLOR_REDD,query,2);
	}
	else if(killerid != INVALID_PLAYER_ID && GetPlayerState(killerid) != 2 && !IsACop(killerid) && !IsAArm(killerid) && !IsAMafia(killerid) && !IsAGang(killerid) && !IsAMayor(killerid) && !GetPVarInt(playerid, "player_paint"))
	{
		User[killerid][pWantedLevel] += 3;
		SetPlayerWantedLevel(killerid,User[playerid][pWantedLevel]);
		SetPlayerCriminal(killerid,"Неизвестный", "Убийство");
	}
	if(GetPVarInt(playerid, "is_boat") - 1 != 0)
	{
		DestroyVehicle(GetPVarInt(playerid, "is_boat") - 1);
		DeletePVar(playerid, "is_boat");
	}
	foreach(new i:Player)
	{
		if(User[i][pAdmin] >= 1)
		{
			SendDeathMessageToPlayer(i,killerid, playerid, reason);
		}
	}
	//SetPVarInt(playerid, "IsADeath", 1);
	//SetTimerEx("Death_timer", 3000, false, "i", playerid);
	DisablePlayerCheckpoint(playerid);
	return true;
}
public OnPlayerSpawn(playerid)
{
    if(!User[playerid][pLogin] && GetPVarInt(playerid,"Register") == 0) return SendClientMessage(playerid, COLOR_WHITE, "Необходимо авторизоваться!"), KickEx(playerid, "Spawn on unlogged state");
    if(GetPVarInt(playerid,"BoneStol") && GetPVarInt(playerid,"CasinoRank")) ExitBone(playerid);
    if(GetPVarInt(playerid,"Register") == 1) DeletePVar(playerid,"Register");
	DeletePVar(playerid,"CasinoRank");
	ResetPlayerWeaponsEx(playerid);
	DeletePVar(playerid,"K_Times");
	SetPVarInt(playerid, "AntiBreik", 2);
	TeleportTime[playerid] = 4;
	SetPVarInt(playerid, "GunCheckTime", 2);
	//Killed[playerid] = false;
	ResetPlayerWeaponsEx(playerid);
	SetPlayerHealthAC(playerid,100);
	if(robscdtimer[playerid] != -1)
	{
		KillTimer(robscdtimer[playerid]);
		robscdtimer[playerid] = -1;
	}
	RobInts[playerid] = -1;
	RobTickRTC[playerid] = 0;
	if(User[playerid][pSex] > 0 && User[playerid][pTut] == 0) return ChosePlayerSkin(playerid);
	if(!GetPVarInt(playerid, "player_paint")) LoadTextures(playerid);
	switch(User[playerid][pMember]) { case 5,6,14,13,12,15,17,18,34,35,36: SetPVarInt(playerid,"Fraction_Duty",1); }
	if(User[playerid][pMember] > 0) SetPlayerSkin(playerid, User[playerid][pModel]);
	if(User[playerid][pMember] <= 0) SetPlayerSkin(playerid, User[playerid][pChar][0]);
	SetPlayerSkills(playerid);
	if(Spectate[playerid])
    {
		Spectate[playerid] = 0;
		t_SetPlayerPos(playerid,SpecPlayer[playerid][0],SpecPlayer[playerid][1],SpecPlayer[playerid][2]);
		SetPlayerInterior(playerid,SpecPlayerInt[playerid]);
		SetPlayerVirtualWorld(playerid,SpecPlayerWorld[playerid]);
		SetPlayerFacingAngle(playerid, SpecPlayerAngle[playerid]);
		PlayerPlaySound(playerid, 1145, 0.0, 0.0, 0.0);
		SetPlayerHealth(playerid, 255.0);
 	 	for(new i; i < 35; i++) PlayerTextDrawHide(playerid, ReconPlayer[i]);
		return 1;
    }
	SetPlayerSpawn(playerid);
	/*for(new idx = 0; idx < 10; idx++)
	{
		if(User[playerid][pWeapon][idx] && !vidachagun[idx][playerid])
		{
			GiveWeapon(playerid, User[playerid][pWeapon][idx], User[playerid][pAmmo][idx]);
			vidachagun[idx][playerid] = 1;
		}
	}*/
	
	ResetPlayerWeaponsEx(playerid);
	
    for (new a = 0; a < 12; a++)
	{
		GiveWeapon(playerid, User[playerid][kLibWeapon][kLibWeaponid][a], User[playerid][kLibWeapon][kLibAmmo][a]);
		User[playerid][kLibWeapon][kLibWeaponid][a] = 0;
		User[playerid][kLibWeapon][kLibAmmo][a] = 0;
	}
	User[playerid][acDied] = false;
	if(User[playerid][pFamilyText] == Text3D:INVALID_3DTEXT_ID) // есть ли фама у игрока
	{
	    if(User[playerid][pFamilyMember] > 0)
	    {
			format(YCMDstr,sizeof(YCMDstr),"{%s}%s", family_chat_color[FamilyInfo[User[playerid][pFamilyMember]][famChatColor]], FamilyInfo[User[playerid][pFamilyMember]][famName]);//??? ???
			User[playerid][pFamilyText] = CreateDynamic3DTextLabel(YCMDstr, -1, 0.0, 0.0, 0.4, 6.0,  playerid, INVALID_VEHICLE_ID, 1 );
		}
	}
	if(GetPVarInt(playerid, "Milosti"))
    {
		DestroyDynamicObject(User[playerid][pBeg][2]);
    	DestroyDynamicObject(User[playerid][pBeg][2]+1);

    	User[playerid][pBeg][1] = 0;
    	ApplyAnimation(playerid, !"CARRY", !"crry_prtial", 4.0, 0, 0, 0, 0, 0);
	    DeletePVar(playerid, "Milosti"), SCM(playerid, COLOR_RED, "Вы закончили просить милостыню");
		//TogglePlayerControllable(playerid, 1);
	}
	dinamicashs[playerid] = CreateDynamicCP(-2026.6854,-114.3436,1035.1719,1.5, 1, 3, playerid,5.0);
	PreloadAllAnimLibs(playerid);
	if(User[playerid][pBeg][0] == -1 && User[playerid][pLevel] < 6
        && User[playerid][pCash] < 20000 && !User[playerid][pMember])
    {
        User[playerid][pBeg][0] = 0;
        SendClientMessage(playerid, -1, !"{DFCFCF}»> До 6-го уровня{DCD45C} Вы можете просить милостыню на улице.");
		SendClientMessage(playerid, -1, !"{DCD45C}Используйте команду {DFCFCF}/alms{DCD45C}, чтобы поставить табличку и тарелку для сбора денег.");
	}
	return true;
}
public OnPlayerEnterCheckpoint(playerid)
{
    //SCMF(playerid,COLOR_BLUE,"ENTERCHECKPOINT - %d",playerid);
    //SCMF(playerid,COLOR_BLUE,"FARM STATUS 1 - %d",GetPVarInt(playerid,"farm_status"));
    DeletePVar(playerid,"checkpoint");
	new tmpcar = GetPlayerVehicleID(playerid);
    //if(GetPVarInt(playerid,"FloodPickUpPickup") > gettime()) return 1;
	//SetPVarInt(playerid,"FloodPickUpPickup",gettime()+2);
	///
	/*if(GetPVarInt(playerid,"farm_status") == 1)
	{
		switch(booston)
		{
		case 0:ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0), Farmtimer[playerid] = SetTimerEx("FarmDuty", 15000, false, "d", playerid);
		case 1:ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0), Farmtimer[playerid] = SetTimerEx("FarmDuty", 4950, false, "d", playerid);
		}
	}*/
	if(booston == true)
	{
	    if(GetPVarInt(playerid,"farm_status") == 1)
		{
		    //SCMF(playerid,COLOR_BLUE,"FARM STATUS 2 - %d",GetPVarInt(playerid,"farm_status"));
			ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0);
			Farmtimer[playerid] = SetTimerEx("FarmDuty", 4950, false, "d", playerid);
			SetPVarInt(playerid,"farm_status",4);
			return 1;
		}
	}
	else
	{
		if(GetPVarInt(playerid,"farm_status") == 1)
		{
			ApplyAnimation(playerid,"BOMBER","BOM_Plant",4.0,1,1,1,1,0);
			Farmtimer[playerid] = SetTimerEx("FarmDuty", 15000, false, "d", playerid);
			SetPVarInt(playerid,"farm_status",4);
			return 1;
		}
	}
	if(GetPVarInt(playerid,"installation") == 2 && IsPlayerInRangeOfPoint(playerid, 10.0, 1067.3966,2128.3901,10.5110) && GetPVarInt(playerid,"Workshop") > 0)
	{
	    switch(GetPVarInt(GetPVarInt(playerid,"installation_"),"detals"))
	    {
	        case 99: CarInfo[GetPVarInt(playerid,"installation_")][carPercent][GetPVarInt(GetPVarInt(playerid,"installation_"),"SelectCar")] = 100;
			case 100:
			{
		 		CarInfo[GetPVarInt(playerid,"installation_")][carColor_one][GetPVarInt(GetPVarInt(playerid,"installation_"),"SelectCar")] = GetPVarInt(GetPVarInt(playerid,"installation_"),"color0");
		 		CarInfo[GetPVarInt(playerid,"installation_")][carColor_two][GetPVarInt(GetPVarInt(playerid,"installation_"),"SelectCar")] = GetPVarInt(GetPVarInt(playerid,"installation_"),"color1");
		 		DeletePVar(GetPVarInt(playerid,"installation_"),"color0");
	        	DeletePVar(GetPVarInt(playerid,"installation_"),"color1");
			}
		}
		ApplyAnimation(playerid,"GANGS","hndshkba",4.1,0,1,1,0,1,1);
		SendClientMessage(playerid,COLOR_GREEN,"Деталь установлена");
		SendClientMessage(GetPVarInt(playerid,"installation_"),COLOR_GREEN,"Механик установил деталь");// "installation"
		WorkshopInfo[GetPVarInt(playerid,"Workshop")][wProds]-=GetPVarInt(GetPVarInt(playerid,"installation_"),"prods");
		WorkshopInfo[GetPVarInt(playerid,"Workshop")][wBank]+=(GetPVarInt(GetPVarInt(playerid,"installation_"),"cost")/80);
		User[GetPVarInt(playerid,"installation_")][pBank]-=GetPVarInt(GetPVarInt(playerid,"installation_"),"cost");
		SetPVarInt(playerid,"Workshop_",GetPVarInt(playerid,"Workshop_")+((GetPVarInt(GetPVarInt(playerid,"installation_"),"cost")/1000)*WorkshopInfo[GetPVarInt(playerid,"Workshop")][wZp]));
		DeletePVar(GetPVarInt(playerid,"installation_"),"cost");
		DeletePVar(GetPVarInt(playerid,"installation_"),"prods");
		DeletePVar(GetPVarInt(playerid,"installation_"),"detals");
		DeletePVar(GetPVarInt(playerid,"installation_"),"number");
		DeletePVar(GetPVarInt(playerid,"installation_"),"color0");
		DeletePVar(GetPVarInt(playerid,"installation_"),"color1");
		DeletePVar(playerid,"installation");
		//SaveTuning(GetPVarInt(playerid,"installation_"),house_car[GetPVarInt(playerid,"installation_")]);
		//SaveTuning(GetPVarInt(playerid,"installation_"),CarInfo[GetPVarInt(playerid,"installation_")][carColor_two][GetPVarInt(GetPVarInt(playerid,"installation_"), "chosencar")]);
		return DisablePlayerCheckpoint(playerid);
	}
	if(GetPVarInt(playerid,"w_time") > gettime() && GetPVarInt(playerid,"w_id"))
	{
	    if(GetVehicleModel(house_car[playerid]) == 0) return SendClientMessage(playerid,COLOR_GREY,"У вас нет автомобиля!");
		if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER || GetPlayerVehicleID(playerid) != house_car[playerid]) return SendClientMessage(playerid,COLOR_GREY,"Вы должны находиться за рулем автомобиля!");
		new null = -1;
  		foreach(new i : Player)
		{
			if(!IsPlayerInAnyVehicle(i) || GetPlayerVehicleID(i) != GetPlayerVehicleID(playerid) || GetPVarInt(i,"Workshop") != GetPVarInt(playerid,"w_id") || i == playerid) continue;
			null = i;
		}
		if(null == -1) return SendClientMessage(playerid,COLOR_GREY,"Механик должен находиться с вами в авто!");
		SetPVarInt(playerid,"InWorkshop",GetPVarInt(playerid,"w_id"));
		DeletePVar(playerid,"w_time");
		SetPVarInt(null,"installation_",playerid);
		SetPVarInt(playerid,"mechanic",null);
		SetPlayerVirtualWorld(playerid,GetPVarInt(playerid,"w_id"));
		SetPlayerVirtualWorld(null,GetPVarInt(playerid,"w_id"));
		SetVehicleVirtualWorld(GetPlayerVehicleID(playerid),GetPVarInt(playerid,"w_id"));
		t_SetVehiclePos(GetPlayerVehicleID(playerid),1067.3966,2128.3901,10.5110);
		SetVehicleZAngle(GetPlayerVehicleID(playerid),271.2212);
		SendClientMessage(null,COLOR_YELLOW,"Используйте /tupdate");
		return DisablePlayerCheckpoint(playerid);
	}
	if(PicCP[playerid]==3)
    {
        ShowPlayerDialogEx(playerid, 7925, 2, "Доступное оружие", "Desert Eagle\t[$500]\nSilenced 9mm\t[$300]\nCountry Rifle\t[$750]\nShotgun\t[$500]\nSMG\t\t[$250]\nAK47\t\t[$500]\nM4\t\t[$500]\nTear Gas\t[$1000]\n\n\nGolf Club\t[$1200]\nBaseboll Bat\t[$1000]\nShovel\t\t[$1200]\nPool Cue\t[$1300]\nKatana\t\t[$2500]\nPurle Dildo\t[$1500]\nFlowers\t[$3000]\nCane\t\t[$1300]\nParachute\t[$1000]", "Далее", "Закрыть");
        return 1;
	}
	if(GetPVarInt(playerid, "RabotaOn") == 1)
	{
		if(avtocar[playerid] != GetPlayerVehicleID(playerid)) return SendClientMessage(playerid,COLOR_BLUE,"Это не та машина, которую мы заказывали!");
		new Float:hp;
		GetVehicleHealth(tmpcar,hp);
		if(hp < 700) return SendClientMessage(playerid,COLOR_BLUE,"Нам не нужен металлолом!");
		if(IsANope(tmpcar))
		{
			SendClientMessage(playerid,COLOR_BLUE,"[SMS]: Отличная работа. Приходи ещё.");
			User[playerid][pCash] +=500;
			GameTextForPlayer(playerid,"~b~+$500", 3000, 1);
			timecar[playerid] = 0;
			//if(User[playerid][pSkilla] < 1000 && booston == false) User[playerid][pSkilla]++;
			//else if(User[playerid][pSkilla] < 1000 && booston == true) User[playerid][pSkilla]+=3;
			if(User[playerid][pDonateRank]) User[playerid][pSkilla] += 3;
			else User[playerid][pSkilla]++;
		}
		else if(IsAB(tmpcar))
		{
			SendClientMessage(playerid,COLOR_BLUE,"[SMS]: Отличная работа. Приходи ещё.");
			User[playerid][pCash] +=3000;
			GameTextForPlayer(playerid,"~b~+$3000", 3000, 1);
			timecar[playerid] = 0;
			//if(User[playerid][pSkilla] < 1000 && booston == false) User[playerid][pSkilla]+=2;
			//else if(User[playerid][pSkilla] < 1000 && booston == true) User[playerid][pSkilla]+=6;
			if(User[playerid][pDonateRank]) User[playerid][pSkilla] += 6;
			else User[playerid][pSkilla]+=2;
		}
		else if(IsAA(tmpcar))
		{
			SendClientMessage(playerid,COLOR_BLUE,"[SMS]: Отличная работа. Приходи ещё.");
			User[playerid][pCash] +=7000;
			GameTextForPlayer(playerid,"~b~+$7000", 3000, 1);
			timecar[playerid] = 0;
			//if(User[playerid][pSkilla] < 1000 && booston == false) User[playerid][pSkilla]+=3;
			//else if(User[playerid][pSkilla] < 1000 && booston == true) User[playerid][pSkilla]+=9;
			if(User[playerid][pDonateRank]) User[playerid][pSkilla] += 9;
			else User[playerid][pSkilla]+=3;
		}
		if(IsPlayerConnected(Vehicleforeach(tmpcar)) && caroff[tmpcar] == 0) SetVehicleToRespawn(tmpcar);
		else if(caroff[tmpcar] == 1) caroff[tmpcar] = 0, DestroyVehicle(tmpcar);
		DeletePVar(playerid, "RabotaOn");
		avtocar[playerid] = 0;
		DisablePlayerCheckpoint(playerid);
	}
	if(GetPVarInt(playerid, "Patrul"))
	{
		SCM(playerid, -1, "Вы достигли места назначения!");
		DisablePlayerCheckpoint(playerid);
		return DeletePVar(playerid, "Patrul");
	}
	if(VertMats[playerid]==1)
	{
	    if(vertmatbi >= 30000)
		{
			SendClientMessage(playerid, COLOR_GREY, "Вертолёт загружен");
			SendClientMessage(playerid, COLOR_WHITE, "Отвезите материалы на зону 51");
			VertMats[playerid]=2;
			DisablePlayerCheckpoint(playerid);
			SetPlayerCheckpoint(playerid,334.5107,1994.6956,17.6406,10);
			return true;
		}
