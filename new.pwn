stock WriteLog(const file[],string[])
{
 	new write[256],minute,second,hour,day,month,year;
 	gettime(hour,minute,second);
 	getdate(year,month,day);
 	if(strlen(file)>0)format(write, sizeof(write), "[Logs]/%s",file); else format(write, sizeof(write), "[Logs]/%04.d-%02.d-%02.d.log",year,month,day);
 	new File:hFile = fopen(write, io_append);
 	format(write, sizeof(write), "[%d.%02d.%02d | %02d:%02d:%02d] %s\r\n",day,month,year,hour,minute,second,string);
 	for(new i; i < strlen(write); i ++) fputchar(hFile, write[i], false);
 	fclose(hFile);
}
stock SetHostName(const name[])
{
	new string[100];
	format(string,sizeof(string),"hostname %s",name);
	return SendRconCommand(string);
}
stock IsTextInvalid(text[])
{
	if(strfind(text, "'", true) != -1) return true;
	if(strfind(text, "%", true) != -1) return true;
	if(strfind(text, "&", true) != -1) return true;
	if(strfind(text, "*", true) != -1) return true;
	if(strfind(text, "(", true) != -1) return true;
	if(strfind(text, ")", true) != -1) return true;
	//if(strfind(text, "\", true) != -1) return true;
	return false;
}
publics: Kicking(playerid)
{
    SCM(playerid, COLOR_YELLOW, " Новый пароль и IP Key высланы на E-Mail");
	KickEx(playerid, "New pass send email");
	return 1;
}
UpdatePlayerData(playerid, fields[], data)
{
	new str [144];
	mysql_format(dbHandle,str, 144, "UPDATE `accounts` SET `%s` = '%d' WHERE `pID` = '%d' LIMIT 1",fields, data, PlayerIDs[playerid]);
	mysql_query(dbHandle, str);
	return true;
}
forward StatsBizz(playerid);
public StatsBizz(playerid)
{
    print("шаг 1");
    new rows;
 	cache_get_row_count(rows);

    if(!rows) return SendClientMessage(playerid, -1, "Статистика доходов еще не составлена.");

	if(rows > 20)
	{
	    new shuutuup[264];
		new b = GetPVarInt(playerid, "CheckStatsBizz");
		mysql_format(dbHandle, shuutuup, sizeof(shuutuup), "SELECT * FROM `bizz_stats` WHERE `bID` = '%d' LIMIT %d,%d", b, rows-20, rows);
		mysql_tquery(dbHandle, shuutuup, "StatsBizzDop", "dd", playerid);
		return 1;
	}

	new stringers[320];
	new bDate[16], strg[124], bSumma;

	strcat(stringers, "{AFAFAF}Дата\t\t\t\tДоход\n\n");
	for(new i; i < rows; i++)
	{
		cache_get_value_name(i, "bData", bDate, 16);
		cache_get_value_name_int(i, "bSumma", bSumma);

		format(strg,sizeof(strg),"{FFFFFF}%s\t\t\t%d$\n",bDate,bSumma), strcat(stringers,strg);
	}
	ShowPlayerDialogEx(playerid,0,DIALOG_STYLE_MSGBOX,"{F1C33A}Доход бизнеса за 20 дней", stringers, "Закрыть","");
	return 1;
}
stock MysqlUpdateFamStr(idx, field[], data[])
{
	new mysql_update_string[128];
	format(mysql_update_string, 128, "UPDATE "T_FAMILY" SET %s = '%s' WHERE id = %d LIMIT 1", field, data, idx);
	mysql_tquery(dbHandle, mysql_update_string, "", "");
	return 1;
}

stock MysqlUpdateFamInt(idx, field[], data)
{
	new mysql_update_string[128];
	format(mysql_update_string, 128, "UPDATE "T_FAMILY" SET %s = %d WHERE id = %d LIMIT 1", field, data, idx);
