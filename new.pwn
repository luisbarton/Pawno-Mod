	if(ReconnectTime[2] < 15)
	{
 		f(YCMDstr, " Повторный вход на сервер возможен не раньше чем через %d секунд!", 15-ReconnectTime[2]);
		SCM(playerid, COLOR_LIGHTRED,YCMDstr);
   		return Kick(playerid);
	}*/
	//SCM(playerid, COLOR_RED,"Внимание! Мы объединились с 1 сервером. {FFFFFF}IP: 176.32.39.167:7777");
	//SCM(playerid, COLOR_RED,"Чтобы восстановить аккаунт, войдите под вашим ником на {FFFFFF}1 сервер!");
	//SCM(playerid, COLOR_YELLOW,"Команда для восстановления - {FFFFFF}/olduser (вводите пароль от аккаунта на 2 сервере)");
	//if(ReconnectTime[0]) DeleteSVar(ip);
	//
	SpecAd[playerid] = 65535;
	SpecID[playerid] = 65535;
	TimeNumberShot[playerid] = 0;
	TimeNumberShotTarget[playerid] = 0;
	Spectate[playerid] = 0;
	LastReconClick[playerid][0] = 0;
	LastReconClick[playerid][1] = 0;
	ReconSelect[playerid] = INVALID_TEXT_DRAW;
	ReconSelectSub[playerid] = INVALID_TEXT_DRAW;
	//
	SetPlayerArmourAC(playerid, 0);
	SetPlayerColor(playerid, TEAM_HIT_COLOR);
	User[playerid][SalonCar] = INVALID_VEHICLE_ID;
	User[playerid][SalonTime] = 0;
	SetPVarInt(playerid,"SelectAvto",-1);
    SpeedoGo(playerid);
	return true;
}
