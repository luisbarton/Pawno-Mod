			if(User[playerid][pDrugs]+ammo > 151) { SendClientMessage(playerid, COLOR_GREY, "Нельзя купить больше"); return true; }
			if(ammo > 151 || ammo < 1) { SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 150!"); return true; }
			if(User[playerid][pCash] < ammo) { SendClientMessage(playerid, COLOR_GREY, "У вас нет столько денег!"); return true; }
			User[playerid][pCash] -= ammo*20;
			User[playerid][pDrugs] += ammo;
			format(str, sizeof(str), "Вы купили %i грамм наркотиков за %i вирт (У вас есть %i грамм)", ammo, ammo*20, User[playerid][pDrugs]);
			SendClientMessage(playerid, 0x6495EDFF, str);
		}
		else
		{
			SendClientMessage(playerid, COLOR_GRAD1, "Вы не в притоне!");
			return true;
		}
