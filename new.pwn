CMD:offban(playerid, params[])
{
	if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
	new strlen_params;
	strlen_params = strlen(params);
	if(strlen_params < 1 || strlen_params > MAX_PLAYER_NAME+60) return SCM(playerid, -1, " Введите: /offban [name] [reason]");
	new ban_name[24],ban_reason[60];
	if(sscanf(params, "s[24]s[60]",ban_name,ban_reason)) return SCM(playerid, -1, " Введите: /offban [name] [reason]");
	//if(!CanBan(ban_name)) return SCM(playerid, COLOR_GREY, " Его нельзя");
	new year1, month1, day1, hour1, minute1, second1;
	getdate(year1, month1, day1);
	gettime(hour1, minute1, second1);
	format(YCMDstr, sizeof(YCMDstr), " OffBan[забанил: %s][забанен: %s][Причина: %s][%i/%02i/%02i  %02i:%02i:%02i]",Name(playerid),ban_name,ban_reason,year1,month1,day1,hour1, minute1,second1);
	ABroadCast(COLOR_LIGHTRED,YCMDstr,1);
	mysql_format(dbHandle,QUERY, 300, "INSERT INTO `ban` (`Text`, `Name`, `NameAdmin`, `Date`, `Unban`) VALUES ('OffBan: %s', '%s', '%s', '%i', '%i')",ban_reason,ban_name,Name(playerid),gettime(), mktime(5,0,0,30,month1,year1));
	mysql_tquery(dbHandle,QUERY,"","");
	AdminInfo[playerid][admOffBaned]++;
	YCMDstr[0] = EOS;
	format(YCMDstr, 200, "UPDATE admin SET offbaned=%i WHERE admid=%i LIMIT 1", AdminInfo[playerid][admOffBaned], AdminInfo[playerid][admID]);
	mysql_tquery(dbHandle, YCMDstr, "", "");
	printf("Администратор %s забанил в оффлайн-режиме %s. Причина: %s", User[playerid][pName], ban_name, ban_reason);
	return true;
}
CMD:unban(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "s[128]",params[0])) return SendClientMessage(playerid, COLOR_GRAD1, "Введите: /unban [name]");
	mysql_format(dbHandle,QUERY,128, "DELETE FROM `ban` WHERE `Name` = '%e'",params[0]);
    mysql_tquery(dbHandle,QUERY,"","");
	format(YCMDstr, sizeof(YCMDstr), "Admin: %s unbanned: %s",User[playerid][pName],params[0]);
	ABroadCast(COLOR_YELLOW,YCMDstr,1);
	return true;
}
CMD:offuninvite(playerid, params[])
{
	if(User[playerid][pLogin] == 0) return true;
	if(sscanf(params, "s[64]",params[0])) return SCM(playerid, COLOR_GREY, "Используйте: /offuninvite [name]");
	if(User[playerid][pAdmin] < 5 || GetPVarInt(playerid, "Dostup"))
	{
	    if(User[playerid][pLeader] == 0) return SCM(playerid, COLOR_GRAD1, "Вам недоступна эта функция!");
	    format(YCMDstr, sizeof(YCMDstr), "SELECT * FROM `accounts` WHERE Name = '%s'",params[0]);
		mysql_tquery(dbHandle,YCMDstr,"OnMySQL_QUERY","iis",39,playerid,params[0]);
		return 1;
	}
	else
	{
	    mysql_format(dbHandle,QUERY, 256, "UPDATE accounts SET pLeader = '0',pMember = '0',pRank = '0',pText = '5',pJobHeal = '0' WHERE name = '%s'",params[0]);
		mysql_tquery(dbHandle,QUERY,"","");
		format(YCMDstr, sizeof(YCMDstr), "Admin: %s offUninvite: %s",Name(playerid),params[0]);
		ABroadCast(COLOR_YELLOW,YCMDstr,1);
	}
	return true;
}
