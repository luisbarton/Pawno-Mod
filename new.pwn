CMD:buyinterior(playerid, params[])
{
	if(!HGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "У вас нет дома");
	new bouse = GetPVarInt(playerid,"House");
	if((PlayerToPoint(30, playerid,HouseInfo[bouse][hExitx],HouseInfo[bouse][hExity],HouseInfo[bouse][hExitz]) && GetPlayerVirtualWorld(playerid) == bouse+50) || GetPVarInt(playerid, "BuyInt") != 0)
	{
		if(HouseInfo[GetPVarInt(playerid,"House")][hKlass] == 0) ShowPlayerDialogEx(playerid, 195, DIALOG_STYLE_LIST, "Список интерьеров", "N-I\nN-II\nN-III\nN-IV\nN-V\nN-VI", "Осмотреть", "Отмена");
		if(HouseInfo[GetPVarInt(playerid,"House")][hKlass] == 1) ShowPlayerDialogEx(playerid, 20, DIALOG_STYLE_LIST, "Список интерьеров", "D-I\nD-II\nD-III\nD-IV\nD-V\nD-VI\nD-VII", "Осмотреть", "Отмена");
		if(HouseInfo[GetPVarInt(playerid,"House")][hKlass] == 2) ShowPlayerDialogEx(playerid, 185, DIALOG_STYLE_LIST, "Список интерьеров", "C-I\nC-II\nC-III\nC-IV\nC-V\nC-VI\nC-VII\nC-VIII\nC-IX", "Осмотреть", "Отмена");
