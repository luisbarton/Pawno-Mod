CMD:stexts(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "us[64]",params[0],params[1])) return SendClientMessage(playerid, -1, " Введите: /stexts [id] [Текст]");
    if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, -1, "Игрок не в игре!");
    if(playerid == params[0]) return true;
    OnPlayerText(params[0],params[1]);
    return true;
}
CMD:bank(playerid, params[])
{

    if(!IsABank(playerid)) return SendClientMessage(playerid,COLOR_GREY, "Вы не в банке");
	if(sscanf(params, "d", params[0]))
	{
		SendClientMessage(playerid, COLOR_GREY, "Используйте: /bank [Сумма]");
		new string[80];
		f(string, "На вашем счету: %i вирт",User[playerid][pBank]);
		return SCM(playerid, COLOR_WHITE, string);
	}
	if(User[playerid][pCash] < params[0]) { SendClientMessage(playerid, COLOR_GREY, "У Вас нет столько денег!"); return true; }
	if(params[0] > 100000000 || params[0] < 1) { SendClientMessage(playerid, COLOR_GREY, "Неправильное количество денег!"); return true; }
	SendClientMessage(playerid, COLOR_GRAD1, "---------===[ ЧЕК ]===---------");
	format(YCMDstr, sizeof(YCMDstr), "Старый баланс: %i вирт", User[playerid][pBank]);
	SendClientMessage(playerid, COLOR_GREY, YCMDstr);
	User[playerid][pCash] -= params[0];
	User[playerid][pBank] += params[0];
	format(YCMDstr, sizeof(YCMDstr), "Переведено: %i вирт", params[0]);
	SendClientMessage(playerid, COLOR_GRAD4, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Новый баланс: %i вирт", User[playerid][pBank]);
	SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	return true;
}
CMD:whonear(playerid, params[])
{
	new str[60];
    if(User[playerid][pAdmin] < 1 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "fdd", params[0], params[1], params[2]) || params[2] > 1 || params[2] < 0) return SendClientMessage(playerid, -1, "Введите: /whonear [радиус в метрах] [лвл] [0 - равно и меньше, 1 - равно и больше]");
    new Float: POS[3];
    GetPlayerPos(playerid, POS[0], POS[1], POS[2]);
    for(new i; i<MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i) || !IsPlayerInRangeOfPoint(playerid, params[0], POS[0], POS[1], POS[2])) continue;
        if(params[2] == 0 && User[i][pLevel] > params[1]) continue;
        if(params[2] == 1 && User[i][pLevel] < params[1]) continue;
        format(str, sizeof(str), "%s [ID: %i]", User[i][pName], i);
        SendClientMessage(playerid, -1, str);
    }
    return 1;
}
