CMD:refill(playerid, params[])
{
	if(User[playerid][pJob] != 2) return SCM(playerid, COLOR_GREY, "Вы не работаете механиком");
	if(gcontract[playerid] != 1) return SCM(playerid, COLOR_GREY, "У вас не подписан контракт с заправкой!");
	if(sscanf(params, "ud", params[0])) return SCM(playerid, -1, " Введите: /refill [playerid]");
	if(!IsPlayerConnected(params[0])) return true;
	if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 525) return SCM(playerid, COLOR_GREY, "Вы не в рабочем транспорте");
	if(!ProxDetectorS(8.0, playerid, params[0]) || !IsPlayerInAnyVehicle(params[0])) return true;
	if(params[0] == playerid) return SCM(playerid, COLOR_GREY, " [Ошибка]: {AFAFAF}Вы указали свой ID");
	format(YCMDstr, sizeof(YCMDstr), " Вы предложили %s заправить его машину за %i вирт.",Name(params[0]),cenabenza[playerid]);
	SCM(playerid, 0x6495EDFF, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), " Механик %s хочет заправить ваш автомобиль за %i вирт, (( /accept refill ))",Name(playerid),cenabenza[playerid]);
	SCM(params[0], 0x6495EDFF, YCMDstr);
	SetPVarInt(playerid,"RefillOffer",params[0]);
	RefillOffer[params[0]] = playerid;
	RefillPrice[params[0]] = cenabenza[playerid];
	return true;
}
CMD:changehouse(playerid, params[])
{
    if(!HGet(playerid)) return SendClientMessage(playerid, COLOR_GREY, "У Вас нет дома!");
    new bouse = GetPVarInt(playerid,"House");
	if(sscanf(params, "ud", params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /changehouse [id] [цена]");
	if(params[1] < 1 || params[0] > 100000000) return SendClientMessage(playerid, COLOR_GREY, "Не менее 1 и не более 100000000 вирт!");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок должен находиться рядом с Вами!");
	if(GetPVarInt(playerid,"changehouse")) return SendClientMessage(playerid,COLOR_GREY, "Вы уже предложили кому то купить Ваш дом!");
	if(GetPVarInt(params[0],"_changehouse")) return SendClientMessage(playerid,COLOR_GREY, "Этому игроку уже предложили купить дом!");
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете продать дом самому себе!");
	if((!PlayerToPoint(10, playerid,HouseInfo[bouse][hExitx], HouseInfo[bouse][hExity], HouseInfo[bouse][hExitz]) || GetPlayerVirtualWorld(playerid) != bouse+50) && !PlayerToPoint(2.0, playerid, HouseInfo[bouse][hEntrancex], HouseInfo[bouse][hEntrancey], HouseInfo[bouse][hEntrancez])) return SendClientMessage(playerid,COLOR_GREY,"Вы должны находиться возле, или внутри вашего дома");
	new str[256];
	if(HGet(params[0]))
	{
	    f(str, "Вы предложили %s обменяться домами. Доплата: [%i вирт]",User[params[0]][pName], params[1]);
	    SCM(playerid, 0x6495EDFF, str);
	    f(str, "%s предлагает вам обменяться домами. Ваша доплата: [%i вирт]",User[playerid][pName], params[1]);
	    SCM(params[0], 0x6495EDFF, str);
	}
	else
	{
		f(str, "Вы предложили %s купить ваш дом. Стоимость: [%i вирт]",User[params[0]][pName], params[1]);
		SCM(playerid, 0x6495EDFF, str);
		f(str, "%s предлагает вам купить его дом. Стоимость: [%i вирт]",User[playerid][pName], params[1]);
		SCM(params[0], 0x6495EDFF, str);
	}
	SendClientMessage(playerid,0x6495EDFF,"(( Введите /(ac)cept house для подтверждения сделки! ))");
	format(YCMDstr, sizeof(YCMDstr), "%s предложил(а) обменяться домами %s.",User[playerid][pName] ,User[params[0]][pName]);
	SendBeside(playerid, COLOR_PURPLE, YCMDstr, 30.0);
	SetPVarInt(playerid,"changehouse",params[0]+1);
	SetPVarInt(playerid,"changehouse_price",params[1]);
	SetPVarInt(params[0],"_changehouse",playerid+1);
	DeletePVar(params[0],"changehouse_h");
	return true;
}
CMD:changecar(playerid, params[])
{
    if(User[playerid][pLogin] == 0) return true;
	if(KGet(playerid) && GetVehicleModel(house_car[playerid]) == 462 || house_car[playerid] == -1) return SendClientMessage(playerid, COLOR_GREY, "Вы не владеете транспортом!");
	if(sscanf(params, "ud", params[0], params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /changecar [id игрока] [доплата]");
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете обменять транспорт себе!");
	if(User[playerid][pPayDayHad] < 5) return SendClientMessage(playerid, COLOR_WHITE, "Необходимо отыграть 5 часов");
	if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid,COLOR_GREY,"Игрок должен находиться рядом с вами");
	if(!HGet(params[0]) && !KGet(params[0])) return SendClientMessage(playerid, COLOR_GREY, "У игрока нет дома");
	if(KGet(params[0]) && GetVehicleModel(house_car[params[0]]) == 462 || house_car[params[0]] == -1) return SendClientMessage(playerid, COLOR_GREY, "Игрок не владеет транспортом!");
	if(params[1] < 0 || params[1] > 10000000) return SendClientMessage(playerid, COLOR_GREY, "Кол-во доплаты от 1 до 10000000!");
	if(GetPVarInt(playerid,"changecar")) return SendClientMessage(playerid,COLOR_GREY,"Вы уже предложили кому то купить ваш автомобиль!");
	if(GetPVarInt(params[0],"_changecar")) return SendClientMessage(playerid,COLOR_GREY,"Этому игроку уже предложили купить автомобиль!");
	SCMF(playerid,0x6495EDFF,"Вы предложили %s обменяться транспортом. Доплата: [%i вирт]",User[params[0]][pName], params[1]);
	SCMF(params[0],0x6495EDFF,"%s предлагает вам обменяться транспортом. Ваша доплата: [%i вирт]",User[playerid][pName], params[1]);
	SendClientMessage(playerid,0x6495EDFF,"(( Введите /(ac)cept car для подтверждения сделки! ))");
	format(YCMDstr, sizeof(YCMDstr), "%s предложил(а) обменяться транспортом %s.",Name(playerid) ,Name(params[0]));
	SendBeside(playerid, COLOR_PURPLE, YCMDstr, 30.0);
	SetPVarInt(playerid,"changecar",params[0]+1);
	SetPVarInt(playerid,"changecar_price",params[1]);
	SetPVarInt(params[0],"_changecar",playerid+1);
	return 1;
}
CMD:repair(playerid, params[])
{
    if(User[playerid][pJob] != 2) return SendClientMessage(playerid, COLOR_GREY, "Вы не работаете механиком");
	if(sscanf(params, "ud", params[0],params[1])) return	SendClientMessage(playerid, COLOR_GRAD2, "Введите: /repair [id] [цена]");
	if(params[1] < 1 || params[1] > 10000) return SendClientMessage(playerid, COLOR_GREY, "Нельзя меньше 1, и больше 10000 вирт");
	if(!IsPlayerConnected(params[0])) return true;
	if(GetVehicleModel(GetPlayerVehicleID(playerid)) != 525) return SendClientMessage(playerid, COLOR_GREY, "Вы не на эвакуаторе!");
    if(GetPlayerState(params[0]) != 2) return SCM(playerid, COLOR_GREY, "Игрок не находиться в автомобиле за рулем!");
	if(!ProxDetectorS(8.0, playerid, params[0])|| !IsPlayerInAnyVehicle(params[0])) return true;
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете чинить машину самому себе");
	new string[120];
	format(string, sizeof(string), "Вы предложили %s отремонтировать его машину за %d вирт.",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6495EDFF, string);
	format(string, sizeof(string), "Механик %s предлагает отремонтировать ваш автомобиль за %d вирт. (( /accept repair ))",User[playerid][pName],params[1]);
	SendClientMessage(params[0], 0x6495EDFF, string);
	RepairOffer[params[0]] = playerid;
	RepairPrice[params[0]] = params[1];
	return true;
}
CMD:dice(playerid, params[])
{
	if(!gDice[playerid]) return SendClientMessage(playerid, COLOR_GREY, "У Вас нет игральных костей");
	format(YCMDstr, sizeof(YCMDstr), "%s бросил(а) игральные кости на стол, выпало %i очков из 12",User[playerid][pName], random(12)+1);
	SendBeside(playerid, COLOR_INDIGO, YCMDstr, 10.0);
	return 1;//ProxDetector(5.0, playerid, YCMDstr, COLOR_INDIGO,COLOR_INDIGO,COLOR_INDIGO,COLOR_INDIGO,COLOR_INDIGO);
}
CMD:eject(playerid, params[])
{
	if(!IsPlayerInAnyVehicle(playerid)) return true;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return SendClientMessage(playerid,COLOR_GREY, "Вы не водитель!");
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /eject [id]");
	if(!IsPlayerConnected(params[0]) || !IsPlayerInVehicle(params[0],GetPlayerVehicleID(playerid))) return true;
	if(params[0] == playerid) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете выкинуть из машины себя!");
	new string[46];
	format(string, sizeof(string), "Вы выкинули из машины %s",User[params[0]][pName]);
	SendClientMessage(playerid, 0x6495EDFF, string);
	format(string, sizeof(string), "Вас выкинул из машины %s",User[playerid][pName]);
	SendClientMessage(params[0], 0x6495EDFF, string);
	return RemovePlayerFromVehicleAC(params[0]);
}

