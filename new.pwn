		}
	}
	else if(strcmp(text, "xD", true) == 0 || strcmp(text, "хД", true) == 0 || strcmp(text, "хД", true) == 0 || strcmp(text, "хД", true) == 0 )
	{
	    new str[90];
        if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
		format(str,sizeof(str), "%s смеется", User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, str, 30.0);
		SetPlayerChatBubble(playerid, "смеется", COLOR_PURPLE, 30.0, 10000);
		return false;
	}
	else if(strcmp(text, "чВ", true) == 0 || strcmp(text, "хДД", true) == 0 || strcmp(text, "хДД", true) == 0 || strcmp(text, "xDD", true) == 0)
	{
	    new str[156];
        if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
		format(str,sizeof(str), "%s валяется от смеха", User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, str, 30.0);
		SetPlayerChatBubble(playerid, "валяется от смеха",COLOR_PURPLE,30.0,10000);
		if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
		{
		}
		return false;
	}
	else if(strcmp(text, ")", true) == 0 || strcmp(text, "))", true) == 0)
	{
	    new str[90];
        if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
		format(str,sizeof(str), "%s улыбается", User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, str, 30.0);
		SetPlayerChatBubble(playerid, "улыбается",COLOR_PURPLE,30.0,10000);
		return false;
	}
	else if(strcmp(text, ":D", true) == 0)
	{
	    new str[156];
        if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
		format(str,sizeof(str), "%s хохочет во весь голос", User[playerid][pName]);
		SendBeside(playerid, COLOR_PURPLE, str, 30.0);
		SetPlayerChatBubble(playerid, "хохочет во весь голос",COLOR_PURPLE,30.0,10000);
		return false;
	}
	if(GetPVarInt(playerid,"BoneStol"))
	{
	    new str[156];
	    if(User[playerid][pLogin] == 0) return false;
	    if(Flood[playerid] > 0)
	    {
	        SendClientMessage(playerid,0xFFD5BBAA, "Не флуди!");
	        SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
	        if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood stol");
			return false;
		}
	    format(str, sizeof(str),"- %s: %s",User[playerid][pName],text);
	    foreach(new i : Player)
 		{
			if(GetPVarInt(i,"BoneStol") == GetPVarInt(playerid,"BoneStol")) SendClientMessage(i,0xFF9DB6FF,str);
		}
	    if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
		{
			ApplyAnimation(playerid, "PED", "IDLE_CHAT",4.1,0,1,1,1,1,1);
			SetTimerEx("ClearAnim", 2400, false, "d", playerid);
		}
		SetPlayerChatBubble(playerid, text, 0x6495EDFF, 20.0, 10000);
		Flood[playerid] = 2;
		SetPVarInt(playerid,"Flood",0);
	    return false;
	}
	if(realchat)
	{
	    if(Flood[playerid] > 0)
	    {
	        SendClientMessage(playerid,0xFFD5BBAA, "Не флуди!");
	        SetPVarInt(playerid,"Flood",GetPVarInt(playerid,"Flood")+1);
	        if(GetPVarInt(playerid,"Flood") >= 5) KickEx(playerid, "Flood chat");
			return false;
		}
		if(User[playerid][pMuted] > 0)
		{
		    new str[156];
			format(str, sizeof(str), "У Вас бан чата! До снятия: %i секунд(ы)",User[playerid][pMuted]);
			SendClientMessage(playerid, COLOR_LIGHTRED, str);
			return false;
		}
		if(User[playerid][pLevel] <= 1)
		{
			new succ;
			for(new i; i<strlen(text); i++) if(PText[playerid][i] == text[i]) succ++;
			if(succ == strlen(text))
			{
				SendClientMessage(playerid,0xFFD5BBAA, "Не флуди!");
				return false;
			}
		}
		strmid(PText[playerid],text,0,256,256);
        if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
		{
		    if(GetPVarInt(playerid, #PlayerAnimation ) == 0 || GetPVarInt(playerid, "PlayerCuffed") == 0)
			{
				ApplyAnimation(playerid, "PED", "IDLE_CHAT",4.1,0,1,1,1,1,1);
				SetTimerEx("ClearAnim", 2400, false, "d", playerid);
			}
		}
		new str[156];
		format(str,sizeof(str), "- %s: %s", User[playerid][pName], text);
		SetPlayerChatBubble(playerid, text, 0x6495EDFF, 20.0, 10000);
		SendBeside(playerid, COLOR_FADE1, str, 20.0);
		Flood[playerid] = 1;
		SetPVarInt(playerid,"Flood",0);
		return false;
	}
	return true;
}
