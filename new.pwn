stock ShowStats(playerid,targetid)
{
	if(IsPlayerConnected(playerid)&&IsPlayerConnected(targetid))
	{
		new atext[32];
		new jtext[20];
		new drank[20];
		switch(User[targetid][pSex])
		{
		    case 1: atext = "Мужчина";
		    case 2: atext = "Женщина";
		}
		switch(User[targetid][pJob])
		{
		    case 1: jtext = "Водитель автобуса";
			case 2: jtext = "Механик";
			case 3: jtext = "Продавец хотдогов";
			case 4: jtext = "Таксист";
			case 5: jtext = "Развозчик продуктов";
			case 6: jtext = "Тренер";
			//case 8: jtext = "Инкассатор";
			case 9: jtext = "Прораб";
			case 99: jtext = "Дальнобойщик";
			default: jtext = "Безработный";
		}
		switch(User[targetid][pLevel])
		{
		    case 1: drank = "Новичок";
		    case 2,3: drank = "Освоившийся";
		    case 4,5: drank = "Освоившийся";
		    case 10: drank = "Постоянный игрок";
		    case 6,7,8,9: drank = "Освоившийся";
		    default: drank = "Дед";
		}
		switch(User[targetid][pDonateRank])
		{
		    case 1: drank = "Премиум VIP";
		    //case 2: drank = "SILVER VIP";
		    //case 3: drank = "GOLD VIP";
		}
		new cash = User[targetid][pCash];
		new wdeaths = User[targetid][pWantedDeaths];
		new drugs = User[targetid][pDrugs];
		new mats = User[targetid][pMats];
		new wanted = User[targetid][pWantedLevel];
		new level = User[targetid][pLevel];
		new exp = User[targetid][pExp];
		new nxtlevel = User[targetid][pLevel]+1;
		new expamount = nxtlevel*4;
		new pnumber = User[targetid][pPnumber];
		new warns = User[targetid][pWarns];
		new zakon = User[targetid][pZakonp];
		new addiction = User[targetid][pAddiction];
		new Float:fishes = User[targetid][pFishes];
		new crimes = User[targetid][pCrimes];
		new arrests = User[targetid][pArrested];
		new coordsstring[1200];
		new msg[] = "{FFFFFF}Имя:\t\t\t\t{589A76}%s{FFFFFF}\n\nУровень:\t\t\t%i\nExp:\t\t\t\t%i/%i\nДеньги:\t\t\t%i\nТелефон:\t\t\t%i\nВарнов:\t\t\t%i\nЗаконопослушность:\t\t%i\nПреступлений:\t\t\t%i\nАрестов:\t\t\t%i\nСмертей в розыске:\t\t%i\nУровень розыска:\t\t%i\nДата регистрации:\t\t%s\nЗависимость:\t\t\t%i\nНаркотики:\t\t\t%i\nМатериалы:\t\t\t%i\nРыб поймано:\t\t\t%.1f кг\nОрганизация:\t\t\t%s\nРанг:\t\t\t\t%s\nРабота:\t\t\t\t%s\nСтатус:\t\t\t\t%s\nЖена/Муж:\t\t\t%s\nПол:\t\t\t\t%s";
		format(coordsstring, 1000, msg, User[targetid][pName],level,exp,expamount,cash,pnumber,warns,zakon,crimes,arrests,wdeaths,wanted,User[targetid][pDataReg],addiction,drugs,mats,fishes,GetFractionName[User[targetid][pMember]],GetRank(targetid),jtext,drank,User[targetid][pMarriedTo],atext);
		ShowPlayerDialogEx(playerid,9999,DIALOG_STYLE_MSGBOX, "{F1C33A}Статистика персонажа",coordsstring, "Готово", "");
	}
}
publics: SetPlayerToTeamColor(playerid)
{
	switch(User[playerid][pMember])
	{
	case 0:	SetPlayerColor(playerid, TEAM_HIT_COLOR);
	case 1: SetPlayerColor(playerid, 0x110CE7FF);
	case 2: SetPlayerColor(playerid, 0x313131AA);
	case 3: SetPlayerColor(playerid, COLOR_GREEN);
	case 4: SetPlayerColor(playerid, 0xA52A2AFF);
	case 5: SetPlayerColor(playerid, 0xDDA701FF);
	case 6: SetPlayerColor(playerid, COLOR_REDD);
	case 7: SetPlayerColor(playerid, 0x114D71FF);
	case 8: SetPlayerColor(playerid, 0xB313E7FF);
	case 9: SetPlayerColor(playerid, 0xFF830000);
	case 10: SetPlayerColor(playerid, 0x110CE7FF);
	case 11: SetPlayerColor(playerid, 0x139BECFF);
	case 12: SetPlayerColor(playerid, 0xB313E7FF);
	case 13: SetPlayerColor(playerid, 0xFFDE24FF);
	case 14: SetPlayerColor(playerid, COLOR_GRAD1);
	case 15: SetPlayerColor(playerid, 0x009F00AA);
	case 16: SetPlayerColor(playerid, 0x40848BAA);
	case 17: SetPlayerColor(playerid, TEAM_AZTECAS_COLOR);
	case 18: SetPlayerColor(playerid, 0x2A9170FF);
	case 19: SetPlayerColor(playerid, COLOR_GREEN);
	case 20: SetPlayerColor(playerid, 0xE6284EFF);
	case 21: SetPlayerColor(playerid, 0x110CE7FF);
	case 22: SetPlayerColor(playerid, 0xA52A2AFF);
	case 23: SetPlayerColor(playerid, 0x9ED201FF);
	case 25: SetPlayerColor(playerid, 0x49E789FF);
	case 27: SetPlayerColor(playerid, 0xF45000FF);
	case 28: SetPlayerColor(playerid, 0xFFEE8AFF);
	case 30: SetPlayerColor(playerid, 0xE6284EFF);
	case 31: SetPlayerColor(playerid, 0xB30000FF);
	case 32: SetPlayerColor(playerid, 0xFF9DB6FF);
	case 33: SetPlayerColor(playerid, 0xA52A2AFF);
	case 34: SetPlayerColor(playerid, 0xF45000FF);
	case 35: SetPlayerColor(playerid, 0xB30000FF);
	case 36: SetPlayerColor(playerid, 0xFFEE8AFF);
	}
	return true;
}
