new MzCheckTimer;
new WarStart;
new ZoneWar;
new ZoneID;
new ZoneTimer;

new kills_mafia[2],mafia_frac_id[2];
stock GetMafiaName2(fnumbwer)
{
	new str[8];
	switch(fnumbwer)
	{
	case 5: format(str,sizeof(str), "LCN");
	case 6: format(str,sizeof(str), "Yakuza");
	case 14: format(str,sizeof(str), "RM");
	}
	return str;
}
