			SendClientMessage(playerid, COLOR_GREEN, str);
			if(User[playerid][pCheckip] == 1) return ShowPlayerDialogEx(playerid, 9635, DIALOG_STYLE_LIST, "{AFAFAF}Ключ безопасности", "[0] Установить ключ\n[1] Отключить проверку по IP\n[2] Сменить ключ", "Выбрать", "Назад");
