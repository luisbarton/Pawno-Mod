	`pWantedLevel` = '%d',`pGunSkills` = '%s',`ptaxiexp` = '%d',`ptaxilvl` = '%d',`pBoxSkill` = '%d',`pKongfuSkill` = '%d',`pKickboxSkill` = '%d',`pDLevel` = '%d',`pDExp` = '%d' WHERE `Name` = '%e'",
    User[i][punWarns], User[i][pFuel], User[i][pMarriedTo], User[i][pMushrooms], User[i][pFishes],User[i][pBank], User[i][pMobile], User[i][pDolg], User[i][pKrisha],
	User[i][pUseKrisha], User[i][pWantedLevel], User[i][pGunSkills], User[i][ptaxiexp], User[i][ptaxilvl],
	User[i][pBoxSkill], User[i][pKongfuSkill], User[i][pKickboxSkill], User[i][pDLevel], User[i][pDExp], User[i][pName]);
	mysql_tquery(dbHandle, t_query, "", "");

	t_query = "";

	mysql_format(dbHandle, t_query, sizeof(t_query), "UPDATE `accounts` SET `pDMgruz` = '%d',`pPSkill` = '%d',`pPProc` = '%d',`pPMGruz` = '%d',`pDonateAccount` = '%d',`pOnline` = '%02d/%02d/%02d',`pChas` = '%d',`pMin` = '%d',`pOnlineLid` = '%02d:%02d',`pSkilla` = '%d',`prods_skill` = '%d',`prods_exp` = '%d',`pLighter` = '%d',`pCigarettes` = '%d',`pRecognition` = '%d',`pRobHouse` = '%d',`pFishesPach` = '%d',`pGoogle` = '%d', \
	`pGoogleAuth` = '%s' WHERE `Name` = '%e'",
	User[i][pDMgruz], User[i][pPSkill], User[i][pPProc], User[i][pPMGruz], User[i][pDonateAccount], day, month, year, User[i][pChas], User[i][pMin],User[i][pChas],
	User[i][pMin],User[i][pSkilla], User[i][pProdsSkill][0], User[i][pProdsSkill][1], User[i][pLighter], User[i][pCigarettes], User[i][pRecognition],
	User[i][pRobHouse], User[i][pFishesPach], User[i][pGoogle], User[i][pGoogleAuth], User[i][pName]);
	mysql_tquery(dbHandle, t_query, "", "");

	t_query = "";

	mysql_format(dbHandle, t_query, sizeof(t_query), "UPDATE `accounts` SET `pGifts` = '%d',`pEmail` = '%s', `activate_mail` = '%i', `pAptechka` = '%d', `fam_m` = '%d', `spawnchange` = '%d', `fam_r` = '%d' WHERE `Name` = '%e'", User[i][pGifts], User[i][pEmail], User[i][pActivemail], User[i][pAptechka], User[i][pFamilyMember], User[i][pSpawnChange], User[i][pFamilyRank], User[i][pName]);
	mysql_tquery(dbHandle, t_query, "", "");

	DeletePVar(i, "player_save");
	printf("[Save Accounts] %s Good! (in %d <ms>)", User[i][pName], GetTickCount() - time);
	return 1;
}
