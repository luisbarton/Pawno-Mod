publics: ProxDetectorS(Float:radi, playerid, targetid)
{
	if(IsPlayerConnected(playerid)&&IsPlayerConnected(targetid))
	{
		new Float:posx, Float:posy, Float:posz;
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		GetPlayerPos(targetid, posx, posy, posz);
		tempposx = (oldposx -posx);
		tempposy = (oldposy -posy);
		tempposz = (oldposz -posz);
		if (((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi)))
		{
			return true;
		}
	}
	return false;
}
publics: ClearMarriage(playerid)
{
	if(!IsPlayerConnected(playerid))
	{
		mysql_format(dbHandle,QUERY, 128, "UPDATE accounts SET pMarriedTo = '-' WHERE name = '%s'",User[playerid][pName]);
		mysql_tquery(dbHandle,QUERY,"","");
	}
	else strmid(User[playerid][pMarriedTo],"-", 0, strlen("-"), 32);
	return true;
}
public OnPlayerText(playerid, text[])
{
    if(User[playerid][pLogin] == 0)
	{
		SendClientMessage(playerid, COLOR_GREY, "Вам нужно авторизироватся!");
		return 0;
	}
    if(CountFloodForPlayer[playerid] >= 2) return 0;
	CountFloodForPlayer[playerid]++;
    if(User[playerid][pMuted] > 0)
	{
		format(YCMDstr,156, "У Вас бан чата! До снятия: %i секунд(ы)",User[playerid][pMuted]);
		SendClientMessage(playerid, COLOR_LIGHTRED, YCMDstr);
		return false;
	}
	new ip[26];
	GetPlayerIp(playerid,ip,sizeof(ip));
	if(IsIP(text) || CheckString(text))
	{
	    new str[156];
		User[playerid][pMuted] = 10800;
		format(str, sizeof(str), "Сказал: %s: %s",User[playerid][pName],text);
		ABroadCast(COLOR_LIGHTRED,str,1);
		format(str, sizeof(str), "ID: %i | IP: [%s]",playerid,ip);
		ABroadCast(COLOR_LIGHTRED,str,1);
		format(str, sizeof(str), "Вы получили бан чата на 3 часа. /mm - репорт");
		SendClientMessage(playerid, COLOR_LIGHTRED, str);
		SetPlayerChatBubble(playerid, "заткнут(а)",COLOR_PURPLE,30.0,10000);
		return false;
	}
	if(TalkingLive[playerid] == 1)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
		format(str, sizeof(str), "< [Тел] SF News > %s: %s", User[playerid][pName], text);
		OOCNews(COLOR_GREEN, str);
		Flood[playerid] = 2;
	}
	if(TalkingLivels[playerid] == 1)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
		format(str, sizeof(str), "< [Тел] LS News %s: %s", User[playerid][pName], text);
		LSNews(0x0073B7AA, str);
		Flood[playerid] = 2;
	}
	if(TalkingLivelv[playerid] == 1)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
		format(str, sizeof(str), "< [Тел] LV News > %s: %s", User[playerid][pName], text);
		LVNews(TEAM_CYAN_COLOR, str);
		Flood[playerid] = 2;
	}
	if(TalkingLive[playerid] == 2)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
		if(User[playerid][pMember] == 9)
		{
			format(str, sizeof(str), "< SF News > Ведущий %s: %s", User[playerid][pName], text);
			OOCNews(COLOR_GREEN, str);
			Flood[playerid] = 2;
			return false;
		}
		else
		{
			format(str, sizeof(str), "< SF News > Гость %s: %s", User[playerid][pName], text);
			OOCNews(COLOR_GREEN, str);
			Flood[playerid] = 2;
			return false;
		}
	}
	if(TalkingLivels[playerid] == 2)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
