// CMD'S
CMD:fcars(playerid, params[])
{
	SCMF(playerid, -1, " МАШИНА #0 %d", FamilyInfo[User[playerid][pFamilyMember]][famCar][0]);
	SCMF(playerid, -1, " МАШИНА #1 %d", FamilyInfo[User[playerid][pFamilyMember]][famCar][1]);
	SCMF(playerid, -1, " МАШИНА #2 %d", FamilyInfo[User[playerid][pFamilyMember]][famCar][2]);
	SCMF(playerid, -1, " МАШИНА #3 %d", FamilyInfo[User[playerid][pFamilyMember]][famCar][3]);
	SCMF(playerid, -1, " МАШИНА #4 %d", FamilyInfo[User[playerid][pFamilyMember]][famCar][4]);
	
	SCMF(playerid, -1, " rang #0 %s", family_rank [ User[playerid][pFamilyMember]] [ 0 ]);
	return 1;
}
CMD:acc(playerid, params[])
{
    new line_string [ 42 ] ;
	QUERY [ 0 ] = EOS ;
	strcat ( QUERY, "{"#cBL"}Выберите слот аксессуара\n" ) ;
	for ( new j = 0 ; j < 8 ; j ++ )
	{
		if ( User [ playerid ] [ accessories ] [ j ] == 0 )
		{
			strcat ( QUERY, "{"#cGR"}- Пусто\n" ) ;
		}
		else
		{
			format ( line_string, 42, "{ffffff}- %s\n", get_accessorie_name ( User [ playerid ] [ accessories ] [ j ] ) ) ;
			strcat ( QUERY, line_string ) ;
		}
	}
	return ShowPlayerDialogEx ( playerid, d_main_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", QUERY, "Выбрать", "Назад" ) ;
	//return ShowPlayerDialogEx ( playerid, d_accessories, DIALOG_STYLE_LIST, "{"#cBL"}Аксессуары", "{"#cGR"}- {"#cWH"}Наушники\n{"#cGR"}- {"#cWH"}Шапки\n{"#cGR"}- {"#cWH"}Панамы\n{"#cGR"}- {"#cWH"}Кепки\n{"#cGR"}- {"#cWH"}Каски\n{"#cGR"}- {"#cWH"}Береты\n{"#cGR"}- {"#cWH"}Парики\n{"#cGR"}- {"#cWH"}Очки\n{"#cGR"}- {"#cWH"}Повязки\n{"#cGR"}- {"#cWH"}Шляпы\n{"#cGR"}- {"#cWH"}Часы\n{"#cGR"}- {"#cWH"}Портфели\n{"#cGR"}- {"#cWH"}Банданы", "Выбрать", "Закрыть" ) ;
}
CMD:givegifts(playerid, params[])
{
    if(!GetPVarInt(playerid, "Dostup")) return true;
    if(User[playerid][pAdmin] < 9 || !GetPVarInt(playerid, "Dostup")) return true;
    foreach(new i : Player) User[i][pGifts] +=1;
	format(YCMDstr, sizeof(YCMDstr), "[A] Администратор %s[%i]: Выдал всем онлайн игрокам вращение",User[playerid][pName],playerid);
	SendAdminMessage(COLOR_RED, YCMDstr);
    return true;
}
CMD:gift(playerid, params[])
{
    if(User[playerid][pGifts] == 0) return SCM(playerid, COLOR_RED, "У Вас нет доступных прокруток!");
    switch(random(4))
	{
 		case 0: currentcase[playerid] = 1;
		case 1: currentcase[playerid] = 2;
		case 2: currentcase[playerid] = 3;
		case 3: currentcase[playerid] = 4;
	}
    ShowPlayerDialogEx(playerid,22820, DIALOG_STYLE_TABLIST_HEADERS, "{FFFFFF}Прокрутка | {1E90FF}Подарочное вращение",
	"{FFFFFF}Наименование\t{FFFFFF}Подробнее\n\
	{FFFFFF}+2 EXP\t+2 к опыту\n\
	{FFFFFF}Полный комплект лицензий\tКатегории A, B, C, AIR\n\
	{FFFFFF}Все скиллы на 100%\tПолная прокачка скиллов\n\
	{FFFFFF}Санятие одного Warn\tСнятие предупреждения\n\
	{FFFFFF}Donate Coins\tОт 2, до 100\n\
	{FFFFFF}Игровая валюта\tОт 10000, до 100000\n\
	{FFFFFF}Персональный скин\tPremium & VIP\n\
	{FFFFFF}VIP статус\tVIP статус 1 & 2 класса","Крутить","");
    SCM(playerid, COLOR_GREEN, "Сейчас случайным образом для Вас определится подарок!");
    SetPlayerSpecialAction (playerid, SPECIAL_ACTION_CARRY);
	SetPlayerAttachedObject(playerid, 1, 19054, 1, 0.11, 0.36, 0.0, 0.0, 0.0,0.40, 0.40, 0.40);
	return 1;
}
CMD:taxigps(playerid,params[])
{
	if User[playerid][pJob] != 4 && User[playerid][pAdmin] < 1 && User[playerid][pHelper] == 0 *then return true;
	new integer[7], string[460];
	foreach(new i : Player)
	{
	    if Works[i] *then integer[5]++; // Грузчики
	    if Prorab[i] *then integer[6]++; // Прорабы
	    for(new x = 0; x < 5; x++)
	    {
	        if GetPVarInt(i, "farm_id") == x+1 *then integer[x]++;
	    }
	}
	format(string, sizeof(string), "{ffffff}[Грузчики] {33AA33} Прорабов %d Рабочих %d\n\
	                                {ffffff}[Ферма №0] {33AA33} Фермеров %d {FFFF00} Цена за куст: %d$\n\
	                                {ffffff}[Ферма №1] {33AA33} Фермеров %d {FFFF00} Цена за куст: %d$\n\
	                                {ffffff}[Ферма №2] {33AA33} Фермеров %d {FFFF00} Цена за куст: %d$\n\
	                                {ffffff}[Ферма №3] {33AA33} Фермеров %d {FFFF00} Цена за куст: %d$\n\
	                                {ffffff}[Ферма №4] {33AA33} Фермеров %d {FFFF00} Цена за куст: %d$",
	                                							integer[5],				integer[6],
	                                							integer[0],				FarmInfo[1][fZp],
	                                							integer[1],				FarmInfo[2][fZp],
	                                							integer[2],				FarmInfo[3][fZp],
	                                							integer[3],				FarmInfo[4][fZp],
	                                							integer[4],             FarmInfo[5][fZp]);
	ShowPlayerDialogEx(playerid, 1344, DIALOG_STYLE_LIST, "Статистика работ", string, "GPS", "Закрыть");
	return true;
}
CMD:prodmenu(playerid, params[])
{
	if User[playerid][pJob] != 5 *then return SCM(playerid, COLOR_GREY, "Вам недоступна данная команда!");
	if(GetPVarInt(playerid,"rentcar_job") != GetPlayerVehicleID(playerid)) return SCM(playerid, COLOR_GREY, "Это не Ваш транспорт!");
 	new veh = GetPlayerVehicleID(playerid);
 	if(veh >= comptruck[0] && veh <= comptruck[1]) return ShowPlayerDialogEx(playerid, 1322, DIALOG_STYLE_LIST, "{F1C33A}Загрузка - Разгрузка зерна", "{FFFFFF}Загрузить зерно\nРазгрузить зерно\nЗагрузить урожая\nРазгрузка урожая", "Выбрать", "Отмена");
 	if(veh >= comptruck[2] && veh <= comptruck[3]) return ShowPlayerDialogEx(playerid, 1375, DIALOG_STYLE_LIST, "{F1C33A}Развозка бензина", "{FFFFFF}Купить\nПродать\nМониторинг\nСтатистика\nВыбросить продукты", "Выбрать", "Отмена");
	if(veh >= comptruck[4] && veh <= comptruck[9]) return ShowPlayerDialogEx(playerid, 1375, DIALOG_STYLE_LIST, "{F1C33A}Развозка продуктов", "{FFFFFF}Купить\nПродать\nМониторинг\nСтатистика\nВыбросить продукты", "Выбрать", "Отмена");
	return true;
}

CMD:funload(playerid, params[])
{
	new veh = GetPlayerVehicleID(playerid), farmid = GetPVarInt(playerid,"farm_id"), str[15];
	new string[144];
	//
	if(GetPVarInt(playerid,"farm_rank") < 2
								|| (veh != FarmInfo[farmid][fSeed_Car][0]
									&& veh != FarmInfo[farmid][fSeed_Car][1])) return true;
    if(!IsPlayerInRangeOfPoint(playerid,20.0,FarmInfo[farmid][fMenu][0],FarmInfo[farmid][fMenu][1],FarmInfo[farmid][fMenu][2])) return SCM(playerid, COLOR_GREY, "Необходимо находиться возле фермы!");
    if(FarmInfo[farmid][fProds] >= 10000) return SCM(playerid, COLOR_GREY, "Склад полон!");
    if(!Farmcar_prods[veh]) return SCM(playerid, COLOR_GREY, "В грузовике нет урожая");
	//
	FarmInfo[farmid][fProds] += Farmcar_prods[veh];
	FarmStat[farmid][3] += Farmcar_prods[veh];
	FarmStatDay[farmid][3] += Farmcar_prods[veh];
	format(str,sizeof(str), "~g~+$%d",Farmcar_prods[veh]*3);
	GameTextForPlayer(playerid, str, 5000, 1);
	User[playerid][pCash] += Farmcar_prods[veh]*3;
	Farmcar_prods[veh] = 0;
	f(string, "В грузовике 0 / 1000 урожая. На складе %d / 10000",FarmInfo[farmid][fProds]);
	return SCM(playerid, COLOR_GREEN, string);
}

CMD:fpanel(playerid, params[])
{
	if(GetPVarInt(playerid,"farm_rank") < 3) return true;
	new farmid = GetPVarInt(playerid,"farm_id");
	if(!PlayerToPoint(10, playerid,FarmInfo[farmid][fMenu][0], FarmInfo[farmid][fMenu][1], FarmInfo[farmid][fMenu][2])) return SCM(playerid, COLOR_GREY, "Необходимо находиться около фермы");
	ShowPlayerDialogEx(playerid, 9600, DIALOG_STYLE_LIST, "Панель настроек", "Установить цену зерна\nУстановить цену продуктов\nУстановить цену работы\nВвести вирты на счёт 'LandTax'\nВвести вирты на ферму\nВывести вирты с фермы\n\
	Статистика за прошлый час\nСтатистика за этот день\nСменить продаваемый продукт\nНазначить Зама [1]\nНазначить Зама [2]\nНазначить Зама [3]\n\
 	Назначить Фермера [1]\nНазначить Фермера [2]\nНазначить Фермера [3]\nНазначить Фермера [4]\nНазначить Фермера [5]", "Выбрать", "Отмена");
	return true;
}

CMD:finfo(playerid, params[])
{
	for(new i = 1; i <= TOTALFARM; i++)
	{
	    if(!IsPlayerInRangeOfPoint(playerid, 10, FarmInfo[i][fMenu][0], FarmInfo[i][fMenu][1], FarmInfo[i][fMenu][2])) continue;
	    return FarmStats(playerid,i);
	}
	return SCM(playerid,COLOR_GREY,"Необходимо находиться возле фермы!");
}

CMD:ffixcar(playerid, params[])
{
 	if(GetPVarInt(playerid,"farm_rank") < 2) return true;
 	new farminfo = GetPVarInt(playerid,"farm_id");
 	SetVehicleToRespawn(FarmInfo[farminfo][fCombine]);
 	for(new i = 0; i <= 1; i++)
 	{
     	SetVehicleToRespawn(FarmInfo[farminfo][fSeed_Car][i]);
     	if(Farmcar_pickup[FarmInfo[farminfo][fSeed_Car][i]] > 0)
     	{
         	if(IsValidDynamic3DTextLabel(Farmcar_text[FarmInfo[farminfo][fSeed_Car][i]])) DestroyDynamic3DTextLabel(Farmcar_text[FarmInfo[farminfo][fSeed_Car][i]]);
   			DestroyDynamicPickup(Farmcar_pickup[FarmInfo[farminfo][fSeed_Car][i]]);
   			Farmcar_pickup[FarmInfo[farminfo][fSeed_Car][i]] = 0;
     	}
 	}
 	return true;
}
CMD:fminvite(playerid, params[])
{
    new farminfo = GetPVarInt(playerid,"farm_id");
	if(GetPVarInt(playerid,"farm_rank") < 3 || !PlayerToPoint(10, playerid, FarmInfo[farminfo][fMenu][0], FarmInfo[farminfo][fMenu][1], FarmInfo[farminfo][fMenu][2])) return true;
	if(sscanf(params, "udd", params[0], params[1], params[2])) return SCM(playerid, COLOR_GREY, "Используйте: /fminvite [playerid (-1 для увольнения)] [тип (1 - заместитель | 2 - фермер)] [место (от 1)]");
	if(!PlayerInConnected(params[0]) || playerid == params[0]) return err(!"Ошибка: {ffffff} Человек не найден!");
	if(params[0] >= 0 && User[params[0]][pMember]) return SendClientMessage(playerid,COLOR_GREY,"Этот человек состоит в организации!");
	if(GetDistanceBetweenPlayers(playerid, params[0]) > 5.0) return SCM(playerid, COLOR_GREY, "Вы слишком далеко");
	switch(params[1])
	{
	    case 1:
	    {
	        if(GetPVarInt(playerid,"farm_rank") < 4) return SendClientMessage(playerid,COLOR_GREY,"Вы не можете нанимать заместителей");
	        switch(params[2])
	        {
	            case 1:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fDeputy_1],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fDeputy_1],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            case 2:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fDeputy_2],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fDeputy_2],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
				}
	            case 3:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fDeputy_3],"None", 0, strlen("None"), 32);
	                else strmid(FarmInfo[farminfo][fDeputy_3],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            default: return SendClientMessage(playerid,COLOR_GREY,"Неверное значение");
	        }
	        static const fmt_query[] = "Вы приняли %s на должность заместителя";
	        new string[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
			f(string, fmt_query, User[params[0]][pName]);
			SCM(playerid, COLOR_BLUE, string);
	    }
	    case 2:
	    {
	        switch(params[2])
	        {
	            case 1:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fFarmer_1],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fFarmer_1],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            case 2:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fFarmer_2],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fFarmer_2],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            case 3:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fFarmer_3],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fFarmer_3],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            case 4:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fFarmer_4],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fFarmer_4],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
	            case 5:
	            {
	                if(params[0] == -1) return strmid(FarmInfo[farminfo][fFarmer_5],"None", 0, strlen("None"), 32);
					else strmid(FarmInfo[farminfo][fFarmer_5],User[params[0]][pName], 0, strlen(User[params[0]][pName]), 32);
	            }
				default: return SendClientMessage(playerid,COLOR_GREY,"Неверное значение");
	        }
	        static const fmt_query[] = "Вы приняли %s на должность фермера";
	        new string[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	        f(string, fmt_query, User[params[0]][pName]);
	        SCM(playerid, COLOR_BLUE, string);
	    }
	}
	return true;
}

CMD:gmap(playerid, params[])
{
	if(!IsAGang(playerid)) return true;
	new num, string[60];
	if(IsAGang(playerid))
	{
		for(new i = 1; i < TOTALGZ; i++)
		{
			if(User[playerid][pMember] == GZInfo[i][gFrakVlad]) num++;
		}
		f(string, "Количество территорий, контролируемых вашей бандой: %d", num);
		SCM(playerid, 0x6BB3FFAA, string);
	}
	/*else if(IsAGangSF(playerid))
	{
		for(new i = 0; i < sizeof(GZInfoSF); i++)
		{
			if(User[playerid][pMember] == GZInfoSF[i][gFrakVlad]) num++;
		}
		f(string, "Количество территорий, контролируемых вашей бандой: %d", num);
		SCM(playerid, 0x6BB3FFAA, string);
	}*/
	return 1;
}
CMD:tpanel(playerid, params[])
{
	if(!WGet(playerid)) return true;
	new i = GetPVarInt(playerid,"wShop");
	if(!PlayerToPoint(15, playerid,WorkshopInfo[i][wEntr][0],WorkshopInfo[i][wEntr][1],WorkshopInfo[i][wEntr][2])
		&& !PlayerToPoint(15, playerid,WorkshopInfo[i][wExit][0],WorkshopInfo[i][wExit][1],WorkshopInfo[i][wExit][2]))
			return SCM(playerid, COLOR_GREY, "Вы слишком далеко от вашей мастерской!");
   	ShowPlayerDialogEx(playerid, 9592, DIALOG_STYLE_LIST, "Панель управления", "[1] Пополнить банк автомастерской\n[2] Пополнить 'LandTax' счёт\n[3] Снять деньги с банка\n[4] Установить стоимость 1 продукта\n[5] Установить зарплату рабочим\n[6] Нанять заместителя (1)\
	\n[7] Нанять заместителя (2)\n[8] Нанять заместителя (3)\n[9] Нанять механика (1)\n[10] Нанять механика (2)\n[11] Нанять механика (3)\n[12] Нанять механика (4)\n[13] Нанять механика (5)", "Выбрать", "Отмена");
	return true;
}

CMD:tinfo(playerid, params[])
{
    for(new i = 1; i <= TOTALSHOPS; i++)
    {
        if(!PlayerToPoint(3, playerid,WorkshopInfo[i][wEntr][0], WorkshopInfo[i][wEntr][1], WorkshopInfo[i][wEntr][2])) continue;
        return WorkshopStats(playerid,i);
    }
	return SCM(playerid, COLOR_GREY, "Необходимо находиться возле автомастерской!");
}

CMD:tupdate(playerid, params[])
{
    if(!GetPVarInt(playerid,"Workshop")) return SCM(playerid, COLOR_GREY, "Вы не работаете в автомастерской!");
    if(!PlayerToPoint(10, playerid,1067.3966,2128.3901,10.5110)) return SCM(playerid, COLOR_GREY , "Вы должны находиться в гараже автомастерской");
    if(GetPVarInt(playerid,"installation") != 0) return SCM(playerid, COLOR_GREY ,"Вы не установили деталь!");
    if(GetPVarInt(GetPVarInt(playerid,"installation_"),"InWorkshop") != GetPVarInt(playerid,"Workshop")) return SCM(playerid, COLOR_GREY, "Игрок не находится с вами в гараже!");
    return ShowDetals(playerid, GetPVarInt(playerid,"installation_"), GetPVarInt(playerid,"Workshop"));
}

CMD:endtune(playerid, params[])
{
	new installation = GetPVarInt(playerid,"installation_"), x = GetPVarInt(playerid,"Workshop");
    if(!x) return SCM(playerid, COLOR_GREY, "Вы не работаете в автомастерской!");
    if(!PlayerToPoint(10, playerid,1067.3966,2128.3901,10.5110)) return SCM(playerid, COLOR_GREY, "Вы должны находиться в гараже автомастерской");
    if(GetPVarInt(playerid,"installation") != 0) return SCM(playerid, COLOR_GREY, "Вы не установили деталь!");
    if(!ProxDetectorS(8.0, playerid, installation)) return SCM(playerid, COLOR_GREY, "Человек не рядом с вами!");
    if(!IsPlayerInAnyVehicle(installation)) return SCM(playerid, COLOR_GREY, "Игрок должен находиться в автомобиле");
    if(GetPVarInt(installation,"InWorkshop") != GetPVarInt(playerid,"Workshop")) return SCM(playerid, COLOR_GREY, "Игрок не находится в гараже!");
    if(!IsPlayerInAnyVehicle(playerid)) return SCM(playerid, -1, "Вы должны находиться в автомобиле"); // Проверить (не уверен)
    SetPlayerVirtualWorld(playerid,0);
    SetPlayerVirtualWorld(installation,0);
    SetVehicleVirtualWorld(GetPlayerVehicleID(playerid),0);
    t_SetVehiclePos(GetPlayerVehicleID(playerid),WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][0],WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][1],WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][2]);
    DeletePVar(installation,"cost");
	DeletePVar(installation,"prods");
	DeletePVar(installation,"detals");
	DeletePVar(installation,"color0");
	DeletePVar(installation,"color1");
	SaveTuning(GetPVarInt(playerid,"installation_"),house_car[GetPVarInt(playerid,"installation_")]);
	SaveCar(GetPVarInt(playerid,"installation_"));
	DeletePVar(playerid,"installation");
	DeletePVar(installation,"mechanic");
 	for(new x_ = 0; x_ < 9; x_++)
	{
		WorkshopList[x_][x][wlID] = WorkshopList[x_+1][x][wlID];
		strmid(WorkshopList[x_][x][wlName],WorkshopList[x_+1][x][wlName],0,strlen(WorkshopList[x_+1][x][wlName]), MAX_PLAYER_NAME);
		WorkshopList[x_+1][x][wlID] = -1;
		strmid(WorkshopList[x_+1][x][wlName],"", 0, strlen(""), 5);
	}
	if(WorkshopList[0][x][wlID] != -1 && strlen(WorkshopList[0][x][wlName]))
	{
		SendClientMessage(WorkshopList[0][x][wlID],0x6BB3FFAA,"Подошла ваша очередь. У вас есть 2 минуты что бы прибыть к гаражу!");
		SetPVarInt(WorkshopList[0][x][wlID],"w_time", gettime() + 120);
		SetPlayerCheckpoint(WorkshopList[0][x][wlID],WorkshopInfo[x][wMenu][0],WorkshopInfo[x][wMenu][1],WorkshopInfo[x][wMenu][2], 10.0);
	}
	DeletePVar(installation,"w_time");
	DeletePVar(installation,"w_id");
	DeletePVar(installation,"InWorkshop");
 	DeletePVar(playerid,"installation_");
	return true;
}
CMD:addtunnequeue(playerid, params[])
{
    if(!GetPVarInt(playerid,"Workshop")) return true;
	if(GetPVarInt(playerid,"Workshop__") < 2) return SendClientMessage(playerid,COLOR_WHITE,"Вы не можете добавлять в очередь");
	if(!PlayerToPoint(10, playerid,1496.0302,1308.6653,1093.2892)) return SendClientMessage(playerid,-1, "Вы должны находиться в автомастерской");
	if(sscanf(params, "u",params[0])) return	SendClientMessage(playerid, COLOR_GREY, "Используйте: /addtunnequeue [id]");
	if(!ProxDetectorS(8.0, playerid, params[0])) return true;
	new null = -1, null_ = 0;
	for(new i = 9; i >= 0; i--)
	{
		if(!strlen(WorkshopList[i][GetPVarInt(playerid,"Workshop")][wlName])) null = i;
		if(strcmp(WorkshopList[i][GetPVarInt(playerid,"Workshop")][wlName],User[params[0]][pName],true) == 0 && strlen(WorkshopList[i][GetPVarInt(playerid,"Workshop")][wlName])) null_++;
	}
	if(null == -1) return SendClientMessage(playerid,COLOR_GREY," Очередь заполнена!");
	if(null_ > 0) return SendClientMessage(playerid,COLOR_GREY," Игрок уже ждет свою очередь!");
	SetPVarInt(params[0], "w_id",GetPVarInt(playerid,"Workshop"));
	WorkshopList[null][GetPVarInt(playerid,"Workshop")][wlID] = params[0];
	strmid(WorkshopList[null][GetPVarInt(playerid,"Workshop")][wlName],User[params[0]][pName],0,strlen(User[params[0]][pName]), 32);
	new string[128];
	f(string, "Вы добавили игрока %s в очередь!", User[params[0]][pName]);
	SCM(playerid,0x6BB3FFAA, string);
	if(null == 0)
	{
		SetPVarInt(params[0], "w_time", gettime() + 120);
		SendClientMessage(params[0],0x6BB3FFAA,"Механик добавил вас в очередь. У вас есть 2 минуты что бы прибыть к гаражу!");
		SetPlayerCheckpoint(params[0],WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][0],WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][1],WorkshopInfo[GetPVarInt(playerid,"Workshop")][wMenu][2], 10.0);
	}
	else SendClientMessage(params[0],0x6BB3FFAA,"Механик добавил вас в очередь");
	return true;
}
/*CMD:setmemleader(playerid, params[])
{
	if(User[playerid][pLeader] != 4) return true;
	if(sscanf(params, "ud", params[0], params[1]) || params[1] < 0 || params[1] > 3 || params[0] == playerid) return SCM(playerid, COLOR_GREY, "Используйте: /setmemleader [playerid] [подразделение] (1 - ЛС, 2 - СФ, 3 - ЛВ)");
	if(User[params[0]][pMember] != 4) return SCM(playerid, COLOR_GREY, "Данный игрок из другой организации!");
	new string[156], str[3];
	switch(params[1])
	{
		case 1: str = "ЛС";
		case 2: str = "СФ";
		case 3: str = "ЛВ";
