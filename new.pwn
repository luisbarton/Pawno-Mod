public OnPlayerCommandText(playerid, cmdtext[]) return true;
public OnPlayerCommandPerformed(playerid, cmdtext[], success)
{
    if(IsTextInvalid(cmdtext)) printf("CMDLOG: ВОЗМОЖНА АТАКА: %s", cmdtext);
	SetPVarInt(playerid, "AntiFlood", GetTickCount());
	printf("Игрок %s только что использовал команду \"%s\"", User[playerid][pName], cmdtext);
	return true;
}
//==============================================================================
public OnPlayerCommandReceived(playerid, cmdtext[])
{
    if(!User[playerid][pLogin])
	{
		SendClientMessage(playerid, -1,"Вам нужно авторизироватся");
		return 0;
	}
	if(GetTickCount()-GetPVarInt(playerid, "AntiFlood") < 500)
	{
	    if(CountFloodForPlayer[playerid] >= 2) return 0;
		CountFloodForPlayer[playerid]++;
		//SCM(playerid, COLOR_GREY, "Нельзя писать в чат слишком часто!");
		return false;
	}
	return true;
}
stock SendBeside(playerid,color,string[],Float:distance = 30.0)
{
	new
        Float: x,
        Float: y,
        Float: z;
    GetPlayerPos(playerid, x, y, z);

	#if defined FOREACH_I_PlayerPlayersStream
    foreach(PlayerPlayersStream[playerid],i)
    {
	#else
    for(new i = GetPlayerPoolSize()+1; i != -1; i--)
    {
        if(0 == IsPlayerConnected(i))
            continue;
	#endif
		if(IsPlayerInRangeOfPoint(i,distance,x,y,z))
		{
			SendClientMessage(i,color,string);
		}
	}
	#if defined FOREACH_I_PlayerPlayersStream
	SendClientMessage(playerid,color,string);
	#endif
	return 1;
}
