CMD:tskill(playerid)
{
	new gtext[7];
	switch(Gruz[playerid])
	{
		case 1: gtext ="Бензин";
		case 2: gtext ="Уголь";
		case 3: gtext ="Дерево";
		case 0: gtext ="Нет";
	}
	new level = User[playerid][pDLevel];
	new exp = User[playerid][pDExp];
	new nxtlevel = User[playerid][pDLevel];
	new expamount = nxtlevel*levelDexp;
	new gruz = User[playerid][pDgruz];
	new mazgruz = User[playerid][pDMgruz];
	new msg[] = "{FFFFFF}Навык:\n\t\tLVL: %i\n\t\tExp: %i/%i\nФура:\n\t\tМакс груз: %iт.\n\t\tЗагружено: %i\nГруз: %s";
	format(YCMDstr, 128, msg,level,exp,expamount,mazgruz,gruz,gtext);
	ShowPlayerDialogEx(playerid,9999,0, "{F1C33A}Статистика дальнобойщика",YCMDstr, "Готово", "");
	return true;
}
CMD:tmonitor(playerid, params[])
{
	//peremennn[playerid] = 0;
	if(User[playerid][pJob] != 99)return SCM(playerid,COLOR_GREY, "Вы не Дальнобойщик");
	if(!IsAtTPlace(playerid)) return SCM(playerid,0x81DA99AA,"Вы должны находиться в порту / заводе");
	new msg1[] = "{FFFFFF}Заводы:\nНефтезавод №1 Цена 1т: \n\t%i\nНефтезавод №2 Цена 1т: \n\t%i\nСклад угля №1 Цена 1т: \n\t%i\nСклад угля №2 Цена 1т:\n\t%i\nЛесопилка №1 Цена 1т:\n\t%i\nЛесопилка №2 Цена 1т: \n\t%i\n\nПорты:\nПорт LS, Цена 1т:\n\tНефть: %i\n\tУголь: %i\n\tДерево: %i\nПорт SF, Цена 1т:\n\tНефть: %i\n\tУголь: %i\n\tДерево: %i";
	format(YCMDstr, 500, msg1,Benzbuy[0],Benzbuy[1],ugolbuy[0],ugolbuy[1],Buyderevo[0],Buyderevo[1],Sellbenz[0],Sellugol[0],Sellderevo[0],Sellbenz[1],Sellugol[1],Sellderevo[1]);
	ShowPlayerDialogEx(playerid,31998,0, "{F1C33A}Мониторинг цен:",YCMDstr, "Готово", "");
	return true;
}
CMD:netstats(playerid)
{
	new stats[400+20];
 	GetNetworkStats(stats, sizeof(stats)); // get the servers networkstats
  	return ShowPlayerDialogEx(playerid, 0, DIALOG_STYLE_MSGBOX, "Server Network Stats", stats, "Close", "");
}
CMD:timestat(playerid)
{
	new str[256];
	format(str, sizeof(str),"Последнее время прокрутки FreshTimer: (%d ms). пик: (%d ms).\n", time_grandtimer, time_grandtimer_max);
	format(str, sizeof(str),"%sПоследнее время прокрутки OnPlayerUpdate: (%d ms). пик: (%d ms).\nПоследнее время прокрутки \"newkeys\": (%d ms). пик: (%d ms).", str, time_update,time_update_max,time_newkeys,time_newkeys_max);
	ShowPlayerDialogEx(playerid,0,0,"Нагрузка мода", str, "Окей", "");
	return 1;
}
CMD:taxiskill(playerid)
{
	format(YCMDstr, sizeof(YCMDstr), "Ваш уровень таксиста %i. До следующего осталось %i/%i exp",User[playerid][ptaxilvl], User[playerid][ptaxiexp], User[playerid][ptaxilvl]*8);
	SendClientMessage(playerid, 0x6495EDFF, YCMDstr);
	return true;
}
CMD:prodskill(playerid)
{
	new string[128];
	f(string, "Вам уровень развозчика продуктов: %d", User[playerid][pPSkill]);
	SCM(playerid, 0x6495EDFF, string);
	return true;
}
CMD:switchwave(playerid, params[])
{
    if(sscanf(params, "d", params[0]))
	{
		SendClientMessage(playerid, COLOR_GREY, "Используйте: /switchwave [номер]");
		SendClientMessage(playerid, COLOR_WHITE, " [0] Выключить");
		SendClientMessage(playerid, COLOR_WHITE, " [1] SF News");
		SendClientMessage(playerid, COLOR_WHITE, " [2] LS News");
		SendClientMessage(playerid, COLOR_WHITE, " [3] LV News");
		return true;
	}
	switch (params[0])
	{
		case 1:
		{
			lNews[playerid] = true;
			gNews[playerid] = false;
			LvNews[playerid] = true;
			SendClientMessage(playerid, COLOR_WHITE, "Волна переключена на SF News");
		}
		case 2:
		{
			lNews[playerid] = false;
			gNews[playerid] = true;
			LvNews[playerid] = true;
			SendClientMessage(playerid, COLOR_WHITE, "Волна переключена на LS News");
		}
		case 3:
		{
			lNews[playerid] = true;
			gNews[playerid] = true;
			LvNews[playerid] = false;
			SendClientMessage(playerid, COLOR_WHITE, "Волна переключена на LV News");
		}
		case 0:
		{
			lNews[playerid] = true;
			gNews[playerid] = true;
			LvNews[playerid] = true;
			SendClientMessage(playerid, COLOR_WHITE, "Вы выключили радио");
		}
	}
	return true;
}
CMD:instopen(playerid, params[])
{
    if(User[playerid][pMember] != 11 && User[playerid][pLeader] != 11 && TakingLesson[playerid] != 1) return true;
	if(!PlayerToPoint(8.0,playerid,-2074.50000000,-94.90000153,35.00000000)) return SCM(playerid, -1, "Вы должны быть около шлагбаума");
	SetObjectRot(licgate,0.00000000,0.00000000,270.00000000);
	SetTimer("LicClose", 8000, 0);
	SendClientMessage(playerid, 0x6495EDFF, "Шлагбаум отпуститься через 8 секунд");
	return true;
}
CMD:givelicense(playerid, params[])
{
	if(User[playerid][pMember] == 11)
	{
	    if(sscanf(params, "u", params[0])) return SCM(playerid, -1, "Введите: /givelicense [ID игрока]");
	    if(!ProxDetectorS(8.0, playerid, params[0])) return SendClientMessage(playerid,COLOR_GREY,"Игрок должен находиться рядом с вами");
		if(!GetPVarInt(playerid,"Fraction_Duty")) return SendClientMessage(playerid,COLOR_GRAD1, "Вам нужно начать рабочий день в автошколе");
		new listitems[] = " [0] Водительские права\n [1] Лицензия на полёты\n [2] Лицензия на рыболовлю\n [3] Лицензия на вождение водного транспорта\n [4] Лицензия на оружие\n [5] Лицензия на бизнес\n [6] Начать урок\n [7] Завершить урок";
		ShowPlayerDialogEx(playerid, 7777, DIALOG_STYLE_LIST, "Выдача лицензий", listitems, "Выбрать", "Отмена");
		ChosenPlayer[playerid] = params[0];
		SetPVarInt(ChosenPlayer[playerid],"PlayerSell",playerid);
	}
	return true;
}
CMD:givenewskeys(playerid, params[])
{
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /givenewskeys [id]");
	if(User[playerid][pMember] == 9 || User[playerid][pMember] == 16 || User[playerid][pMember] == 20 || User[playerid][pAdmin] == 5)
	{
		if(!IsPlayerConnected(params[0])) return true;
        if(GetDistanceBetweenPlayers(playerid, params[0]) > 5.0) return SCM(playerid, COLOR_GREY, "Вы слишком далеко");
		if(params[0] == INVALID_PLAYER_ID) return true;
		if(User[params[0]][pNkeys] == 1) return SCM(playerid, COLOR_GREY, "У данного человека уже имеется пропуск!");
        if(User[params[0]][pMember] == 9 || User[params[0]][pMember] == 16 || User[params[0]][pMember] == 20) return SCM(playerid, COLOR_GREY, "Данный человек работает в новостях!");
		User[params[0]][pNkeys] = 1;
		format(YCMDstr, sizeof(YCMDstr), "Сотрудник News %s выдал пропуск в офис %s",User[playerid][pName],User[params[0]][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	}
	return true;
}
CMD:takenewskeys(playerid, params[])
{
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /takenewskeys [id]");
	if(User[playerid][pMember] == 9 || User[playerid][pMember] == 16 || User[playerid][pMember] == 20 || User[playerid][pAdmin] == 5)
	{
		if(!IsPlayerConnected(params[0])) return true;
		if(params[0] == INVALID_PLAYER_ID) return true;
		if(User[params[0]][pNkeys] == 0) return SCM(playerid, COLOR_GREY, "У данного человека нет пропуска!");
		if(User[params[0]][pMember] == 9 || User[params[0]][pMember] == 16 || User[params[0]][pMember] == 20) return SCM(playerid, COLOR_GREY, "Данный человек работает в новостях!");
		User[params[0]][pNkeys] = 0;
		format(YCMDstr, sizeof(YCMDstr), "Сотрудник News %s забрал пропуск в офис %s",User[playerid][pName],User[params[0]][pName]);
		SendBeside(playerid,COLOR_PURPLE,YCMDstr,30.0);
	}
	return true;
}
CMD:news(playerid, params[])
{
	new newcar = GetPlayerVehicleID(playerid);
	if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
	if(sscanf(params, "s[64]", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /news [текст]");
	switch(User[playerid][pMember])
	{
		case 9:
		{
			if(newcar >= cnncar[0] && newcar <= cnncar[4] || newcar == cnnmav || PlayerToPoint(30.0,playerid,-2064.4141,471.2328,191.6799)) { } else { SendClientMessage(playerid, COLOR_GRAD1, "Вы не в репортёрской машине / вертолёте / офисе!"); return true;}
			format(YCMDstr, sizeof(YCMDstr), "< SF News > %s: %s",User[playerid][pName], params[0]);
			OOCNews(COLOR_GREEN,YCMDstr);
			gNews[playerid] = false;
		}
		case 16:
		{
			if(newcar >= lsnewscar[0] && newcar <= lsnewscar[5] || PlayerToPoint(30.0,playerid,1639.6208,-1619.5801,96.0863)) { } else { SendClientMessage(playerid, COLOR_GRAD1, "Вы не в репортёрской машине / вертолёте / офисе!"); return true;}
			format(YCMDstr, sizeof(YCMDstr), "< LS News > %s: %s",User[playerid][pName],params[0]);
			LSNews(0x0073B7AA,YCMDstr);
			lNews[playerid] = false;
		}
		case 20:
		{
			if(newcar >= lvnewscar[0] && newcar <= lvnewscar[5] || PlayerToPoint(30.0,playerid,2630.0166,1228.8519,50.1059)) { } else { SendClientMessage(playerid, COLOR_GRAD1, "Вы не в репортёрской машине / вертолёте / офисе!"); return true;}
			format(YCMDstr, sizeof(YCMDstr), "< LV News > %s: %s",User[playerid][pName],params[0]);
			LVNews(0xC3003AAA,YCMDstr);
			LvNews[playerid] = false;
		}
	}
	return true;
}
CMD:npanel(playerid, params[])
{
    if(User[playerid][pLogin] == 0 || !GetPVarInt(playerid,"Fraction_Duty")) return true;
    new model = GetVehicleModel(GetPlayerVehicleID(playerid));
	if(model != 582 && model != 488 &&  !PlayerToPoint(30.0,playerid,2648.8855,1224.7946,41.0859) && !PlayerToPoint(30.0,playerid,-2052.6719,473.1645,191.0859) && !PlayerToPoint(30.0,playerid,1656.0978,-1623.1172,101.0859)) return SendClientMessage(playerid, COLOR_GRAD1, "Вы не в репортёрской машине / вертолёте / офисе!");
	switch(User[playerid][pMember])
	{
		case 9: ShowPlayerDialogEx(playerid, 2223, DIALOG_STYLE_LIST, "[ NEWS MENU ]", " [ 1 ] Прямой эфир\n [ 2 ] Выйти из прямого эфира\n [ 3 ] Начать принимать звонки / смс\n [ 4 ] Завершить принимать звонки / смс\n [ 5 ] Установить цену за звонки и смс\n [ 6 ] Установить цену за объявления\n [ 7 ] Объявления\n [ 8 ] Банк\n [ 9 ] Раздел лидера", "Enter", "Cancel");
		case 16: ShowPlayerDialogEx(playerid,2224, DIALOG_STYLE_LIST, "[ NEWS MENU ]", " [ 1 ] Прямой эфир\n [ 2 ] Выйти из прямого эфира\n [ 3 ] Начать принимать звонки / смс\n [ 4 ] Завершить принимать звонки / смс\n [ 5 ] Установить цену за звонки и смс\n [ 6 ] Установить цену за объявления\n [ 7 ] Объявления\n [ 8 ] Банк\n [ 9 ] Раздел лидера", "Enter", "Cancel");
		case 20: ShowPlayerDialogEx(playerid,2225, DIALOG_STYLE_LIST, "[ NEWS MENU ]", " [ 1 ] Прямой эфир\n [ 2 ] Выйти из прямого эфира\n [ 3 ] Начать принимать звонки / смс\n [ 4 ] Завершить принимать звонки / смс\n [ 5 ] Установить цену за звонки и смс\n [ 6 ] Установить цену за объявления\n [ 7 ] Объявления\n [ 8 ] Банк\n [ 9 ] Раздел лидера", "Enter", "Cancel");
		default: SendClientMessage(playerid,COLOR_GREY,"Вам недоступна данная команда");
	}
	return true;
}
CMD:live(playerid, params[])
{
    if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return true; }
    if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /live [id/name]");
    if(params[0] == playerid) { SendClientMessage(playerid, COLOR_GREY, "Вы не можете брать интервью у себя!"); return true; }
	if (ProxDetectorS(5.0, playerid, params[0])){} else { SendClientMessage(playerid, COLOR_GREY, "Человек далеко от вас!"); return true; }
	if(params[0] == INVALID_PLAYER_ID) { SendClientMessage(playerid, COLOR_GREY, "Человек не найден!"); return true; }
    new newcar = GetPlayerVehicleID(playerid);
	switch(User[playerid][pMember])
	{
