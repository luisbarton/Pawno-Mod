CMD:warnmans(playerid, params[])
{
    if(User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup")) return true;
	new countmute = 0;
	foreach(new i : Player)
	{
		if(User[i][pWarns] >= 1 && IsPlayerConnected(i))
		{
			format(YCMDstr, sizeof(YCMDstr), "%s [ID: %i] | Warns: %i ",User[i][pName],i,User[i][pWarns]);
			countmute++;
			SendClientMessage(playerid, COLOR_LIGHTGREEN, YCMDstr);
		}
	}
	if(countmute == 0) SendClientMessage(playerid, COLOR_GRAD1, "Нет игроков с Варнами");
	else
	{
		format(YCMDstr, sizeof(YCMDstr), "Всего: %i человек!", countmute);
		SendClientMessage(playerid, COLOR_WHITE, YCMDstr);
	}
	return true;
}
