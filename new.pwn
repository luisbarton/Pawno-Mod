	return true;
}*/
CMD:invite(playerid, params[])
{
	new ftext[50], invite[100];
	if(IsPlayerConnected(playerid))
	{
		switch (User[playerid][pMember])
		{
		    case 1..4, 7, 8, 9, 10, 11, 16, 19, 20, 21, 25, 26:
			{
			    if(!GetPVarInt(playerid,"Fraction_Duty")) return SCM(playerid, COLOR_GREY, "Ошибка! Вы не на службе");
			}
		}
		if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /invite [id игрока]");
		if(!PlayerInConnected(params[0]) || playerid == params[0]) return err(!"Ошибка: {ffffff} Человек не найден!");
		if(GetDistanceBetweenPlayers(playerid, params[0]) > 10.0) return SendClientMessage(playerid, 0xAFAFAFAA, "Игрок далеко от вас");
		if(IsPlayerInAnyVehicle(params[0])) return SendClientMessage(playerid, 0xAFAFAFAA, "Игрок в машине!");
		if((User[params[0]][pMember] > 0) || (User[params[0]][pLeader] > 0)) return SendClientMessage(playerid, 0xAFAFAFAA, "Игрок уже где то состоит");
		if(User[params[0]][pWarns] >= 1) return SendClientMessage(playerid, COLOR_GRAD1, "У игрока WARN!");
		if((User[playerid][pLeader] == 1) || (User[playerid][pMember] == 1) && (User[playerid][pRank] == 14))
		{
			if((User[playerid][pMember] == 1) && (User[playerid][pRank] < 3) || (User[params[0]][pLevel] < 2)) return SendClientMessage(playerid, 0xAFAFAFAA, "Приём возможен с 2 lvl");
			ftext             = "Los Santos Police Department",InviteSkin[params[0]] = 280;
		}
		else if((User[playerid][pLeader] == 2) || (User[playerid][pMember] == 2) && (User[playerid][pRank] == 9))
		{
			ftext             = "Federal Bureau of Investigation",InviteSkin[params[0]] = 286;
		}
		else if((User[playerid][pLeader] == 3) || (User[playerid][pMember] == 3) && (User[playerid][pRank] == 14))
		{
			ftext             = "Army SF";
			InviteSkin[params[0]] = 287;
		}
		else if((User[playerid][pLeader] == 4) || (User[playerid][pMember] == 4) && (User[playerid][pRank] >= 9))
		{
			ftext             = "Больница Los Santos";
			InviteSkin[params[0]] = 70;
		}
		else if((User[playerid][pLeader] == 5) || (User[playerid][pMember] == 5) && (User[playerid][pRank] == 9))
		{
			ftext             = "La Cosa Nostra";
			InviteSkin[params[0]] = 223;
		}
		else if((User[playerid][pLeader] == 6) || (User[playerid][pMember] == 6) && (User[playerid][pRank] == 9))
		{
			ftext             = "Yakuza";
			InviteSkin[params[0]] = 120;
		}
		else if((User[playerid][pLeader] == 7) || (User[playerid][pMember] == 7) && (User[playerid][pRank] >= 5))
		{
			ftext             = "Мэрия";
			InviteSkin[params[0]] = 57;
		}
		else if((User[playerid][pLeader] == 9) || (User[playerid][pMember] == 9) && (User[playerid][pRank] == 9))
		{
			ftext             = "San Fierro News";
			InviteSkin[params[0]] = 261;
		}
		else if((User[playerid][pLeader] == 10) || (User[playerid][pMember] == 10) && (User[playerid][pRank] == 14))
		{
			ftext             = "San Fierro Police Department";
			InviteSkin[params[0]] = 286;
		}
		else if((User[playerid][pLeader] == 11) || (User[playerid][pMember] == 11) && (User[playerid][pRank] == 9))
		{
			ftext             = "Автошкола";
			InviteSkin[params[0]] = 59;
		}
		else if((User[playerid][pLeader] == 12) || (User[playerid][pMember] == 12) && (User[playerid][pRank] == 9))
		{
			ftext             = "The Ballas Gang";
			InviteSkin[params[0]] = 102;
		}
		else if((User[playerid][pLeader] == 13) || (User[playerid][pMember] == 13) && (User[playerid][pRank] == 9))
		{
			ftext             = "Los Santos Vagos";
			InviteSkin[params[0]] = 108;
		}
		else if((User[playerid][pLeader] == 14) || (User[playerid][pMember] == 14) && (User[playerid][pRank] == 9))
		{
			ftext             = "Русская мафия";
			InviteSkin[params[0]] = 111;
		}
		else if((User[playerid][pLeader] == 15) || (User[playerid][pMember] == 15) && (User[playerid][pRank] == 9))
		{
			ftext             = "Grove Street Gang";
			InviteSkin[params[0]] = 106;
		}
		else if((User[playerid][pLeader] == 16) || (User[playerid][pMember] == 16) && (User[playerid][pRank] == 9))
		{
			ftext             = "Los Santos News";
			InviteSkin[params[0]] = 261;
		}
		else if((User[playerid][pLeader] == 17) || (User[playerid][pMember] == 17) && (User[playerid][pRank] == 9))
		{
			ftext             = "Varios Los Aztecas";
			InviteSkin[params[0]] = 115;
		}
		else if((User[playerid][pLeader] == 18) || (User[playerid][pMember] == 18) && (User[playerid][pRank] == 9))
		{
			ftext             = "The Rifa Gang";
			InviteSkin[params[0]] = 174;
		}
		else if((User[playerid][pLeader] == 19) || (User[playerid][pMember] == 19) && (User[playerid][pRank] == 14))
		{
			ftext             = "Army LV";
			InviteSkin[params[0]] = 287;
		}
		else if((User[playerid][pLeader] == 20) || (User[playerid][pMember] == 20) && (User[playerid][pRank] == 9))
		{
			ftext             = "Las Venturas News";
			InviteSkin[params[0]] = 261;
		}
		else if((User[playerid][pLeader] == 21) || (User[playerid][pMember] == 21) && (User[playerid][pRank] == 14))
		{
			ftext             = "Las Venturas Police Department";
			InviteSkin[params[0]] = 280;
		}
		else if((User[playerid][pLeader] == 23) || (User[playerid][pMember] == 23) && (User[playerid][pRank] == 11))
		{
			ftext             = "Больница San Fierro";
			InviteSkin[params[0]] = 70;
		}
		else if((User[playerid][pLeader] == 37) || (User[playerid][pMember] == 37) && (User[playerid][pRank] == 7))
		{
		    ftext             = "Central Intelligence Agency";
		    InviteSkin[params[0]] = 303;
		}
		else return true;
		IDINVITE[params[0]]    = playerid;
		InviteOffer[params[0]] = User[playerid][pMember];
		SCMF(playerid, 0xF0E79CFF, "Вы предложили %s вступить в %s.", User[params[0]][pName], ftext);
		format(invite, sizeof(invite), "{FFFFFF}%s предлагает Вам вступить в организацию {F0E79C}%s", User[playerid][pName], ftext);
		ShowPlayerDialogEx(params[0], 231, DIALOG_STYLE_MSGBOX, "{F1C33A}Приглашение в организацию", invite, "Вступить", "Отклонить");
	}
	return true;
}
CMD:iinvite(playerid, params[])
{
    if(sscanf(params,"u",params[0])) return SendClientMessage(playerid, COLOR_WHITE, " Введите: /iinvite [id игрока]");
	if(GetDistanceBetweenPlayers(playerid, params[0]) > 5.0) return SCM(playerid, COLOR_GREY, "Вы слишком далеко!");
	if(params[0] == INVALID_PLAYER_ID || !IsPlayerConnected(params[0])) return SendClientMessage(playerid, COLOR_GREY, "Игрок не найден!");
    if(User[params[0]][pLevel] < 2) return SendClientMessage(playerid, COLOR_GREY, "Требуется 2 уровень");
    if(User[params[0]][pLeader] > 0) return SendClientMessage(playerid, COLOR_GREY, "Нельзя пригласить лидера.");
    if(User[playerid][pLeader] == 1 || User[playerid][pMember] == 1 && User[playerid][pRank] >= 14)
    {
        if(IsAArm(params[0]) && User[params[0]][pRank] >= 3) { ChosenSkin[params[0]] = 280; }
        else return SendClientMessage(playerid, COLOR_GREY, "Этот игрок не отслужил в армии");
    }
    else if (User[playerid][pLeader] == 2 || User[playerid][pMember] == 2 && User[playerid][pRank] >= 9)
    {
        if(IsAArm(params[0]) && User[params[0]][pRank] >= 10 || IsACop(params[0]) && User[params[0]][pRank] >= 7) { ChosenSkin[params[0]] = 286; }
        else return SendClientMessage(playerid, COLOR_GREY, "Этот игрок не отслужил в армии");
    }
    else if (User[playerid][pLeader] == 10 || User[playerid][pMember] == 10 && User[playerid][pRank] >= 14)
    {
        if(IsAArm(params[0]) && User[params[0]][pRank] >= 3) { ChosenSkin[params[0]] = 280; }
        else return SendClientMessage(playerid, COLOR_GREY, "Этот игрок не отслужил в армии");
    }
    else if (User[playerid][pLeader] == 21 || User[playerid][pMember] == 21 && User[playerid][pRank] >= 14)
    {
        if(IsAArm(params[0]) && User[params[0]][pRank] >= 3) { ChosenSkin[params[0]] = 280; }
        else return SendClientMessage(playerid, COLOR_GREY, "Этот игрок не отслужил в армии");
    }
    else return SendClientMessage(playerid,COLOR_GREY, "Вам не доступна данная функция.");
    User[params[0]][pMember] = User[playerid][pMember];
    User[params[0]][pRank] = 1;
    new string[156];
    f(string, "Вы пригласили %s присоединиться к '%s'", User[params[0]][pName], GetFractionName[User[playerid][pMember]]);
    SCM(playerid, 0x6AB1FFAA, string);
    f(string, "Вы были приглашены в %s лидером '%s'", GetFractionName[User[playerid][pMember]], User[playerid][pName]);
    SCM(params[0], 0x6AB1FFAA, string);
    User[params[0]][pJob] = 0;
    User[params[0]][pModel] = ChosenSkin[params[0]];
	SetPlayerSkin(params[0], User[params[0]][pChar][0]);
	SetPlayerColor(params[0], TEAM_HIT_COLOR);
	DeletePVar(params[0],"Fraction_Duty");
	SetPlayerArmourAC(params[0],0);
	ResetPlayerWeaponsEx(params[0]);
    return 1;
}
CMD:uninvite(playerid, params[])
{
    if(!GetPVarInt(playerid,"Fraction_Duty")) return SCM(playerid, COLOR_GREY, "Вам недоступна данная команда!");
    if(!IsPlayerConnected(playerid)) return true;
	if(sscanf(params, "us[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /uninvite [id] [причина]");
	if(User[playerid][pRank] <= User[params[0]][pRank]) return SendClientMessage(playerid, COLOR_GREY, "Вы не можете уволить этого игрока");
	if(params[0] == playerid) return SendClientMessage(playerid,-1,"Себя невозможно уволить");
	if(User[params[0]][pMember] == User[playerid][pLeader] || User[params[0]][pMember] == User[playerid][pMember])
	{
		if(!IsPlayerConnected(params[0])) return true;
		if(!CanUninviteforeach(playerid,params[0])) return true;
		if(User[params[0]][pMember] <= 0) return true;
		mysql_format(dbHandle, YCMDstr, sizeof(YCMDstr), "UPDATE `employment_history` SET data_un_invite = 'NOW()', rang = '%d', organization = '%s', organization_position = '%s' WHERE name_player = '%e' LIMIT 1",User[params[0]][pRank], GetFractionName[User[params[0]][pMember]], GetRank(params[0]), Name(params[0]));
		mysql_query(dbHandle, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "%s выгнал вас из организации. Причина: %s",User[playerid][pName],params[1]);
		SendClientMessage(params[0], 0x6BB3FFAA, YCMDstr);
		format(YCMDstr, sizeof(YCMDstr), "Вы выгнали %s из организации. Причина: %s",User[params[0]][pName],params[1]);
		SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
       	SendClientMessage(params[0], 0x6BB3FFAA, "Вы снова гражданский");
        SendClientMessage(params[0], 0x6BB3FFAA, "Рабочий день окончен");
        if(GetPVarInt(params[0],"capture_on"))
	    {
	        DeletePVar(params[0],"capture_on");
	        for(new t = 0x0; t != 6;t++) PlayerTextDrawHide(params[0],CaptureG[params[0]][t]);
			PlayerTextDrawHide(playerid, Capture[params[0]]);
			for(new i_ = 0; i_ < 5; i_++) { SendDeathMessageToPlayer(params[0],INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0); }
		}
		User[params[0]][pMember] = 0;
		User[params[0]][pLeader] = 0;
		User[params[0]][pJobHeal] = 0;
		User[params[0]][pJobHealLeader] = 0;
		User[params[0]][pRank] = 0;
		TalkingLive[params[0]] = 255;
		TalkingLivels[params[0]] = 255;
		TalkingLivelv[params[0]] = 255;
		DeletePVar(params[0],"Fraction_Duty");
		SetPlayerArmourAC(params[0],0);
		ResetPlayerWeaponsEx(params[0]);
		DeletePVar(playerid, "Tipster");
		DeletePVar(playerid, "TipsterListen");
		DeletePVar(playerid, "TipsterFracOn");
		DeletePVar(playerid, "TipsterOn");
		DeletePVar(playerid, "TipsterOnPlayer");
        SpawnPlayer(params[0]);
		SetPlayerColor(params[0], TEAM_HIT_COLOR);
		SetPlayerSkin(params[0], User[params[0]][pChar][0]);
	}
	return true;
}
CMD:auninvite(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "us[128]",params[0],params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /auninvite [playerid] [причина]");
	if(!IsPlayerConnected(params[0])) return true;
	if(User[params[0]][pMember] == 0) return true;
	format(YCMDstr, sizeof(YCMDstr), "%s выгнал вас из организации. Причина: %s",User[playerid][pName],params[1]);
	SendClientMessage(params[0], 0x6BB3FFAA, YCMDstr);
	format(YCMDstr, sizeof(YCMDstr), "Вы выгнали %s из организации. Причина: %s",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, 0x6BB3FFAA, YCMDstr);
    SendClientMessage(params[0], 0x6BB3FFAA, "Вы снова гражданский");
    SendClientMessage(params[0], 0x6BB3FFAA, "Рабочий день окончен");
    if(GetPVarInt(params[0],"capture_on"))
    {
		DeletePVar(params[0],"capture_on");
		for(new t = 0x0; t != 6;t++) PlayerTextDrawHide(params[0],CaptureG[params[0]][t]);
		PlayerTextDrawHide(playerid, Capture[params[0]]);
		for(new i_ = 0; i_ < 5; i_++) { SendDeathMessageToPlayer(params[0],INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0); }
	}
	User[params[0]][pMember] = 0;
	User[params[0]][pLeader] = 0;
	User[params[0]][pRank] = 0;
	User[params[0]][pJobHeal] = 0;
	User[params[0]][pJobHealLeader] = 0;
	DeletePVar(params[0],"Fraction_Duty");
	SetPlayerArmourAC(params[0],0);
    ResetPlayerWeaponsEx(params[0]);
	//ResetPlayerWeaponsEx(params[0]);
    SpawnPlayer(params[0]);
	SetPlayerColor(params[0], TEAM_HIT_COLOR);
	SetPlayerSkin(params[0],User[params[0]][pChar][0]);
    return true;
}
CMD:setfprods(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "dd", params[0], params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setfprods [id farm] [кол-во]");
	FarmInfo[params[0]+1][fProds] = params[1];
	SCMF(playerid, COLOR_RED, "Количество урожая установлено (Ферма #%d)", params[0]);
	return 1;
}
CMD:setfgrain(playerid, params[])
{
    if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "dd", params[0], params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /setfgrain [id farm] [кол-во]");
	FarmInfo[params[0]+1][fGrain] = params[1];
	SCMF(playerid, COLOR_RED, "Количество зерна установлено (Ферма #%d)", params[0]);
	return 1;
}
CMD:makeadmin(playerid, params[])
{
	if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
	new name[32];
	if(sscanf(params, "s[32]i", name, params[1])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /makeadmin [ник] [уровень администратора]");
	if((params[1] > 6 || params[1] < 0) && User[playerid][pAdmin] < 10) return SendClientMessage(playerid, COLOR_GREY, "Вы допустили оишбку");
	static const fmt_query[] = "SELECT * FROM `admin` WHERE `name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle,query, sizeof(query), fmt_query, name);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",17,params[1],name);
	SCM(playerid, -1, "Вы назначили игрока администратором сервера!");
	return true;
}
CMD:setsupport(playerid, params[])
{
    if(User[playerid][pAdmin] < 6 || !GetPVarInt(playerid, "Dostup")) return true;
    if(!IsPlayerConnected(playerid)) return true;
    if(sscanf(params, "ud",params[0],params[1])) return SendClientMessage(playerid, COLOR_GRAD2, "Введите: /setsupport [playerid] [0 снять - 1 назначить]");
    if(params[1] > 1 || params[1] < 0) return SendClientMessage(playerid, COLOR_GREY, "Вы сделали ошибку");
	if(!IsPlayerConnected(params[0])) return true;
	User[params[0]][pHelper] = params[1];
	format(YCMDstr, sizeof(YCMDstr), "Вы назначили/сняли саппорта %s",User[params[0]][pName],params[1]);
	SendClientMessage(playerid, COLOR_LIGHTBLUE, YCMDstr);
	return true;
}
CMD:setac(playerid, params[])
{
    if(User[playerid][pAdmin] < 7 || !GetPVarInt(playerid, "Dostup")) return true;
    if(sscanf(params, "dd",params[0],params[1])) return SCM(playerid, COLOR_GRAD2, "Введите: /setac [КОД античита] [(0 - выключить / 1 - включить]");
    EnableAntiCheat(params[0], params[1]);
    SCMF(playerid, COLOR_RED, "Успешно! Античит %i успешно изменен [Состояние: %i]", params[0], IsAntiCheatEnabled(params[0]));
	return true;
}
CMD:geton(playerid, params[])
{
    if(User[playerid][pAdmin] < 3 || !GetPVarInt(playerid, "Dostup")) return SendClientMessage(playerid,COLOR_GREY, "Вам недоступна эта функция");
    if(sscanf(params, "s[63]",params[0])) return SendClientMessage(playerid,COLOR_GREY, "Используйте: /geton [name]");
	static const fmt_query[] = "SELECT * FROM `accounts` WHERE `Name` = '%s'";
	new query[sizeof(fmt_query)+(-2+MAX_PLAYER_NAME)];
	mysql_format(dbHandle,query, sizeof(query), fmt_query,params[0]);
	mysql_tquery(dbHandle,query,"OnMySQL_QUERY","iis",18,playerid,params[0]);
	return true;
}
CMD:getleader(playerid, params[])
{
    if(User[playerid][pAdmin] < 4 || !GetPVarInt(playerid, "Dostup")) return SendClientMessage(playerid,COLOR_GREY, "Вам недоступна эта функция");
    if(sscanf(params, "d",params[0])) return SendClientMessage(playerid, COLOR_GREY, "Используйте: /getleader [номер фракции]");
    if(params[0] > 36 || params[0] < 1) { SCM(playerid, COLOR_GREY, "Нельзя меньше 1 или больше 36!"); return true; }
    mysql_format(dbHandle,QUERY, 256, "SELECT * FROM `accounts` WHERE `pLeader` = '%i'",params[0]);
	mysql_tquery(dbHandle,QUERY,"OnMySQL_QUERY","iis",38,playerid,params[0]);
	return true;
}
CMD:makeleader(playerid, params[])
{
	if User[playerid][pAdmin] < 5 || !GetPVarInt(playerid, "Dostup") *then return true;
	if sscanf(params, "ud", params[0], params[1]) *then return SCM(playerid, COLOR_GREY, "Используйте: /makeleader [id] [номер организации]");
	if params[1] < 0 || params[1] > 37 *then return SCM(playerid, COLOR_GREY, "Данной организации не существует!");
	if !IsPlayerConnected(params[0]) *then return SCM(playerid, COLOR_GREY, "Игрок оффлайн");
	if User[params[0]][pWarns] > 0 *then return SCM(playerid, COLOR_GREY, "У игрока имеется варн");
	switch(params[1])
	{
		case 0:
		{
			User[params[0]][pRank] = 0;
			User[params[0]][pMember] = User[params[0]][pLeader] = 0;
			if(GetPVarInt(params[0],"capture_on"))
			{
				DeletePVar(params[0],"capture_on");
				for(new t = 0x0; t != 6;t++) PlayerTextDrawHide(params[0],CaptureG[params[0]][t]);
				for(new i_ = 0; i_ < 5; i_++) SendDeathMessageToPlayer(params[0],INVALID_PLAYER_ID-1, INVALID_PLAYER_ID-1, 0);
			}
			TalkingLive[params[0]] = 255;
			TalkingLivels[params[0]] = 255;
			TalkingLivelv[params[0]] = 255;
			new string[70];
			f(string, "Администратор %s снял с вас контроль организации", User[playerid][pName]);
			SCM(params[0], 0x6495EDFF, string);
			f(string, "Вы сняли с %s контроль организации.", User[params[0]][pName]);
			SCM(playerid, 0x6495EDFF, string);
			DeletePVar(params[0],"Fraction_Duty");
			SavePlayer(params[0]);
			return SpawnPlayer(params[0]);
		}
		case 1, 10, 21:
		{
			User[params[0]][pRank] = 15;
			InviteSkin[params[0]] = 283;
		}
		case 2: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 166;
		case 3, 19: User[params[0]][pRank] = 15, InviteSkin[params[0]] = 287;
		case 4: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 70, User[params[0]][pJobHeal] = 1;
		case 5: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 113;
		case 6: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 120;
		case 7: User[params[0]][pRank] = 6, InviteSkin[params[0]] = 147;
		case 9, 16, 20: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 261;
		case 11: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 240;
		case 12: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 104;
		case 13: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 110;
		case 14: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 125;
		case 15: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 270;
		case 17: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 115;
		case 18: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 173;
		case 24, 26, 29: User[params[0]][pRank] = 9, InviteSkin[params[0]] = 100;
		case 37: User[params[0]][pRank] = 7, InviteSkin[params[0]] = 147;
		//case 34: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 176;
		//case 35: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 294;
		//case 36: User[params[0]][pRank] = 10, InviteSkin[params[0]] = 220;
		default: return SCM(playerid, COLOR_GREY, "Данной организации не существует!");
	}
	User[params[0]][pMember] = User[params[0]][pLeader] = params[1];
	User[params[0]][pJob] = 0;
	new string[84];
	f(string, "Вы назначили %s контролировать организацию номер %d.", User[params[0]][pName], params[1]);
	SCM(playerid, 0x6495EDFF, string);
	f(string, "Администратор %s назначил вас контролировать данную организацию", User[playerid][pName]);
	SCM(params[0], 0x6495EDFF, string);
	SendClientMessage(params[0], 0x6495EDFF,"Рабочий день начат");
	User[params[0]][pModel] = InviteSkin[params[0]];
	SavePlayer(params[0]);
	SetPlayerArmourAC(params[0],0);
	SetPlayerHealthAC(params[0],100);
	SetPlayerToTeamColor(params[0]);
	SetPlayerSkin(params[0], InviteSkin[params[0]]);
	SetPVarInt(params[0],"Fraction_Duty",1);
	SetPlayerToTeamColor(params[0]);
	return SpawnPlayer(params[0]);
}
CMD:fid(playerid, params[])
{
	if(User[playerid][pLogin] == 0 || User[playerid][pAdmin] < 1) return true;
	return ShowPlayerDialogEx(playerid, 9999, DIALOG_STYLE_MSGBOX, "Список организаций", "1. LSPD\n2. FBI\n3. Army SF\n4. Больница\n5. La Cosa Nostra\n\
	6. Yakuza\n7. Мэрия\n8. Казино (недоступно)\n9.Новости SF\n10.SFPD\n11. Автошкола\n12. Ballas\n13. Vagos\n14. Russian Mafia\n15. Grove\n16. News LS\n17. Aztecas\n18. Rifa\n19. Army LV\n\
	20. News LV\n21. LVPD\n24. Hells Angels\n26. Warlocks MC\n29. Pagans MC","Закрыть", "");
}
CMD:demote(playerid, params[])
{
	if(User[playerid][pMember] != 2 && User[playerid][pMember] != 7) return err(!"Ошибка: {ffffff}Вам недоступна эта команда!");
	switch (User[playerid][pMember]) {
		case 2: if(User[playerid][pRank] < 6) return err(!"Ошибка: {ffffff}Вам недоступна эта команда!");
		case 7: if(User[playerid][pRank] < 6) return err(!"Ошибка: {ffffff}Вам недоступна эта команда!");
	}
	if(sscanf(params, "u", params[0])) return SendClientMessage(playerid, COLOR_WHITE, "Введите: /demote [id]");
	if(!PlayerInConnected(params[0]) || playerid == params[0]) return 1;
	//new query_[256];
	if(User[params[0]][pLeader] != 0) return err(!"Ошибка: {ffffff}Вы не можете уволить лидера!");
	if(User[params[0]][pMember] == 3 || User[params[0]][pMember] == 19 || User[params[0]][pMember] == 1 || User[params[0]][pMember] == 10 ||
	User[params[0]][pMember] == 21)
	{
		new mes[128],string_[128];
		if((User[params[0]][pMember] == 1 || User[params[0]][pMember] == 10 || User[params[0]][pMember] == 21) && User[params[0]][pRank]-1 == 0)
		{
		    //leave_team(params[0], User[params[0]][pMember]);

			User[params[0]][pMember] = 19;

			User[params[0]][pRank] = 3;
			User[params[0]][pJob] = 0;
			User[params[0]][pModel] = 287;
			SetPlayerArmourAC(params[0],0);
			ResetPlayerWeaponsEx(params[0]);
			format(string_,sizeof(string_),"%s %s перевел вас обратно в армию",GetRank(playerid), User[playerid][pName]);
			SendClientMessage(params[0],0x6495EDFF,string_);
			format(mes,sizeof(mes),"Вы перевели %s обратно в армию.", User[params[0]][pName]);
			SendClientMessage(playerid,0x6495EDFF,mes);
			/*format(query_, sizeof query_ , "UPDATE `s_users` SET `pMember` = '%d', `pRank` = '%d', `pJob` = '%d', `pModel` = '%d', `playerspawn` = '%d' WHERE `Name` = '%s'",
			User[params[0]][pMember], User[params[0]][pRank], User[params[0]][pJob], User[params[0]][pModel], User[params[0]][PlayerSpawn], User[params[0]][pName]);
			mysql_tquery(dbHandle, query_, "", "");*/
			SetPlayerSkin(params[0], 287);
			return 1;
		}
		if(User[params[0]][pRank]-1 == 0 && (User[params[0]][pMember] == 3 || User[params[0]][pMember] == 19))
		{

		    User[params[0]][pMember] = 0;

			User[params[0]][pLeader] = 0;
			User[params[0]][pJobHeal] = 0;
			User[params[0]][pRank] = 0;
			//if(User[params[0]][PlayerSpawn] == 2) User[params[0]][n] = 0;
			//pTemp[params[0]][frac_forma] =0;
			DeletePVar(playerid,"Fraction_Duty");
			SetPlayerArmourAC(params[0],0);
			ResetPlayerWeaponsEx(params[0]);
			format(string_,sizeof(string_),"%s %s уволил вас из армии",GetRank(playerid), User[playerid][pName]);
			SendClientMessage(params[0],0x6495EDFF,string_);
			SendClientMessage(params[0], 0x6495EDFF, "Вы снова гражданский");
			format(mes,sizeof(mes),"Вы уволили %s из армии.", User[params[0]][pName]);
			SendClientMessage(playerid,0x6495EDFF,mes);
			/*format(query_, sizeof query_ , "UPDATE `s_users` SET `pLeader` = '%d', `pMember` = '%d', `pRank` = '%d', `pJob` = '%d', `playerspawn` = '%d', `pJobHeal` = '%d' WHERE `Name` = '%s'",
			User[params[0]][pLeader], User[params[0]][pMember], User[params[0]][pRank], User[params[0]][pJob], User[params[0]][PlayerSpawn], User[params[0]][pJobHeal], User[params[0]][pName]);
			mysql_tquery(dbHandle, query_, "", "");*/
			SpawnPlayer(params[0]);
			return 1;
		}
		if(User[params[0]][pMember] != 0)
		{
			User[params[0]][pRank] --;
			format(string_,sizeof(string_),"%s %s понизил вас до %d ранга",GetRank(playerid), User[playerid][pName], User[params[0]][pRank]);
			SendClientMessage(params[0],0x6495EDFF,string_);
			format(mes,sizeof(mes),"Вы понизили %s до %d ранга.", User[params[0]][pName], User[params[0]][pRank]);
			SendClientMessage(playerid,0x6495EDFF,mes);
			/*format(query_, sizeof query_ , "UPDATE `s_users` SET `pRank` = '%d' WHERE `Name` = '%s'", User[params[0]][pRank], User[params[0]][pName]);
			mysql_tquery(dbHandle, query_, "", "");*/
		}
		else err(!"Ошибка: {ffffff}Игрок уволен!");
	}
	else err(!"Ошибка: {ffffff}Этот человек не состоит в армии/ПД!");
	return 1;
}
