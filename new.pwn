	if(!User[playerid][pLogin]) return SendClientMessage(playerid,COLOR_WHITE,"Вы не авторизованы!");
	if(User[playerid][pAdmin] < 10 || !GetPVarInt(playerid, "Dostup")) return true;
	if(sscanf(params, "dd", params[0],params[1]))
	{
		SendClientMessage(playerid, COLOR_GREY, "Используйте: /setmats [номер] [количество]");
