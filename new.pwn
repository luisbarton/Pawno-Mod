			LSNews(0x0073B7AA, str);
			Flood[playerid] = 2;
			return false;
		}
	}
	if(TalkingLivelv[playerid] == 2)
	{
	    new str[156];
		if(User[playerid][pMuted] > 0) { SendClientMessage(playerid, TEAM_CYAN_COLOR, "У Вас бан чата!"); return false; }
