            }
        }
    }
    return 0;
}
stock RobSuccessFilly(pids, tip ,member, robin)
{
//    ClearActorAnimations(ActorsRob[act]);
	if(tip == 0)
	{
		new maxform;
		foreach(new i : Player)
		{
			if(maxform >= 4) break;
		    else if(PlayerToPoint(30,i,204.8515,-8.1603,1001.2109) || PlayerToPoint(30,i,463.6687,-1498.0747,3001.0859) && User[i][pMember] == member && RobInts[i] == robin)
		    {
	            if(User[i][pSex] == 2) SetPlayerSkin(i, 191);
	            else SetPlayerSkin(i, 287);
	            SetPVarInt(i, "ProverkaForma", 1);
	            maxform++;
			}
		}
	}
	else if(tip == 1)
	{
		if(User[pids][pMember] == 5)
		{
			FracStore[LCN] += 2500;
			if(FracStore[LCN] > 100000) FracStore[LCN] = 100000;
		}
		else if(User[pids][pMember] == 6)
		{
			FracStore[Yakuza] += 2500;
			if(FracStore[Yakuza] > 100000) FracStore[Yakuza] = 100000;
		}
		else if(User[pids][pMember] == 14)
		{
			FracStore[RM] += 2500;
			if(FracStore[RM] > 100000) FracStore[RM] = 100000;
		}
		SendClientMessage(pids, -1, "На склад вашей мафии добавлено 2500 материалов");
	}
	return 0;
}
publics: RobsEnabledCD(ids)
{
    if(cdrob[ids] != true) return 0;
    cdrob[ids] = false;
    return 0;
}
stock wantedsrobfriend(fraks, reason, introb)
{
	foreach(new i : Player)
	{
		if(reason == 0)
		{
			if(PlayerToPoint(30,i, 463.6687,-1498.0747,3001.0859) && User[i][pMember] == fraks && RobInts[i] == introb)
			{
    			if(User[i][pWantedLevel] > 3) User[i][pWantedLevel] += 1;
    			else User[i][pWantedLevel] += 3;
				SetPlayerWantedLevel(i,User[i][pWantedLevel]);
				SetPlayerCriminal(i,"Неизвестный", "Ограбление Victim LS");
			}
		}
		else if(reason == 1)
		{
			if(PlayerToPoint(30,i,204.8515,-8.1603,1001.2109) && User[i][pMember] == fraks && RobInts[i] == introb)
			{
    			if(User[i][pWantedLevel] > 3) User[i][pWantedLevel] += 1;
    			else User[i][pWantedLevel] += 3;
				SetPlayerWantedLevel(i,User[i][pWantedLevel]);
				SetPlayerCriminal(i,"Неизвестный", "Ограбление Victim SF");
			}
		}
		else if(reason == 2)
		{
			if(PlayerToPoint(30,i,316.1089,-133.7254,999.6016) && User[i][pMember] == fraks && RobInts[i] == introb)
			{
    			if(User[i][pWantedLevel] > 3) User[i][pWantedLevel] += 1;
    			else User[i][pWantedLevel] += 3;
				SetPlayerWantedLevel(i,User[i][pWantedLevel]);
				SetPlayerCriminal(i,"Неизвестный", "Ограбление Ammo LV");
			}
		}
		else if(reason == 3)
		{
			if(PlayerToPoint(30,i,295.4810,-40.2167,1001.5156) && User[i][pMember] == fraks && RobInts[i] == introb)
			{
    			if(User[i][pWantedLevel] > 3) User[i][pWantedLevel] += 1;
    			else User[i][pWantedLevel] += 3;
				SetPlayerWantedLevel(i,User[i][pWantedLevel]);
				SetPlayerCriminal(i,"Неизвестный", "Ограбление Ammo SF");
			}
		}
		else if(reason == 4)
		{
			if(PlayerToPoint(30,i,296.8526,-82.5276,1001.5156) && User[i][pMember] == fraks && RobInts[i] == introb)
			{
    			if(User[i][pWantedLevel] > 3) User[i][pWantedLevel] += 1;
    			else User[i][pWantedLevel] += 3;
				SetPlayerWantedLevel(i,User[i][pWantedLevel]);
				SetPlayerCriminal(i,"Неизвестный", "Ограбление Ammo LS");
			}
		}
	}
	return 0;
}
publics: RobbingTimer()
{
	for(new ac = 0; ac < 5; ac++) SetActorHealth(ActorsRob[ac], 255);
    new pl[5][8];
	foreach(new i : Player)
	{
		if(GetPlayerInterior(i) == 5)
		{
			if(PlayerToPoint(30,i,204.8515,-8.1603,1001.2109) && RobInts[i] == 3)
			{
           	 	if(cdrob[1] == false)
                {
            		switch(User[i][pMember])
            		{
						case 12: pl[1][0]++;
						case 13: pl[1][1]++;
						case 15: pl[1][2]++;
						case 17: pl[1][3]++;
						case 18: pl[1][4]++;
						default: continue;
            		}
		    		new PTA = GetPlayerCameraTargetActor(i),
		    		    keys,
						updown,
						leftright;
                	GetPlayerKeys(i, keys, updown, leftright);
    	    		if(PTA != INVALID_ACTOR_ID && keys & KEY_HANDBRAKE)
    	    		{
						if(PTA != ActorsRob[4]) continue;
                		new PW = GetPlayerWeapon(i);
                		if(PW == 23 || PW == 24 || PW == 25 || PW == 29 || PW == 30 || PW == 31 || PW == 32)
                		{
							if(pl[1][0] > 1 || pl[1][1] > 1 || pl[1][2] > 1 || pl[1][3] > 1 || pl[1][4] > 1)
							{
                        		ApplyActorAnimation(PTA, "SHOP", "SHP_HandsUp_Scr",4.1,0,0,0,1,0);
                            	cdrob[1] = true;
                            	SetTimerEx("RobsEnabledCD", 1800000, false, "d",1);
                            	RobTickRTC[i] = 30;
                            	robscdtimer[i] = SetTimerEx("RobTickRTSC", 1000, true, "ddddi", i, 0, User[i][pMember], 3, ActorsRob[4]);
                            	wantedsrobfriend(User[i][pMember], 1, 3);
                        	}
                        	else SendClientMessage(i, COLOR_GREY, "Для начала ограбления нужно минимум 2 напарника");
                		}
            		}
            	}
